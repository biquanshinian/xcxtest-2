# adminGateway HTTP 访问地址（与 bilibili-publisher 相同的云函数 HTTP 触发 URL）
REPLAY_ADMIN_API_BASE=

# Agent 鉴权 token（≥16 位；对应云函数环境变量 REPLAY_AGENT_TOKEN，缺省共用 BILI_AGENT_TOKEN）
REPLAY_AGENT_TOKEN=

# 轮询间隔毫秒（默认 10 分钟；回放不是实时需求，无需高频）
REPLAY_POLL_MS=600000

# yt-dlp 可执行文件路径（默认 PATH 中的 yt-dlp）
YTDLP_PATH=yt-dlp

# ffmpeg 所在目录（yt-dlp 合并音视频用；已在 PATH 中可留空）
FFMPEG_PATH=

# 下载清晰度上限（默认 480，即"压缩方式"：只取小分辨率源，不做本地转码）
REPLAY_MAX_HEIGHT=480

# 单文件大小上限 MB（超过则该源失败换下一源）
REPLAY_MAX_FILE_MB=1024

# 访问 YouTube/X 需要的代理（如 http://127.0.0.1:7890），可留空
REPLAY_PROXY=
