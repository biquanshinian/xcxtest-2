# B 站管理端 HTTP 地址（与 admin-web 相同的云函数入口）
BILI_ADMIN_API_BASE=https://cloud1-9gdqgdt5bfaa20fb-1397421562.ap-shanghai.app.tcloudbase.com/admin

# 与云开发环境变量 BILI_AGENT_TOKEN 一致（至少 16 位）
BILI_AGENT_TOKEN=replace_with_long_random_token

# 轮询间隔毫秒
BILI_POLL_MS=60000

# 有头模式便于首次调试（true/false）
BILI_HEADED=false
