/* custom-tab-bar/index.wxss
 * 布局占位见 utils/layout.js（TABBAR_* 常量）
 * 圆角：iOS 26/27 Liquid Glass 约 22pt → 44rpx；底部悬浮：TABBAR_FLOAT_BOTTOM 10rpx
 */
.custom-tab-bar-root {
  position: relative;
  background-color: transparent;
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc((182 + 96 + 14) * 1rpx + env(safe-area-inset-bottom) - 2px);
  padding-bottom: calc(env(safe-area-inset-bottom) + 10rpx);
  z-index: 9999;
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-sizing: border-box;
  pointer-events: none;
  background: transparent;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 1;
  transition: opacity 0.12s ease;
}
/* ========== 添加到桌面提示横条（NASA 悬浮按钮同款玻璃质感） ========== */
/* 横条外框与指引图外框共用同一套视觉（与 tab-bar-content 族一致） */
.tab-add-desktop-strip,
.desktop-guide-img-frame {
  box-sizing: border-box;
  background: rgba(12, 14, 18, 0.06);
  /* 性能：与 tab-bar-content 同步降半径 72→48rpx，观感一致、合成开销减半以上 */
  backdrop-filter: blur(48rpx) saturate(220%);
  -webkit-backdrop-filter: blur(48rpx) saturate(220%);
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 44rpx;
  box-shadow:
    0 -8rpx 24rpx rgba(0, 0, 0, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
  position: relative;
  overflow: hidden;
}

.tab-add-desktop-strip::before,
.desktop-guide-img-frame::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.45) 20%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0.45) 80%,
    transparent 100%);
  pointer-events: none;
  z-index: 1;
}

.tab-add-desktop-strip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
  min-height: 80rpx;
  padding: calc(16rpx - 1px) 18rpx;
  pointer-events: auto;
}

.tab-add-desktop-strip-close {
  flex-shrink: 0;
  min-width: 44rpx;
  min-height: 44rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.tab-add-desktop-strip-close text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
}

.tab-add-desktop-strip-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.92);
  z-index: 2;
}

.tab-add-desktop-strip-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #34c759;
  z-index: 2;
}

.tab-add-desktop-strip-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
}

.tab-add-desktop-strip-btn:active {
  opacity: 0.88;
}

.tab-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 156rpx;
  flex-shrink: 0;
  background: rgba(12, 14, 18, 0.06);
  /* 性能：模糊半径 72→48rpx。此半径下背后内容已完全不可辨识，观感一致；
     模糊开销随半径平方增长，Tab 栏全程悬浮在滚动内容上，每帧都在实时合成 */
  backdrop-filter: blur(48rpx) saturate(220%);
  -webkit-backdrop-filter: blur(48rpx) saturate(220%);
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.22),
    0 -8rpx 24rpx rgba(0, 0, 0, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
  padding: 10rpx 24rpx;
  border-radius: 44rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  pointer-events: auto;
  will-change: transform;
  transform: translateZ(0);
}
.tab-bar-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.45) 20%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0.45) 80%,
    transparent 100%);
  pointer-events: none;
  z-index: 1;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0;
  transition: all 0.3s ease;
  height: 100%;
}
.icon-wrapper {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  overflow: visible;
}

.red-dot {
  position: absolute;
  top: 0;
  right: -6rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff3b30;
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(255, 59, 48, 0.6);
}

.tab-bar-item-active {
  position: relative;
}

.tab-bar-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 8rpx;
}

.tab-bar-item-profile .tab-bar-icon {
  width: 60rpx;
  height: 60rpx;
}

.tab-bar-item-profile .red-dot {
  top: -6rpx;
  right: -8rpx;
}

.tab-bar-hidden {
  opacity: 0 !important;
  visibility: hidden !important;
  pointer-events: none !important;
}

/* ========== 添加到桌面指引图 ========== */
.desktop-guide-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 10050;
}

.desktop-guide-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.52);
}

.desktop-guide-stack {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}

.desktop-guide-safe-top {
  flex-shrink: 0;
  width: 100%;
}

.desktop-guide-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 0 40rpx 24rpx;
  box-sizing: border-box;
  pointer-events: auto;
}

.desktop-guide-img-frame {
  width: 100%;
  max-width: 640rpx;
  padding: 16rpx 18rpx;
  pointer-events: auto;
  flex-shrink: 0;
}

.desktop-guide-img {
  position: relative;
  z-index: 2;
  width: 100%;
  display: block;
  border-radius: 28rpx;
}

/* 添加到桌面指引弹窗关闭按钮（形态参考 morning-briefing，叉号更大更醒目） */
.desktop-guide-close-row {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.popup-close {
  box-sizing: border-box;
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.popup-close--hover {
  background: rgba(255, 255, 255, 0.16);
}

.popup-close-icon {
  font-size: 36rpx;
  color: #ffffff;
  line-height: 1;
  pointer-events: none;
}

/* ========== 明亮主题 ========== */
.theme-light .tab-bar-content,
.theme-light .tab-add-desktop-strip,
.theme-light .desktop-guide-img-frame {
  background: rgba(255, 255, 255, 0.62);
  border-color: rgba(0, 0, 0, 0.06);
  /* iOS 扁平风：去投影，细灰边分层 */
  box-shadow: var(--shadow-tabbar);
}

.theme-light .tab-bar-content::before,
.theme-light .tab-add-desktop-strip::before,
.theme-light .desktop-guide-img-frame::before {
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.9) 20%,
    rgba(255, 255, 255, 1) 50%,
    rgba(255, 255, 255, 0.9) 80%,
    transparent 100%);
}

.theme-light .tab-add-desktop-strip-text {
  color: rgba(28, 28, 30, 0.92);
}

.theme-light .tab-add-desktop-strip-close text {
  color: rgba(60, 60, 67, 0.5);
}

.theme-light .popup-close {
  background: rgba(255, 255, 255, 0.85);
}

.theme-light .popup-close--hover {
  background: rgba(255, 255, 255, 1);
}

.theme-light .popup-close-icon {
  color: #1C1C1E;
}
