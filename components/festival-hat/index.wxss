/* 基准设计稿按圆直径 112rpx；外层按 size 缩放，贴合不同圆图 */
.festival-hat {
  position: absolute;
  left: 50%;
  top: 0;
  z-index: 6;
  pointer-events: none;
  overflow: visible;
}

.festival-hat-scale {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 112rpx;
  height: 56rpx;
  margin-left: -56rpx;
  transform-origin: 50% 100%;
}

.festival-hat-inner {
  position: relative;
  width: 112rpx;
  height: 56rpx;
}

/* —— 春节：矮圆红绒帽 —— */
.hat-spring-shell {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: 6rpx;
  height: 36rpx;
  border-radius: 56rpx 56rpx 18rpx 18rpx;
  background: linear-gradient(165deg, #ff6b6b 0%, #e11d48 42%, #9f1239 100%);
  box-shadow:
    0 6rpx 12rpx rgba(159, 18, 57, 0.28),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.22);
}

.hat-spring-band {
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  bottom: 8rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fbbf24 0%, #d97706 100%);
  box-shadow: 0 2rpx 4rpx rgba(180, 83, 9, 0.25);
}

.hat-spring-badge {
  position: absolute;
  left: 50%;
  top: 14rpx;
  width: 28rpx;
  height: 28rpx;
  margin-left: -14rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #fff7cc 0%, #facc15 55%, #ca8a04 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(202, 138, 4, 0.35);
}

.hat-spring-fu {
  font-size: 16rpx;
  font-weight: 800;
  color: #b91c1c;
  line-height: 1;
}

/* —— 端午：贴额艾叶环 —— */
.hat-duan-band {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 10rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4d7c0f 0%, #65a30d 50%, #3f6212 100%);
  box-shadow: 0 3rpx 8rpx rgba(63, 98, 18, 0.28);
}

.hat-duan-leaf {
  position: absolute;
  width: 20rpx;
  height: 28rpx;
  border-radius: 70% 70% 45% 45%;
  background: linear-gradient(160deg, #bbf7d0 0%, #4ade80 40%, #15803d 100%);
  bottom: 18rpx;
  box-shadow: 0 2rpx 4rpx rgba(21, 128, 61, 0.2);
}

.hat-duan-leaf--1 { left: 22rpx; transform: rotate(-32deg); }
.hat-duan-leaf--2 {
  left: 50%;
  margin-left: -10rpx;
  bottom: 22rpx;
  height: 30rpx;
  transform: rotate(0deg);
}
.hat-duan-leaf--3 { right: 22rpx; transform: rotate(32deg); }

.hat-duan-knot {
  position: absolute;
  left: 50%;
  bottom: 6rpx;
  width: 12rpx;
  height: 12rpx;
  margin-left: -6rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #fda4af 0%, #e11d48 100%);
}

/* —— 中秋：贴头兔耳 + 额前小月 —— */
.hat-moon-base {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 8rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fafaf9 0%, #e7e5e4 100%);
  box-shadow: 0 2rpx 6rpx rgba(68, 64, 60, 0.18);
}

.hat-moon-ear {
  position: absolute;
  bottom: 16rpx;
  width: 16rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fafaf9 0%, #e7e5e4 70%, #d6d3d1 100%);
  box-shadow: 0 2rpx 4rpx rgba(68, 64, 60, 0.16);
  overflow: hidden;
}

.hat-moon-ear--l { left: 30rpx; transform: rotate(-14deg); }
.hat-moon-ear--r { right: 30rpx; transform: rotate(14deg); }

.hat-moon-chip {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 18rpx;
  height: 18rpx;
  margin-left: -9rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 28%, #fef9c3 0%, #fde047 45%, #ca8a04 100%);
  box-shadow: 0 2rpx 6rpx rgba(202, 138, 4, 0.35);
}

/* —— 国庆：贴额红星发带 —— */
.hat-gq-band {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  bottom: 10rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #b91c1c 0%, #ef4444 45%, #b91c1c 100%);
  box-shadow:
    0 3rpx 8rpx rgba(185, 28, 28, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.hat-gq-star-wrap {
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 28rpx;
  height: 28rpx;
  margin-left: -14rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #fef08a 0%, #eab308 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(202, 138, 4, 0.4);
}

.hat-gq-star {
  font-size: 18rpx;
  line-height: 1;
  color: #b91c1c;
  font-weight: 700;
}

/* —— 劳动节：贴头矮盔 —— */
.hat-ld-shell {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 8rpx;
  height: 34rpx;
  border-radius: 48rpx 48rpx 14rpx 14rpx;
  background: linear-gradient(165deg, #fde68a 0%, #fbbf24 40%, #d97706 100%);
  box-shadow:
    0 5rpx 10rpx rgba(180, 83, 9, 0.28),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.35);
}

.hat-ld-visor {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  bottom: 8rpx;
  height: 11rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f59e0b 0%, #92400e 100%);
}

.hat-ld-ridge {
  position: absolute;
  left: 50%;
  top: 12rpx;
  width: 10rpx;
  height: 26rpx;
  margin-left: -5rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.38);
}

/* —— 圣诞：贴头软帽 —— */
.hat-xmas-shell {
  position: absolute;
  left: 18rpx;
  right: 22rpx;
  top: 2rpx;
  height: 40rpx;
  border-radius: 40rpx 48rpx 12rpx 20rpx;
  background: linear-gradient(155deg, #ef4444 0%, #dc2626 45%, #991b1b 100%);
  box-shadow:
    0 5rpx 10rpx rgba(153, 27, 27, 0.28),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
  transform: rotate(-8deg);
}

.hat-xmas-trim {
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  bottom: 8rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #e7e5e4 100%);
  box-shadow: 0 2rpx 5rpx rgba(68, 64, 60, 0.16);
}

.hat-xmas-pompom {
  position: absolute;
  right: 10rpx;
  top: 0;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #ffffff 0%, #f5f5f4 55%, #d6d3d1 100%);
  box-shadow: 0 2rpx 5rpx rgba(68, 64, 60, 0.18);
}
