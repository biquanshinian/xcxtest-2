.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  text-align: center;
}
.empty-state-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.empty-state-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}
.empty-state-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}
