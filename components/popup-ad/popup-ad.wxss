.popup-ad-root {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 100000;
}

.popup-ad-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
}

.popup-ad-card-wrap {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  perspective: 1200px;
}

.popup-ad-card {
  width: 96vw;
  max-width: 750rpx;
  box-sizing: border-box;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  pointer-events: auto;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.45);
  border: 1rpx solid var(--color-divider);
  will-change: transform, opacity;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.popup-ad-card--enter {
  animation: popupCardSpin 0.72s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.popup-ad-card--leave {
  animation: popupCardLeave 0.38s ease-in forwards;
}

@keyframes popupCardSpin {
  0% {
    opacity: 0;
    transform: scale3d(0.72, 0.72, 1) rotateY(-90deg) translate3d(0, 40rpx, 0);
  }
  35% {
    opacity: 1;
    transform: scale3d(1.02, 1.02, 1) rotateY(120deg) translate3d(0, 0, 0);
  }
  65% {
    transform: scale3d(0.98, 0.98, 1) rotateY(300deg) translate3d(0, 0, 0);
  }
  100% {
    opacity: 1;
    transform: scale3d(1, 1, 1) rotateY(360deg) translate3d(0, 0, 0);
  }
}

@keyframes popupCardLeave {
  0% {
    opacity: 1;
    transform: scale3d(1, 1, 1) translate3d(0, 0, 0);
  }
  100% {
    opacity: 0;
    transform: scale3d(0.85, 0.85, 1) translate3d(0, 60rpx, 0);
  }
}

.popup-ad-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 5;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-ad-close-x {
  color: #fff;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 300;
}

.popup-ad-header {
  padding: 32rpx 28rpx 16rpx;
  padding-right: 88rpx;
}

.popup-ad-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.popup-ad-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.popup-ad-product-area {
  padding-bottom: 24rpx;
  padding-left: 0;
  padding-right: 0;
}

.popup-ad-store-wrap {
  width: 100%;
  min-height: 280rpx;
}

.popup-ad-store-product {
  width: 100%;
  display: block;
}

.popup-ad-fallback {
  margin: 0 28rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #2c2c2e;
  min-height: 240rpx;
}

.popup-ad-cover {
  width: 100%;
  height: 280rpx;
  display: block;
}

.popup-ad-fallback-tip {
  padding: 24rpx;
  font-size: 26rpx;
  color: rgba(245, 245, 247, 0.55);
  text-align: center;
}
