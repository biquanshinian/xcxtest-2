.privacy-modal-root {
  position: fixed;
  inset: 0;
  /* 需压过弹窗广告(100000)/开屏(99999)/太空简报(12000)，保证任何时点弹出都在最上层 */
  z-index: 200000;
}

/* 授权确认前的全屏禁触层：透明不影响开屏视觉，仅吞触控；低于弹窗本体(200000)，
   也低于开屏「跳过」按钮(200000)——跳过是安全操作且能加速隐私弹窗弹出，不应被禁触 */
.privacy-gate-blocker {
  position: fixed;
  inset: 0;
  z-index: 199999;
  background: transparent;
}

.privacy-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.68);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.privacy-modal-panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 36rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: var(--color-bg-card);
  box-sizing: border-box;
}

.privacy-modal-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.privacy-modal-title {
  font-size: 36rpx;
  line-height: 1.3;
  color: var(--color-text-primary);
  font-weight: 700;
}

.privacy-modal-subtitle {
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.privacy-modal-body {
  margin-top: 28rpx;
}

.privacy-modal-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--color-divider-faint);
  border: 1px solid var(--color-divider);
}

.privacy-modal-card-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.privacy-modal-card-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
}

.privacy-modal-scene {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: rgba(64, 156, 255, 0.92);
}

.privacy-modal-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.privacy-modal-actions {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.privacy-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn-primary {
  background: linear-gradient(135deg, #2f7cff 0%, #62a7ff 100%);
  color: #ffffff;
  font-weight: 600;
}

.privacy-btn-ghost {
  background: var(--color-divider);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border-glass);
}

.privacy-btn-secondary {
  background: transparent;
  color: var(--color-text-secondary);
  border: 1px solid var(--color-divider);
}
