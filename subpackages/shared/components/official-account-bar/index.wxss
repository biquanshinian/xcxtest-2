/* 关注公众号 — 无卡片包裹，左右拉满以免原生组件信息被裁切 */
.official-account-bar {
  /* 抵消 .content-scroll 的左右 padding: 30rpx */
  width: calc(100% + 60rpx);
  margin: var(--space-md, 20rpx) -30rpx var(--space-xs, 12rpx);
  box-sizing: border-box;
}

.official-account-card {
  width: 100%;
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.official-account-card--dragging {
  transition: none;
}

/* 关闭按钮 — 简报 popup-close 同款，尺寸缩小 50% */
.popup-close {
  box-sizing: border-box;
  position: absolute;
  top: 0;
  right: 16rpx;
  z-index: 2;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: var(--color-divider);
  flex-shrink: 0;
}

.popup-close--hover {
  background: var(--color-divider-strong);
}

.popup-close-icon {
  font-size: 14rpx;
  color: var(--color-text-secondary);
  line-height: 1;
  pointer-events: none;
}

/* 自定义标题区 — 与下方列表内容左右对齐 */
.official-account-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm, 14rpx);
  padding: 0 30rpx 12rpx;
  padding-right: 70rpx;
}

.official-account-icon-wrap {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.official-account-icon {
  width: 52rpx;
  height: 52rpx;
  display: block;
}

.official-account-header-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.official-account-title {
  font-size: var(--font-size-md, 28rpx);
  font-weight: var(--font-weight-semibold, 600);
  color: var(--color-text-primary, #ffffff);
  line-height: var(--line-height-tight, 1.2);
}

.official-account-subtitle {
  font-size: var(--font-size-sm, 22rpx);
  color: var(--color-text-secondary, #8e8e93);
  line-height: var(--line-height-normal, 1.45);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/*
 * 原生组件区：全宽铺开，不再套圆角卡片边框
 * - 上移隐藏微信内置灰色说明文案
 * - 高度裁出白色横条主体
 */
.official-account-native-wrap {
  position: relative;
  width: 100%;
  height: 116rpx;
  overflow: hidden;
  background: transparent;
}

.official-account-native-inner {
  width: 100%;
  height: 168rpx;
  transform: translateY(-52rpx);
}

.official-account-native-inner official-account {
  display: block;
  width: 100%;
  height: 168rpx;
}
