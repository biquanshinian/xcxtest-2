/* ══ 会员续费提醒弹窗（深空玻璃拟态，与简报弹窗同一视觉体系） ══ */
.renewal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  /* 与简报弹窗同层级；两者由页面串行调度，不会同时出现 */
  z-index: 12000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: calc(12px + env(safe-area-inset-top, 0px)) 40rpx calc(16px + env(safe-area-inset-bottom, 0px));
  box-sizing: border-box;
  animation: renewalFadeIn 0.25s ease;
}

@keyframes renewalFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.renewal-popup {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  background: var(--color-bg-card);
  border-radius: 36rpx;
  border: 1px solid var(--color-border-glass);
  box-shadow:
    0 32rpx 96rpx rgba(0, 0, 0, 0.55),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.16);
  overflow: hidden;
  animation: renewalSlideUp 0.32s cubic-bezier(0.22, 0.9, 0.32, 1.1);
}

@keyframes renewalSlideUp {
  from { transform: translateY(72rpx) scale(0.96); opacity: 0; }
  to { transform: translateY(0) scale(1); opacity: 1; }
}

/* 顶部金色光晕 */
.renewal-glow {
  position: absolute;
  top: -180rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 560rpx;
  height: 360rpx;
  background: radial-gradient(ellipse at center, rgba(255, 196, 92, 0.28) 0%, rgba(255, 160, 60, 0.1) 45%, transparent 72%);
  pointer-events: none;
}

/* 星点装饰 */
.renewal-stars { position: absolute; inset: 0; pointer-events: none; }
.renewal-star {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  animation: renewalTwinkle 2.8s ease-in-out infinite;
}
.renewal-star.s1 { top: 12%; left: 14%; }
.renewal-star.s2 { top: 8%; right: 22%; width: 4rpx; height: 4rpx; animation-delay: 0.6s; }
.renewal-star.s3 { top: 22%; right: 10%; animation-delay: 1.2s; }
.renewal-star.s4 { top: 30%; left: 8%; width: 4rpx; height: 4rpx; animation-delay: 1.8s; }
.renewal-star.s5 { top: 5%; left: 46%; animation-delay: 0.9s; }
.renewal-star.s6 { top: 26%; left: 30%; width: 4rpx; height: 4rpx; animation-delay: 2.2s; }

@keyframes renewalTwinkle {
  0%, 100% { opacity: 0.25; }
  50% { opacity: 1; }
}

.renewal-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  background: var(--color-divider);
  z-index: 2;
}

.renewal-close--hover { background: var(--color-divider-strong); }

.renewal-close-icon {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1;
  pointer-events: none;
}

.renewal-body {
  position: relative;
  padding: 64rpx 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 会员徽章 + 呼吸光环 */
.renewal-badge-wrap {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.renewal-badge {
  width: 120rpx;
  height: 120rpx;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 8rpx 24rpx rgba(255, 180, 80, 0.35));
}

.renewal-badge-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 196, 92, 0.5);
  animation: renewalPulse 2.4s ease-out infinite;
}

@keyframes renewalPulse {
  0% { transform: scale(0.86); opacity: 0.9; }
  70% { transform: scale(1.18); opacity: 0; }
  100% { transform: scale(1.18); opacity: 0; }
}

.renewal-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

.renewal-days {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.renewal-days-num {
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1;
  background: linear-gradient(180deg, #ffe1a8, #ffb054);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.renewal-days-unit {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.renewal-days--expired .renewal-days-unit {
  font-size: 32rpx;
  color: #ff9f7a;
  font-weight: 600;
}

.renewal-date {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 36rpx;
}

.renewal-perks {
  width: 100%;
  background: var(--color-divider-faint);
  border: 1px solid var(--color-divider);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}

.renewal-perk {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-on-glass);
}

.renewal-perk-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd98a, #ff9d4d);
  flex-shrink: 0;
  box-shadow: 0 0 8rpx rgba(255, 180, 80, 0.6);
}

.renewal-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #ffcf7d 0%, #ff9d4d 100%);
  color: #3a2404;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  padding: 0;
  box-shadow: 0 12rpx 32rpx rgba(255, 157, 77, 0.35);
}

.renewal-btn::after { border: none; }

.renewal-btn--hover {
  opacity: 0.88;
  transform: scale(0.985);
}

.renewal-later {
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.renewal-later--hover { color: var(--color-text-secondary); }

/* ══ 免费用户升级推荐变体 ══ */
.promo-subtitle {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin: -8rpx 0 32rpx;
  letter-spacing: 2rpx;
}

.promo-benefits {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.promo-benefit {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--color-divider-faint);
  border: 1px solid var(--color-divider-faint);
  border-radius: 20rpx;
  padding: 18rpx 22rpx;
}

.promo-benefit-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(255, 209, 138, 0.22), rgba(255, 157, 77, 0.16));
  border: 1px solid rgba(255, 196, 92, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 32rpx;
  color: #ffcf7d;
  font-weight: 700;
}

.promo-benefit-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.promo-benefit-name {
  font-size: 27rpx;
  font-weight: 600;
  color: var(--color-text-on-glass);
}

.promo-benefit-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.promo-price-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.promo-price-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.promo-price-hint--em {
  color: #ffcf7d;
  font-weight: 600;
}

.promo-price-divider {
  width: 2rpx;
  height: 24rpx;
  background: var(--color-divider-strong);
}
