<!-- AI 太空助手：面板由 NASA 圆盘菜单唤起 -->



<!-- 聊天面板：sheet=半屏；page=详情页全屏 -->

<view class="ai-panel {{visible ? 'ai-panel--show' : ''}} {{isPageMode ? 'ai-panel--page' : ''}}" wx:if="{{panelMounted}}">

  <view class="ai-panel-mask" bindtap="closeChat" wx:if="{{!isPageMode}}"></view>

  <view class="ai-panel-body {{visible ? 'ai-panel-body--show' : ''}} {{themeClass}}" style="{{isPageMode ? '' : ('height: ' + panelHeight + 'px; bottom: ' + keyboardHeight + 'px;')}}">

    <!-- 标题栏：仅半屏模式；详情页用顶部导航，不再显示「新对话」栏 -->

    <view class="ai-panel-header" wx:if="{{!isPageMode}}" bindtap="dismissKeyboard">

      <view class="ai-panel-header-left">

        <text class="ai-panel-title">✦ 星问</text>

        <text class="ai-panel-subtitle">AI太空助手</text>

      </view>

      <view class="ai-panel-header-actions">

        <view class="ai-header-btn ai-panel-close" bindtap="closeChat">

          <text>✕</text>

        </view>

      </view>

    </view>



    <!-- 消息列表 -->

    <scroll-view

      class="ai-messages"

      scroll-y

      enhanced

      show-scrollbar="{{false}}"

      scroll-into-view="{{scrollTarget}}"

      scroll-with-animation

      bindtap="dismissKeyboard"

    >

      <!-- 欢迎消息（无历史时显示）：首次进入弹跳动态头像 -->

      <view class="ai-welcome" wx:if="{{!messages.length}}">

        <!-- stage 固定：粒子常驻 DOM（避免 wx:if 重挂卡顿）；动画只动 transform/opacity -->
        <view class="ai-welcome-mascot-stage {{welcomeBounce ? 'ai-welcome-mascot-stage--bounce' : ''}} {{festivalHat ? 'ai-welcome-mascot-stage--hatted' : ''}}">

          <view class="ai-welcome-mascot-trail" aria-hidden="true">
            <view class="ai-welcome-mascot-streak"></view>
            <view class="ai-welcome-particle ai-welcome-particle--1"></view>
            <view class="ai-welcome-particle ai-welcome-particle--2"></view>
            <view class="ai-welcome-particle ai-welcome-particle--3"></view>
            <view class="ai-welcome-particle ai-welcome-particle--4"></view>
            <view class="ai-welcome-particle ai-welcome-particle--5"></view>
          </view>

          <view class="ai-welcome-mascot {{festivalHat ? 'ai-welcome-mascot--hatted' : ''}}">

          <view class="ai-welcome-mascot-ring"></view>

          <!-- 头+帽同一节点：弹跳/idle 只动外层或 face，帽永不单独位移 -->
          <view class="ai-welcome-mascot-face">

            <festival-hat hat="{{festivalHat}}" size="{{112}}" />

            <view class="ai-welcome-mascot-cheek ai-welcome-mascot-cheek--l"></view>

            <view class="ai-welcome-mascot-cheek ai-welcome-mascot-cheek--r"></view>

            <view class="ai-welcome-mascot-star">

              <text class="ai-welcome-mascot-star-glyph">✦</text>

            </view>

          </view>

          <view class="ai-welcome-mascot-shadow"></view>

          </view>
        </view>

        <!-- 开发模式：轮播预览全部节日帽，看完把 FESTIVAL_HAT_DEV_MODE 改 false -->
        <view class="ai-welcome-hat-dev" wx:if="{{festivalHatDev}}">
          <text class="ai-welcome-hat-dev-label">帽预览 · {{festivalHatName}}（{{festivalHatTip}}）</text>
          <scroll-view class="ai-welcome-hat-dev-scroll" scroll-x enhanced show-scrollbar="{{false}}">
            <view class="ai-welcome-hat-dev-row">
              <view
                class="ai-welcome-hat-dev-chip {{festivalHat === item.id ? 'ai-welcome-hat-dev-chip--on' : ''}}"
                wx:for="{{festivalHatList}}"
                wx:key="id"
                data-id="{{item.id}}"
                bindtap="onFestivalHatDevPick"
              >{{item.name}}</view>
            </view>
          </scroll-view>
        </view>

        <text class="ai-welcome-title">你好，我是星问</text>

        <text class="ai-welcome-desc">查发射、看回放与统计，或打开飞行剖面、在轨追踪等互动工具——有航天问题都可以问我。</text>

      </view>



      <!-- 聊天消息 -->

      <block wx:for="{{messages}}" wx:key="id">

        <view class="ai-msg ai-msg--{{item.role === 'user' ? 'user' : 'bot'}}" id="msg-{{item.id}}">

          <!-- 机器人头像 -->

          <view class="ai-bot-avatar" wx:if="{{item.role !== 'user'}}">

            <view class="ai-star-wrap ai-star-wrap--bot">

              <text class="ai-star-glyph">✦</text>

            </view>

          </view>

          <view class="ai-msg-col" wx:if="{{item.role !== 'user'}}">

            <view class="ai-msg-bubble ai-msg-bubble--bot {{item.error ? 'ai-msg-bubble--error' : ''}}">

              <text class="ai-msg-text" user-select wx:if="{{item.content}}">{{item.content}}</text>

              <view class="ai-msg-typing" wx:if="{{item.typing}}">

                <view class="typing-dot"></view>

                <view class="typing-dot"></view>

                <view class="typing-dot"></view>

              </view>

            </view>

            <!-- 结构化富卡片：任务 / 发射列表 / 星舰状态 -->

            <view class="ai-mission-cards" wx:if="{{item.cards && item.cards.length}}">

              <block wx:for="{{item.cards}}" wx:for-item="card" wx:key="id">

                <!-- 发射列表卡 -->

                <view class="ai-rich-card glass-card" wx:if="{{card.cardType === 'launch_list'}}">

                  <view class="ai-rich-card-header">

                    <text class="ai-rich-card-title">{{card.title}}</text>

                    <text class="ai-rich-card-count">{{card.items.length}} 次</text>

                  </view>

                  <view

                    class="ai-launch-row"

                    wx:for="{{card.items}}"

                    wx:for-item="row"

                    wx:key="id"

                    bindtap="onMissionCardTap"

                    data-id="{{row.id}}"

                    data-type="{{row.detailType}}"

                  >

                    <image

                      class="ai-launch-row-thumb"

                      wx:if="{{row.rocketImage}}"

                      src="{{row.rocketImage}}"

                      mode="aspectFill"

                      binderror="onMissionCardRocketError"

                      data-msgid="{{item.id}}"

                      data-id="{{row.id}}"

                    ></image>

                    <view class="ai-launch-row-thumb ai-launch-row-thumb--ph" wx:else></view>

                    <view class="ai-launch-row-body">

                      <view class="ai-launch-row-top">

                        <text class="mission-status-badge status-{{row.statusCategory || 'pending'}}">{{row.statusText}}</text>

                        <text class="ai-launch-row-agency" wx:if="{{row.launchAgency}}">{{row.launchAgency}}</text>

                      </view>

                      <text class="ai-launch-row-name">{{row.name}}</text>

                      <text class="ai-launch-row-time">{{row.formattedTime}}</text>

                    </view>

                  </view>

                  <view class="ai-rich-card-footer" bindtap="onLaunchListMoreTap">

                    <text class="ai-rich-card-cta">查看首页更多 ›</text>

                  </view>

                </view>

                <!-- 星舰 B/S 状态卡 -->

                <view class="ai-rich-card glass-card" wx:elif="{{card.cardType === 'starship_status'}}" bindtap="onStarshipStatusTap">

                  <view class="ai-rich-card-header">

                    <text class="ai-rich-card-title">{{card.title}}</text>

                  </view>

                  <view class="ai-ss-vehicles">

                    <view class="ai-ss-vehicle" catchtap="onStarshipStatusTap" data-vehicle="booster">

                      <text class="ai-ss-id">{{card.booster.id || '待公布'}}</text>

                      <text class="ai-ss-label">超重助推器</text>

                      <text class="ai-ss-status">{{card.booster.status}}</text>

                      <view class="ai-ss-track" wx:if="{{card.booster.progress != null}}">

                        <view class="ai-ss-fill" style="{{card.booster.progressStyle}}"></view>

                      </view>

                    </view>

                    <view class="ai-ss-vehicle" catchtap="onStarshipStatusTap" data-vehicle="ship">

                      <text class="ai-ss-id">{{card.ship.id || '待公布'}}</text>

                      <text class="ai-ss-label">星舰飞船</text>

                      <text class="ai-ss-status">{{card.ship.status}}</text>

                      <view class="ai-ss-track" wx:if="{{card.ship.progress != null}}">

                        <view class="ai-ss-fill" style="{{card.ship.progressStyle}}"></view>

                      </view>

                    </view>

                  </view>

                  <view class="ai-ss-checklist" wx:if="{{card.checklist}}">

                    <text class="ai-ss-checklist-text">飞行准备清单：{{card.checklist.done}}/{{card.checklist.total}} 项完成</text>

                  </view>

                  <text class="ai-rich-card-cta ai-ss-cta">进入星舰进度 ›</text>

                </view>

                <!-- 发射商卡 -->

                <view

                  class="ai-rich-card glass-card ai-agency-card"

                  wx:elif="{{card.cardType === 'agency'}}"

                  bindtap="onAgencyCardTap"

                  data-id="{{card.id}}"

                  data-gateid="{{card.gateProductId}}"

                  data-gatename="{{card.gateProductName}}"

                >

                  <view class="ai-agency-row">

                    <image

                      class="ai-agency-logo"

                      wx:if="{{card.logoUrl}}"

                      src="{{card.logoUrl}}"

                      mode="aspectFit"

                    ></image>

                    <view class="ai-agency-logo-ph" wx:else>

                      <text>{{card.abbrev || 'AG'}}</text>

                    </view>

                    <view class="ai-agency-main">

                      <view class="ai-agency-title-row">

                        <text class="ai-agency-name">{{card.displayName}}</text>

                        <text class="ai-agency-type" wx:if="{{card.typeZh}}">{{card.typeZh}}</text>

                      </view>

                      <text class="ai-agency-meta" wx:if="{{card.metaLine}}">{{card.metaLine}}</text>

                      <text class="ai-agency-desc" wx:if="{{card.desc}}">{{card.desc}}</text>

                    </view>

                  </view>

                  <text class="ai-rich-card-cta ai-agency-cta">{{card.cta || '进入发射商详情 ›'}}</text>

                </view>

                <!-- 发射统计卡 -->

                <view

                  class="ai-rich-card glass-card ai-stats-card"

                  wx:elif="{{card.cardType === 'launch_stats'}}"

                  bindtap="onLaunchStatsCardTap"

                  data-year="{{card.year}}"

                  data-country="{{card.countryKey}}"

                  data-gateid="{{card.gateProductId}}"

                  data-gatename="{{card.gateProductName}}"

                >

                  <view class="ai-rich-card-header">

                    <text class="ai-rich-card-title">{{card.title}}</text>

                    <text class="ai-rich-card-count">{{card.scopeLabel}}</text>

                  </view>

                  <view class="ai-stats-numbers">

                    <view class="ai-stats-num-block">

                      <text class="ai-stats-num">{{card.total}}</text>

                      <text class="ai-stats-num-label">总发射</text>

                    </view>

                    <view class="ai-stats-num-block">

                      <text class="ai-stats-num ai-stats-num--ok">{{card.success}}</text>

                      <text class="ai-stats-num-label">成功</text>

                    </view>

                    <view class="ai-stats-num-block">

                      <text class="ai-stats-num ai-stats-num--fail">{{card.failure}}</text>

                      <text class="ai-stats-num-label">失败</text>

                    </view>

                  </view>

                  <text class="ai-stats-sub" wx:if="{{card.subtitle}}">{{card.subtitle}}</text>

                  <text class="ai-rich-card-cta ai-stats-cta">{{card.cta || '查看全球发射统计 ›'}}</text>

                </view>

                <!-- 发射集锦/回放卡：封面 + 门控播放 -->

                <view

                  class="ai-rich-card glass-card ai-replay-card"

                  wx:elif="{{card.cardType === 'mission_replay'}}"

                  bindtap="onMissionReplayCardTap"

                  data-launchid="{{card.launchId}}"

                  data-type="{{card.detailType}}"

                  data-name="{{card.missionName}}"

                  data-playable="{{card.playable ? 1 : 0}}"

                  data-videourl="{{card.videoUrl}}"

                  data-poster="{{card.poster}}"

                  data-gateid="{{card.gateProductId}}"

                  data-gatename="{{card.gateProductName}}"

                >

                  <view class="ai-replay-media">

                    <image

                      class="ai-replay-poster"

                      wx:if="{{card.poster}}"

                      src="{{card.poster}}"

                      mode="aspectFill"

                    />

                    <view class="ai-replay-poster-ph" wx:else></view>

                    <view class="ai-replay-play" wx:if="{{card.playable}}">

                      <text class="ai-replay-play-icon">▶</text>

                    </view>

                  </view>

                  <view class="ai-replay-body">

                    <text class="ai-replay-tag">REPLAY</text>

                    <text class="ai-replay-title">{{card.title}}</text>

                    <text class="ai-replay-desc">{{card.desc}}</text>

                    <text class="ai-rich-card-cta ai-replay-cta">{{card.cta || '观看集锦 ›'}}</text>

                  </view>

                </view>

                <!-- 入口卡：飞行演示 / 在轨追踪 -->

                <view

                  class="ai-entry-card glass-card ai-entry-card--{{card.variant || 'demo'}}"

                  wx:elif="{{card.cardType === 'entry'}}"

                  bindtap="onEntryCardTap"

                  data-kind="{{card.entryKind}}"

                  data-missionid="{{card.missionId}}"

                  data-type="{{card.detailType}}"

                  data-name="{{card.missionName}}"

                  data-stationid="{{card.stationId}}"

                  data-gateid="{{card.gateProductId}}"

                  data-gatename="{{card.gateProductName}}"

                  data-needsim="{{card.needMissionSimFlag ? 1 : 0}}"

                >

                  <view class="ai-entry-glow"></view>

                  <view class="ai-entry-left">

                    <view class="ai-entry-tagrow">

                      <view class="ai-entry-dot"></view>

                      <text class="ai-entry-tag">{{card.tag}}</text>

                    </view>

                    <text class="ai-entry-title">{{card.title}}</text>

                    <text class="ai-entry-desc">{{card.desc}}</text>

                  </view>

                  <view class="ai-entry-arrow">

                    <text>{{card.cta || '进入 ›'}}</text>

                  </view>

                </view>

                <!-- 默认：单任务卡（与首页 mission-card 同结构） -->

                <view

                  class="mission-list-card-root mission-card glass-card card-hover mission-card-link mission-card--{{card.statusCategory || 'pending'}}"

                  wx:else

                  bindtap="onMissionCardTap"

                  data-id="{{card.id}}"

                  data-type="{{card.detailType}}"

                >

                  <view class="mission-card-inner-row">

                    <view class="mission-rocket-slot">

                      <image

                        class="mission-rocket-image"

                        wx:if="{{card.rocketImage}}"

                        src="{{card.rocketImage}}"

                        mode="aspectFill"

                        binderror="onMissionCardRocketError"

                        data-msgid="{{item.id}}"

                        data-id="{{card.id}}"

                      ></image>

                      <view wx:else class="mission-rocket-image mission-rocket-image--placeholder"></view>

                    </view>

                    <view class="mission-info-content">

                      <view class="mission-card-header">

                        <text class="mission-status-badge status-{{card.statusCategory || 'pending'}}">{{card.statusText}}</text>

                        <view class="mission-card-header-right">

                          <text class="mission-meta mission-rocket" wx:if="{{card.rocketName}}">{{card.rocketName}}</text>

                        </view>

                      </view>

                      <text class="mission-main-title">{{card.name}}</text>

                      <text class="mission-time">{{card.formattedTime}}</text>

                      <text class="mission-meta mission-pad" wx:if="{{card.padLocation}}">{{card.padLocation}}</text>

                      <text class="mission-meta ai-mission-card-cta">点击查看详情</text>

                    </view>

                  </view>

                </view>

              </block>

            </view>

            <!-- 失败重试按钮 -->

            <view class="ai-retry-btn ai-retry-btn--inline" wx:if="{{item.error}}" bindtap="retryLastMessage">

              <text class="ai-retry-icon">↻</text>

              <text class="ai-retry-text">重试</text>

            </view>

          </view>

          <view class="ai-msg-bubble ai-msg-bubble--user" wx:else>

            <text class="ai-msg-text" user-select wx:if="{{item.content}}">{{item.content}}</text>

          </view>

        </view>

      </block>



      <view id="msg-bottom" style="height: 20rpx;"></view>

    </scroll-view>



    <!-- AI生成内容声明 -->

    <view class="ai-disclaimer" bindtap="dismissKeyboard">

      <text class="ai-disclaimer-icon">⚠</text>

      <text class="ai-disclaimer-text">本服务由人工智能(AI)生成内容，结果仅供参考，不代表专业意见</text>

    </view>

    <!-- 输入栏上方：跳转卡快捷入口（横向滑动） -->

    <scroll-view

      class="ai-shortcut-scroll"

      scroll-x

      enhanced

      show-scrollbar="{{false}}"

      enable-flex

    >

      <view class="ai-shortcut-row">

        <view

          class="ai-shortcut-chip {{sending ? 'ai-shortcut-chip--disabled' : ''}}"

          wx:for="{{quickShortcuts}}"

          wx:key="id"

          bindtap="onQuickQuestion"

          data-q="{{item.q}}"

        >

          <text class="ai-shortcut-label">{{item.label}}</text>

        </view>

      </view>

    </scroll-view>

    <view class="ai-input-bar {{keyboardHeight > 0 ? 'ai-input-bar--keyboard' : ''}}">

      <input

        class="ai-input"

        placeholder="{{sending ? '星问正在思考...' : ''}}"

        placeholder-class="ai-input-placeholder"

        value="{{inputValue}}"

        bindinput="onInput"

        bindconfirm="sendMessage"

        bindfocus="onInputFocus"

        bindblur="onInputBlur"

        bindkeyboardheightchange="onInputKeyboardHeightChange"

        confirm-type="send"

        disabled="{{sending}}"

        focus="{{inputFocus}}"

        adjust-position="{{false}}"

        cursor-spacing="24"

        hold-keyboard="{{true}}"

      />

      <view class="ai-send-btn {{inputValue.length > 0 && !sending ? 'ai-send-btn--active' : ''}} {{sending ? 'ai-send-btn--sending' : ''}}" bindtap="sendMessage">

        <text class="ai-send-icon" wx:if="{{!sending}}">↑</text>

        <view class="ai-send-spinner" wx:else></view>

      </view>

    </view>

  </view>

</view>

