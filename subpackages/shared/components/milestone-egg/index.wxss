.egg-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.egg-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.65);
}
.egg-container {
  position: relative;
  width: 600rpx;
  background: var(--color-bg-card);
  border-radius: 32rpx;
  padding: 60rpx 40rpx 48rpx;
  box-shadow: 0 20rpx 80rpx rgba(0,0,0,0.5);
  animation: eggPopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes eggPopIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.egg-close {
  position: absolute;
  top: 20rpx; right: 24rpx;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

/* ── 阶段1：金蛋 ── */
.egg-stage { text-align: center; }
.egg-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffd700;
  margin-bottom: 40rpx;
  text-shadow: 0 2rpx 8rpx rgba(255,215,0,0.3);
}
.egg-body { position: relative; display: inline-block; }
.egg-image {
  width: 240rpx; height: 300rpx;
}
.egg-default {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.egg-golden {
  width: 160rpx;
  height: 220rpx;
  background: linear-gradient(155deg, #fff6b0 0%, #ffd700 20%, #ffb800 45%, #e6a200 70%, #cc8800 100%);
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  box-shadow:
    inset -12rpx -8rpx 24rpx rgba(180,120,0,0.4),
    inset 12rpx 12rpx 24rpx rgba(255,255,200,0.4),
    0 8rpx 40rpx rgba(255,180,0,0.5),
    0 0 60rpx rgba(255,215,0,0.3);
  position: relative;
  animation: eggWobble 2s ease-in-out infinite;
  overflow: hidden;
}
.egg-golden-highlight {
  position: absolute;
  top: 22%;
  left: 18%;
  width: 35%;
  height: 28%;
  background: radial-gradient(ellipse, rgba(255,255,255,0.65) 0%, transparent 70%);
  border-radius: 50%;
  transform: rotate(-25deg);
}
@keyframes eggWobble {
  0%,100% { transform: rotate(-3deg) scale(1); }
  25% { transform: rotate(3deg) scale(1.03); }
  50% { transform: rotate(-2deg) scale(1); }
  75% { transform: rotate(2deg) scale(1.02); }
}
.egg-shine {
  position: absolute;
  top: -20rpx; right: -20rpx;
  width: 60rpx; height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,215,0,0.8), transparent 70%);
  animation: eggShine 1.5s ease-in-out infinite;
}
@keyframes eggShine {
  0%,100% { opacity: 0.5; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}
.egg-hint {
  color: var(--color-text-secondary);
  font-size: 26rpx;
  margin-top: 24rpx;
  animation: hintBlink 1.5s ease-in-out infinite;
}
@keyframes hintBlink {
  0%,100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* ── 阶段2：裂开 ── */
.egg-stage--crack { min-height: 400rpx; display: flex; align-items: center; justify-content: center; }
.egg-crack-wrap {
  position: relative;
  width: 300rpx; height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.egg-crack-left, .egg-crack-right {
  position: absolute;
  overflow: hidden;
}
.egg-half {
  width: 84rpx;
  height: 220rpx;
  background: linear-gradient(155deg, #fff6b0 0%, #ffd700 20%, #ffb800 45%, #e6a200 70%, #cc8800 100%);
}
.egg-half--left {
  border-radius: 100rpx 0 0 80rpx / 130rpx 0 0 90rpx;
  box-shadow: inset 8rpx 8rpx 16rpx rgba(255,255,200,0.4);
}
.egg-half--right {
  border-radius: 0 100rpx 80rpx 0 / 0 130rpx 90rpx 0;
  box-shadow: inset -8rpx -6rpx 16rpx rgba(180,120,0,0.4);
}
.egg-crack-left {
  animation: crackLeft 0.6s ease-out forwards;
}
.egg-crack-right {
  animation: crackRight 0.6s ease-out forwards;
}
@keyframes crackLeft {
  0% { transform: translateX(0) rotate(0); opacity: 1; }
  100% { transform: translateX(-100rpx) rotate(-30deg); opacity: 0; }
}
@keyframes crackRight {
  0% { transform: translateX(0) rotate(0); opacity: 1; }
  100% { transform: translateX(100rpx) rotate(30deg); opacity: 0; }
}
.egg-sparkles {
  font-size: 80rpx;
  animation: sparkleGrow 0.6s ease-out forwards;
}
@keyframes sparkleGrow {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.5); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

/* ── 阶段3：奖品 ── */
.egg-stage--prize { animation: prizeFadeIn 0.5s ease-out; }
@keyframes prizeFadeIn {
  0% { opacity: 0; transform: translateY(30rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
.prize-badge { font-size: 80rpx; margin-bottom: 16rpx; }
.prize-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffd700;
  margin-bottom: 32rpx;
}
.prize-image {
  width: 280rpx; height: 280rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}
.prize-emoji { font-size: 120rpx; margin-bottom: 24rpx; }
.prize-desc {
  font-size: 30rpx;
  color: var(--color-text-on-glass);
  margin-bottom: 12rpx;
}
.prize-ship-note {
  font-size: 24rpx;
  color: var(--color-warning);
  margin-bottom: 40rpx;
}
.prize-claim-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  margin: 0 auto;
  text-align: center;
}

/* ── 阶段4：表单 ── */
.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 36rpx;
}
.form-group { margin-bottom: 28rpx; text-align: left; }
.form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
}
.form-input {
  width: 100%;
  height: 80rpx;
  background: var(--color-divider);
  border: 1rpx solid var(--color-divider-strong);
  border-radius: 16rpx;
  padding: 0 24rpx;
  color: var(--color-text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  height: 140rpx;
  background: var(--color-divider);
  border: 1rpx solid var(--color-divider-strong);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  color: var(--color-text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
}
.size-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 10rpx;
}
.size-item {
  min-width: 80rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  padding: 0 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-divider);
  border: 1rpx solid var(--color-divider-strong);
  box-sizing: border-box;
}
.size-item--active {
  color: #1a1a2e;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  border-color: #ffd700;
  font-weight: 700;
}
.form-note-color {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
  text-align: left;
}
.form-note {
  font-size: 22rpx;
  color: var(--color-warning);
  margin-bottom: 28rpx;
  text-align: left;
}
.form-submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  margin: 0;
  text-align: center;
}

/* ── 阶段5：完成 ── */
.egg-stage--done { animation: prizeFadeIn 0.5s ease-out; }
.done-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.done-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4ecdc4;
  margin-bottom: 20rpx;
}
.done-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
  line-height: 1.6;
}
.done-btn {
  width: 60%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--color-divider-strong);
  color: var(--color-text-primary);
  font-size: 30rpx;
  border-radius: 40rpx;
  border: 1rpx solid var(--color-divider-strong);
  padding: 0;
  margin: 0 auto;
  text-align: center;
}
