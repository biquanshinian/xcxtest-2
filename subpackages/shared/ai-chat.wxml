<page-meta background-color="{{pageBgColor}}" background-color-top="{{pageBgColor}}" background-color-bottom="{{pageBgColor}}" />
<!-- pageAllowed=false 时不渲染星问 UI，避免过审关闭后分享直达仍露出详情 -->
<view class="ai-chat-detail-page {{themeClass}}" wx:if="{{pageAllowed}}">
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-grid">
      <view class="nav-left top-nav-slot--back {{isDirectEntry ? 'top-nav-slot--home' : ''}}" bindtap="goBack" style="width: {{menuButtonWidth}}px;">
        <text class="icon-back icon-back--nav">‹</text>
      </view>
      <view class="nav-title-wrap nav-title-wrap--page-grid">
        <text class="nav-title nav-title--page-grid">星问</text>
        <text class="ai-chat-nav-sub">AI太空助手</text>
      </view>
      <view class="nav-right-space top-nav-slot--spacer" style="width: {{menuButtonWidth}}px;"></view>
    </view>
  </view>

  <view class="ai-chat-detail-body" style="padding-top: {{navPlaceholderHeight}}px; padding-bottom: {{keyboardHeight}}px;">
    <ai-chat id="aiChat" mode="page" bind:sharehint="onShareHint" bind:keyboardheight="onKeyboardHeight" />
  </view>

  <share-guide />
</view>
