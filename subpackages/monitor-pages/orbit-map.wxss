page {
  background: #000;
  overflow: hidden;
  height: 100vh;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
}

.main-map {
  width: 100%;
  height: 100vh;
}

.glass-card {
  background: rgba(18, 18, 20, 0.78);
  backdrop-filter: blur(18rpx);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* 轨道实时数据网格 */
.orbit-stats-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.orbit-stat-card {
  flex: 1;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  text-align: center;
}

.orbit-stat-card-value {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.orbit-stat-card-label {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 轨道参数详情 */
.orbit-detail-card {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
}

.orbit-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.orbit-detail-row:last-child {
  border-bottom: none;
}

.orbit-detail-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.orbit-detail-value {
  font-size: 24rpx;
  color: #ffffff;
  font-family: 'Menlo', 'Courier New', monospace;
}

/* 图例 */
.orbit-legend-row {
  margin-top: 14rpx;
  display: flex;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-line {
  width: 24rpx;
  height: 4rpx;
  border-radius: 2rpx;
}

.legend-line--future {
  background: #00ff88;
}

.legend-line--past {
  background: #4ea1ff;
  opacity: 0.5;
}

.legend-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 数据来源 */
.data-meta-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-meta-text {
  color: rgba(255, 255, 255, 0.54);
  font-size: 20rpx;
  line-height: 1.4;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.85);
  border-color: var(--color-divider);
}

.theme-light .orbit-stat-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .orbit-stat-card-value {
  color: var(--color-text-primary);
}

.theme-light .orbit-stat-card-label {
  color: var(--color-text-tertiary);
}

.theme-light .orbit-detail-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .orbit-detail-row {
  border-bottom-color: var(--color-divider);
}

.theme-light .orbit-detail-label {
  color: var(--color-text-tertiary);
}

.theme-light .orbit-detail-value {
  color: var(--color-text-primary);
}

.theme-light .legend-text {
  color: var(--color-text-secondary);
}

.theme-light .data-meta-text {
  color: var(--color-text-tertiary);
}
