/* agency-list.wxss —— 全球发射商图鉴完整列表页（与监控页板块同款卡片样式，套用星舰硬件设施布局） */
page {
  background: #000;
  color: #fff;
}

.list-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
}

.list-scroll {
  height: 100vh;
}

.list-body {
  padding: 20rpx 30rpx 0;
}

/* 导航标题包裹层：min-width:0 允许在 grid 中收缩，flex 保证标题始终水平居中 */
.nav-title-wrap {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.glass-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  overflow: hidden;
}

.card-hover {
  transition: transform 0.15s ease;
}
.card-hover:active {
  transform: scale(0.97);
}

/* 筛选胶囊 */
.agency-filter-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.agency-filter-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 6rpx;
}

.agency-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.agency-chip text {
  color: #C7C7CC;
  font-size: 24rpx;
  line-height: 1;
}

.agency-chip-active {
  background: rgba(10, 132, 255, 0.2);
  border-color: rgba(10, 132, 255, 0.55);
}

.agency-chip-active text {
  color: #9FD0FF;
  font-weight: 600;
}

/* 搜索框 */
/* 简洁搜索条：纯色圆角灰底 + 左侧放大镜 + “搜索”占位 */
.agency-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 24rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid transparent;
}

.agency-search-icon {
  color: #8E8E93;
  font-size: 34rpx;
  line-height: 1;
}

.agency-search-input {
  flex: 1;
  min-width: 0;
  color: #FFFFFF;
  font-size: 26rpx;
  height: 52rpx;
  line-height: 52rpx;
}

.agency-search-placeholder {
  color: #636366;
}

.agency-search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
}

.agency-search-clear text {
  color: #C7C7CC;
  font-size: 30rpx;
  line-height: 1;
}

/* 结果计数 */
.list-count {
  margin-bottom: 16rpx;
  padding: 0 6rpx;
}
.list-count text {
  font-size: 22rpx;
  color: #8E8E93;
}

/* 卡片网格 */
.agency-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.agency-hw-card {
  width: calc((100% - 20rpx) / 2);
  padding: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* 扫光走全局 skeleton-shimmer（app.wxss） */
.agency-hw-card-skeleton {
  height: 380rpx;
}

.agency-hw-card-image-wrap {
  width: 100%;
  aspect-ratio: 4 / 3;
  position: relative;
  overflow: hidden;
  background: rgba(30, 30, 30, 0.35);
}

.agency-hw-card-image {
  width: 100%;
  height: 100%;
  display: block;
  background-color: rgba(30, 30, 30, 0.35);
}

/* 仅有 logo 时：留白居中展示，白色衬底保证深色 logo 可见 */
.agency-hw-card-image--logo {
  box-sizing: border-box;
  padding: 36rpx;
  background-color: rgba(255, 255, 255, 0.92);
}

.agency-hw-card-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle, rgba(90, 200, 250, 0.12), rgba(28, 28, 30, 0.95));
}

.agency-hw-card-image-placeholder text {
  font-size: 64rpx;
}

.agency-hw-card-image-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 55%;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, rgba(22, 22, 24, 0.92) 100%);
  pointer-events: none;
}

.agency-hw-card-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  pointer-events: none;
}

.agency-hw-card-name {
  max-width: 100%;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.8);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.agency-hw-card-body {
  padding: 14rpx 18rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.agency-hw-card-meta {
  font-size: 22rpx;
  color: #8E8E93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.agency-hw-card-notes {
  font-size: 22rpx;
  color: #AEAEB2;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 类型徽标 */
.agency-type-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(28, 28, 30, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.1);
}
.agency-type--government {
  color: #FFD60A;
  background: rgba(66, 56, 8, 0.72);
  border-color: rgba(255, 214, 10, 0.25);
}
.agency-type--commercial {
  color: #30D158;
  background: rgba(10, 52, 22, 0.72);
  border-color: rgba(48, 209, 88, 0.25);
}

/* 空态 */
.agency-empty {
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agency-empty text {
  color: #8E8E93;
  font-size: 26rpx;
  text-align: center;
}

/* 数据来源 */
.source-note {
  padding: 24rpx 0 0;
  text-align: center;
}
.source-note text {
  font-size: 22rpx;
  color: #48484A;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.list-page.theme-light {
  background: var(--color-bg-page);
}
.theme-light .glass-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .agency-chip {
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid var(--color-divider);
}
.theme-light .agency-chip text {
  color: var(--color-text-secondary);
}
.theme-light .agency-chip-active {
  background: rgba(10, 132, 255, 0.12);
  border-color: rgba(10, 132, 255, 0.45);
}
.theme-light .agency-chip-active text {
  color: #007AFF;
}
.theme-light .agency-search {
  background: #FFFFFF;
  border: 1px solid var(--color-divider);
}
.theme-light .agency-search-icon {
  color: var(--color-text-secondary);
}
.theme-light .agency-search-input {
  color: var(--color-text-primary);
}
.theme-light .agency-search-placeholder {
  color: var(--color-text-tertiary);
}
.theme-light .agency-search-clear {
  background: rgba(0, 0, 0, 0.06);
}
.theme-light .agency-search-clear text {
  color: var(--color-text-secondary);
}
.theme-light .list-count text {
  color: var(--color-text-secondary);
}
.theme-light .agency-hw-card {
  border: 1px solid var(--color-divider);
}
/* 骨架浅色底色由全局 .theme-light .skeleton-shimmer 提供 */
.theme-light .agency-hw-card-image-wrap {
  background: rgba(0, 0, 0, 0.05);
}
.theme-light .agency-hw-card-image {
  background-color: rgba(0, 0, 0, 0.05);
}
.theme-light .agency-hw-card-image-placeholder {
  background: radial-gradient(circle, rgba(90, 200, 250, 0.14), #ECECF1);
}
/* agency-hw-card-image-mask / overlay 白字压在图片上，保持深色渐变收边 */
.theme-light .agency-hw-card-meta {
  color: var(--color-text-secondary);
}
.theme-light .agency-hw-card-notes {
  color: var(--color-text-secondary);
}
.theme-light .agency-empty text {
  color: var(--color-text-secondary);
}
.theme-light .source-note text {
  color: var(--color-text-tertiary);
}
