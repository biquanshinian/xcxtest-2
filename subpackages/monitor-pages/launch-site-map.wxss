page {
  background: #000;
  overflow: hidden;
  height: 100vh;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
}

.main-map {
  width: 100%;
  height: 100vh;
}

.glass-card {
  background: rgba(18, 18, 20, 0.78);
  backdrop-filter: blur(18rpx);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.state-card {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.state-title {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.state-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.5;
}

.panel-header {
  align-items: flex-start;
}

.panel-subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.panel-badge {
  flex-shrink: 0;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(10, 132, 255, 0.16);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.panel-badge text {
  color: #9FD0FF;
  font-size: 20rpx;
}

.data-meta-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-meta-text {
  color: rgba(255, 255, 255, 0.54);
  font-size: 20rpx;
  line-height: 1.4;
}

.type-list,
.site-list {
  margin-top: 22rpx;
  white-space: nowrap;
}

.type-row,
.site-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 12rpx;
}

.type-chip {
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.type-chip text {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.type-chip--active {
  background: rgba(10, 132, 255, 0.18);
  border: 1px solid rgba(10, 132, 255, 0.55);
}

.type-chip--active text {
  color: #9FD0FF;
}

.site-chip {
  min-width: 220rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

.site-chip--active {
  background: rgba(10, 132, 255, 0.14);
  border: 1px solid rgba(10, 132, 255, 0.55);
}

.site-chip-name {
  display: block;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.site-chip-region {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 20rpx;
}

.detail-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.detail-name {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-meta,
.detail-vehicle,
.detail-summary,
.detail-latest,
.detail-next,
.detail-time {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  line-height: 1.5;
}

.detail-activity-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.detail-activity-badge text {
  font-size: 20rpx;
}

.detail-stats-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-stat-chip {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.detail-stat-chip text {
  color: #fff;
  font-size: 20rpx;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.85);
  border-color: var(--color-divider);
}

.theme-light .state-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .state-title {
  color: var(--color-text-primary);
}

.theme-light .state-desc {
  color: var(--color-text-secondary);
}

.theme-light .panel-subtitle {
  color: var(--color-text-secondary);
}

.theme-light .panel-badge {
  background: rgba(10, 132, 255, 0.12);
}

.theme-light .panel-badge text {
  color: #0A84FF;
}

.theme-light .data-meta-text {
  color: var(--color-text-tertiary);
}

.theme-light .type-chip {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .type-chip text {
  color: var(--color-text-secondary);
}

.theme-light .type-chip--active {
  background: rgba(10, 132, 255, 0.12);
}

.theme-light .type-chip--active text {
  color: #0A84FF;
}

.theme-light .site-chip {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .site-chip--active {
  background: rgba(10, 132, 255, 0.12);
}

.theme-light .site-chip-name {
  color: var(--color-text-primary);
}

.theme-light .site-chip-region {
  color: var(--color-text-secondary);
}

.theme-light .detail-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .detail-name {
  color: var(--color-text-primary);
}

.theme-light .detail-meta,
.theme-light .detail-vehicle,
.theme-light .detail-summary,
.theme-light .detail-latest,
.theme-light .detail-next,
.theme-light .detail-time {
  color: var(--color-text-secondary);
}

.theme-light .detail-stat-chip {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .detail-stat-chip text {
  color: var(--color-text-primary);
}
