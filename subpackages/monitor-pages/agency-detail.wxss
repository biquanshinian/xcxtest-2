/* ========== 事件更新（推文）板块 ========== */
.atw-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.atw-card {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  transition: transform 0.15s ease;
}
.atw-card:active {
  transform: scale(0.98);
}
.atw-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.atw-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.08);
}
.atw-avatar--placeholder {
  background: radial-gradient(circle at center, rgba(90, 200, 250, 0.15), rgba(255, 255, 255, 0.04) 72%);
}
.atw-head-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.atw-author {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.atw-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}
.atw-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.25);
  flex-shrink: 0;
}
.atw-content {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  font-size: 26rpx;
  line-height: 40rpx;
  color: rgba(255, 255, 255, 0.85);
}
.atw-media-row {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}
.atw-media-thumb {
  flex: 1;
  max-width: calc((100% - 20rpx) / 3);
  height: 160rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.06);
}
.atw-loading {
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  text-align: center;
}
.atw-loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}
/* --- 事件更新浅色覆盖 --- */
