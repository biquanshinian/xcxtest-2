page {
  background: #000;
  height: 100vh;
  overflow: hidden;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000;
}

.map-shell {
  position: relative;
  width: 100%;
  height: 100vh;
}

.main-map {
  width: 100%;
  height: 100vh;
}

.glass-card {
  background: rgba(18, 18, 20, 0.76);
  backdrop-filter: blur(20rpx);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 14rpx 44rpx rgba(0, 0, 0, 0.35);
}

.state-card,
.floating-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  border-radius: 28rpx;
  padding: 28rpx;
  z-index: 10;
}

.state-title {
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.5;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-header--with-action {
  align-items: flex-start;
}

.summary-header-actions,
.sheet-header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.summary-head-main {
  flex: 1;
  min-width: 0;
}

.summary-title {
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.summary-location {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
}

.summary-badge {
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.panel-toggle-btn {
  min-width: 84rpx;
  min-height: 48rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.panel-toggle-btn text {
  color: rgba(255, 255, 255, 0.82);
  font-size: 18rpx;
  line-height: 1;
}

.summary-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.data-meta-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-meta-text {
  color: rgba(255, 255, 255, 0.54);
  font-size: 20rpx;
  line-height: 1.4;
}

.summary-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
}

.summary-tag text {
  color: rgba(255, 255, 255, 0.72);
  font-size: 20rpx;
}

.pass-option-list {
  margin-top: 18rpx;
  white-space: nowrap;
}

.pass-option-row {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 12rpx;
}

.pass-option-chip {
  min-width: 170rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

.pass-option-chip--active {
  background: rgba(10, 132, 255, 0.14);
  border: 1px solid rgba(10, 132, 255, 0.55);
}

.pass-option-time,
.pass-option-dir {
  display: block;
  color: #fff;
  font-size: 22rpx;
}

.pass-option-dir {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
}

.summary-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.summary-item {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.05);
}

.summary-label {
  display: block;
  color: rgba(255, 255, 255, 0.55);
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.bottom-sheet {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  border-radius: 32rpx;
  padding: 26rpx;
  z-index: 10;
}

.floating-card--collapsed,
.bottom-sheet--collapsed {
  padding: 18rpx 20rpx 16rpx;
}

.mini-summary-row {
  margin-top: 10rpx;
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
}

.mini-summary-text {
  display: block;
  color: rgba(255, 255, 255, 0.82);
  font-size: 20rpx;
  line-height: 1.4;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.sheet-title {
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.sheet-subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.sheet-nav-btn {
  min-width: 108rpx;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0A84FF, #64D2FF);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.candidate-highlight {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(10, 132, 255, 0.08);
  border: 1px solid rgba(10, 132, 255, 0.2);
}

.candidate-highlight-main {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.candidate-highlight-title {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.candidate-highlight-score {
  color: #9FD0FF;
  font-size: 22rpx;
}

.candidate-highlight-text {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.5;
}

.candidate-list {
  margin-top: 22rpx;
  white-space: nowrap;
}

.candidate-row {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 12rpx;
}

.candidate-card {
  width: 316rpx;
  display: inline-flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
  overflow: hidden;
}

.candidate-card--active {
  border-color: rgba(10, 132, 255, 0.7);
  background: rgba(10, 132, 255, 0.12);
}

.candidate-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.candidate-title {
  flex: 1;
  min-width: 0;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.candidate-score {
  flex-shrink: 0;
  min-width: 52rpx;
  text-align: center;
  color: #7DFFAE;
  font-size: 22rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(52, 199, 89, 0.14);
}

.candidate-meta,
.candidate-scene,
.candidate-desc,
.sheet-tips text {
  display: block;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: anywhere;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
  line-height: 1.5;
}

.candidate-scene {
  color: rgba(159, 208, 255, 0.88);
}

.sheet-tips {
  margin-top: 20rpx;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.85);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}

.theme-light .state-title {
  color: var(--color-text-primary);
}

.theme-light .state-desc {
  color: var(--color-text-secondary);
}

.theme-light .summary-title {
  color: var(--color-text-primary);
}

.theme-light .summary-location {
  color: var(--color-text-secondary);
}

.theme-light .summary-badge {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .summary-tag {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .summary-tag text {
  color: var(--color-text-secondary);
}

.theme-light .data-meta-text {
  color: var(--color-text-tertiary);
}

.theme-light .pass-option-chip {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .pass-option-chip--active {
  background: rgba(10, 132, 255, 0.12);
}

.theme-light .pass-option-time {
  color: var(--color-text-primary);
}

.theme-light .pass-option-dir {
  color: var(--color-text-secondary);
}

.theme-light .summary-item {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .summary-label {
  color: var(--color-text-tertiary);
}

.theme-light .summary-value {
  color: var(--color-text-primary);
}

.theme-light .sheet-title {
  color: var(--color-text-primary);
}

.theme-light .sheet-subtitle {
  color: var(--color-text-secondary);
}

.theme-light .candidate-highlight {
  background: rgba(10, 132, 255, 0.08);
  border-color: rgba(10, 132, 255, 0.2);
}

.theme-light .candidate-highlight-title {
  color: var(--color-text-primary);
}

.theme-light .candidate-highlight-score {
  color: #0A84FF;
}

.theme-light .candidate-highlight-text {
  color: var(--color-text-secondary);
}

.theme-light .candidate-card {
  background: rgba(0, 0, 0, 0.04);
  border-color: var(--color-divider);
}

.theme-light .candidate-card--active {
  border-color: rgba(10, 132, 255, 0.7);
  background: rgba(10, 132, 255, 0.1);
}

.theme-light .candidate-title {
  color: var(--color-text-primary);
}

.theme-light .candidate-score {
  color: #248A3D;
  background: rgba(52, 199, 89, 0.12);
}

.theme-light .candidate-meta,
.theme-light .candidate-scene,
.theme-light .candidate-desc,
.theme-light .sheet-tips text {
  color: var(--color-text-secondary);
}

.theme-light .candidate-scene {
  color: #0A84FF;
}
