/* booster-genealogy.wxss — 独立全屏可回收火箭族谱页（暗色毛玻璃，与监控中心一致） */
page {
  background: #000;
  color: #fff;
}
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
}
.page-scroll {
  width: 100%;
  height: 100vh;
}
.glass-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* 加载 / 错误 / 空态 */
.loading-wrap, .error-wrap, .empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
}
.empty-wrap {
  padding-top: 80rpx;
  padding-bottom: 80rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #636366;
}
.error-icon, .empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}
.error-text, .empty-text {
  font-size: 28rpx;
  color: #8E8E93;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}
.error-btn {
  font-size: 28rpx;
  color: #007AFF;
  padding: 12rpx 40rpx;
  border: 1px solid rgba(0, 122, 255, 0.3);
  border-radius: 999rpx;
  margin-top: 18rpx;
}

/* 国家/厂商筛选 chip（固定式，自动换行） */
.filter-wrap {
  width: 100%;
  padding: 20rpx 0 4rpx;
}
.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 30rpx;
}
.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}
.filter-chip--active {
  color: #fff;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.35), rgba(88, 86, 214, 0.35));
  border-color: rgba(0, 122, 255, 0.55);
}

/* 状态筛选 + 排序 */
.sub-filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 30rpx;
}
.sub-filter-group {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
.sub-chip {
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}
.sub-chip--active {
  color: #5AC8FA;
  background: rgba(90, 200, 250, 0.12);
  border-color: rgba(90, 200, 250, 0.35);
}

/* 汇总条 */
.summary-bar {
  display: flex;
  justify-content: space-around;
  margin: 8rpx 30rpx 12rpx;
  padding: 24rpx;
  border-radius: 20rpx;
}
.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.summary-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  font-variant-numeric: tabular-nums;
}
.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 4rpx;
}

/* 区块标题 */
.section-block {
  margin-top: 20rpx;
}
.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  padding: 0 30rpx 16rpx;
}

/* 型号卡片区（两列固定网格，与箭实体网格视觉一致） */
.model-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 30rpx;
}
.model-card {
  border-radius: 20rpx;
  overflow: hidden;
}
.model-img-wrap {
  position: relative;
  width: 100%;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.03);
}
.model-img {
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.35s ease;
}
.model-img--loaded {
  opacity: 1;
}
.model-img--placeholder {
  opacity: 1;
  background: radial-gradient(circle at center, rgba(90, 200, 250, 0.08), rgba(255, 255, 255, 0.02) 72%);
}
.model-reusable-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #34C759;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
  border: 1px solid rgba(52, 199, 89, 0.4);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
.model-card-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 16rpx 20rpx 20rpx;
}
.model-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.model-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}
.model-flag {
  font-size: 24rpx;
  line-height: 1;
}
.model-alias {
  font-size: 20rpx;
  color: rgba(255, 149, 0, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.model-mfr {
  font-size: 20rpx;
  color: #5AC8FA;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.model-stats-row {
  margin-top: 6rpx;
}
.model-stat {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}
.model-stat--pending {
  color: #FF9500;
}

/* 箭实体网格（两列） */
.booster-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 30rpx;
}
.bg-card {
  border-radius: 20rpx;
  overflow: hidden;
}
.bg-img-wrap {
  position: relative;
  width: 100%;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.03);
}
.bg-img {
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.35s ease;
}
.bg-img--loaded {
  opacity: 1;
}
.bg-img--placeholder {
  opacity: 1;
  background: radial-gradient(circle at center, rgba(90, 200, 250, 0.08), rgba(255, 255, 255, 0.02) 72%);
}
.bg-status-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
.bg-status-badge--active { color: #34C759; }
.bg-status-badge--retired { color: #8E8E93; }
.bg-status-badge--destroyed { color: #FF3B30; }
.bg-status-badge--expended { color: #FF9500; }
.bg-status-badge--unknown { color: #8E8E93; }
.bg-card-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 14rpx 18rpx 18rpx;
}
.bg-serial-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.bg-serial {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}
.bg-flag {
  font-size: 22rpx;
  line-height: 1;
}
.bg-family {
  font-size: 20rpx;
  color: rgba(255, 149, 0, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bg-stats-row {
  display: flex;
  gap: 14rpx;
  margin-top: 2rpx;
}
.bg-stat {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}
.bg-flights-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 8rpx;
}
.flight-block {
  width: 14rpx;
  height: 14rpx;
  border-radius: 3rpx;
}
.flight-success {
  background: rgba(52, 199, 89, 0.55);
}
.flight-fail {
  background: rgba(255, 59, 48, 0.55);
}
.flight-pending {
  background: rgba(255, 149, 0, 0.55);
}
.flight-unknown {
  background: rgba(255, 255, 255, 0.14);
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.container.theme-light {
  background: var(--color-bg-page);
}
.theme-light .glass-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .loading-text {
  color: var(--color-text-tertiary);
}
.theme-light .error-text,
.theme-light .empty-text {
  color: var(--color-text-secondary);
}
.theme-light .empty-hint {
  color: var(--color-text-tertiary);
}
.theme-light .filter-chip {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.08);
}
/* 激活 chip 保持蓝色渐变白字（实色按钮语义） */
.theme-light .filter-chip--active {
  color: #fff;
  background: linear-gradient(135deg, #007AFF, #5856D6);
  border-color: rgba(0, 122, 255, 0.55);
}
.theme-light .sub-chip {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(0, 0, 0, 0.08);
}
.theme-light .sub-chip--active {
  color: #0071A4;
  background: rgba(0, 122, 255, 0.1);
  border-color: rgba(0, 122, 255, 0.35);
}
.theme-light .summary-value {
  color: var(--color-text-primary);
}
.theme-light .summary-label {
  color: var(--color-text-tertiary);
}
.theme-light .block-title {
  color: var(--color-text-primary);
}
.theme-light .model-img-wrap {
  background: rgba(0, 0, 0, 0.03);
}
.theme-light .model-img--placeholder {
  background: radial-gradient(circle at center, rgba(0, 122, 255, 0.08), rgba(0, 0, 0, 0.03) 72%);
}
/* 可复用徽标 / 状态徽标压在火箭照片上，保持深色衬底原色文字 */
.theme-light .model-name {
  color: var(--color-text-primary);
}
.theme-light .model-alias {
  color: #C77700;
}
.theme-light .model-mfr {
  color: #0071A4;
}
.theme-light .model-stat {
  color: var(--color-text-secondary);
}
.theme-light .model-stat--pending {
  color: #C77700;
}
.theme-light .bg-img-wrap {
  background: rgba(0, 0, 0, 0.03);
}
.theme-light .bg-img--placeholder {
  background: radial-gradient(circle at center, rgba(0, 122, 255, 0.08), rgba(0, 0, 0, 0.03) 72%);
}
.theme-light .bg-serial {
  color: var(--color-text-primary);
}
.theme-light .bg-family {
  color: #C77700;
}
.theme-light .bg-stat {
  color: var(--color-text-secondary);
}
.theme-light .flight-unknown {
  background: rgba(0, 0, 0, 0.12);
}
