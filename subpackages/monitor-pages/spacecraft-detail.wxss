/* spacecraft-detail.wxss — 飞船构型详情页（暗色毛玻璃，与监控中心一致） */
page {
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  overflow: hidden;
  height: 100vh;
  width: 100%;
}

.detail-page {
  min-height: 100vh;
  height: 100vh;
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  overflow: hidden;
}

.detail-scroll {
  height: 100vh;
}

.detail-container {
  padding: 32rpx;
  box-sizing: border-box;
}

.glass-card {
  background: rgba(18, 20, 24, 0.62);
  backdrop-filter: blur(28rpx) saturate(170%);
  -webkit-backdrop-filter: blur(28rpx) saturate(170%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.detail-card {
  padding: 28rpx;
}

/* ── 加载 / 错误 ── */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
  gap: 24rpx;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 20rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.error-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
}

.retry-btn {
  margin-top: 12rpx;
  padding: 16rpx 56rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #0a84ff, #5ac8fa);
  border: none;
}

/* ── Hero ── */
.hero-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  background: #131313;
}

.hero-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: #131313;
  opacity: 0;
  transform: scale(1.02);
  transition: opacity 0.36s ease, transform 0.36s ease;
}

.hero-image--loaded {
  opacity: 1;
  transform: scale(1);
}

.hero-image--placeholder {
  opacity: 1;
  transform: none;
  background: radial-gradient(circle at center, rgba(191, 90, 242, 0.12), rgba(19, 19, 19, 1) 72%);
}

/* 仅底部渐变收边，不再叠信息浮层（与火箭型号详情页一致） */
.hero-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
}

/* 信息头：名称/状态/徽标在头图下方 */
.info-header {
  margin-bottom: 28rpx;
}

.hero-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-name-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.25;
}

.hero-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
}

.hero-status {
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-status--active {
  color: #30d158;
  background: rgba(48, 209, 88, 0.16);
  border: 1px solid rgba(48, 209, 88, 0.35);
}

.hero-status--inactive {
  color: rgba(255, 255, 255, 0.55);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.16);
}

.hero-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.hero-badge {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #bf5af2;
  background: rgba(191, 90, 242, 0.15);
  border: 1px solid rgba(191, 90, 242, 0.3);
}

/* 发射商跳转按钮：全局统一的蓝色渐变胶囊样式（同族谱/型号详情页 info-tag--link） */
.hero-agency-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 18rpx 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(135deg, #007AFF, #5856D6);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.35);
}
.hero-agency-btn:active {
  opacity: 0.7;
  transform: scale(0.96);
}
.hero-agency-arrow {
  font-size: 26rpx;
  line-height: 1;
}

/* ── 战绩网格 ── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 22rpx 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.stat-value--good {
  color: #30d158;
}

.stat-value--bad {
  color: #ff453a;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ── 区块 ── */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 18rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title-row .section-title {
  margin-bottom: 0;
  flex: 1;
}

/* ── 规格 ── */
.info-grid {
  display: flex;
  flex-direction: column;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.07);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
}

.info-value {
  font-size: 26rpx;
  color: #fff;
  text-align: right;
}

/* ── 简介 ── */
.desc-block {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.desc-block:last-child {
  margin-bottom: 0;
}

.desc-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #5ac8fa;
}

.desc-text {
  font-size: 27rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.78);
  word-break: break-word;
}

/* ── 链接 ── */
.link-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.link-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.07);
}

.link-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.link-url {
  font-size: 22rpx;
  color: rgba(90, 200, 250, 0.85);
  word-break: break-all;
}

/* ── 数据来源 ── */
.data-source {
  padding-top: 8rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.detail-page.theme-light {
  background: var(--color-bg-page);
}
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .loading-text {
  color: var(--color-text-secondary);
}
.theme-light .error-title {
  color: var(--color-text-primary);
}
.theme-light .error-text {
  color: var(--color-text-secondary);
}
/* Hero 容器与占位：深底 → 浅灰底 */
.theme-light .hero-wrap {
  background: #E8E8ED;
}
.theme-light .hero-image {
  background: #E8E8ED;
}
.theme-light .hero-image--placeholder {
  background: radial-gradient(circle at center, rgba(191, 90, 242, 0.1), #E8E8ED 72%);
}
/* hero-gradient 压在飞船照片上，保持深色收边 */
.theme-light .hero-name {
  color: var(--color-text-primary);
}
.theme-light .hero-sub {
  color: var(--color-text-secondary);
}
.theme-light .hero-status--inactive {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.1);
}
.theme-light .hero-badge {
  color: #8944AB;
  background: rgba(191, 90, 242, 0.12);
  border: 1px solid rgba(191, 90, 242, 0.25);
}
.theme-light .stat-card {
  background: rgba(0, 0, 0, 0.04);
  border: 1px solid var(--color-divider);
}
.theme-light .stat-value {
  color: var(--color-text-primary);
}
.theme-light .stat-label {
  color: var(--color-text-secondary);
}
.theme-light .section-title {
  color: var(--color-text-primary);
}
.theme-light .info-grid {
  background: rgba(0, 0, 0, 0.03);
  border: 1px solid var(--color-divider);
}
.theme-light .info-row {
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}
.theme-light .info-row:last-child {
  border-bottom: none;
}
.theme-light .info-label {
  color: var(--color-text-secondary);
}
.theme-light .info-value {
  color: var(--color-text-primary);
}
.theme-light .desc-label {
  color: #0071A4;
}
.theme-light .desc-text {
  color: var(--color-text-primary);
}
.theme-light .link-item {
  background: rgba(0, 0, 0, 0.03);
  border: 1px solid var(--color-divider);
}
.theme-light .link-name {
  color: var(--color-text-primary);
}
.theme-light .link-url {
  color: #0071A4;
}
.theme-light .data-source {
  color: var(--color-text-tertiary);
}
