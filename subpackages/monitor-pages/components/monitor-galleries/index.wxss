@import "../../../../styles/monitor-block.wxss";
/* 监控页图鉴四板块样式（从 pages/monitor/monitor.wxss 拆出）。
   共享基类（section-title / glass-card 等）与 theme-light 覆盖仍在页面 wxss，
   经 styleIsolation: apply-shared 作用进组件。

   注意：组件 wxss 优先级高于页面 apply-shared，不可把 section 的 padding/margin 置 0，
   否则会盖掉 .monitor-block 的内边距（数值唯一来源：styles/monitor-block.wxss）。 */

/* ========== 可回收火箭族谱 ========== */
.booster-card {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  border-radius: 20rpx;
  width: calc((100% - 20rpx) / 2);
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  transition: transform 0.25s ease;
}
.booster-card:active {
  transform: scale(0.97);
}
/* 图片区域 */
.booster-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 3;
  overflow: hidden;
}
.booster-img {
  width: 100%;
  height: 100%;
  opacity: 0;
  transform: scale(1.02);
  transition: opacity 0.32s ease, transform 0.32s ease;
  background: rgba(255, 255, 255, 0.04);
}
.booster-img--loaded {
  opacity: 1;
  transform: scale(1);
}
.booster-img--placeholder {
  opacity: 1;
  transform: scale(1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at center, rgba(90, 200, 250, 0.10), rgba(255, 255, 255, 0.03) 72%);
}
.booster-img-icon {
  font-size: 48rpx;
}
/* 状态角标 */
.booster-status-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
.booster-status-badge--active {
  color: #34C759;
  background: rgba(52, 199, 89, 0.25);
  border: 1px solid rgba(52, 199, 89, 0.4);
}
.booster-status-badge--retired {
  color: #8E8E93;
  background: rgba(142, 142, 147, 0.25);
  border: 1px solid rgba(142, 142, 147, 0.4);
}
.booster-status-badge--destroyed {
  color: #FF3B30;
  background: rgba(255, 59, 48, 0.25);
  border: 1px solid rgba(255, 59, 48, 0.4);
}
.booster-status-badge--expended {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.25);
  border: 1px solid rgba(255, 149, 0, 0.4);
}
.booster-status-badge--unknown {
  color: #8E8E93;
  background: rgba(142, 142, 147, 0.15);
  border: 1px solid rgba(142, 142, 147, 0.3);
}
/* 信息区 */
.booster-card-body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  white-space: normal;
}
.booster-serial-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.booster-serial {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}
.booster-country-flag {
  font-size: 24rpx;
  line-height: 1;
}
.booster-tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}
.booster-family-tag {
  font-size: 20rpx;
  color: rgba(255, 149, 0, 0.9);
}
.booster-mfr-tag {
  font-size: 18rpx;
  color: #5AC8FA;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: rgba(90, 200, 250, 0.12);
  border: 1px solid rgba(90, 200, 250, 0.25);
}

/* 「查看全部」PRO 金色胶囊（族谱/发射商图鉴/发射场共用，示意会员内容） */
.booster-view-all {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5C3A00;
  padding: 8rpx 20rpx 8rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FFE3A0 0%, #F7BE45 55%, #F0AE2C 100%);
  border: 1px solid rgba(255, 210, 122, 0.65);
  box-shadow: 0 4rpx 14rpx rgba(230, 165, 40, 0.28);
  transition: transform 0.12s ease, opacity 0.12s ease;
}
.booster-view-all--pressed {
  transform: scale(0.94);
  opacity: 0.85;
}
.booster-view-all-arrow {
  font-size: 30rpx;
  line-height: 1;
  color: #5C3A00;
}
.booster-key-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 4rpx;
}
.booster-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.booster-stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  font-variant-numeric: tabular-nums;
}
.booster-stat-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.45);
}
.booster-flights-bar {
  display: flex;
  gap: 3rpx;
  flex-wrap: wrap;
  justify-content: center;
  max-width: 240rpx;
}
.flight-block {
  width: 14rpx;
  height: 14rpx;
  border-radius: 3rpx;
}
.flight-success {
  background: #34C759;
  box-shadow: 0 0 4rpx rgba(52, 199, 89, 0.4);
}
.flight-fail {
  background: #FF3B30;
  box-shadow: 0 0 4rpx rgba(255, 59, 48, 0.4);
}
.flight-pending {
  background: #FF9500;
  box-shadow: 0 0 4rpx rgba(255, 149, 0, 0.4);
}
.flight-unknown {
  background: rgba(255, 255, 255, 0.2);
}
.booster-turnaround {
  font-size: 18rpx;
  color: rgba(90, 200, 250, 0.8);
  margin-top: 2rpx;
}
/* 箭头 */
.booster-card-arrow {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}
.booster-loading {
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}


/* ========== 全球飞船图鉴（骨架镜像族谱卡片） ========== */
.sc-card {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  border-radius: 20rpx;
  width: calc((100% - 20rpx) / 2);
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  transition: transform 0.25s ease;
}
.sc-card:active {
  transform: scale(0.97);
}
.sc-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 3;
  overflow: hidden;
}
.sc-img {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.04);
}
.sc-img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at center, rgba(90, 200, 250, 0.10), rgba(255, 255, 255, 0.03) 72%);
}
.sc-img-icon {
  font-size: 48rpx;
}
.sc-status-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
.sc-status-badge--active {
  color: #34C759;
  background: rgba(52, 199, 89, 0.25);
  border: 1px solid rgba(52, 199, 89, 0.4);
}
.sc-status-badge--retired {
  color: #8E8E93;
  background: rgba(142, 142, 147, 0.25);
  border: 1px solid rgba(142, 142, 147, 0.4);
}
.sc-card-body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  white-space: normal;
}
.sc-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  line-height: 34rpx;
  /* 固定两行高度并截断：长短船名卡片高度一致，横排不错位 */
  height: 68rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.sc-tag-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  /* 标签单行截断，避免换行撑高卡片 */
  max-width: 100%;
  overflow: hidden;
  white-space: nowrap;
}
.sc-type-tag {
  font-size: 20rpx;
  color: rgba(255, 149, 0, 0.9);
  flex-shrink: 0;
}
.sc-agency-tag {
  font-size: 18rpx;
  color: #5AC8FA;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: rgba(90, 200, 250, 0.12);
  border: 1px solid rgba(90, 200, 250, 0.25);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}


