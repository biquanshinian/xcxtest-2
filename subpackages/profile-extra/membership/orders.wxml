<view class="container {{themeClass}}">
  <!-- 顶部导航 -->
  <view class="top-nav-wrapper" style="padding-top:{{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-grid">
      <view class="top-nav-slot--back" bindtap="goBack">
        <text class="icon-back icon-back--nav">‹</text>
      </view>
      <text class="nav-title nav-title--page-grid">订单记录</text>
      <view class="top-nav-slot--spacer"></view>
    </view>
  </view>

  <!-- 全屏滚动骨架：内容从磨砂导航栏下方穿过，加载/错误态也在滚动区内 -->
  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view style="height: {{navPlaceholderHeight}}px;"></view>

    <!-- 加载骨架 -->
    <view class="od-skeleton" wx:if="{{loading}}">
      <view class="od-skeleton-summary skeleton-shimmer"></view>
      <view class="od-skeleton-card skeleton-shimmer" wx:for="{{[0, 1, 2]}}" wx:key="*this"></view>
    </view>

    <!-- 加载失败 -->
    <view class="od-error" wx:elif="{{errorMessage}}">
      <text class="od-error-icon">⚠️</text>
      <text class="od-error-text">{{errorMessage}}</text>
      <view class="od-retry-btn" bindtap="onRetry">重试</view>
    </view>

    <block wx:else>
      <!-- 汇总条：账单概览 -->
      <view class="od-summary" wx:if="{{orders.length > 0}}">
        <view class="od-summary-item">
          <text class="od-summary-value">{{summary.total}}</text>
          <text class="od-summary-label">全部订单</text>
        </view>
        <view class="od-summary-item">
          <text class="od-summary-value od-summary-value--paid">{{summary.paidCount}}</text>
          <text class="od-summary-label">已完成</text>
        </view>
        <view class="od-summary-item">
          <text class="od-summary-value">¥{{summary.paidAmountText}}</text>
          <text class="od-summary-label">累计支付</text>
        </view>
      </view>

      <!-- 按月分组的订单列表 -->
      <view class="od-group" wx:for="{{groups}}" wx:for-item="group" wx:key="month">
        <text class="od-group-title">{{group.month}}</text>
        <view class="od-card" wx:for="{{group.items}}" wx:key="id"
              hover-class="od-card--pressed" hover-start-time="200" hover-stay-time="120"
              bindlongpress="onOrderLongPress" data-id="{{item.id}}" data-name="{{item.name}}">
          <!-- 第一行：商品名 + 状态徽标 -->
          <view class="od-card-top">
            <text class="od-name">{{item.name}}</text>
            <text class="od-status od-status--{{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <!-- 第二行：类型标签 + 金额 -->
          <view class="od-card-mid">
            <text class="od-type-tag od-type-tag--{{item.orderType}}">{{item.typeText}}</text>
            <view class="od-amount-col">
              <text class="od-amount">¥{{item.amountText}}</text>
              <text class="od-refund-note" wx:if="{{item.refundText}}">{{item.refundText}}</text>
            </view>
          </view>
          <!-- 第三行：时间 + 订单号（点击复制，售后凭证） -->
          <view class="od-card-bottom">
            <text class="od-time">{{item.timeText}}</text>
            <view class="od-no-row" bindtap="onCopyOrderNo" data-no="{{item.id}}">
              <text class="od-no">{{item.id}}</text>
              <text class="od-no-copy">复制</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空态 -->
      <view class="od-empty" wx:if="{{orders.length === 0}}">
        <text class="od-empty-icon">🧾</text>
        <text class="od-empty-text">暂无订单记录</text>
        <text class="od-empty-hint">开通订阅或解锁功能后，记录会显示在这里</text>
      </view>

      <!-- 底部说明 -->
      <view class="od-footer-note" wx:if="{{orders.length > 0}}">
        <text>· 订单号是售后与退款的唯一凭证，点击可复制</text>
        <text>· 长按订单卡片可删除记录，删除后不可恢复</text>
        <text>· 如有疑问请联系客服，提供订单号与用户ID</text>
      </view>
    </block>

    <view style="height: 80rpx;"></view>
  </scroll-view>
</view>
