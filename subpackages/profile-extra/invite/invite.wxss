/* invite.wxss — 邀请得月卡（暗色玻璃风格，与订单记录页一致） */
.container {
  background: #000000;
}

.content-scroll {
  padding: 0 30rpx;
}

/* ── 加载骨架 ── */
.iv-skeleton {
  padding-top: 24rpx;
}

/* 扫光走全局 skeleton-shimmer（app.wxss） */
.iv-skeleton-card {
  height: 140rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
}

.iv-skeleton-card--tall {
  height: 300rpx;
}

/* ── 错误态 ── */
.iv-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx 60rpx;
  gap: 16rpx;
}

.iv-error-icon {
  font-size: 72rpx;
}

.iv-error-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.iv-retry-btn {
  margin-top: 12rpx;
  padding: 14rpx 52rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #FFAA00;
  background: rgba(255, 170, 0, 0.1);
  border: 1rpx solid rgba(255, 170, 0, 0.35);
}

.iv-retry-btn:active {
  opacity: 0.65;
}

/* ── 规则卡 ── */
.iv-rule-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 28rpx 30rpx;
  border-radius: 20rpx;
  background: rgba(255, 170, 0, 0.06);
  border: 1rpx solid rgba(255, 170, 0, 0.2);
}

.iv-rule-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.iv-rule-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
}

/* ── 进度卡 ── */
.iv-progress-card {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.iv-progress-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.iv-progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.iv-progress-count {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFAA00;
}

.iv-progress-total {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.4);
}

.iv-progress-bar {
  margin-top: 20rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.iv-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #FFAA00, #FFD466);
  transition: width 0.4s ease;
}

.iv-stat-row {
  display: flex;
  margin-top: 28rpx;
}

.iv-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.iv-stat-item + .iv-stat-item {
  border-left: 1rpx solid rgba(255, 255, 255, 0.08);
}

.iv-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.iv-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}

.iv-granted-tip {
  display: block;
  margin-top: 24rpx;
  font-size: 22rpx;
  text-align: center;
  color: #4CD964;
}

/* ── 邀请按钮 ── */
.iv-share-btn {
  margin: 32rpx 0 0;
  width: 100%;
  height: 92rpx;
  padding: 0;
  /* 原生 button 自带 padding 与行高基线偏移会导致文字不居中，改 flex 居中 */
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  background: linear-gradient(90deg, #FFAA00, #FFD466);
  border: none;
}

.iv-share-btn::after {
  border: none;
}

.iv-share-btn--pressed {
  opacity: 0.75;
}

/* ── 邀请记录 ── */
.iv-records {
  margin-top: 40rpx;
}

.iv-records-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.iv-record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-bottom: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.iv-record-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.iv-record-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}

.iv-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 60rpx 0 30rpx;
}

.iv-empty-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.iv-empty-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ── 底部说明 ── */
.iv-footer-note {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 36rpx;
  padding: 0 8rpx;
}

.iv-footer-note text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ── 分享海报画布（移出可视区，不可 display:none，否则无法绘制导出） ── */
.iv-poster-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  height: 300px;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.container.theme-light {
  background: var(--color-bg);
}

/* 骨架浅色底色由全局 .theme-light .skeleton-shimmer 提供 */

.theme-light .iv-error-text {
  color: var(--color-text-secondary);
}

.theme-light .iv-rule-card {
  background: rgba(255, 149, 0, 0.08);
  border-color: rgba(255, 149, 0, 0.25);
}

.theme-light .iv-rule-text {
  color: var(--color-text-primary);
}

.theme-light .iv-progress-card {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}

.theme-light .iv-progress-title {
  color: var(--color-text-primary);
}

.theme-light .iv-progress-count {
  color: #E68A00;
}

.theme-light .iv-progress-total {
  color: var(--color-text-tertiary);
}

.theme-light .iv-progress-bar {
  background: rgba(0, 0, 0, 0.06);
}

.theme-light .iv-stat-item + .iv-stat-item {
  border-left-color: var(--color-divider);
}

.theme-light .iv-stat-value {
  color: var(--color-text-primary);
}

.theme-light .iv-stat-label {
  color: var(--color-text-tertiary);
}

.theme-light .iv-granted-tip {
  color: #2FA84F;
}

.theme-light .iv-records-title {
  color: var(--color-text-secondary);
}

.theme-light .iv-record-item {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}

.theme-light .iv-record-text {
  color: var(--color-text-primary);
}

.theme-light .iv-record-time {
  color: var(--color-text-tertiary);
}

.theme-light .iv-empty-text {
  color: var(--color-text-secondary);
}

.theme-light .iv-empty-hint {
  color: var(--color-text-tertiary);
}

.theme-light .iv-footer-note text {
  color: var(--color-text-tertiary);
}
