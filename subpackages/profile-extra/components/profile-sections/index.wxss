.oa-alert-switch {
  margin-top: 2rpx;
  transform-origin: center right;
}

.oa-alert-status {
  margin-top: 16rpx;
}

.oa-alert-status-text {
  font-size: 22rpx;
  color: rgba(255, 200, 120, 0.9);
}

.oa-alert-status-text--ready {
  color: rgba(120, 220, 160, 0.95);
}

.oa-alert-guide {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.oa-alert-guide-text {
  flex: 1;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.oa-alert-guide-copy {
  font-size: 22rpx;
  color: #07C160;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
}
