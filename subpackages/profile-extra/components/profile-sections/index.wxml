<!-- 我的页下半屏区块（从 pages/profile/profile.wxml 原样拆出，交互经 sectionevent 回传页面） -->
<view class="{{themeClass}}">
  <!-- ══ 我的提醒 ══ -->
  <view class="reminder-section">
    <view class="section-title-row">
      <text class="section-title-text">我的提醒</text>
      <view class="section-title-action" bindtap="emitGoPreferences">
        <image class="section-settings-icon" src="/images/icon-settings.svg" mode="aspectFit" />
      </view>
    </view>

    <!-- 服务号 B 通道：自动发射提醒 -->
    <view class="oa-alert-card glass-card">
      <view class="oa-alert-row">
        <view class="oa-alert-info">
          <text class="oa-alert-title">服务号自动提醒</text>
          <text class="oa-alert-desc">开启后发射前约30分钟及完成后结果由服务号自动推送，无需再逐条订阅</text>
        </view>
        <switch
          class="oa-alert-switch"
          checked="{{oaAlertEnabled}}"
          color="#07C160"
          disabled="{{oaAlertLoading}}"
          bindchange="emitOnOaAlertSwitch"
        />
      </view>
      <view class="oa-alert-status" wx:if="{{oaAlertMessage}}">
        <text class="oa-alert-status-text {{oaAlertReady ? 'oa-alert-status-text--ready' : ''}}">{{oaAlertMessage}}</text>
      </view>
      <view class="oa-alert-guide" wx:if="{{oaAlertEnabled && !oaAlertFollowed}}">
        <text class="oa-alert-guide-text">请先微信搜索并关注服务号「火星探索日志」</text>
        <text class="oa-alert-guide-copy" catchtap="emitOnCopyOaName">复制名称</text>
      </view>
    </view>

    <!-- 有提醒时：发射时间线（按时间升序，节点颜色区分紧急程度） -->
    <view class="reminder-timeline glass-card" wx:if="{{myReminders.length > 0}}">
      <view class="rm-item" wx:for="{{myReminders}}" wx:key="key">
        <!-- 左侧时间轴：节点 + 连线 -->
        <view class="rm-rail">
          <view class="rm-node rm-node--{{item.status}}"></view>
          <view class="rm-line" wx:if="{{index < myReminders.length - 1}}"></view>
        </view>
        <!-- 右侧内容 -->
        <view class="rm-body {{index === myReminders.length - 1 ? 'rm-body--last' : ''}}" bindtap="emitOnReminderTap" data-type="{{item.type}}" data-missionid="{{item.missionId}}" data-date="{{item.date}}">
          <view class="rm-time-row">
            <text class="rm-time rm-time--{{item.status}}">{{item.dateLabel}}</text>
            <text class="rm-badge rm-badge--{{item.status}}">{{item.daysLabel}}</text>
            <view class="rm-cancel" catchtap="emitOnCancelReminder" data-key="{{item.key}}" data-type="{{item.type}}" data-missionid="{{item.missionId}}">
              <text>✕</text>
            </view>
          </view>
          <view class="rm-main">
            <image class="rm-thumb" wx:if="{{item.rocketImg}}" src="{{item.rocketImg}}" mode="aspectFill" lazy-load />
            <view class="rm-thumb rm-thumb--placeholder" wx:else>
              <text>🚀</text>
            </view>
            <view class="rm-text-col">
              <text class="rm-title">{{item.title}}</text>
              <text class="rm-rocket" wx:if="{{item.rocketName}}">{{item.rocketName}}</text>
            </view>
            <text class="rm-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 无提醒时显示引导 -->
    <view class="reminder-empty glass-card" wx:else bindtap="emitOnGoAstroCalendar">
      <text class="reminder-empty-text">{{oaAlertReady ? '服务号自动提醒已开启' : '暂无提醒'}}</text>
      <text class="reminder-empty-hint">{{oaAlertReady ? '发射前约30分钟及完成后结果将自动推送，无需再逐条添加' : '在发射详情中点击「发射提醒」添加 ›'}}</text>
    </view>
  </view>

  <!-- ══ 发射竞猜统计 ══ -->
  <view class="vote-stats-section" wx:if="{{voteStats.total > 0}}">
    <view class="section-title-row">
      <text class="section-title-text">竞猜战绩</text>
      <text class="section-title-count">参与 {{voteStats.total}} 场</text>
    </view>
    <view class="vote-stats-card glass-card">
      <!-- 核心数据 -->
      <view class="vote-stats-grid">
        <view class="vote-stats-cell">
          <text class="vote-stats-num">{{voteStats.settled}}</text>
          <text class="vote-stats-label">已揭晓</text>
        </view>
        <view class="vote-stats-cell">
          <text class="vote-stats-num vote-stats-num--correct">{{voteStats.correct}}</text>
          <text class="vote-stats-label">猜对</text>
        </view>
        <view class="vote-stats-cell">
          <text class="vote-stats-num {{voteStats.accuracy >= 60 ? 'vote-stats-num--correct' : ''}}">{{voteStats.accuracy}}%</text>
          <text class="vote-stats-label">命中率</text>
        </view>
        <view class="vote-stats-cell">
          <text class="vote-stats-num vote-stats-num--streak">{{voteStats.bestStreak}}</text>
          <text class="vote-stats-label">最佳连胜</text>
        </view>
      </view>

      <!-- 当前连胜提示 -->
      <view class="vote-streak-bar" wx:if="{{voteStats.streak > 0}}">
        <text class="vote-streak-text">🔥 当前连胜 {{voteStats.streak}} 场</text>
      </view>

      <!-- 近期记录 -->
      <view class="vote-history" wx:if="{{voteHistory.length > 0}}">
        <view class="vote-history-title-row">
          <text class="vote-history-title">近期竞猜</text>
          <view class="vote-history-clear" hover-class="vote-history-clear--pressed" hover-stay-time="120" catchtap="emitOnClearVoteHistory">
            <text>清除</text>
          </view>
        </view>
        <view class="vote-history-list">
          <view class="vote-history-item" wx:for="{{voteHistoryExpanded ? voteHistory : voteHistory}}" wx:if="{{voteHistoryExpanded || index < 5}}" wx:key="id" bindtap="emitOnVoteHistoryTap" data-id="{{item.launchId || item.id}}">
            <view class="vote-history-icon vote-history-icon--launch">
              <image
                class="vote-history-rocket-img"
                src="{{item.rocketImage}}"
                mode="aspectFit"
                binderror="emitOnVoteHistoryRocketImageError"
                data-index="{{index}}"
              />
            </view>
            <view class="vote-history-left">
              <view class="vote-history-name-row">
                <text class="vote-history-type vote-history-type--{{item.voteType}}">{{item.voteTypeLabel || (item.voteType === 'outcome' ? '成败' : '准时')}}</text>
                <text class="vote-history-name">{{item.name}}</text>
              </view>
              <text class="vote-history-rocket" wx:if="{{item.rocket}}">{{item.rocket}}</text>
            </view>
            <view class="vote-history-right">
              <text class="vote-choice-tag vote-choice-tag--{{item.choice}}">我猜{{item.choiceLabel}}</text>
              <text class="vote-history-days {{item.result ? (item.isCorrect ? 'vote-history-days--win' : 'vote-history-days--lose') : ''}}">{{item.daysLabel}}</text>
            </view>
          </view>
        </view>
        <view class="vote-history-expand" wx:if="{{voteHistory.length > 5}}" bindtap="emitOnToggleVoteHistory">
          <text>{{voteHistoryExpanded ? '收起' : '展开全部 (' + voteHistory.length + ')'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ══ 每日问答挑战 ══ -->
  <view class="quiz-section" wx:if="{{quizQuestion}}">
    <view class="section-title-row">
      <text class="section-title-text">每日挑战</text>
      <text class="section-title-count">正确率 {{quizStats.accuracy}}%</text>
    </view>
    <view class="quiz-card glass-card">
      <view class="quiz-header">
        <text class="quiz-badge">太空问答 #{{quizQuestion.id}}</text>
      </view>
      <text class="quiz-question">{{quizQuestion.question}}</text>
      <view class="quiz-options">
        <view
          class="quiz-option {{quizSelectedIndex === index ? 'quiz-option--selected' : ''}} {{quizAnswered && index === quizQuestion.answer ? 'quiz-option--correct' : ''}} {{quizAnswered && quizSelectedIndex === index && index !== quizQuestion.answer ? 'quiz-option--wrong' : ''}} {{quizAnswered ? 'quiz-option--disabled' : ''}}"
          wx:for="{{quizQuestion.options}}"
          wx:key="*this"
          bindtap="emitOnQuizSelect"
          data-index="{{index}}"
        >
          <text class="quiz-option-letter">{{['A','B','C','D'][index]}}</text>
          <text class="quiz-option-text">{{item}}</text>
          <!-- 图标位始终占宽，避免答题后插入 ✓/✕ 把选项行撑高 -->
          <text
            class="quiz-option-icon {{quizAnswered && index === quizQuestion.answer ? 'quiz-option-icon--visible quiz-option-icon--ok' : ''}} {{quizAnswered && quizSelectedIndex === index && index !== quizQuestion.answer ? 'quiz-option-icon--visible quiz-option-icon--bad' : ''}}"
          >{{quizAnswered && quizSelectedIndex === index && index !== quizQuestion.answer ? '✕' : '✓'}}</text>
        </view>
      </view>
      <!-- 答题结果 -->
      <view class="quiz-result" wx:if="{{quizResult}}">
        <text class="quiz-result-tag {{quizResult.correct ? 'quiz-result-tag--correct' : 'quiz-result-tag--wrong'}}">{{quizResult.correct ? '回答正确！' : '回答错误'}}</text>
        <text class="quiz-explanation">{{quizResult.explanation}}</text>
      </view>
    </view>
  </view>

  <!-- ══ 在线客服 ══ -->
  <view class="about-section">
    <view class="section-title-row">
      <text class="section-title-text">在线客服</text>
    </view>
    <view class="about-card glass-card">
      <text class="about-text">{{aboutText}}</text>
      <view class="about-wechat" wx:if="{{aboutWechat}}">
        <text class="about-wechat-label">微信：</text>
        <text class="about-wechat-id">{{aboutWechat}}</text>
        <button class="about-copy-btn" size="mini" catchtap="emitOnCopyWechat" hover-class="about-copy-btn--hover">复制</button>
      </view>

      <!-- 在线客服：微信小程序官方客服会话（open-type="contact"） -->
      <button class="service-contact-row" open-type="contact" bindcontact="emitOnContactCallback" session-from="profile-about" hover-class="service-contact-row--hover">
        <view class="service-contact-icon">
          <image class="service-contact-icon-img" src="/images/icon-customer-service.svg" mode="aspectFit" />
        </view>
        <view class="service-contact-text">
          <text class="service-contact-title">立即联系</text>
          <text class="service-contact-sub">遇到问题或有建议？点击直接对话</text>
        </view>
        <text class="service-contact-arrow">›</text>
      </button>

      <view wx:if="{{figmaShareEnabled}}" class="figma-share-row" bindtap="emitOnShareFigma" hover-class="figma-share-row--hover">
        <view class="figma-share-icon">
          <text class="figma-share-icon-text">F</text>
        </view>
        <view class="figma-share-text">
          <text class="figma-share-title">Starship Tracking 设计稿</text>
          <text class="figma-share-sub">点击查看设计稿</text>
        </view>
        <text class="figma-share-arrow">›</text>
      </view>
    </view>
  </view>
</view>
