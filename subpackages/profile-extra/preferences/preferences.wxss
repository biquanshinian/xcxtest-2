.container {
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
}

.content-scroll {
  padding: 0 30rpx;
}

.section {
  margin-top: 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.section-title--inline {
  margin-bottom: 0;
}

.section-desc {
  font-size: 24rpx;
  color: #8B92B8;
  margin-bottom: 24rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tag-item {
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #A0A8D0;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  transition: all 0.2s;
}

.tag-active {
  color: #FFFFFF;
  background: rgba(7, 193, 96, 0.25);
  border-color: rgba(7, 193, 96, 0.6);
}

.radio-group {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.radio-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #A0A8D0;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.radio-active {
  color: #FFFFFF;
  background: rgba(7, 193, 96, 0.25);
  border-color: rgba(7, 193, 96, 0.6);
}

.save-area {
  margin: 48rpx 0;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  padding-left: 0;
  padding-right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn--loading {
  opacity: 0.6;
}

.save-btn::after {
  border: none;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.container.theme-light {
  background: var(--color-bg-page);
}
.theme-light .section {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .section-title {
  color: var(--color-text-primary);
}
.theme-light .section-desc {
  color: var(--color-text-secondary);
}
.theme-light .tag-item {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.08);
}
.theme-light .tag-active {
  color: #07C160;
  background: rgba(7, 193, 96, 0.12);
  border-color: rgba(7, 193, 96, 0.55);
}
.theme-light .radio-item {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.08);
}
.theme-light .radio-active {
  color: #07C160;
  background: rgba(7, 193, 96, 0.12);
  border-color: rgba(7, 193, 96, 0.55);
}
