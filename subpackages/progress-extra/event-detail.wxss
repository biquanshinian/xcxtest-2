}

.theme-light .ll2-event-info-divider {
  background: rgba(0, 0, 0, 0.06);
}

.theme-light .ll2-event-section-icon {
  filter: invert(45%) sepia(10%) saturate(245%) hue-rotate(180deg);
}

.theme-light .ll2-event-section-title text {
  color: var(--color-text-primary);
}

.theme-light .ll2-event-section-body {
  color: var(--color-text-secondary);
}

.theme-light .ll2-event-webcast-icon {
  filter: invert(48%) sepia(60%) saturate(500%) hue-rotate(180deg);
}

.theme-light .ll2-event-webcast-title {
  color: var(--color-text-primary);
}

.theme-light .ll2-event-webcast-meta {
  color: var(--color-text-tertiary);
}

.theme-light .ll2-event-webcast-hint {
  color: var(--color-brand);
}

.theme-light .ll2-event-webcast-arrow {
  color: var(--color-text-tertiary);
}

.theme-light .ll2-event-source-tip {
  color: var(--color-text-tertiary);
}

/* —— LL2 详细数据区块 —— */
.theme-light .ll2-detail-loading-text {
  color: var(--color-text-tertiary);
}

.theme-light .ll2-detail-launch-name {
