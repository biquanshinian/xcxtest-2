page {
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  overflow: hidden;
  height: 100vh;
  width: 100%;
}

.detail-page {
  min-height: 100vh;
  height: 100vh;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  overflow: hidden;
}

/* 导航标题包裹层：min-width:0 允许在 grid 中收缩，flex 保证标题始终水平居中 */
.nav-title-wrap {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.detail-scroll {
  height: 100vh;
  width: 100%;
  box-sizing: border-box;
}

.detail-container {
  padding: 32rpx;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

.glass-card {
  background: rgba(18, 20, 24, 0.62);
  backdrop-filter: blur(28rpx) saturate(170%);
  -webkit-backdrop-filter: blur(28rpx) saturate(170%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.detail-card {
  padding: 28rpx;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  min-width: 0;
}

.list-day-hint {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.list-day-hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.5;
  word-break: break-word;
  overflow-wrap: break-word;
}

.list-card-item {
  margin-bottom: 28rpx;
}

.list-card-item:last-child {
  margin-bottom: 0;
}

.empty-list-hint {
  padding: 36rpx 28rpx;
  text-align: center;
}

.list-load-footer {
  padding: 24rpx 0 40rpx;
  text-align: center;
}

.list-load-footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

.empty-list-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
  word-break: break-word;
  overflow-wrap: break-word;
}

.meta-top {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  min-width: 0;
}

.date-text {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 24rpx;
  color: #8e8e93;
  word-break: break-word;
  overflow-wrap: break-word;
}

.author-tag-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  flex: 0 1 auto;
  max-width: 100%;
  min-width: 0;
  padding: 6rpx 16rpx 6rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.author-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.author-tag {
  color: #d0d0d4;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  max-width: 360rpx;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 24rpx;
  max-width: 100%;
  box-sizing: border-box;
  word-break: break-word;
  overflow-wrap: break-word;
}

.detail-content {
  display: block;
  font-size: 29rpx;
  line-height: 1.9;
  color: #d7d7db;
  white-space: pre-wrap;
  text-align: justify;
  text-justify: inter-ideograph;
  max-width: 100%;
  box-sizing: border-box;
  /* 正文中常见长 URL / 无空格英文：允许在任意位置断行，避免顶出卡片右缘 */
  word-break: break-all;
  overflow-wrap: anywhere;
}

.event-live-card {
  margin-top: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.event-live-cover-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.event-live-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.event-live-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

.event-live-cover-placeholder-text {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.2);
  font-weight: 600;
}

.event-live-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  font-size: 22rpx;
  color: #8E8E93;
  z-index: 2;
}

.event-live-badge-on {
  background: rgba(255, 40, 40, 0.85);
  color: #fff;
}

.event-live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
  animation: livePulse 1.5s ease-in-out infinite;
}

@keyframes livePulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.75); }
}

.event-live-play-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.2);
}

.event-live-play-btn {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 44rpx;
  color: #fff;
  background: rgba(0, 178, 255, 0.8);
  border-radius: 50%;
  box-shadow: 0 4rpx 20rpx rgba(0, 178, 255, 0.4);
}

.event-live-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
}

.event-live-action-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #00B2FF;
  font-weight: 500;
  word-break: break-word;
  overflow-wrap: break-word;
}

.event-live-action-arrow {
  font-size: 36rpx;
  color: #00B2FF;
  font-weight: 300;
}

.event-media-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

/* ≤4 张一排均分；>4 张按 4 列换行。宽高由 wrap 控制（image 不支持 height:auto） */
.event-media-image-wrap {
  position: relative;
  flex-shrink: 0;
  /* 必须 content-box：border-box + height:0 会吃掉 padding-bottom，格子塌成一条线 */
  box-sizing: content-box;
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  height: 0;
}

.event-media-list--n1 .event-media-image-wrap {
  width: 62%;
  max-width: 420rpx;
  padding-bottom: 46.5%; /* ≈ 4:3 of 62% width */
}

.event-media-list--n2 .event-media-image-wrap {
  width: calc((100% - 12rpx) / 2);
  padding-bottom: calc((100% - 12rpx) / 2);
}

.event-media-list--n3 .event-media-image-wrap {
  width: calc((100% - 24rpx) / 3);
  padding-bottom: calc((100% - 24rpx) / 3);
}

.event-media-list--n4 .event-media-image-wrap {
  width: calc((100% - 36rpx) / 4);
  padding-bottom: calc((100% - 36rpx) / 4);
}

.event-media-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.event-media-video,
.event-media-video-wrap {
  width: 100%;
  flex: 0 0 100%;
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
}

.event-media-video-thumb,
.event-media-video {
  width: 100%;
  min-height: 320rpx;
  max-height: 720rpx;
}

.event-media-video-wrap {
  position: relative;
}

.event-media-video-thumb {
  display: block;
}

.event-media-play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 40rpx;
}

.event-media-link-badge {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  font-size: 22rpx;
  color: #ccc;
}

/* 骨架/错误态：与任务卡片详情页（mission-detail）完全一致 */
.loading-state,
.error-state {
  width: 100%;
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  text-align: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 122, 255, 0.2);
  border-top-color: #4ea1ff;
  animation: spin 0.8s linear infinite;
}

.loading-text,
.error-text {
  display: block;
  width: 100%;
  max-width: 560rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #b6b6bb;
  text-align: center;
  box-sizing: border-box;
}

.error-title {
  display: block;
  width: 100%;
  max-width: 560rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  box-sizing: border-box;
}

.retry-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: center;
  margin-top: 10rpx;
  margin-left: auto;
  margin-right: auto;
  min-width: 220rpx;
  height: 84rpx;
  line-height: 1;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0a84ff, #4ea1ff);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.retry-btn::after {
  border: none;
}

.event-share-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 1300;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.event-share-sheet {
  width: 100%;
  max-width: 620rpx;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: rgba(18, 20, 24, 0.96);
  backdrop-filter: blur(24rpx) saturate(160%);
  -webkit-backdrop-filter: blur(24rpx) saturate(160%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.45);
}

.event-share-sheet-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

.event-share-sheet-desc {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.62);
  text-align: center;
}

.event-share-sheet-btn {
  width: 100%;
  min-height: 92rpx;
  margin: 0 0 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.event-share-sheet-btn--primary {
  padding: 0 !important;
  line-height: 92rpx !important;
  background: linear-gradient(135deg, #1677ff 0%, #55a3ff 100%) !important;
  border: none !important;
  color: #fff !important;
}

.event-share-sheet-btn--primary::after {
  border: none;
}

.event-share-sheet-btn--cancel {
  color: rgba(255, 255, 255, 0.72);
}

/* 事件更新：多图选择保存原图 */
.event-image-save-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.event-image-save-sheet {
  width: 100%;
  max-height: 72vh;
  background: #1a1d24;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.event-image-save-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.event-image-save-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}
.event-image-save-select-all {
  font-size: 26rpx;
  color: #55a3ff;
  padding: 8rpx 4rpx;
}
.event-image-save-scroll {
  max-height: 48vh;
}
.event-image-save-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}
.event-image-save-item {
  width: 33.33%;
  padding: 8rpx;
  box-sizing: border-box;
  position: relative;
}
.event-image-save-thumb {
  width: 100%;
  height: 210rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.06);
  display: block;
}
.event-image-save-item.is-selected .event-image-save-thumb {
  outline: 3rpx solid #1677ff;
  outline-offset: -3rpx;
}
.event-image-save-check {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #1677ff;
  color: #fff;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
}
.event-image-save-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.event-image-save-actions .event-share-sheet-btn {
  flex: 1;
}

/* ── 星舰飞行检查清单（与进度页 NSF 区块同数据，详情走本页壳层） ── */
.nsf-starship-missions {
  margin: 0 0 20rpx;
}

.nsf-starship-missions-head {
  padding: 0 8rpx 12rpx;
}

.nsf-starship-missions-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.78);
}

.nsf-starship-mission-card {
  display: block;
  margin-bottom: 16rpx;
}

.nsf-starship-mission-card:last-child {
  margin-bottom: 0;
}

.nsf-checklist-detail-card {
  border-left: 4rpx solid rgba(52, 199, 89, 0.85);
}

.nsf-checklist-detail-desc {
  display: block;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.72);
}

.nsf-checklist-progress-block {
  padding: 20rpx 0 8rpx;
  margin-bottom: 0;
}

.nsf-checklist-progress-bar-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nsf-checklist-progress-bar-row .nsf-checklist-progress-track {
  flex: 1;
  min-width: 0;
}

.nsf-checklist-bar-refresh {
  flex-shrink: 0;
}

.event-detail-sync-btn {
  font-size: 24rpx;
  color: #64d2ff;
  padding: 4rpx 16rpx;
  border: 1px solid rgba(100, 210, 255, 0.35);
  border-radius: 8rpx;
  margin-left: auto;
}

.nsf-checklist-progress-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.nsf-checklist-progress-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
  font-weight: 500;
}

.nsf-checklist-progress-ratio {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(52, 199, 89, 0.95);
  font-variant-numeric: tabular-nums;
}

.nsf-checklist-progress-track {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.nsf-checklist-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(
    90deg,
    rgba(48, 209, 88, 0.85) 0%,
    rgba(52, 199, 89, 1) 45%,
    rgba(142, 232, 112, 0.92) 100%
  );
  min-width: 0;
  transition: width 0.35s ease-out;
}

.nsf-checklist-detail-rows {
  margin-top: 8rpx;
  margin-left: -28rpx;
  margin-right: -28rpx;
}

.nsf-checklist-detail-rows .flight-checklist-row:first-child {
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.nsf-checklist-detail-empty {
  margin-top: 16rpx;
  padding-top: 8rpx;
}

.flight-checklist-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 28rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.flight-checklist-row:last-child {
  border-bottom: none;
}

.flight-checklist-check {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(142, 142, 147, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.flight-checklist-check--done {
  border-color: rgba(52, 199, 89, 0.85);
  background: rgba(52, 199, 89, 0.18);
}

.flight-checklist-check-mark {
  font-size: 26rpx;
  color: #34c759;
  font-weight: 700;
  line-height: 1;
}

.flight-checklist-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.flight-checklist-category {
  font-size: 22rpx;
  color: rgba(142, 142, 147, 0.95);
}

.flight-checklist-row-title {
  font-size: 29rpx;
  color: #ffffff;
  line-height: 1.45;
}

.flight-checklist-chevron {
  flex-shrink: 0;
  font-size: 44rpx;
  color: rgba(142, 142, 147, 0.85);
  font-weight: 300;
  padding: 8rpx 4rpx 8rpx 16rpx;
  line-height: 1;
}

.flight-checklist-empty {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.flight-checklist-empty-title {
  font-size: 28rpx;
  color: #8e8e93;
}

.flight-checklist-empty-hint {
  font-size: 22rpx;
  color: rgba(142, 142, 147, 0.85);
  line-height: 1.55;
}

.detail-ll2-page-card {
  border-left: 4rpx solid rgba(100, 210, 255, 0.78);
  padding: 28rpx;
  box-sizing: border-box;
}

/* 标题左 + 翻译/刷新按钮右（全局统一布局） */
.detail-ll2-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.detail-ll2-header-row .detail-title--ll2 {
  margin-bottom: 0;
  flex: 1;
}
.detail-ll2-toolbar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.detail-ll2-timeline-item {
  display: flex;
  align-items: stretch;
  flex-direction: row;
  min-height: 72rpx;
}

.detail-ll2-timeline-axis {
  width: 56rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-ll2-timeline-line {
  width: 3rpx;
  flex: 1;
  min-height: 14rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}

.detail-ll2-timeline-node {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(30, 34, 42, 0.95);
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.detail-ll2-timeline-mark {
  flex-shrink: 0;
  box-sizing: border-box;
}

.detail-ll2-timeline-mark--dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.detail-ll2-timeline-mark--solid {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
}

.detail-ll2-timeline-mark--ring {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
}

.detail-ll2-timeline-mark--diamond {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.88);
  transform: rotate(45deg);
}

.detail-ll2-timeline-mark--square {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.88);
}

.detail-ll2-timeline-mark--lift {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 9rpx 15rpx 9rpx;
  border-color: transparent transparent rgba(255, 255, 255, 0.9) transparent;
  background: transparent;
}

.detail-ll2-timeline-main {
  flex: 1;
  min-width: 0;
  padding: 4rpx 16rpx 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-ll2-timeline-main .ll2-timeline-title {
  font-size: 29rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.45;
  font-weight: 500;
}

.detail-ll2-timeline-main .ll2-timeline-title--lift {
  font-weight: 700;
  color: #ffffff;
}

.detail-ll2-timeline-desc {
  font-size: 22rpx;
  color: rgba(142, 142, 147, 0.95);
  line-height: 1.45;
}

.detail-ll2-timeline-clock {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  font-variant-numeric: tabular-nums;
  padding-top: 6rpx;
  padding-left: 8rpx;
  max-width: 200rpx;
  text-align: right;
}

.detail-ll2-updates-body {
  padding-top: 8rpx;
}

.detail-ll2-update-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.detail-ll2-update-row:last-child {
  border-bottom: none;
}

.detail-ll2-update-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.detail-ll2-update-comment {
  font-size: 29rpx;
  color: #ffffff;
  line-height: 1.5;
}

.detail-ll2-update-meta {
  font-size: 22rpx;
  color: rgba(142, 142, 147, 0.95);
}

.detail-ll2-update-chevron {
  margin-top: 4rpx;
}

/* ============================================================== */
/* LL2 在轨事件详情页（pageMode = 'll2_event'）专用样式             */
/* ============================================================== */
.ll2-event-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 28rpx 60rpx;
}

/* Hero：头图 + 类型胶囊 + 倒计时 + 标题 */
.ll2-event-hero {
  position: relative;
  width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 28rpx 28rpx;
  box-sizing: border-box;
}

/* 与全局 .glass-card 叠层一致，避免裁切圆角被撑破 */
.ll2-event-hero.glass-card {
  overflow: hidden;
}

/* overflow 裁剪 + 略大于容器并 translate 居中，稳定对齐裁剪中心 */
.ll2-event-hero-bg-wrap {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 0;
}

/* 头图按容器原尺寸铺满，aspectFill 居中裁切 */
.ll2-event-hero-img-stage {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

.ll2-event-hero-img-crop {
  width: 100%;
  height: 100%;
  display: block;
}

.ll2-event-hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.05) 0%, rgba(0, 0, 0, 0.55) 60%, rgba(0, 0, 0, 0.85) 100%);
  z-index: 2;
}

.ll2-event-hero-tags {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.ll2-event-type-chip {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  background: rgba(90, 200, 250, 0.22);
  color: #5AC8FA;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1.5rpx;
  text-transform: uppercase;
  border: 1rpx solid rgba(90, 200, 250, 0.5);
}

.ll2-event-type-chip--docking,
.ll2-event-type-chip--berthing {
  color: #5AC8FA;
  background: rgba(90, 200, 250, 0.22);
  border-color: rgba(90, 200, 250, 0.5);
}

.ll2-event-type-chip--eva,
.ll2-event-type-chip--spacewalk {
  color: #BF5AF2;
  background: rgba(191, 90, 242, 0.22);
  border-color: rgba(191, 90, 242, 0.5);
}

.ll2-event-type-chip--undocking,
.ll2-event-type-chip--unberthing {
  color: #FF9F0A;
  background: rgba(255, 159, 10, 0.22);
  border-color: rgba(255, 159, 10, 0.5);
}

.ll2-event-type-chip--orbital-insertion,
.ll2-event-type-chip--reboost {
  color: #34C759;
  background: rgba(52, 199, 89, 0.22);
  border-color: rgba(52, 199, 89, 0.5);
}

.ll2-event-countdown {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  flex-shrink: 0;
}

.ll2-event-countdown--realtime {
  gap: 4rpx;
}

.ll2-event-cd-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 52rpx;
}

.ll2-event-cd-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}

.ll2-event-cd-unit {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2rpx;
}

.ll2-event-cd-sep {
  font-size: 30rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.5);
  margin-top: -16rpx;
}

.ll2-event-countdown--live {
  border-color: rgba(255, 69, 58, 0.4);
  background: rgba(255, 69, 58, 0.15);
}

.ll2-event-cd-live {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF453A;
}

.ll2-event-hero-title {
  position: relative;
  z-index: 3;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.6);
}

/* 信息卡片（日期 / 地点） */
.ll2-event-info {
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
}

.ll2-event-info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.ll2-event-info-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  filter: invert(70%) sepia(8%) saturate(245%) hue-rotate(180deg);
}

.ll2-event-info-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.ll2-event-info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.ll2-event-info-value {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.4;
  word-break: break-word;
}

.ll2-event-info-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* 通用 section 卡片（任务概述 / 直播） */
.ll2-event-section {
  border-radius: 24rpx;
  padding: 28rpx;
}

.ll2-event-section-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.ll2-event-section-icon {
  width: 32rpx;
  height: 32rpx;
  filter: invert(70%) sepia(10%) saturate(245%) hue-rotate(180deg);
}

.ll2-event-section-title text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}

/* 标题行内的翻译按钮不吃标题字号/字重（覆盖上面的 text 选择器） */
.ll2-event-section-title text.translate-toggle {
  font-size: 26rpx;
  font-weight: 400;
  color: #4a9eff;
  letter-spacing: 0;
  margin-left: auto;
  flex-shrink: 0;
}

.ll2-event-section-body {
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  word-break: break-word;
}

/* 直播 CTA */
.ll2-event-webcast {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ll2-event-webcast-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  filter: invert(70%) sepia(60%) saturate(500%) hue-rotate(180deg);
}

.ll2-event-webcast-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.ll2-event-webcast-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  word-break: break-word;
}

.ll2-event-webcast-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}

.ll2-event-webcast-hint {
  font-size: 22rpx;
  color: rgba(90, 200, 250, 0.85);
  margin-top: 6rpx;
}

.ll2-event-webcast-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 300;
  flex-shrink: 0;
}

.ll2-event-source-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  text-align: center;
  margin-top: 8rpx;
}

/* ========== LL2 详细数据区块 ========== */
.ll2-detail-loading {
  text-align: center;
  padding: 24rpx 0;
}

.ll2-detail-loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.ll2-detail-launches {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ll2-detail-launch-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ll2-detail-launch-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.ll2-detail-launch-info {
  flex: 1;
  min-width: 0;
}

.ll2-detail-launch-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ll2-detail-launch-meta {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 6rpx;
}

.ll2-detail-launch-status {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
}

.ll2-detail-launch-status--Success {
  color: #34C759;
  background: rgba(52, 199, 89, 0.15);
}

.ll2-detail-launch-status--Go {
  color: #5AC8FA;
  background: rgba(90, 200, 250, 0.15);
}

.ll2-detail-launch-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.ll2-detail-agencies {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ll2-detail-agency-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.ll2-detail-agency-abbrev {
  font-size: 24rpx;
  font-weight: 700;
  color: #007AFF;
  min-width: 60rpx;
}

.ll2-detail-agency-name {
  font-size: 24rpx;
  color: #fff;
  flex: 1;
}

.ll2-detail-agency-type {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.08);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.ll2-detail-stations {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ll2-detail-station-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ll2-detail-station-img {
  width: 100rpx;
  height: 70rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.ll2-detail-station-info {
  flex: 1;
}

.ll2-detail-station-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.ll2-detail-station-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
  display: block;
}

.ll2-detail-programs {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ll2-detail-program-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ll2-detail-program-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  object-fit: contain;
  background: rgba(255, 255, 255, 0.05);
}

.ll2-detail-program-info {
  flex: 1;
}

.ll2-detail-program-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.ll2-detail-program-type {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
  display: block;
}

.ll2-detail-updates {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-left: 20rpx;
  border-left: 3rpx solid rgba(255, 255, 255, 0.15);
}

.ll2-detail-update-item {
  display: flex;
  gap: 16rpx;
  position: relative;
}

.ll2-detail-update-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #5AC8FA;
  flex-shrink: 0;
  margin-top: 10rpx;
  margin-left: -27rpx;
}

.ll2-detail-update-body {
  flex: 1;
}

.ll2-detail-update-comment {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  display: block;
}

.ll2-detail-update-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 6rpx;
}

.ll2-detail-update-by {
  font-size: 20rpx;
  color: #5AC8FA;
}

.ll2-detail-update-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ========== 明亮主题（theme-light）覆盖 ========== */

/* —— 页面底色（根节点自身挂 theme-light）—— */
.detail-page.theme-light {
  background: var(--color-bg-page);
}

/* —— 下拉刷新指示 —— */
.theme-light .refresher-spinner {
  border: 4rpx solid rgba(0, 0, 0, 0.08);
  border-top-color: #4ea1ff;
}

.theme-light .refresher-text {
  color: var(--color-text-secondary);
}

/* —— 玻璃卡片 → 浅色玻璃 —— */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

/* —— 列表提示 / 页脚 —— */
.theme-light .list-day-hint-text {
  color: var(--color-text-tertiary);
}

.theme-light .list-load-footer-text {
  color: var(--color-text-tertiary);
}

.theme-light .empty-list-text {
  color: var(--color-text-tertiary);
}

/* —— 推文卡片：日期 / 作者胶囊 / 标题 / 正文 —— */
.theme-light .date-text {
  color: var(--color-text-secondary);
}

.theme-light .author-tag-wrap {
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid var(--color-divider);
}

.theme-light .author-tag {
  color: var(--color-text-secondary);
}

.theme-light .detail-title {
  color: var(--color-text-primary);
}

.theme-light .detail-content {
  color: var(--color-text-primary);
}

/* —— 直播卡片（封面图上的角标/播放按钮保持深色压图样式）—— */
.theme-light .event-live-card {
  background: rgba(0, 0, 0, 0.04);
  border: 1px solid var(--color-divider);
}

/* —— 媒体占位底（图片/视频加载前）—— */
.theme-light .event-media-image-wrap,
.theme-light .event-media-video,
.theme-light .event-media-video-wrap {
  background: rgba(0, 0, 0, 0.04);
}

/* —— 加载 / 错误态 —— */
.theme-light .loading-text,
.theme-light .error-text {
  color: var(--color-text-secondary);
}

.theme-light .error-title {
  color: var(--color-text-primary);
}

/* —— 分享面板（全屏遮罩保持深色，面板改浅色）—— */
.theme-light .event-share-sheet {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid var(--color-divider);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.16);
}

.theme-light .event-share-sheet-title {
  color: var(--color-text-primary);
}

.theme-light .event-share-sheet-desc {
  color: var(--color-text-secondary);
}

.theme-light .event-share-sheet-btn {
  color: var(--color-text-primary);
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid var(--color-divider);
}

.theme-light .event-share-sheet-btn--cancel {
  color: var(--color-text-secondary);
}

.theme-light .event-image-save-sheet {
  background: rgba(255, 255, 255, 0.98);
}
.theme-light .event-image-save-title {
  color: var(--color-text-primary);
}
.theme-light .event-image-save-thumb {
  background: rgba(0, 0, 0, 0.04);
}

/* —— NSF 星舰飞行检查清单 —— */
.theme-light .nsf-starship-missions-title {
  color: var(--color-text-secondary);
}

.theme-light .nsf-checklist-detail-desc {
  color: var(--color-text-secondary);
}

.theme-light .event-detail-sync-btn {
  color: var(--color-brand);
  border: 1px solid rgba(0, 122, 255, 0.35);
}

.theme-light .nsf-checklist-progress-title {
  color: var(--color-text-secondary);
}

.theme-light .nsf-checklist-progress-track {
  background: rgba(0, 0, 0, 0.06);
}

.theme-light .nsf-checklist-detail-rows .flight-checklist-row:first-child {
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}

.theme-light .flight-checklist-row {
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.theme-light .flight-checklist-row:last-child {
  border-bottom: none;
}

.theme-light .flight-checklist-check {
  border-color: rgba(0, 0, 0, 0.25);
}

.theme-light .flight-checklist-check--done {
  border-color: rgba(52, 199, 89, 0.85);
  background: rgba(52, 199, 89, 0.12);
}

.theme-light .flight-checklist-row-title {
  color: var(--color-text-primary);
}

.theme-light .flight-checklist-empty-title {
  color: var(--color-text-secondary);
}

.theme-light .flight-checklist-empty-hint {
  color: var(--color-text-tertiary);
}

/* —— LL2 时间线 —— */
.theme-light .detail-ll2-timeline-line {
  background: rgba(0, 0, 0, 0.12);
}

.theme-light .detail-ll2-timeline-node {
  background: var(--color-bg-card);
  border: 2rpx solid rgba(0, 0, 0, 0.15);
}

.theme-light .detail-ll2-timeline-mark--dot,
.theme-light .detail-ll2-timeline-mark--solid,
.theme-light .detail-ll2-timeline-mark--diamond,
.theme-light .detail-ll2-timeline-mark--square {
  background: var(--color-text-primary);
}

.theme-light .detail-ll2-timeline-mark--ring {
  border-color: var(--color-text-primary);
}

.theme-light .detail-ll2-timeline-mark--lift {
  border-color: transparent transparent var(--color-text-primary) transparent;
}

.theme-light .detail-ll2-timeline-main .ll2-timeline-title {
  color: var(--color-text-primary);
}

.theme-light .detail-ll2-timeline-main .ll2-timeline-title--lift {
  color: var(--color-text-primary);
}

.theme-light .detail-ll2-timeline-desc {
  color: var(--color-text-tertiary);
}

.theme-light .detail-ll2-timeline-clock {
  color: var(--color-text-primary);
}

/* —— LL2 动态追踪（翻译后文本同此区）—— */
.theme-light .detail-ll2-update-row {
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.theme-light .detail-ll2-update-row:last-child {
  border-bottom: none;
}

.theme-light .detail-ll2-update-comment {
  color: var(--color-text-primary);
}

.theme-light .detail-ll2-update-meta {
  color: var(--color-text-tertiary);
}

/* —— LL2 在轨事件详情 ——
 * Hero 头图卡片整体保持深色（压图白字 + 深渐变遮罩），恢复深色玻璃底 */
.theme-light .ll2-event-hero.glass-card {
