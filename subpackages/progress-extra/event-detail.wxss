  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

.theme-light .ll2-event-info-icon {
  filter: invert(45%) sepia(8%) saturate(245%) hue-rotate(180deg);
}

.theme-light .ll2-event-info-label {
  color: var(--color-text-tertiary);
}

.theme-light .ll2-event-info-value {
