page {
  background: #000;
  overflow: hidden;
  height: 100vh;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
}

.main-map {
  width: 100%;
  height: 100vh;
}

.glass-card {
  background: rgba(18, 18, 20, 0.78);
  backdrop-filter: blur(18rpx);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.state-card {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.state-title {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.state-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.5;
}

.panel-header {
  align-items: center;
}

.panel-badge {
  flex-shrink: 0;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.panel-badge text {
  color: #fff;
  font-size: 20rpx;
}

.panel-badge--red {
  background: rgba(255, 69, 58, 0.16);
}

.panel-badge--red text {
  color: #FFD1CC;
}

.panel-summary,
.detail-label,
.detail-text,
.timeline-label,
.timeline-value {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  line-height: 1.5;
}

.status-row {
  margin-top: 16rpx;
}

.data-meta-row {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-meta-text {
  color: rgba(255, 255, 255, 0.54);
  font-size: 20rpx;
  line-height: 1.4;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(142, 142, 147, 0.18);
  box-sizing: border-box;
}

.status-pill text {
  color: #fff;
  font-size: 20rpx;
}

.status-pill--active {
  background: rgba(255, 69, 58, 0.2);
}

.timeline-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.timeline-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.timeline-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #FF453A;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.timeline-content {
  flex: 1;
}

.timeline-label {
  color: rgba(255, 255, 255, 0.5);
  margin-top: 0;
}

.timeline-value {
  color: #fff;
  margin-top: 4rpx;
}

.detail-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.detail-label {
  color: rgba(255, 255, 255, 0.48);
}

.detail-text {
  color: #fff;
}

/* 展开面板：限制高度并在卡片内滚动，避免顶到状态栏 */
.map-page .panel--expanded {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.map-page .panel--expanded .panel-header,
.map-page .panel--expanded .state-card {
  flex-shrink: 0;
}

.panel-scroll {
  width: 100%;
  box-sizing: border-box;
}

.panel-scroll-inner {
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.85);
  border-color: var(--color-divider);
}

.theme-light .state-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .state-title {
  color: var(--color-text-primary);
}

.theme-light .state-desc {
  color: var(--color-text-secondary);
}

.theme-light .panel-badge {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .panel-badge text {
  color: var(--color-text-primary);
}

.theme-light .panel-badge--red {
  background: rgba(255, 69, 58, 0.12);
}

.theme-light .panel-badge--red text {
  color: #D70015;
}

.theme-light .panel-summary,
.theme-light .timeline-value {
  color: var(--color-text-secondary);
}

.theme-light .data-meta-text {
  color: var(--color-text-tertiary);
}

.theme-light .status-pill {
  background: rgba(142, 142, 147, 0.15);
}

.theme-light .status-pill text {
  color: var(--color-text-primary);
}

.theme-light .status-pill--active {
  background: rgba(255, 69, 58, 0.14);
}

.theme-light .status-pill--active text {
  color: #D70015;
}

.theme-light .timeline-label {
  color: var(--color-text-tertiary);
}

.theme-light .timeline-value {
  color: var(--color-text-primary);
}

.theme-light .detail-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .detail-label {
  color: var(--color-text-tertiary);
}

.theme-light .detail-text {
  color: var(--color-text-primary);
}
