<view class="detail-page {{themeClass}}">
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-grid">
      <view class="nav-left top-nav-slot--back {{isDirectEntry ? 'top-nav-slot--home' : ''}}" bindtap="goBack" style="width: {{menuButtonWidth}}px;">
        <text class="icon-back icon-back--nav">‹</text>
      </view>
      <view class="nav-title-wrap nav-title-wrap--page-grid">
        <text class="nav-title nav-title--page-grid">{{navTitle}}</text>
      </view>
      <view class="nav-right-space top-nav-slot--spacer" style="width: {{menuButtonWidth}}px;"></view>
    </view>
    <page-progress active="{{loading}}" />
  </view>

  <!-- 滚动区整体下移到固定导航栏下方：refresher 插槽自然出现在导航栏和卡片之间，
       下拉/回弹由 enhanced scroll-view 原生弹簧处理，刷新后回弹到导航栏正下方 -->
  <scroll-view class="detail-scroll" scroll-y="true" scroll-top="{{detailScrollTop}}" enhanced="{{true}}" bounces="{{false}}" show-scrollbar="{{false}}" lower-threshold="{{120}}" bindscrolltolower="onDetailScrollToLower">
    <view style="height: {{navPlaceholderHeight}}px;"></view>
    <view class="detail-container">
      <!-- 加载中：内容区留白，进度由导航栏下方的 page-progress 绿色进度条呈现 -->
      <block wx:if="{{loading}}"></block>

      <view class="error-state glass-card" wx:elif="{{errorMessage}}">
        <text class="error-title">加载失败</text>
        <text class="error-text">{{errorMessage}}</text>
        <button class="retry-btn" bindtap="retryLoad">重新加载</button>
      </view>

      <block wx:elif="{{pageMode === 'nsf_checklist' && !errorMessage}}">
        <!-- 即将发射的星舰任务（与首页即将发射列表同款信息，点击进任务详情） -->
        <view class="nsf-starship-missions" wx:if="{{nsfStarshipMissions.length > 0}}">
          <view class="nsf-starship-missions-head">
            <text class="nsf-starship-missions-title">即将发射 · 星舰</text>
          </view>
          <view
            class="nsf-mission-card glass-card card-hover"
            wx:for="{{nsfStarshipMissions}}"
            wx:key="_wxkey"
            bindtap="onNsfStarshipMissionTap"
            data-id="{{item.id}}"
            data-type="{{item._detailType || 'upcoming'}}"
          >
            <view class="nsf-mission-rocket-slot">
              <image class="nsf-mission-rocket-image" wx:if="{{item.rocketImage}}" src="{{item.rocketImage}}" mode="aspectFill"></image>
              <view wx:else class="nsf-mission-rocket-image nsf-mission-rocket-image--placeholder"></view>
            </view>
            <view class="nsf-mission-info">
              <view class="nsf-mission-info-top">
                <text class="nsf-mission-status nsf-mission-status--{{item.statusCategory || 'pending'}}">{{item.statusBadgeText || item.status || '计划中'}}</text>
                <text class="nsf-mission-country" wx:if="{{item.countryDisplay}}">{{item.countryDisplay}}</text>
              </view>
              <text class="nsf-mission-name">{{item.missionName || item.name || '未知任务'}}</text>
              <text class="nsf-mission-meta" wx:if="{{item.rocketName}}">{{item.rocketName}}</text>
              <text class="nsf-mission-meta">{{item.formattedTime}}</text>
              <text class="nsf-mission-meta" wx:if="{{item.padLocation}}">{{item.padLocation}}</text>
            </view>
            <text class="nsf-mission-chevron">›</text>
          </view>
        </view>

        <view class="detail-card glass-card nsf-checklist-detail-card">
          <view class="meta-top" wx:if="{{nsfChecklistSourceLastFetch}}">
            <text class="date-text">{{nsfChecklistSourceLastFetch}}</text>
          </view>

          <text class="detail-title">星舰飞行检查清单</text>
          <view class="nsf-checklist-progress-block">
            <view class="nsf-checklist-progress-head">
              <text class="nsf-checklist-progress-title">清单进度</text>
              <text class="nsf-checklist-progress-ratio">{{nsfChecklistProgressDone}}/{{nsfChecklistProgressTotal}}</text>
            </view>
            <view class="nsf-checklist-progress-bar-row">
              <view class="nsf-checklist-progress-track">
                <view class="nsf-checklist-progress-fill" style="width: {{nsfChecklistProgressPercent}}%;"></view>
              </view>
              <text class="event-detail-sync-btn nsf-checklist-bar-refresh" catchtap="onRefreshNsfChecklistDetail">{{nsfChecklistSyncing ? '同步中…' : '刷新'}}</text>
            </view>
          </view>

          <view class="nsf-checklist-detail-rows" wx:if="{{nsfChecklistItems.length > 0}}">
            <view class="flight-checklist-row" wx:for="{{nsfChecklistItems}}" wx:key="id">
              <view class="flight-checklist-check {{item.done ? 'flight-checklist-check--done' : ''}}">
                <text wx:if="{{item.done}}" class="flight-checklist-check-mark">✓</text>
              </view>
              <view class="flight-checklist-main">
                <text wx:if="{{item.category}}" class="flight-checklist-category">{{item.category}}</text>
                <text class="flight-checklist-row-title">{{item.title}}</text>
              </view>
              <text
                wx:if="{{item.detailUrl}}"
                class="flight-checklist-chevron"
                catchtap="onFlightChecklistDetailTap"
                data-url="{{item.detailUrl}}"
              >›</text>
            </view>
          </view>

          <view class="flight-checklist-empty nsf-checklist-detail-empty" wx:elif="{{nsfChecklistError}}">
            <text class="flight-checklist-empty-title">{{nsfChecklistError}}</text>
          </view>
          <view class="flight-checklist-empty nsf-checklist-detail-empty" wx:else>
            <text class="flight-checklist-empty-title">暂无数据</text>
          </view>

        </view>

        <!-- 贴图讨论区：NSF 检查清单详情；topic 固定为页面标题，组件内已截断至 20 字 -->
        <official-account-publish-panel topic="{{navTitle || '星舰飞行检查清单'}}" />

        <view style="height: {{tabBarReservedHeight}}px;"></view>
      </block>

      <block wx:elif="{{pageMode === 'll2_timeline' && !errorMessage}}">
        <view class="detail-card glass-card detail-ll2-page-card">
          <text class="detail-title">星舰飞行时间线</text>
          <view class="detail-ll2-toolbar">
            <text class="event-detail-sync-btn" catchtap="onRefreshLl2TimelineDetail">{{detailLl2Refreshing ? '…' : '刷新'}}</text>
          </view>
          <view wx:if="{{ll2DetailTimelineRows.length > 0}}">
            <view class="detail-ll2-timeline-item" wx:for="{{ll2DetailTimelineRows}}" wx:key="id">
              <view class="detail-ll2-timeline-axis">
                <view class="detail-ll2-timeline-line detail-ll2-timeline-line--up" wx:if="{{index !== 0}}"></view>
                <view class="detail-ll2-timeline-node">
                  <view class="detail-ll2-timeline-mark detail-ll2-timeline-mark--{{item.iconVariant}}"></view>
                </view>
                <view class="detail-ll2-timeline-line detail-ll2-timeline-line--down" wx:if="{{index !== ll2DetailTimelineRows.length - 1}}"></view>
              </view>
              <view class="detail-ll2-timeline-main">
                <text class="{{item.titleClass}}" user-select="{{true}}">{{item.title}}</text>
                <text class="detail-ll2-timeline-desc" wx:if="{{item.description}}" user-select="{{true}}">{{item.description}}</text>
              </view>
              <text class="detail-ll2-timeline-clock">{{item.timeLabel}}</text>
            </view>
          </view>
          <view class="flight-checklist-empty" wx:else>
            <text class="flight-checklist-empty-title">暂无</text>
          </view>
        </view>
        <view style="height: {{tabBarReservedHeight}}px;"></view>
      </block>

      <block wx:elif="{{pageMode === 'll2_launch_updates' && !errorMessage}}">
        <view class="detail-card glass-card detail-ll2-page-card">
          <view class="detail-ll2-header-row">
            <text class="detail-title detail-title--ll2">星舰动态追踪</text>
            <view class="detail-ll2-toolbar">
              <text class="translate-toggle {{luTranslating ? 'translate-toggle--busy' : ''}}" catchtap="onToggleLaunchUpdatesTranslate">{{luTranslating ? '翻译中…' : (luTranslated ? '原文' : '翻译')}}</text>
              <text class="event-detail-sync-btn" catchtap="onRefreshLl2LaunchUpdatesDetail">{{detailLl2Refreshing ? '…' : '刷新'}}</text>
            </view>
          </view>
          <view class="detail-ll2-updates-body" wx:if="{{ll2DetailLaunchUpdates.length > 0}}">
            <view class="detail-ll2-update-row" wx:for="{{ll2DetailLaunchUpdates}}" wx:key="id">
              <view class="detail-ll2-update-main">
                <text class="detail-ll2-update-comment">{{descI18n.launchUpdates[index] || item.comment}}</text>
                <text class="detail-ll2-update-meta">{{item.createdBy}}{{item.timeLabel ? ' · ' + item.timeLabel : ''}}</text>
              </view>
              <text
                wx:if="{{item.infoUrl}}"
                class="flight-checklist-chevron detail-ll2-update-chevron"
                catchtap="onFlightChecklistDetailTap"
                data-url="{{item.infoUrl}}"
              >›</text>
            </view>
          </view>
          <view class="flight-checklist-empty" wx:else>
            <text class="flight-checklist-empty-title">暂无</text>
          </view>
        </view>
        <view style="height: {{tabBarReservedHeight}}px;"></view>
      </block>

      <!-- LL2 即将进行的在轨事件（专用样式） -->
      <block wx:elif="{{pageMode === 'll2_event' && !errorMessage && item}}">
        <view class="ll2-event-page">
          <!-- Hero 头图 + 类型胶囊 + 倒计时 -->
          <view class="ll2-event-hero glass-card">
            <view class="ll2-event-hero-bg-wrap" wx:if="{{item.heroImageUrl}}" bindtap="onLl2HeroPreview">
              <view class="ll2-event-hero-img-stage">
                <image class="ll2-event-hero-img-crop" src="{{item.heroImageUrl}}" mode="aspectFill" lazy-load />
              </view>
            </view>
            <view class="ll2-event-hero-mask"></view>
            <view class="ll2-event-hero-tags">
              <view class="ll2-event-type-chip ll2-event-type-chip--{{item.typeKey}}">
                <text>{{item.typeName}}</text>
              </view>
              <view class="ll2-event-countdown ll2-event-countdown--realtime" wx:if="{{!ll2EventCountdown.isExpired}}">
                <view class="ll2-event-cd-item">
                  <text class="ll2-event-cd-value">{{ll2EventCountdown.days}}</text>
                  <text class="ll2-event-cd-unit">天</text>
                </view>
                <text class="ll2-event-cd-sep">:</text>
                <view class="ll2-event-cd-item">
                  <text class="ll2-event-cd-value">{{ll2EventCountdown.hours}}</text>
                  <text class="ll2-event-cd-unit">时</text>
                </view>
                <text class="ll2-event-cd-sep">:</text>
                <view class="ll2-event-cd-item">
                  <text class="ll2-event-cd-value">{{ll2EventCountdown.minutes}}</text>
                  <text class="ll2-event-cd-unit">分</text>
                </view>
                <text class="ll2-event-cd-sep">:</text>
                <view class="ll2-event-cd-item">
                  <text class="ll2-event-cd-value">{{ll2EventCountdown.seconds}}</text>
                  <text class="ll2-event-cd-unit">秒</text>
                </view>
              </view>
              <view class="ll2-event-countdown ll2-event-countdown--live" wx:else>
                <text class="ll2-event-cd-live">进行中 / 已开始</text>
              </view>
            </view>
            <text class="ll2-event-hero-title" user-select="{{true}}">{{item.title}}</text>
          </view>

          <!-- 贴图讨论区：LL2 事件头图下方；topic 取自标题，组件内已截断至 20 字 -->
          <official-account-publish-panel topic="{{item.title || '即将发生'}}" />

          <!-- 信息行：日期 / 地点（图标线条统一风格） -->
          <view class="ll2-event-info glass-card">
            <view class="ll2-event-info-row">
              <image class="ll2-event-info-icon" src="/images/icon-calendar.svg" mode="aspectFit"></image>
              <view class="ll2-event-info-body">
                <text class="ll2-event-info-label">预计时间</text>
                <text class="ll2-event-info-value" user-select="{{true}}">{{item.dateText}}</text>
              </view>
            </view>
            <view class="ll2-event-info-divider"></view>
            <view class="ll2-event-info-row" wx:if="{{item.location}}">
              <image class="ll2-event-info-icon" src="/images/icon-location.svg" mode="aspectFit"></image>
              <view class="ll2-event-info-body">
                <text class="ll2-event-info-label">所在位置</text>
                <text class="ll2-event-info-value" user-select="{{true}}">{{item.location}}</text>
              </view>
            </view>
          </view>

          <!-- 描述 -->
          <view class="ll2-event-section glass-card" wx:if="{{item.description}}">
            <view class="ll2-event-section-title">
              <image class="ll2-event-section-icon" src="/images/icon-orbit.svg" mode="aspectFit"></image>
              <text>任务概述</text>
              <text class="translate-toggle translate-toggle--inline {{evtDescTranslating ? 'translate-toggle--busy' : ''}}" catchtap="onToggleEventDescTranslate">{{evtDescTranslating ? '翻译中…' : (evtDescTranslated ? '原文' : '翻译')}}</text>
            </view>
            <text class="ll2-event-section-body" user-select="{{true}}">{{descI18n.eventDesc || item.description}}</text>
          </view>

          <!-- 直播 / 视频 CTA -->
          <view class="ll2-event-section glass-card" wx:if="{{item.webcastUrl}}" bindtap="onLl2WebcastTap">
            <view class="ll2-event-webcast">
              <image class="ll2-event-webcast-icon" src="/images/icon-play.svg" mode="aspectFit"></image>
              <view class="ll2-event-webcast-body">
                <text class="ll2-event-webcast-title">{{item.webcastTitle || '官方直播'}}</text>
                <text class="ll2-event-webcast-meta" wx:if="{{item.webcastPublisher}}">{{item.webcastPublisher}}</text>
                <text class="ll2-event-webcast-hint">点击复制直播链接</text>
              </view>
              <text class="ll2-event-webcast-arrow">›</text>
            </view>
          </view>

          <!-- 详细数据（异步加载） -->
          <view class="ll2-detail-loading" wx:if="{{ll2DetailedLoading}}">
            <text class="ll2-detail-loading-text">加载详细数据...</text>
          </view>

          <block wx:if="{{ll2DetailedData}}">
            <!-- 关联发射 -->
            <view class="ll2-event-section glass-card" wx:if="{{ll2DetailedData.launches.length}}">
              <view class="ll2-event-section-title">
                <text>关联发射</text>
              </view>
              <view class="ll2-detail-launches">
                <view class="ll2-detail-launch-item" wx:for="{{ll2DetailedData.launches}}" wx:key="id">
                  <image class="ll2-detail-launch-img" wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
                  <view class="ll2-detail-launch-info">
                    <text class="ll2-detail-launch-name">{{item.name}}</text>
                    <view class="ll2-detail-launch-meta">
                      <text class="ll2-detail-launch-status ll2-detail-launch-status--{{item.statusAbbrev}}">{{item.status}}</text>
                      <text class="ll2-detail-launch-time" wx:if="{{item.net}}">{{item.net}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>

            <!-- 参与机构 -->
            <view class="ll2-event-section glass-card" wx:if="{{ll2DetailedData.agencies.length}}">
              <view class="ll2-event-section-title">
                <text>参与机构</text>
              </view>
              <view class="ll2-detail-agencies">
                <view class="ll2-detail-agency-chip" wx:for="{{ll2DetailedData.agencies}}" wx:key="id">
                  <text class="ll2-detail-agency-abbrev">{{item.abbrev}}</text>
                  <text class="ll2-detail-agency-name">{{item.name}}</text>
                  <text class="ll2-detail-agency-type">{{item.type}}</text>
                </view>
              </view>
            </view>

            <!-- 空间站 -->
            <view class="ll2-event-section glass-card" wx:if="{{ll2DetailedData.spacestations.length}}">
              <view class="ll2-event-section-title">
                <text>相关空间站</text>
              </view>
              <view class="ll2-detail-stations">
                <view class="ll2-detail-station-item" wx:for="{{ll2DetailedData.spacestations}}" wx:key="id">
                  <image class="ll2-detail-station-img" wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
                  <view class="ll2-detail-station-info">
                    <text class="ll2-detail-station-name">{{item.name}}</text>
                    <text class="ll2-detail-station-meta">{{item.orbit}} · {{item.status}}</text>
                  </view>
                </view>
              </view>
            </view>

            <!-- 所属项目 -->
            <view class="ll2-event-section glass-card" wx:if="{{ll2DetailedData.programs.length}}">
              <view class="ll2-event-section-title">
                <text>所属项目</text>
              </view>
              <view class="ll2-detail-programs">
                <view class="ll2-detail-program-item" wx:for="{{ll2DetailedData.programs}}" wx:key="id">
                  <image class="ll2-detail-program-img" wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFit" lazy-load />
                  <view class="ll2-detail-program-info">
                    <text class="ll2-detail-program-name">{{item.name}}</text>
                    <text class="ll2-detail-program-type">{{item.type}}</text>
                  </view>
                </view>
              </view>
            </view>

            <!-- 更新日志 -->
            <view class="ll2-event-section glass-card" wx:if="{{ll2DetailedData.updates.length}}">
              <view class="ll2-event-section-title">
                <text>更新日志</text>
                <text class="translate-toggle translate-toggle--inline {{updTranslating ? 'translate-toggle--busy' : ''}}" catchtap="onToggleUpdatesTranslate">{{updTranslating ? '翻译中…' : (updTranslated ? '原文' : '翻译')}}</text>
              </view>
              <view class="ll2-detail-updates">
                <view class="ll2-detail-update-item" wx:for="{{ll2DetailedData.updates}}" wx:key="id">
                  <view class="ll2-detail-update-dot"></view>
                  <view class="ll2-detail-update-body">
                    <text class="ll2-detail-update-comment" user-select="{{true}}">{{descI18n.updates[index] || item.comment}}</text>
                    <view class="ll2-detail-update-meta">
                      <text class="ll2-detail-update-by">{{item.createdBy}}</text>
                      <text class="ll2-detail-update-time">{{item.createdOn}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>

          <text class="ll2-event-source-tip">数据来源：LL2</text>
        </view>
      </block>

      <block wx:elif="{{listMode}}">
        <view class="list-day-hint" wx:if="{{listDayHint}}">
          <text class="list-day-hint-text">{{listDayHint}}</text>
        </view>
        <view class="empty-list-hint glass-card" wx:if="{{items.length === 0}}">
          <text class="empty-list-text">该账号暂无已发布动态，可下拉刷新重试</text>
        </view>
        <block wx:for="{{items}}" wx:for-item="ev" wx:key="_id" wx:for-index="evIdx">
          <view class="detail-card glass-card list-card-item" bindtap="onListCardTap" bindlongpress="openListEventShareSheet" data-id="{{ev._id}}" data-idx="{{evIdx}}">
            <view class="meta-top">
              <text class="date-text">{{ev.publishedAtText}}</text>
              <view class="author-tag-wrap" wx:if="{{ev.author}}">
                <image class="author-avatar" src="{{ev.authorAvatar}}" wx:if="{{ev.authorAvatar && !ev._avatarFailed}}" mode="aspectFill" binderror="onListAvatarError" data-idx="{{evIdx}}" />
                <text class="author-tag">{{ev.author}}</text>
              </view>
            </view>

            <text class="detail-title" wx:if="{{ev.title}}" user-select="{{true}}">{{ev.title}}</text>
            <text class="detail-content" wx:if="{{ev.content}}" user-select="{{true}}">{{ev.content}}</text>

            <view class="event-live-card" wx:if="{{ev.liveRoomId}}" catchtap="onLiveCardTapFromList" data-id="{{ev._id}}">
              <view class="event-live-cover-wrap">
                <image class="event-live-cover" src="{{ev.liveCover || ev._liveCover || ''}}" mode="aspectFill" wx:if="{{ev.liveCover || ev._liveCover}}" />
                <view class="event-live-cover-placeholder" wx:else>
                  <text class="event-live-cover-placeholder-text">直播</text>
                </view>
                <view class="event-live-badge {{ev._liveStatus === 1 ? 'event-live-badge-on' : ''}}">
                  <view class="event-live-dot" wx:if="{{ev._liveStatus === 1}}" />
                  <text>{{ev._liveStatus === 1 ? '直播中' : '未开播'}}</text>
                </view>
                <view class="event-live-play-overlay" wx:if="{{ev._liveStatus === 1}}">
                  <view class="event-live-play-btn">▶</view>
                </view>
              </view>
              <view class="event-live-action">
                <text class="event-live-action-text">{{ev._liveStatus === 1 ? '点击观看直播' : (ev._liveTitle || '未开播')}}</text>
                <text class="event-live-action-arrow" wx:if="{{ev._liveStatus === 1}}">›</text>
              </view>
            </view>

            <view class="event-media-list" wx:if="{{enableEventVideo && ev.mediaList && ev.mediaList.length > 0}}">
              <block wx:for="{{ev.mediaList}}" wx:for-item="media" wx:for-index="mIdx" wx:key="mIdx">
                <image wx:if="{{media.type === 'image'}}" class="event-media-image" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}" show-menu-by-longpress="{{true}}" catchtap="onEventImagePreview" data-urls="{{ev.imageUrls}}" data-current="{{media.url}}" />
                <view wx:if="{{media.type === 'video'}}" class="event-media-video-wrap" catchtap="onVideoThumbnailTap" catchlongpress="onVideoSaveOriginal" data-url="{{media.url}}" data-playurl="{{media.playUrl}}" data-original="{{media.originalUrl || media.url}}" data-sourceurl="{{media.sourceUrl}}" data-videourl="{{media.videoUrl}}" data-islong="{{media.isLongVideo}}" data-thumb="{{media.thumbnailUrl}}" data-eventid="{{ev._id}}" data-midx="{{mIdx}}">
                  <image wx:if="{{media.thumbnailUrl}}" class="event-media-video-thumb" src="{{media.thumbnailUrl}}" mode="aspectFill" lazy-load="{{true}}" />
                  <image wx:else class="event-media-video-thumb" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}" />
                  <view class="event-media-play-icon">▶</view>
                  <view wx:if="{{media.isLongVideo}}" class="event-media-link-badge">长视频 · 点击复制链接</view>
                  <view wx:elif="{{!media.isPlayable}}" class="event-media-link-badge">外部链接</view>
                </view>
              </block>
            </view>
          </view>
        </block>
        <view class="list-load-footer" wx:if="{{listAllMode && items.length > 0}}">
          <text class="list-load-footer-text" wx:if="{{listNoMore}}">- 没有更多了 -</text>
          <text class="list-load-footer-text" wx:elif="{{listLoadingMore}}">加载中...</text>
        </view>
      </block>

      <block wx:elif="{{item}}">
      <view class="detail-card glass-card">
        <view class="meta-top">
          <text class="date-text">{{item.publishedAtText}}</text>
          <view class="author-tag-wrap" wx:if="{{item.author}}">
            <image class="author-avatar" src="{{item.authorAvatar}}" wx:if="{{item.authorAvatar && !avatarError}}" mode="aspectFill" binderror="onAvatarError" />
            <text class="author-tag">{{item.author}}</text>
          </view>
        </view>

        <text class="detail-title" wx:if="{{item.title}}" user-select="{{true}}">{{item.title}}</text>
        <text class="detail-content" wx:if="{{item.content}}" user-select="{{true}}">{{item.content}}</text>

        <view class="event-live-card" wx:if="{{item.liveRoomId}}" bindtap="onLiveCardTap">
          <view class="event-live-cover-wrap">
            <image
              class="event-live-cover"
              src="{{item.liveCover || item._liveCover || ''}}"
              mode="aspectFill"
              wx:if="{{item.liveCover || item._liveCover}}"
            ></image>
            <view class="event-live-cover-placeholder" wx:else>
              <text class="event-live-cover-placeholder-text">直播</text>
            </view>
            <view class="event-live-badge {{item._liveStatus === 1 ? 'event-live-badge-on' : ''}}">
              <view class="event-live-dot" wx:if="{{item._liveStatus === 1}}"></view>
              <text>{{item._liveStatus === 1 ? '直播中' : '未开播'}}</text>
            </view>
            <view class="event-live-play-overlay" wx:if="{{item._liveStatus === 1}}">
              <view class="event-live-play-btn">▶</view>
            </view>
          </view>
          <view class="event-live-action">
            <text class="event-live-action-text">{{item._liveStatus === 1 ? '点击观看直播' : (item._liveTitle || '未开播')}}</text>
            <text class="event-live-action-arrow" wx:if="{{item._liveStatus === 1}}">›</text>
          </view>
        </view>

        <view class="event-media-list" wx:if="{{enableEventVideo && item.mediaList && item.mediaList.length > 0}}">
          <block wx:for="{{item.mediaList}}" wx:for-item="media" wx:for-index="mIdx" wx:key="mIdx">
            <image
              wx:if="{{media.type === 'image'}}"
              class="event-media-image"
              src="{{media.url}}"
              mode="aspectFill"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{true}}"
              bindtap="onEventImagePreview"
              data-urls="{{item.imageUrls}}"
              data-current="{{media.url}}"
            ></image>
            <view wx:if="{{media.type === 'video'}}" class="event-media-video-wrap" bindtap="onVideoThumbnailTap" bindlongpress="onVideoSaveOriginal" data-url="{{media.url}}" data-playurl="{{media.playUrl}}" data-original="{{media.originalUrl || media.url}}" data-sourceurl="{{media.sourceUrl}}" data-videourl="{{media.videoUrl}}" data-islong="{{media.isLongVideo}}" data-thumb="{{media.thumbnailUrl}}" data-eventid="{{item._id}}" data-midx="{{mIdx}}">
              <image wx:if="{{media.thumbnailUrl}}" class="event-media-video-thumb" src="{{media.thumbnailUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
              <image wx:else class="event-media-video-thumb" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}"></image>
              <view class="event-media-play-icon">▶</view>
              <view wx:if="{{media.isLongVideo}}" class="event-media-link-badge">长视频 · 点击复制链接</view>
              <view wx:elif="{{!media.isPlayable}}" class="event-media-link-badge">外部链接</view>
            </view>
          </block>
        </view>

      </view>

      <!-- 贴图讨论区：单条推文详情底部；topic 取自标题，组件内已截断至 20 字 -->
      <official-account-publish-panel topic="{{item.title || '星舰发射讨论'}}" />
      </block>

      <view style="height: {{tabBarReservedHeight}}px;"></view>
    </view>
  </scroll-view>

  <view class="event-share-sheet-mask" wx:if="{{showEventShareSheet}}" bindtap="closeListEventShareSheet">
    <view class="event-share-sheet" catchtap="stopPropagation">
      <text class="event-share-sheet-title">分享这条推文</text>
      <text class="event-share-sheet-desc">可将当前推文分享给朋友；进入单条详情后可分享到朋友圈或收藏。</text>
      <button
        class="event-share-sheet-btn event-share-sheet-btn--primary"
        open-type="share"
        data-share-type="eventUpdateItem"
        data-id="{{selectedEventShareId}}"
        bindtap="onListShareButtonTap"
      >分享给好友</button>
      <view class="event-share-sheet-btn" bindtap="openListSelectedDetailForShare">打开单条详情（朋友圈/收藏）</view>
      <view class="event-share-sheet-btn event-share-sheet-btn--cancel" bindtap="closeListEventShareSheet">取消</view>
    </view>
  </view>

  <share-guide />
  <share-gate-countdown expire-at="{{shareGateExpireAt}}" />
  <privacy-modal id="globalPrivacyModal"></privacy-modal>
</view>
