page {
  background: #000;
  overflow: hidden;
  height: 100vh;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
}

.main-map {
  width: 100%;
  height: 100vh;
}

.moments-map-fallback {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
  background: radial-gradient(ellipse at center, rgba(52, 199, 89, 0.12), #000 70%);
}

.moments-map-fallback-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  margin-bottom: 16rpx;
}

.moments-map-fallback-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
}

.glass-card {
  background: rgba(18, 18, 20, 0.78);
  backdrop-filter: blur(18rpx);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.state-card {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.state-title {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.state-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 22rpx;
  line-height: 1.5;
}

.panel-header {
  align-items: flex-start;
}

.panel-subtitle,
.panel-live {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.panel-live {
  color: #A7FFCA;
}

.panel-focus {
  color: #9FD0FF;
}

.panel-badge {
  flex-shrink: 0;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.panel-badge text {
  color: #fff;
  font-size: 20rpx;
}

.panel-badge--green {
  background: rgba(52, 199, 89, 0.16);
}

.panel-badge--green text {
  color: #A7FFCA;
}

.data-meta-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-meta-text {
  color: rgba(255, 255, 255, 0.54);
  font-size: 20rpx;
  line-height: 1.4;
}

.facility-list {
  margin-top: 22rpx;
  white-space: nowrap;
}

.facility-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 12rpx;
}

.facility-chip {
  min-width: 164rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

.facility-chip--key {
  border: 1px solid rgba(255, 159, 10, 0.55);
  background: rgba(255, 159, 10, 0.12);
}

.facility-chip-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.facility-chip-key {
  color: #FFB340;
  font-size: 18rpx;
}

.facility-chip--active {
  background: rgba(52, 199, 89, 0.16);
  border: 1px solid rgba(52, 199, 89, 0.55);
}

.facility-chip-name {
  display: block;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.facility-chip-type {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 20rpx;
}

.detail-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
}

.detail-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-name {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-category,
.detail-summary,
.detail-coord,
.detail-extra {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  line-height: 1.5;
}

.detail-pills {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-pill {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(52, 199, 89, 0.16);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.detail-pill--blue {
  background: rgba(10, 132, 255, 0.16);
}

.detail-pill text {
  color: #fff;
  font-size: 20rpx;
}

.detail-status {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(52, 199, 89, 0.16);
  color: #7DFFAE;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.detail-key-badge {
  margin-top: 10rpx;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 159, 10, 0.14);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.detail-key-badge text {
  color: #FFB340;
  font-size: 20rpx;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.85);
  border-color: var(--color-divider);
}

.theme-light .state-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .state-title {
  color: var(--color-text-primary);
}

.theme-light .state-desc {
  color: var(--color-text-secondary);
}

.theme-light .panel-subtitle {
  color: var(--color-text-secondary);
}

.theme-light .panel-live {
  color: #248A3D;
}

.theme-light .panel-focus {
  color: #0A84FF;
}

.theme-light .panel-badge {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .panel-badge text {
  color: var(--color-text-primary);
}

.theme-light .panel-badge--green {
  background: rgba(52, 199, 89, 0.12);
}

.theme-light .panel-badge--green text {
  color: #248A3D;
}

.theme-light .data-meta-text {
  color: var(--color-text-tertiary);
}

.theme-light .facility-chip {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .facility-chip--key {
  background: rgba(255, 159, 10, 0.12);
}

.theme-light .facility-chip-key {
  color: #C93400;
}

.theme-light .facility-chip--active {
  background: rgba(52, 199, 89, 0.12);
}

.theme-light .facility-chip-name {
  color: var(--color-text-primary);
}

.theme-light .facility-chip-type {
  color: var(--color-text-tertiary);
}

.theme-light .detail-card {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .detail-name {
  color: var(--color-text-primary);
}

.theme-light .detail-category,
.theme-light .detail-summary,
.theme-light .detail-coord,
.theme-light .detail-extra {
  color: var(--color-text-secondary);
}

.theme-light .detail-pill {
  background: rgba(52, 199, 89, 0.12);
}

.theme-light .detail-pill--blue {
  background: rgba(10, 132, 255, 0.12);
}

.theme-light .detail-pill text {
  color: var(--color-text-primary);
}

.theme-light .detail-status {
  background: rgba(52, 199, 89, 0.12);
  color: #248A3D;
}

.theme-light .detail-key-badge {
  background: rgba(255, 159, 10, 0.12);
}

.theme-light .detail-key-badge text {
  color: #C93400;
}
