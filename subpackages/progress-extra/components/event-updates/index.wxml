<!-- 事件更新区（从 pages/progress/progress.wxml 拆出，wxml/wxss 不占主包）
     纯展示组件：状态经 properties 下发；交互经单一 sectionevent 通道回传 -->
<!-- 事件更新（爱好者追踪） -->
<view class="event-updates-section {{themeClass}}">
  <view class="section-title event-updates-title-row">
    <text>事件更新</text>
    <view class="section-badge" wx:if="{{tweetEventTotal}}">{{tweetEventTotal}}</view>
    <view class="section-title-right">
      <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
            bindtap="emitOpenEventUpdatesList" wx:if="{{eventUpdates.length > 0}}">
        <text>查看更多</text>
        <text class="booster-view-all-arrow">›</text>
      </view>
    </view>
  </view>
  <!-- 今日各账号更新统计（标题下方横向滑动，复用首页发射商胶囊交互） -->
  <view class="tweet-stats-scroll-wrap" wx:if="{{tweetAccountStats.length > 0}}">
    <scroll-view class="tweet-stats-scroll" scroll-x="true" enhanced="true" show-scrollbar="false" bindscroll="emitOnTweetStatsChipsScroll">
      <view class="tweet-stats-bar tweet-stats-chips-row">
        <view class="tweet-stat-item tweet-stat-chip {{isProUser ? 'pro-gold-frame-flat' : ''}}" wx:for="{{tweetAccountStats}}" wx:key="screenName" bindtap="emitOnTweetAccountTap" data-index="{{index}}" data-source="{{item.screenName}}" data-label="{{item.label}}">
          <image class="tweet-stat-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text class="tweet-stat-name">{{item.label}}</text>
          <text class="tweet-stat-count">{{item.todayCount}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="tweet-stats-scroll-fade" wx:if="{{tweetStatsChipsHasOverflow}}"></view>
  </view>

  <view class="event-updates-card glass-card" wx:if="{{eventUpdates.length > 0}}">
    <!-- 折叠状态：只显示最新1条（含媒体） -->
    <view wx:if="{{!eventUpdatesExpanded}}">
      <view class="event-updates-collapsed">
        <view
          class="event-update-item {{pressedEventId === item._id ? 'event-update-item--pressed' : ''}}"
          wx:for="{{eventUpdates}}"
          wx:if="{{index < 1}}"
          wx:key="_id"
          bindtap="emitOpenEventDetail"
          bindtouchstart="emitOnEventItemTouchStart"
          bindtouchend="emitOnEventItemTouchEnd"
          bindtouchcancel="emitOnEventItemTouchEnd"
          bindlongpress="emitOpenEventShareSheet"
          data-id="{{item._id}}"
          data-idx="{{index}}"
        >
          <view class="event-update-link">
            <view class="event-update-header">
              <text class="event-update-time">{{item.publishedAtText}}</text>
              <view class="event-update-author-wrap" wx:if="{{item.author}}">
                <image class="event-author-avatar" src="{{item.authorAvatar}}" wx:if="{{item.authorAvatar && !item._avatarError}}" mode="aspectFill" binderror="emitOnAvatarError" data-id="{{item._id}}" />
                <text class="event-update-author">{{item.author}}</text>
              </view>
            </view>
            <text class="event-update-title" wx:if="{{item.title}}">{{item.title}}</text>
            <text class="event-update-content" wx:if="{{item.content}}">{{item.content}}</text>
          </view>

          <!-- 折叠状态也显示媒体 -->
          <view class="event-media-list event-media-list--n{{item.imageGridCols || 1}}" wx:if="{{enableEventVideo && item.mediaList && item.mediaList.length > 0}}">
            <block wx:for="{{item.mediaList}}" wx:for-item="media" wx:for-index="mIdx" wx:key="mIdx">
              <view wx:if="{{media.type === 'image'}}" class="event-media-image-wrap">
                <image
                  class="event-media-image"
                  src="{{media.url}}"
                  mode="aspectFill"
                  lazy-load="{{true}}"
                  show-menu-by-longpress="{{false}}"
                  catchtap="emitOnEventImagePreview"
                  catchlongpress="emitOnEventImageLongPress"
                  data-urls="{{item.imageUrls}}"
                  data-thumbs="{{item.imageUrls}}"
                  data-originals="{{item.imageOriginalUrls}}"
                  data-current="{{media.url}}"
                  data-original="{{media.remoteUrl || media.url}}"
                ></image>
              </view>
              <view wx:if="{{media.type === 'video'}}" class="event-media-video-wrap" catchtap="emitOnVideoThumbnailTap" catchlongpress="emitOnVideoSaveOriginal" data-url="{{media.url}}" data-playurl="{{media.playUrl}}" data-original="{{media.originalUrl || media.url}}" data-sourceurl="{{media.sourceUrl}}" data-videourl="{{media.videoUrl}}" data-islong="{{media.isLongVideo}}" data-thumb="{{media.thumbnailUrl}}" data-eventid="{{item._id}}" data-midx="{{mIdx}}">
                <image wx:if="{{media.thumbnailUrl}}" class="event-media-video-thumb" src="{{media.thumbnailUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
                <image wx:else class="event-media-video-thumb" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}"></image>
                <view class="event-media-play-icon">▶</view>
                <view wx:if="{{media.isLongVideo}}" class="event-media-link-badge">长视频 · 点击复制链接</view>
                <view wx:elif="{{!media.isPlayable}}" class="event-media-link-badge">外部链接</view>
              </view>
            </block>
          </view>
        </view>
      </view>
    </view>

    <!-- 展开状态 -->
    <view wx:else>
      <scroll-view
        class="event-updates-scroll"
        scroll-y="{{true}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        bounces="{{true}}"
        refresher-enabled="{{true}}"
        refresher-triggered="{{eventScrollRefreshing}}"
        refresher-default-style="none"
        refresher-background="transparent"
        bindrefresherrefresh="emitOnEventScrollRefresh"
        bindscrolltolower="emitOnEventScrollToLower"
      >
      <view
        class="event-update-item {{pressedEventId === item._id ? 'event-update-item--pressed' : ''}}"
        wx:for="{{eventUpdates}}"
        wx:key="_id"
        bindtap="emitOpenEventDetail"
        bindtouchstart="emitOnEventItemTouchStart"
        bindtouchend="emitOnEventItemTouchEnd"
        bindtouchcancel="emitOnEventItemTouchEnd"
        bindlongpress="emitOpenEventShareSheet"
        data-id="{{item._id}}"
        data-idx="{{index}}"
      >
        <view class="event-update-link">
          <view class="event-update-header">
            <text class="event-update-time">{{item.publishedAtText}}</text>
            <view class="event-update-author-wrap" wx:if="{{item.author}}">
              <image class="event-author-avatar" src="{{item.authorAvatar}}" wx:if="{{item.authorAvatar && !item._avatarError}}" mode="aspectFill" binderror="emitOnAvatarError" data-id="{{item._id}}" />
              <text class="event-update-author">{{item.author}}</text>
            </view>
          </view>

          <text class="event-update-title" wx:if="{{item.title}}">{{item.title}}</text>
          <text class="event-update-content" wx:if="{{item.content}}">{{item.content}}</text>
        </view>

        <!-- 直播卡片（enableLiveEntry：过审关闭直播入口时整卡隐藏） -->
        <view class="event-live-card" wx:if="{{enableLiveEntry && item.liveRoomId}}" bindtap="emitOnLiveCardTap" data-idx="{{index}}">
          <view class="event-live-cover-wrap">
            <image
              class="event-live-cover"
              src="{{item.liveCover || item._liveCover || ''}}"
              mode="aspectFill"
              wx:if="{{item.liveCover || item._liveCover}}"
            ></image>
            <view class="event-live-cover-placeholder" wx:else>
              <text class="event-live-cover-placeholder-text">直播</text>
            </view>
            <view class="event-live-badge {{item._liveStatus === 1 ? 'event-live-badge-on' : ''}}">
              <view class="event-live-dot" wx:if="{{item._liveStatus === 1}}"></view>
              <text>{{item._liveStatus === 1 ? '直播中' : '未开播'}}</text>
            </view>
            <view class="event-live-play-overlay" wx:if="{{item._liveStatus === 1}}">
              <view class="event-live-play-btn">▶</view>
            </view>
          </view>
          <view class="event-live-action">
            <text class="event-live-action-text">{{item._liveStatus === 1 ? '点击观看直播' : (item._liveTitle || '未开播')}}</text>
            <text class="event-live-action-arrow" wx:if="{{item._liveStatus === 1}}">›</text>
          </view>
        </view>

        <view class="event-media-list event-media-list--n{{item.imageGridCols || 1}}" wx:if="{{enableEventVideo && item.mediaList && item.mediaList.length > 0}}">
          <block wx:for="{{item.mediaList}}" wx:for-item="media" wx:for-index="mIdx" wx:key="mIdx">
            <view wx:if="{{media.type === 'image'}}" class="event-media-image-wrap">
              <image
                class="event-media-image"
                src="{{media.url}}"
                mode="aspectFill"
                lazy-load="{{true}}"
                show-menu-by-longpress="{{false}}"
                catchtap="emitOnEventImagePreview"
                catchlongpress="emitOnEventImageLongPress"
                data-urls="{{item.imageUrls}}"
                data-thumbs="{{item.imageUrls}}"
                data-originals="{{item.imageOriginalUrls}}"
                data-current="{{media.url}}"
                data-original="{{media.remoteUrl || media.url}}"
              ></image>
            </view>
            <view wx:if="{{media.type === 'video'}}" class="event-media-video-wrap" catchtap="emitOnVideoThumbnailTap" catchlongpress="emitOnVideoSaveOriginal" data-url="{{media.url}}" data-playurl="{{media.playUrl}}" data-original="{{media.originalUrl || media.url}}" data-sourceurl="{{media.sourceUrl}}" data-videourl="{{media.videoUrl}}" data-islong="{{media.isLongVideo}}" data-thumb="{{media.thumbnailUrl}}" data-eventid="{{item._id}}" data-midx="{{mIdx}}">
              <image wx:if="{{media.thumbnailUrl}}" class="event-media-video-thumb" src="{{media.thumbnailUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
              <image wx:else class="event-media-video-thumb" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}"></image>
              <view class="event-media-play-icon">▶</view>
              <view wx:if="{{media.isLongVideo}}" class="event-media-link-badge">长视频 · 点击复制链接</view>
              <view wx:elif="{{!media.isPlayable}}" class="event-media-link-badge">外部链接</view>
            </view>
          </block>
        </view>

        <view class="event-update-actions">
          <view class="event-update-share-wrap" catchtap="stopPropagation">
            <image class="icon-share icon-share--event-update" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button
              class="event-update-share-btn"
              open-type="share"
              hover-class="none"
              plain="true"
              data-share-type="eventUpdateItem"
              data-id="{{item._id}}"
              catchtap="emitOnEventShareButtonTap"
              style="border: none; border-width: 0;"
            ></button>
          </view>
        </view>

        <view class="event-update-divider" wx:if="{{index < eventUpdates.length - 1}}"></view>
      </view>

      <view class="event-updates-footer">
        <text class="event-updates-footer-text" wx:if="{{eventUpdatesNoMore}}">- 没有更多了 -</text>
        <view class="wx-native-dots" wx:elif="{{eventUpdatesLoading}}">
          <view class="wx-native-dots__dot"></view>
          <view class="wx-native-dots__dot"></view>
          <view class="wx-native-dots__dot"></view>
        </view>
      </view>
    </scroll-view>
      <view class="event-updates-collapse-btn" bindtap="emitToggleEventUpdatesExpanded">
        <text>收起事件更新</text>
        <text class="expand-arrow expand-arrow--up">‹</text>
      </view>
    </view>
  </view>

  <view class="event-updates-card glass-card event-updates-empty" wx:else>
    <text class="event-updates-empty-text">{{eventUpdatesLoading ? '加载中...' : (eventUpdatesError || '暂无事件更新')}}</text>
  </view>
</view>

