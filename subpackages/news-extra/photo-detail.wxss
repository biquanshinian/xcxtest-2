@import "./detail.wxss";

/* 小红书式横向看图：贴卡片顶边全宽，固定框内 aspectFit */
.photo-gallery {
  position: relative;
  margin: -28rpx -28rpx 28rpx;
  background: #0a0a0a;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
}

.photo-swiper {
  width: 100%;
  height: 100%;
}

.photo-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #0a0a0a;
}

.photo-slide__img {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-index {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  z-index: 2;
  min-width: 64rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  text-align: center;
  pointer-events: none;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #f2f2f7;
  line-height: 1.35;
  margin-bottom: 20rpx;
}

/* 本页覆盖：明亮主题反色（需写在本文件，避免本地 .detail-title 压过导入规则的观感） */
.detail-page.theme-light {
  background: var(--color-bg-page, linear-gradient(180deg, #F2F2F7 0%, #ECECF1 100%));
}

.theme-light .detail-title {
  color: var(--color-text-primary, #111);
}

.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider, rgba(0, 0, 0, 0.08));
  box-shadow: var(--shadow-card, 0 8rpx 24rpx rgba(0, 0, 0, 0.06)), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.theme-light .type-badge {
  background: rgba(0, 122, 255, 0.12);
  border: 1px solid rgba(0, 122, 255, 0.25);
  color: var(--color-brand, #007AFF);
}

.theme-light .date-text,
.theme-light .info-label {
  color: var(--color-text-secondary, #8e8e93);
}

.theme-light .info-value,
.theme-light .section-title,
.theme-light .section-text {
  color: var(--color-text-primary, #111);
}

.theme-light .info-row {
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.theme-light .error-title {
  color: var(--color-text-primary, #111);
}

.theme-light .error-text {
  color: var(--color-text-secondary, #8e8e93);
}

.theme-light .photo-gallery,
.theme-light .photo-slide {
  background: #E5E5EA;
}

.owner-edit-btn,
.owner-delete-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 80rpx;
  padding: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}

.owner-edit-btn {
  margin-top: 28rpx;
  background: rgba(7, 193, 96, 0.16);
  border: 1px solid rgba(7, 193, 96, 0.4);
  color: #07C160;
}

.owner-delete-btn {
  background: rgba(255, 59, 48, 0.14);
  border: 1px solid rgba(255, 59, 48, 0.35);
  color: #FF453A;
}

.owner-edit-btn::after,
.owner-delete-btn::after {
  border: none;
}

.owner-delete-btn[disabled] {
  opacity: 0.6;
}

.theme-light .owner-edit-btn {
  background: rgba(7, 193, 96, 0.1);
  border-color: rgba(7, 193, 96, 0.35);
  color: #07C160;
}

.theme-light .owner-delete-btn {
  background: rgba(255, 59, 48, 0.08);
  border-color: rgba(255, 59, 48, 0.28);
  color: #FF3B30;
}
