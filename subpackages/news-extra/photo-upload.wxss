@import "./detail.wxss";

.detail-card {
  padding: 28rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f2f2f7;
  margin-bottom: 8rpx;
}

.hint-text {
  display: block;
  font-size: 22rpx;
  color: #8e8e93;
  margin-bottom: 20rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.photo-grid-item,
.photo-grid-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: rgba(255, 255, 255, 0.06);
}

.photo-grid-item--dragging {
  opacity: 0.72;
  transform: scale(1.04);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.35);
  z-index: 2;
}

.photo-grid-thumb {
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.photo-grid-order {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 10rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
  box-sizing: border-box;
}

.photo-grid-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.photo-grid-add {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px dashed rgba(255, 255, 255, 0.2);
}

.photo-grid-add-text {
  font-size: 64rpx;
  color: #8e8e93;
  line-height: 1;
}

.form-row {
  margin-bottom: 22rpx;
}

.form-row--col {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  margin-bottom: 10rpx;
}

.form-input {
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #f2f2f7;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #f2f2f7;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 12rpx;
  width: 100%;
  height: 84rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 明亮主题反色 */
.detail-page.theme-light {
  background: var(--color-bg-page, linear-gradient(180deg, #F2F2F7 0%, #ECECF1 100%));
}

.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider, rgba(0, 0, 0, 0.08));
  box-shadow: var(--shadow-card, 0 8rpx 24rpx rgba(0, 0, 0, 0.06)), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.theme-light .section-title,
.theme-light .form-input,
.theme-light .form-textarea,
.theme-light .form-picker {
  color: var(--color-text-primary, #111);
}

.theme-light .hint-text,
.theme-light .form-label {
  color: var(--color-text-tertiary, #8e8e93);
}

.theme-light .form-input,
.theme-light .form-textarea {
  background: rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.theme-light .photo-grid-item,
.theme-light .photo-grid-add {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .photo-grid-add {
  border-color: rgba(0, 0, 0, 0.15);
}

.theme-light .photo-grid-add-text {
  color: var(--color-text-tertiary, #8e8e93);
}
