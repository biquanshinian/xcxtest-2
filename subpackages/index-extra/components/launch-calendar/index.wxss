/* 首页发射日历组件样式（自 pages/index/index.wxss 拆出）
 * 浅色覆盖：宿主传入 themeClass，挂在组件各顶层节点上 */

/* 组件宿主节点默认无样式，显式设为块级，保证与原先直接内联在页面时的文档流一致 */
:host {
  display: block;
}

.calendar-query-panel-header {
  display: flex;
  align-items: center;
}

.calendar-query-panel-main {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calendar-query-panel-title-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.calendar-query-panel-title {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.calendar-query-panel-divider {
  flex-shrink: 0;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.22);
}

.calendar-query-panel-subtitle {
  min-width: 0;
  flex: 1;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.48);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.calendar-query-panel-meta {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.calendar-query-panel-count {
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  color: #7ec3ff;
  background: rgba(0, 122, 255, 0.12);
  border: 1px solid rgba(0, 122, 255, 0.2);
}

.calendar-query-panel-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.06);
  font-size: 20rpx;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.calendar-query-panel-arrow--collapsed {
  transform: rotate(180deg);
}

.calendar-filter-group {
  margin-bottom: 20rpx;
}

.calendar-filter-group:first-child {
  margin-top: 20rpx;
}

.calendar-filter-group--compact {
  margin-bottom: 12rpx;
}

.calendar-filter-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.calendar-filter-scroll {
  width: 100%;
}

.calendar-filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: max-content;
}

.calendar-filter-row--wrap {
  width: auto;
  flex-wrap: wrap;
}

.calendar-filter-chip {
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  white-space: nowrap;
}

.calendar-filter-chip--active {
  background: rgba(0, 122, 255, 0.18);
  border-color: rgba(0, 122, 255, 0.32);
  color: #7ec3ff;
}

.calendar-query-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 8rpx;
}

.calendar-query-result,
.calendar-query-reset {
  font-size: 22rpx;
}

.calendar-query-result {
  color: rgba(255, 255, 255, 0.45);
}

.calendar-query-reset {
  color: #64a8ff;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  position: relative;
}

.calendar-nav {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.calendar-nav:active {
  background: rgba(255, 255, 255, 0.16);
}

.calendar-arrow {
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid #fff;
  border-right: 4rpx solid #fff;
}

.calendar-arrow--left {
  transform: rotate(-135deg);
  margin-left: 4rpx;
}

.calendar-arrow--right {
  transform: rotate(45deg);
  margin-right: 4rpx;
}

.calendar-month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.calendar-today-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  margin-right: 80rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #007AFF;
  background: rgba(0, 122, 255, 0.12);
  border-radius: 20rpx;
  border: 1px solid rgba(0, 122, 255, 0.3);
}

.calendar-today-btn:active {
  background: rgba(0, 122, 255, 0.25);
}

.calendar-page-stage {
  transform: translateX(0);
  opacity: 1;
  margin-bottom: 20rpx;
}

.calendar-table {
  padding: 20rpx 16rpx 16rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.calendar-table-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.calendar-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.calendar-legend-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.calendar-legend-dot--upcoming {
  background: #007AFF;
  box-shadow: 0 0 8rpx rgba(0, 122, 255, 0.55);
}

.calendar-legend-dot--completed {
  background: #FF9500;
  box-shadow: 0 0 8rpx rgba(255, 149, 0, 0.45);
}

.calendar-legend-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.52);
}

.calendar-page-anim--leave-prev {
  transform: translateX(-42rpx);
  opacity: 0.16;
  transition: transform 0.11s ease-out, opacity 0.11s ease-out;
}

.calendar-page-anim--enter-next {
  transform: translateX(42rpx);
  opacity: 0.18;
  animation: calendar-page-enter-next 0.22s ease-out forwards;
}

.calendar-page-anim--leave-next {
  transform: translateX(42rpx);
  opacity: 0.16;
  transition: transform 0.11s ease-out, opacity 0.11s ease-out;
}

.calendar-page-anim--enter-prev {
  transform: translateX(-42rpx);
  opacity: 0.18;
  animation: calendar-page-enter-prev 0.22s ease-out forwards;
}

@keyframes calendar-page-enter-next {
  from {
    transform: translateX(42rpx);
    opacity: 0.18;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes calendar-page-enter-prev {
  from {
    transform: translateX(-42rpx);
    opacity: 0.18;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 10rpx;
  padding: 10rpx 4rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.03);
}

.calendar-weekday {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.38);
  text-align: center;
  letter-spacing: 1rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  padding: 4rpx;
}

.calendar-cell {
  aspect-ratio: 1;
  min-height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  position: relative;
  box-sizing: border-box;
  border: 1px solid transparent;
  background: rgba(255, 255, 255, 0.02);
  transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
}

.calendar-cell--empty {
  visibility: hidden;
  pointer-events: none;
}

.calendar-cell--has {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.06);
}

.calendar-cell--today {
  border-color: rgba(0, 122, 255, 0.45);
  background: rgba(0, 122, 255, 0.08);
}

.calendar-cell--selected {
  background: rgba(0, 122, 255, 0.22);
  border-color: rgba(0, 122, 255, 0.55);
  box-shadow: inset 0 0 0 1px rgba(0, 122, 255, 0.18);
}

.calendar-cell--heat1 {
  background: rgba(255, 255, 255, 0.04);
}

.calendar-cell--heat2 {
  background: rgba(255, 255, 255, 0.07);
  border-color: rgba(255, 255, 255, 0.08);
}

.calendar-cell--heat3 {
  background: linear-gradient(145deg, rgba(255, 149, 0, 0.16), rgba(255, 149, 0, 0.06));
  border-color: rgba(255, 149, 0, 0.22);
}

.calendar-cell--selected.calendar-cell--heat1,
.calendar-cell--selected.calendar-cell--heat2,
.calendar-cell--selected.calendar-cell--heat3 {
  background: rgba(0, 122, 255, 0.22);
  border-color: rgba(0, 122, 255, 0.55);
}

.calendar-cell-count {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  background: rgba(255, 149, 0, 0.85);
  box-shadow: 0 2rpx 8rpx rgba(255, 149, 0, 0.35);
  z-index: 3;
}

.calendar-cell-day-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
}

.calendar-cell-day-wrap--today {
  background: rgba(0, 122, 255, 0.18);
  box-shadow: 0 0 0 2rpx rgba(0, 122, 255, 0.35);
}

.calendar-cell-day {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1;
}

.calendar-cell-day--today {
  color: #4da3ff;
  font-weight: 700;
}

.calendar-cell-dots {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 5rpx;
  align-items: center;
  justify-content: center;
}

.calendar-cell-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.calendar-cell-dot--upcoming {
  background: #007AFF;
  box-shadow: 0 0 6rpx rgba(0, 122, 255, 0.6);
}

.calendar-cell-dot--completed {
  background: #FF9500;
  box-shadow: 0 0 6rpx rgba(255, 149, 0, 0.5);
}


/* 星舰任务浮窗标签 */
.calendar-starship-tag {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  overflow: hidden;
}


.calendar-starship-tag text {
  font-size: 22rpx;
  color: #ff9500;
  font-weight: 700;
  z-index: 2;
  background: rgba(0, 0, 0, 0.75);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  animation: starshipTextBlink 2s ease-in-out infinite;
}

@keyframes starshipTextBlink {
  0%, 49% { opacity: 1; }
  50%, 99% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes starshipRipple {
  0% {
    transform: translate(-50%, -50%) scale(0);
    opacity: 0.8;
  }
  100% {
    transform: translate(-50%, -50%) scale(6);
    opacity: 0;
  }
}


/* 涟漪圆圈 */
.calendar-starship-tag::before,
.calendar-starship-tag::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 149, 0, 0.7);
  transform: translate(-50%, -50%) scale(0);
  animation: starshipRipple 2.4s ease-out infinite;
}


.calendar-starship-tag::after {
  animation-delay: 1.2s;
}

/* --- 发射日历 --- */
.theme-light .calendar-query-panel-title {
  color: var(--color-text-primary);
}

.theme-light .calendar-query-panel-divider {
  color: rgba(0, 0, 0, 0.15);
}

.theme-light .calendar-query-panel-subtitle {
  color: var(--color-text-tertiary);
}

.theme-light .calendar-query-panel-count {
  color: #007AFF;
}

.theme-light .calendar-query-panel-arrow {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .calendar-filter-title {
  color: var(--color-text-secondary);
}

.theme-light .calendar-filter-chip {
  background: rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(0, 0, 0, 0.06);
  color: var(--color-text-secondary);
}

.theme-light .calendar-filter-chip--active {
  background: rgba(0, 122, 255, 0.12);
  border-color: rgba(0, 122, 255, 0.32);
  color: #007AFF;
}

.theme-light .calendar-query-result {
  color: var(--color-text-tertiary);
}

.theme-light .calendar-query-reset {
  color: #007AFF;
}

.theme-light .calendar-nav {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .calendar-nav:active {
  background: rgba(0, 0, 0, 0.1);
}

.theme-light .calendar-arrow {
  border-top: 4rpx solid var(--color-text-primary);
  border-right: 4rpx solid var(--color-text-primary);
}

.theme-light .calendar-month-title {
  color: var(--color-text-primary);
}

.theme-light .calendar-table-legend {
  border-bottom: 1px solid var(--color-divider);
}

.theme-light .calendar-legend-text {
  color: var(--color-text-tertiary);
}

.theme-light .calendar-weekdays {
  background: rgba(0, 0, 0, 0.03);
}

.theme-light .calendar-weekday {
  color: var(--color-text-tertiary);
}

.theme-light .calendar-cell {
  background: rgba(0, 0, 0, 0.02);
}

.theme-light .calendar-cell--has {
  background: rgba(0, 0, 0, 0.04);
  border-color: rgba(0, 0, 0, 0.06);
}

.theme-light .calendar-cell--heat1 {
  background: rgba(0, 0, 0, 0.03);
}

.theme-light .calendar-cell--heat2 {
  background: rgba(0, 0, 0, 0.06);
  border-color: rgba(0, 0, 0, 0.08);
}

.theme-light .calendar-cell--heat3 {
  background: linear-gradient(145deg, rgba(255, 149, 0, 0.14), rgba(255, 149, 0, 0.05));
  border-color: rgba(255, 149, 0, 0.28);
}

.theme-light .calendar-cell--today {
  background: rgba(0, 122, 255, 0.08);
}

.theme-light .calendar-cell--selected,
.theme-light .calendar-cell--selected.calendar-cell--heat1,
.theme-light .calendar-cell--selected.calendar-cell--heat2,
.theme-light .calendar-cell--selected.calendar-cell--heat3 {
  background: rgba(0, 122, 255, 0.15);
}

.theme-light .calendar-cell-day {
  color: var(--color-text-primary);
}

.theme-light .calendar-cell-day--today {
  color: #007AFF;
}

.theme-light .calendar-starship-tag text {
  color: #E8590C;
  background: rgba(255, 149, 0, 0.14);
}
