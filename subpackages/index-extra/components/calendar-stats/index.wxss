/* 日历统计 / SpaceX 统计（自 pages/index/index.wxss 拆出） */
:host { display: block; }

.calendar-empty {
  padding: 60rpx 0;
  text-align: center;
}

/* ========== 日历内全球发射数据 ========== */
.calendar-stats-section {
  margin-top: 32rpx;
}
.calendar-stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}
.calendar-stats-section .stats-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
}
.calendar-stats-section .stats-highlight-card {
  padding: 28rpx 30rpx 22rpx;
  display: flex;
  flex-direction: column;
}
.calendar-stats-section .stats-highlight-glow {
  position: absolute;
  top: -140rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(0, 122, 255, 0.22) 0%, rgba(0, 122, 255, 0) 68%);
  pointer-events: none;
}
.calendar-stats-section .stats-highlight-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}
.calendar-stats-section .stats-highlight-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}
.calendar-stats-section .stats-highlight-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #7ec3ff;
  box-shadow: 0 0 14rpx rgba(126, 195, 255, 0.85);
  flex-shrink: 0;
}
.calendar-stats-section .stats-highlight-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}
.calendar-stats-section .stats-highlight-tag {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}
.calendar-stats-section .stats-highlight-main {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 22rpx;
  position: relative;
  z-index: 2;
}
.calendar-stats-section .stats-highlight-value {
  font-size: 84rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: linear-gradient(180deg, #ffffff 35%, #9ec9ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.calendar-stats-section .stats-highlight-unit {
  font-size: 26rpx;
  color: #8E8E93;
}
.calendar-stats-section .stats-highlight-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 2;
}
.calendar-stats-section .stats-highlight-sub {
  font-size: 22rpx;
  color: #8E8E93;
}
.calendar-stats-section .stats-highlight-card--active {
  opacity: 0.88;
}
.calendar-stats-section .stats-detail-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-left: auto;
  font-size: 24rpx;
  color: #7ec3ff;
}
.calendar-stats-section .stats-detail-arrow {
  font-size: 28rpx;
  line-height: 1;
}
.calendar-stats-section .stats-loading {
  padding: 30rpx;
}
.calendar-stats-section .stats-loading-text {
  font-size: 26rpx;
  color: #8E8E93;
}
.calendar-stats-section .stats-error {
  padding: 30rpx;
}
.calendar-stats-section .stats-error-text {
  font-size: 26rpx;
  color: #ff6b6b;
}

/* ========== SpaceX 官网发射统计 ========== */
.spacex-stats-section {
  margin-top: 28rpx;
}
.spacex-source-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  margin-left: 12rpx;
  font-weight: 400;
}
.spacex-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.spacex-year-stat {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 16rpx;
}

.spacex-year-stat-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.spacex-year-stat-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.spacex-year-stat-hint {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.42);
}

.spacex-year-stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.spacex-stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
}
.spacex-stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}
.spacex-stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 8rpx;
}
.spacex-upcoming-list {
  margin-top: 20rpx;
}
.spacex-upcoming-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  margin-bottom: 12rpx;
  display: block;
  font-weight: 600;
}
.spacex-upcoming-item {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}
.spacex-upcoming-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}
.spacex-upcoming-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.spacex-upcoming-vehicle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-left: 12rpx;
  flex-shrink: 0;
}
.spacex-upcoming-site {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}
.spacex-upcoming-date {
  font-size: 22rpx;
  color: #4ecdc4;
  flex-shrink: 0;
}

/* ── 统计区样式（自 pages/index/index.wxss 迁入） ── */
/* --- 全球发射数据 / SpaceX 统计 --- */
.theme-light .calendar-stats-title {
  color: var(--color-text-primary);
}

.theme-light .calendar-empty .empty-text,
.theme-light .empty-text {
  color: var(--color-text-tertiary);
}

.theme-light .spacex-upcoming-date {
  color: #0d9488;
}

.calendar-stats-section.theme-light .stats-highlight-label {
  color: var(--color-text-primary);
}

.calendar-stats-section.theme-light .stats-highlight-tag {
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid var(--color-divider);
}

.calendar-stats-section.theme-light .stats-highlight-value {
  background: linear-gradient(180deg, #1C1C1E 35%, #2E6BD6 100%);
  -webkit-background-clip: text;
  background-clip: text;
}

.calendar-stats-section.theme-light .stats-highlight-unit {
  color: var(--color-text-secondary);
}

.calendar-stats-section.theme-light .stats-highlight-footer {
  border-top: 1rpx solid var(--color-divider);
}

.calendar-stats-section.theme-light .stats-highlight-sub {
  color: var(--color-text-secondary);
}

.calendar-stats-section.theme-light .stats-detail-link {
  color: #007AFF;
}

.calendar-stats-section.theme-light .stats-highlight-dot {
  background: #007AFF;
  box-shadow: 0 0 14rpx rgba(0, 122, 255, 0.4);
}

.calendar-stats-section.theme-light .stats-highlight-glow {
  background: radial-gradient(circle, rgba(0, 122, 255, 0.12) 0%, rgba(0, 122, 255, 0) 68%);
}

.calendar-stats-section.theme-light .stats-loading-text {
  color: var(--color-text-secondary);
}

.theme-light .spacex-source-tag {
  color: var(--color-text-tertiary);
}

.theme-light .spacex-year-stat-label {
  color: var(--color-text-primary);
}

.theme-light .spacex-year-stat-hint {
  color: var(--color-text-tertiary);
}

.theme-light .spacex-year-stat-value {
  color: var(--color-text-primary);
}

.theme-light .spacex-stat-value {
  color: var(--color-text-primary);
}

.theme-light .spacex-stat-label {
  color: var(--color-text-secondary);
}

.theme-light .spacex-upcoming-title {
  color: var(--color-text-secondary);
}

.theme-light .spacex-upcoming-name {
  color: var(--color-text-primary);
}

.theme-light .spacex-upcoming-vehicle,
.theme-light .spacex-upcoming-site {
  color: var(--color-text-tertiary);
}
