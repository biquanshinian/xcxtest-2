page {
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  height: 100vh;
}

.detail-page {
  height: 100vh;
  overflow: hidden;
}

.nav-title {
  text-align: center;
  justify-self: center;
}

.detail-scroll {
  height: 100vh;
}

.detail-container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* Hero */
.wc-hero {
  padding: 48rpx 32rpx 44rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.wc-hero-logos {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.wc-hero-logo {
  width: 88rpx;
  height: 88rpx;
}

.wc-hero-x {
  font-size: 36rpx;
  color: #636366;
}

.wc-hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.wc-hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.wc-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.wc-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.wc-status--live {
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
}

.wc-status--live .wc-status-dot {
  background: #34c759;
  animation: wcPulse 1.6s ease-in-out infinite;
}

.wc-status--upcoming {
  background: rgba(0, 122, 255, 0.12);
  color: #7ec3ff;
}

.wc-status--upcoming .wc-status-dot {
  background: #7ec3ff;
}

.wc-status--ended {
  background: rgba(142, 142, 147, 0.12);
  color: #8e8e93;
}

.wc-status--ended .wc-status-dot {
  background: #8e8e93;
}

@keyframes wcPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.45; transform: scale(0.8); }
}

.wc-countdown {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.wc-countdown-label {
  font-size: 24rpx;
  color: #8e8e93;
}

.wc-countdown-main {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.wc-countdown-num {
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1.05;
  color: #ffffff;
  font-variant-numeric: tabular-nums;
}

.wc-countdown-unit {
  font-size: 28rpx;
  color: #8e8e93;
}

.wc-ended-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #8e8e93;
}

/* 运营上传的活动图片/视频 */
.wc-media-list {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.wc-media {
  width: 100%;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  overflow: hidden;
}

.wc-media--video {
  height: 380rpx;
}

/* 信息 / 看点卡 */
.wc-card {
  padding: 28rpx 28rpx 12rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
}

.wc-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.wc-info-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.wc-info-row:last-child {
  border-bottom: none;
}

.wc-info-label {
  flex-shrink: 0;
  width: 88rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.wc-info-value {
  flex: 1;
  font-size: 26rpx;
  color: #e5e5ea;
}

.wc-highlight {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.wc-highlight:last-child {
  border-bottom: none;
}

.wc-highlight-icon {
  font-size: 40rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.wc-highlight-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.wc-highlight-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #ffffff;
}

.wc-highlight-desc {
  font-size: 23rpx;
  color: #8e8e93;
  line-height: 1.5;
}

/* 官网链接 */
.wc-link-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #5ac8fa 0%, #007aff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.wc-link-btn:active {
  opacity: 0.85;
}

.wc-link-hint {
  display: block;
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #636366;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */

/* 页面根背景：深渐变 → 浅渐变（page{} 保持深色默认，由根 view 覆盖整屏） */
.detail-page.theme-light {
  background: var(--color-bg-page, linear-gradient(180deg, #F2F2F7 0%, #ECECF1 100%));
}

/* Hero 区文字层级 */
.theme-light .wc-hero-x {
  color: var(--color-text-tertiary);
}

.theme-light .wc-hero-title {
  color: var(--color-text-primary);
}

.theme-light .wc-hero-sub {
  color: var(--color-text-secondary);
}

/* 状态胶囊：绿色（进行中）保持；浅蓝（未开始）在浅底不可读 → 品牌蓝 */
.theme-light .wc-status--upcoming {
  color: var(--color-brand);
}

.theme-light .wc-status--upcoming .wc-status-dot {
  background: var(--color-brand);
}

.theme-light .wc-status--ended {
  background: rgba(142, 142, 147, 0.14);
  color: var(--color-text-secondary);
}

.theme-light .wc-status--ended .wc-status-dot {
  background: var(--color-text-secondary);
}

/* 倒计时 */
.theme-light .wc-countdown-label {
  color: var(--color-text-secondary);
}

.theme-light .wc-countdown-num {
  color: var(--color-text-primary);
}

.theme-light .wc-countdown-unit {
  color: var(--color-text-secondary);
}

.theme-light .wc-ended-text {
  color: var(--color-text-secondary);
}

/* 媒体加载占位：白透明 → 黑透明浅灰 */
.theme-light .wc-media {
  background: rgba(0, 0, 0, 0.05);
}

/* 信息 / 看点卡 */
.theme-light .wc-card-title {
  color: var(--color-text-primary);
}

.theme-light .wc-info-row {
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.theme-light .wc-info-row:last-child {
  border-bottom: none;
}

.theme-light .wc-info-label {
  color: var(--color-text-secondary);
}

.theme-light .wc-info-value {
  color: var(--color-text-primary);
}

.theme-light .wc-highlight {
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.theme-light .wc-highlight:last-child {
  border-bottom: none;
}

.theme-light .wc-highlight-title {
  color: var(--color-text-primary);
}

.theme-light .wc-highlight-desc {
  color: var(--color-text-secondary);
}

/* 官网链接按钮为实色渐变蓝 + 白字：保持不变 */
.theme-light .wc-link-hint {
  color: var(--color-text-tertiary);
}
