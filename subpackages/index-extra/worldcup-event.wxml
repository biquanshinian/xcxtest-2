<view class="detail-page {{themeClass}}">
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-grid">
      <view class="top-nav-slot--back {{isDirectEntry ? 'top-nav-slot--home' : ''}}" bindtap="goBack">
        <text class="icon-back icon-back--nav">‹</text>
      </view>
      <text class="nav-title nav-title--page-grid">{{navTitle}}</text>
      <view class="top-nav-slot--spacer"></view>
    </view>
  </view>

  <scroll-view class="detail-scroll" scroll-y="true">
    <view style="height: {{navPlaceholderHeight}}px;"></view>

    <view class="detail-container">
      <!-- Hero：标题 + 状态 + 倒计时 + 运营图片/视频 -->
      <view class="wc-hero glass-card">
        <view class="wc-hero-logos">
          <image class="wc-hero-logo" src="{{nasaLogoUrl}}" mode="aspectFit" />
          <text class="wc-hero-x">×</text>
          <image class="wc-hero-logo" src="{{worldcupLogoUrl}}" mode="aspectFit" />
        </view>
        <text class="wc-hero-title">NASA × FIFA 球迷节</text>
        <text class="wc-hero-sub">FIFA Fan Festival™ · 美国 · 休斯顿</text>
        <view class="wc-status wc-status--{{status}}">
          <view class="wc-status-dot"></view>
          <text>{{statusText}}</text>
        </view>

        <view class="wc-countdown" wx:if="{{status !== 'ended'}}">
          <text class="wc-countdown-label">{{countLabel}}</text>
          <view class="wc-countdown-main">
            <text class="wc-countdown-num">{{countDays}}</text>
            <text class="wc-countdown-unit">天</text>
          </view>
        </view>
        <text class="wc-ended-text" wx:else>活动已圆满落幕，感谢关注</text>

        <!-- 运营在后台上传的活动图片/视频（worldcup_event_media 集合，active: true 才展示） -->
        <view class="wc-media-list" wx:if="{{mediaList.length}}">
          <block wx:for="{{mediaList}}" wx:key="id">
            <video
              wx:if="{{item.type === 'video'}}"
              class="wc-media wc-media--video"
              src="{{item.url}}"
              poster="{{item.poster}}"
              controls
              object-fit="contain"
              data-id="{{item.id}}"
              binderror="onMediaError"
            ></video>
            <image
              wx:else
              class="wc-media"
              src="{{item.url}}"
              mode="widthFix"
              lazy-load="{{true}}"
              data-id="{{item.id}}"
              data-url="{{item.url}}"
              bindtap="onPreviewMedia"
              binderror="onMediaError"
            />
          </block>
        </view>
      </view>

      <!-- 活动信息 -->
      <view class="wc-card glass-card">
        <text class="wc-card-title">活动信息</text>
        <view class="wc-info-row">
          <text class="wc-info-label">时间</text>
          <text class="wc-info-value">2026年6月11日 — 7月19日</text>
        </view>
        <view class="wc-info-row">
          <text class="wc-info-label">地点</text>
          <text class="wc-info-value">美国 · 休斯顿 FIFA 球迷节现场</text>
        </view>
        <view class="wc-info-row">
          <text class="wc-info-label">主办</text>
          <text class="wc-info-value">NASA 约翰逊航天中心</text>
        </view>
      </view>

      <!-- 看点 -->
      <view class="wc-card glass-card">
        <text class="wc-card-title">活动看点</text>
        <view class="wc-highlight" wx:for="{{highlights}}" wx:key="key">
          <text class="wc-highlight-icon">{{item.icon}}</text>
          <view class="wc-highlight-col">
            <text class="wc-highlight-title">{{item.title}}</text>
            <text class="wc-highlight-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <!-- 官网链接 -->
      <view class="wc-link-btn" bindtap="onCopyLink">
        <text>复制 NASA 官网链接</text>
      </view>
      <text class="wc-link-hint">链接复制后可在浏览器中打开查看活动详情</text>

      <view style="height: {{tabBarReservedHeight}}px;"></view>
    </view>
  </scroll-view>

  <privacy-modal id="globalPrivacyModal" />
</view>
