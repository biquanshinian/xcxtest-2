/* 星舰任务指挥室：统一详情页骨架（fixed 顶栏 + detail-scroll 内滚动，与其它详情页一致）
   深空 HUD 风（与监控中心星链板块同语言：#00ff88 强调、等宽角标、四角 L 形取景框） */

.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #000000 0%, #060a10 100%);
}

.detail-scroll {
  height: 100vh;
}

.ms-bottom-pad {
  height: calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ===== 统一区块骨架 ===== */

.ms-block {
  position: relative;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.045);
  border: 1rpx solid rgba(0, 255, 136, 0.12);
  overflow: hidden;
}
.ms-block::before,
.ms-block::after {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  pointer-events: none;
  z-index: 1;
}
.ms-block::before {
  top: 0;
  left: 0;
  border-top: 3rpx solid rgba(0, 255, 136, 0.5);
  border-left: 3rpx solid rgba(0, 255, 136, 0.5);
  border-top-left-radius: 12rpx;
}
.ms-block::after {
  bottom: 0;
  right: 0;
  border-bottom: 3rpx solid rgba(0, 255, 136, 0.5);
  border-right: 3rpx solid rgba(0, 255, 136, 0.5);
  border-bottom-right-radius: 12rpx;
}

.ms-block-head {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 24rpx 28rpx 0;
  position: relative;
}
.ms-block-tag {
  font-family: 'Courier New', monospace;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(0, 255, 136, 0.75);
}
.ms-block-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.ms-block-body {
  padding: 20rpx 28rpx 28rpx;
}

/* HUD 取景框（简报弹层复用） */
.hud-frame {
  position: relative;
  background: rgba(10, 18, 14, 0.55);
  border: 1rpx solid rgba(0, 255, 136, 0.14);
  border-radius: 16rpx;
}
.hud-frame::before,
.hud-frame::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  pointer-events: none;
}
.hud-frame::before {
  top: -2rpx;
  left: -2rpx;
  border-top: 3rpx solid rgba(0, 255, 136, 0.55);
  border-left: 3rpx solid rgba(0, 255, 136, 0.55);
  border-top-left-radius: 8rpx;
}
.hud-frame::after {
  bottom: -2rpx;
  right: -2rpx;
  border-bottom: 3rpx solid rgba(0, 255, 136, 0.55);
  border-right: 3rpx solid rgba(0, 255, 136, 0.55);
  border-bottom-right-radius: 8rpx;
}

/* ===== 未开放 ===== */

.ms-disabled {
  padding: 200rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}
.ms-disabled-text { color: rgba(255, 255, 255, 0.5); font-size: 28rpx; }

/* ===== 开始页 ===== */

.ms-start-body { display: flex; flex-direction: column; gap: 24rpx; }
.ms-start-mission {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(0, 255, 136, 0.07);
  border: 1rpx solid rgba(0, 255, 136, 0.25);
}
.ms-start-mission-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00ff88;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.8);
  flex-shrink: 0;
  animation: ms-blink 1.6s ease-in-out infinite;
}
.ms-start-mission-text {
  font-size: 22rpx;
  color: rgba(0, 255, 136, 0.85);
}
.ms-start-desc { font-size: 24rpx; line-height: 1.7; color: rgba(255, 255, 255, 0.65); }
.ms-start-rows { display: flex; flex-direction: column; gap: 12rpx; padding: 8rpx 0; }
.ms-start-row { display: flex; gap: 20rpx; }
.ms-start-k {
  font-family: 'Courier New', monospace;
  font-size: 22rpx;
  color: #00ff88;
  flex-shrink: 0;
  width: 80rpx;
}
.ms-start-v { font-size: 22rpx; color: rgba(255, 255, 255, 0.7); }
.ms-start-note { font-size: 20rpx; color: rgba(255, 255, 255, 0.3); text-align: center; }

/* ===== 通用按钮 ===== */

.ms-btn {
  height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.ms-btn--pressed { transform: scale(0.97); opacity: 0.85; }
.ms-btn--go {
  background: rgba(0, 255, 136, 0.16);
  border: 2rpx solid rgba(0, 255, 136, 0.55);
  color: #00ff88;
}
.ms-btn--nogo {
  background: rgba(255, 69, 58, 0.12);
  border: 2rpx solid rgba(255, 69, 58, 0.5);
  color: #ff6b61;
}
.ms-btn--ghost {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.75);
}

/* ===== 任务钟（在 detail-scroll 内吸顶，top 由 navPlaceholderHeight 内联注入） ===== */

.ms-clock-sticky {
  position: sticky;
  z-index: 20;
  padding: 8rpx 24rpx 20rpx;
}
.ms-clock {
  padding: 18rpx 28rpx 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  border-radius: 20rpx;
  background: rgba(6, 12, 9, 0.92);
  border: 1rpx solid rgba(0, 255, 136, 0.22);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.45);
}
.ms-clock-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ms-clock-t {
  font-family: 'Courier New', monospace;
  font-size: 48rpx;
  font-weight: 700;
  color: #00ff88;
  letter-spacing: 2rpx;
}
.ms-clock-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; }
.ms-clock-phase { font-size: 24rpx; color: rgba(255, 255, 255, 0.75); }
.ms-clock-badges { display: flex; align-items: center; gap: 10rpx; }
.ms-clock-seed {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: rgba(0, 255, 136, 0.7);
  border: 1rpx solid rgba(0, 255, 136, 0.28);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}
.ms-clock-warp {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: #4da3ff;
  border: 1rpx solid rgba(77, 163, 255, 0.4);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}
.ms-clock-warp--hold {
  color: #ffb340;
  border-color: rgba(255, 179, 64, 0.5);
  animation: ms-blink 1s step-end infinite;
}
@keyframes ms-blink { 50% { opacity: 0.35; } }

/* 倒计时倍率档位 */
.ms-rate {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(0, 255, 136, 0.1);
}
.ms-rate-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  flex-shrink: 0;
}
.ms-rate-opts {
  display: flex;
  flex: 1;
  gap: 10rpx;
}
.ms-rate-opt {
  flex: 1;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 10rpx;
}
.ms-rate-opt--pressed { opacity: 0.7; }
.ms-rate-opt--on {
  color: #00ff88;
  background: rgba(0, 255, 136, 0.12);
  border-color: rgba(0, 255, 136, 0.5);
  font-weight: 700;
}

/* ===== 飞行示意图 ===== */

.ms-legend {
  position: absolute;
  right: 28rpx;
  top: 30rpx;
  display: flex;
  gap: 16rpx;
}
.ms-legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.55);
}
.ms-legend-dot { width: 12rpx; height: 12rpx; border-radius: 50%; }
.ms-legend-dot--booster { background: #00ff88; }
.ms-legend-dot--ship { background: #4da3ff; }

.ms-diagram {
  width: 100%;
  height: 620rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.ms-engines {
  width: 100%;
  height: 300rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

/* ===== 加注/水幕条 ===== */

.ms-bars { display: flex; flex-direction: column; gap: 14rpx; margin-top: 20rpx; }
.ms-bar { display: flex; align-items: center; gap: 16rpx; }
.ms-bar-label { width: 110rpx; font-size: 22rpx; color: rgba(255, 255, 255, 0.55); flex-shrink: 0; }
.ms-bar-track {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}
.ms-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(0, 255, 136, 0.5), #00ff88);
  transition: width 0.3s linear;
}
.ms-bar-fill--water { background: linear-gradient(90deg, rgba(77, 163, 255, 0.5), #4da3ff); }
.ms-bar-val {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  width: 64rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ===== 竖向飞行时间线 ===== */

.ms-timeline { padding-top: 8rpx; }

.ms-tl-node {
  display: flex;
  gap: 20rpx;
}
.ms-tl-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 28rpx;
  flex-shrink: 0;
}
.ms-tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  background: transparent;
  margin-top: 8rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}
.ms-tl-line {
  width: 2rpx;
  flex: 1;
  background: rgba(255, 255, 255, 0.12);
  margin: 6rpx 0;
  min-height: 28rpx;
}
.ms-tl-content {
  flex: 1;
  min-width: 0;
  padding-bottom: 26rpx;
}
.ms-tl-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}
.ms-tl-t {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}
.ms-tl-label {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.55);
}
.ms-tl-state {
  font-size: 18rpx;
  color: #00ff88;
  border: 1rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
  animation: ms-blink 1.2s step-end infinite;
}
.ms-tl-state--abort {
  color: #ff6b61;
  border-color: rgba(255, 69, 58, 0.5);
  animation: none;
}
.ms-tl-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 4rpx;
  line-height: 1.5;
}

/* 节点状态 */
.ms-tl-node--done .ms-tl-dot {
  background: rgba(0, 255, 136, 0.85);
  border-color: rgba(0, 255, 136, 0.85);
}
.ms-tl-node--done .ms-tl-line { background: rgba(0, 255, 136, 0.35); }
.ms-tl-node--done .ms-tl-label { color: rgba(255, 255, 255, 0.85); }
.ms-tl-node--done .ms-tl-t { color: rgba(0, 255, 136, 0.6); }

.ms-tl-node--active .ms-tl-dot {
  background: #00ff88;
  border-color: #00ff88;
  box-shadow: 0 0 14rpx rgba(0, 255, 136, 0.8);
}
.ms-tl-node--active .ms-tl-label { color: #FFFFFF; font-size: 28rpx; }
.ms-tl-node--active .ms-tl-t { color: #00ff88; }
.ms-tl-node--active .ms-tl-desc { color: rgba(255, 255, 255, 0.6); }

.ms-tl-node--abort .ms-tl-dot {
  background: #ff453a;
  border-color: #ff453a;
  box-shadow: 0 0 12rpx rgba(255, 69, 58, 0.7);
}
.ms-tl-node--abort .ms-tl-label { color: #ff6b61; }

.ms-tl-node--skip .ms-tl-dot { border-style: dashed; opacity: 0.5; }
.ms-tl-node--skip .ms-tl-label,
.ms-tl-node--skip .ms-tl-t,
.ms-tl-node--skip .ms-tl-desc { opacity: 0.45; }

/* 结果着色（受控溅落/损失/再入失利） */
.ms-tl-node--tone-warn .ms-tl-label { color: #ffb340; }
.ms-tl-node--tone-warn .ms-tl-dot { background: #ffb340; border-color: #ffb340; box-shadow: 0 0 12rpx rgba(255, 179, 64, 0.6); }
.ms-tl-node--tone-bad .ms-tl-label { color: #ff6b61; }
.ms-tl-node--tone-bad .ms-tl-dot { background: #ff453a; border-color: #ff453a; box-shadow: 0 0 12rpx rgba(255, 69, 58, 0.7); }

/* ===== 内联决策门 ===== */

.ms-gate {
  margin-top: 20rpx;
  padding: 28rpx 26rpx;
  border-radius: 16rpx;
  background: rgba(8, 14, 11, 0.9);
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  animation: ms-gate-in 0.3s ease-out;
}
@keyframes ms-gate-in {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.ms-gate-tag {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: #00ff88;
  letter-spacing: 4rpx;
}
.ms-gate-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.ms-gate-desc { font-size: 22rpx; line-height: 1.7; color: rgba(255, 255, 255, 0.65); }
.ms-gate-stations { display: flex; flex-wrap: wrap; gap: 10rpx; }
.ms-gate-station {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
}
.ms-gate-station .ms-station-dot { width: 10rpx; height: 10rpx; }
.ms-gate-btns { display: flex; flex-direction: column; gap: 14rpx; margin-top: 4rpx; }

/* ===== 席位状态板 ===== */

.ms-stations { display: flex; gap: 12rpx; }
.ms-station {
  flex: 1;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.04);
  padding: 14rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}
.ms-station-name { font-size: 22rpx; color: rgba(255, 255, 255, 0.8); font-weight: 600; }
.ms-station-dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.ms-station-note {
  font-size: 17rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.ms-station--go { border-color: rgba(0, 255, 136, 0.3); }
.ms-station--go .ms-station-dot { background: #00ff88; box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.7); }
.ms-station--amber { border-color: rgba(255, 179, 64, 0.45); background: rgba(255, 179, 64, 0.06); }
.ms-station--amber .ms-station-dot { background: #ffb340; box-shadow: 0 0 10rpx rgba(255, 179, 64, 0.7); }
.ms-station--nogo { border-color: rgba(255, 69, 58, 0.5); background: rgba(255, 69, 58, 0.08); }
.ms-station--nogo .ms-station-dot { background: #ff453a; box-shadow: 0 0 10rpx rgba(255, 69, 58, 0.8); }

/* ===== 事件日志 ===== */

.ms-log { height: 260rpx; }
.ms-log-line { display: flex; gap: 14rpx; padding: 6rpx 0; }
.ms-log-t {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: #00ff88;
  flex-shrink: 0;
  opacity: 0.8;
}
.ms-log-text { font-size: 22rpx; color: rgba(255, 255, 255, 0.72); line-height: 1.5; }

/* ===== 任务简报 ===== */

.ms-debrief-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  z-index: 100;
}
.ms-debrief {
  width: 100%;
  max-height: 82vh;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: rgba(8, 14, 11, 0.96);
  box-sizing: border-box;
}
.ms-debrief-title { font-size: 40rpx; font-weight: 700; }
.ms-debrief-title--success { color: #00ff88; }
.ms-debrief-title--partial { color: #ffb340; }
.ms-debrief-title--fail { color: #ff6b61; }
.ms-debrief-title--scrub { color: #4da3ff; }
.ms-debrief-verdict { font-size: 24rpx; line-height: 1.7; color: rgba(255, 255, 255, 0.7); }
.ms-debrief-log {
  height: 300rpx;
  border-top: 1rpx solid rgba(0, 255, 136, 0.12);
  border-bottom: 1rpx solid rgba(0, 255, 136, 0.12);
  padding: 12rpx 0;
  box-sizing: border-box;
}
.ms-debrief-btns { display: flex; gap: 16rpx; }
.ms-debrief-btns .ms-btn { flex: 1; }
.ms-share-btn {
  height: 84rpx;
  border-radius: 999rpx;
  background: rgba(77, 163, 255, 0.14);
  border: 1rpx solid rgba(77, 163, 255, 0.45);
  color: #4da3ff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: normal;
}
.ms-share-btn::after { border: none; }
.ms-debrief-exit {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  padding: 8rpx 0;
}

/* 结算后底部召回条 */
.ms-debrief-recall {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(8, 14, 11, 0.95);
  border: 1rpx solid rgba(0, 255, 136, 0.45);
  color: #00ff88;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
}
