page {
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  overflow: hidden;
  height: 100vh;
  width: 100%;
}

.detail-page {
  min-height: 100vh;
  height: 100vh;
  background: linear-gradient(180deg, #000000 0%, #0a0a0a 100%);
  overflow: hidden;
}



.nav-title-wrap {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  text-align: center;
}

.nav-title-sub {
  max-width: 420rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.42);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.detail-scroll {
  height: 100vh;
}

.detail-container {
  padding: 32rpx;
  box-sizing: border-box;
}

.glass-card {
  background: rgba(18, 20, 24, 0.62);
  backdrop-filter: blur(28rpx) saturate(170%);
  -webkit-backdrop-filter: blur(28rpx) saturate(170%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
}

/* 卡片化改版：外层不再是整块玻璃卡，改为透明容器，各版块独立成圆角卡片（参照监控中心） */
.detail-card {
  padding: 0;
}

/* 版块卡片统一底座：深色玻璃卡 / 浅色白底圆角卡（.theme-light 覆盖） */
.detail-section,
.detail-block {
  background: rgba(18, 20, 24, 0.62);
  backdrop-filter: blur(28rpx) saturate(170%);
  -webkit-backdrop-filter: blur(28rpx) saturate(170%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.28), inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
}

.detail-section {
  padding: 24rpx 28rpx;
}

/* 头部卡片：头图铺到卡片边缘 */
.detail-hero-section {
  padding: 0;
  overflow: hidden;
}

.detail-hero-section .hero-image-wrap {
  border-radius: 0;
  margin-bottom: 24rpx;
}

.detail-hero-section .meta-top,
.detail-hero-section .detail-title,
.detail-hero-section .detail-subhead,
.detail-hero-section .detail-status-note--hero {
  margin-left: 28rpx;
  margin-right: 28rpx;
}

.detail-hero-section official-account-publish-panel {
  display: block;
  margin: 20rpx 28rpx 28rpx;
}

/* 状态徽章行的任务徽章缩略图 */
.meta-patches {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.meta-patch-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  padding: 4rpx;
  box-sizing: border-box;
}

.detail-status-note--hero {
  margin-top: -12rpx;
  margin-bottom: 20rpx;
}

/* 自适应火箭图：widthFix 让 image 按真实比例计算高度，外层包裹紧贴图片不留黑边 */
.hero-image-wrap {
  width: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  background: transparent;
  margin-bottom: 28rpx;
  font-size: 0;
  line-height: 0;
}

.hero-image {
  display: block;
  width: 100%;
  background: #131313;
}

.meta-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.type-badge {
  max-width: 60%;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-badge.status-success {
  color: #34c759;
  background: rgba(52, 199, 89, 0.15);
  border: 1px solid rgba(52, 199, 89, 0.35);
}

.type-badge.status-failure {
  color: #ff3b30;
  background: rgba(255, 59, 48, 0.15);
  border: 1px solid rgba(255, 59, 48, 0.35);
}

.type-badge.status-partial {
  color: #ff9500;
  background: rgba(255, 149, 0, 0.15);
  border: 1px solid rgba(255, 149, 0, 0.35);
}

.type-badge.status-delayed,
.type-badge.status-cancelled {
  color: #ff9500;
  background: rgba(255, 149, 0, 0.12);
  border: 1px solid rgba(255, 149, 0, 0.3);
}

.type-badge.status-pending {
  color: #4ea1ff;
  background: rgba(0, 122, 255, 0.16);
  border: 1px solid rgba(0, 122, 255, 0.35);
}

.type-badge.status-inflight {
  color: #5ac8fa;
  background: rgba(90, 200, 250, 0.16);
  border: 1px solid rgba(90, 200, 250, 0.4);
}

.type-badge.status-deployed {
  color: #34c759;
  background: rgba(52, 199, 89, 0.15);
  border: 1px solid rgba(52, 199, 89, 0.35);
}

.date-text {
  font-size: 24rpx;
  color: #8e8e93;
  text-align: right;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.detail-subhead {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #8ebdff;
  margin-bottom: 28rpx;
}

.detail-section {
  margin-bottom: 28rpx;
}

.detail-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #007aff;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1px solid rgba(0, 122, 255, 0.2);
}

/* 紧凑版块：基础信息 / 规格 / 任务说明 / 火箭信息收紧版块间距与标题留白 */
.detail-basic,
.rocket-spec-section,
.detail-desc-section {
  position: relative;
  margin-bottom: 28rpx;
}

/* 行数测量节点：与正文同宽同字体渲染但不可见、不占位 */
.desc-measure {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  visibility: hidden;
  pointer-events: none;
  z-index: -1;
}

.detail-basic .detail-section-title,
.rocket-spec-section .detail-section-title,
.detail-desc-section .detail-section-title {
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
}

.detail-basic .detail-row {
  padding: 9rpx 0;
}

.detail-basic .detail-section-content {
  line-height: 1.6;
}

.section-text--compact {
  font-size: 26rpx;
  line-height: 1.62;
  color: #c7c7cc;
}

.detail-desc-section .expand-toggle {
  margin-top: 6rpx;
}

/* 「翻译/原文」小按钮（任务说明 / 火箭信息标题右侧） */
/* 全局 .translate-toggle / .translate-toggle--inline 样式在 app.wxss；此处仅保留定位 */
.translate-toggle {
  margin-left: auto;
}

/* 「规格」标题行：右侧型号档案入口（下划线移到整行，保持与纯标题时同宽） */
.rocket-spec-section .rocket-spec-title-row {
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 1px solid rgba(0, 122, 255, 0.2);
}

.rocket-spec-title-row .detail-section-title {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.rocket-spec-title-row .detail-link-chip {
  padding: 6rpx 18rpx;
}

.rocket-spec-title-row .detail-link-chip-text,
.rocket-spec-title-row .detail-link-chip-arrow {
  font-size: 24rpx;
}

/* LL2 rocket.configuration：长度 / 直径 / 质量 / 推力 / 运力（紧凑胶囊流式排列） */
.rocket-spec-section .rocket-spec-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.rocket-spec-cell {
  display: inline-flex;
  align-items: baseline;
  gap: 10rpx;
  box-sizing: border-box;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.rocket-spec-label {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.45);
  white-space: nowrap;
}

.rocket-spec-value {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.35;
}

.countdown-display {
  display: flex;
  align-items: stretch;
  justify-content: center;
  margin: 12rpx 0 8rpx;
  gap: 18rpx;
  flex-shrink: 0;
}

.countdown-display--tech {
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
}

.countdown-display--detail {
  justify-content: space-between;
  gap: 14rpx;
  margin: 4rpx 0 0;
}

.countdown-item--tech {
  min-width: 116rpx;
  padding: 10rpx 8rpx 8rpx;
  flex-direction: column;
  gap: 8rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.countdown-item--detail {
  min-width: 0;
  flex: 1;
  padding: 14rpx 8rpx 12rpx;
}

.countdown-value {
  font-size: 54rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 10rpx rgba(72, 170, 255, 0.08);
}

.countdown-value--detail {
  font-size: 50rpx;
}

.countdown-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
}

.countdown-seconds-window {
  height: 58rpx;
  overflow: hidden;
  position: relative;
}

.countdown-seconds-window--detail {
  height: 54rpx;
}

.countdown-seconds-reel {
  display: flex;
  flex-direction: column;
  transform: translateY(-58rpx);
}

.countdown-display--detail .countdown-seconds-reel {
  transform: translateY(-54rpx);
}

.countdown-seconds-reel--rolling {
  animation: countdown-seconds-roll-up 0.54s linear forwards;
}

.countdown-display--detail .countdown-seconds-reel--rolling {
  animation-name: countdown-seconds-roll-up-detail;
}

.countdown-value-seconds {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  color: #8ebdff;
  text-shadow: none;
  letter-spacing: 2rpx;
}

.countdown-display--detail .countdown-value-seconds {
  height: 54rpx;
}

@keyframes countdown-seconds-roll-up {
  from { transform: translateY(0); }
  to { transform: translateY(-58rpx); }
}

@keyframes countdown-seconds-roll-up-detail {
  from { transform: translateY(0); }
  to { transform: translateY(-54rpx); }
}

/* 直播观看入口（倒计时下方） */
.detail-livestream-section {
  margin-bottom: 24rpx;
}

.detail-section-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.detail-section-title-row .detail-section-title {
  margin-bottom: 0;
}

/* 翻译按钮统一靠标题行最右侧 */
.detail-section-title-row .translate-toggle {
  margin-left: auto;
  flex-shrink: 0;
}

.livestream-live-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff2d55, #ff453a);
  box-shadow: 0 4rpx 12rpx rgba(255, 45, 85, 0.35);
  box-sizing: border-box;
}

.livestream-live-pill .cd-live-eq {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 3rpx;
  height: 18rpx;
  flex-shrink: 0;
}

.livestream-live-pill .cd-live-eq-bar {
  width: 4rpx;
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transform-origin: center bottom;
  animation: cd-live-eq 0.8s ease-in-out infinite;
}

.livestream-live-pill .cd-live-eq-bar:nth-child(1) { animation-delay: 0s; }
.livestream-live-pill .cd-live-eq-bar:nth-child(2) { animation-delay: 0.15s; }
.livestream-live-pill .cd-live-eq-bar:nth-child(3) { animation-delay: 0.3s; }

@keyframes cd-live-eq {
  0%, 100% { transform: scaleY(0.35); }
  25% { transform: scaleY(1); }
  50% { transform: scaleY(0.55); }
  75% { transform: scaleY(0.85); }
}

.livestream-live-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
  letter-spacing: 0.5rpx;
}

.livestream-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.livestream-btn {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  background: rgba(30, 30, 30, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  transition: all 0.18s ease;
}

.livestream-btn:active {
  background: rgba(255, 255, 255, 0.06);
  transform: scale(0.98);
}

.livestream-btn--primary {
  border-color: rgba(78, 161, 255, 0.32);
  background: linear-gradient(135deg, rgba(78, 161, 255, 0.12), rgba(30, 30, 30, 0.45));
}

.livestream-btn--channel-live {
  position: relative;
}

.livestream-btn-tap-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 3;
  opacity: 0;
  border-radius: 20rpx;
}

.livestream-btn--bilibili {
  border-color: rgba(251, 114, 153, 0.3);
  background: linear-gradient(135deg, rgba(251, 114, 153, 0.1), rgba(30, 30, 30, 0.45));
}

.livestream-btn-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.livestream-btn-icon--live {
  background: transparent;
  box-shadow: none;
}

.livestream-btn-icon--bilibili {
  background: transparent;
  box-shadow: none;
}

.livestream-icon-img {
  width: 64rpx;
  height: 64rpx;
  display: block;
}

/* —— 观看回放（发射后） —— */
.detail-replay-section {
  margin-bottom: 24rpx;
}

.replay-member-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 190, 90, 0.22), rgba(255, 140, 60, 0.22));
  border: 1px solid rgba(255, 180, 90, 0.45);
}

.replay-member-pill text {
  font-size: 20rpx;
  color: #ffc46b;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 分组小标题：发射集锦 / 完整回放 */
.replay-group-label {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 4rpx 4rpx 14rpx;
}

.replay-group-label-text {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 1rpx;
}

.replay-group-label-hint {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.38);
}

/* 集锦横滑区 */
.replay-clips-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.replay-clips-track {
  display: inline-flex;
  gap: 16rpx;
}

/* 单段集锦：track 改块级 flex 并占满 scroll-view，卡片 width:100% 才能解析
   （inline-flex 轨道宽度由内容决定，子项百分比宽度会塌缩成窄条） */
.replay-clips-track--single {
  display: flex;
  width: 100%;
}

.replay-clip-card {
  flex-shrink: 0;
  width: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* 只有一段集锦时铺满一行，更像主卡片 */
.replay-clip-card--wide {
  width: 100%;
  flex: 1;
}

.replay-clip-poster-wrap {
  position: relative;
  width: 100%;
  height: 202rpx;
}

.replay-clip-card--wide .replay-clip-poster-wrap {
  height: 348rpx;
}

.replay-clip-poster {
  width: 100%;
  height: 100%;
  display: block;
  background: rgba(255, 255, 255, 0.05);
}

.replay-clip-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 45%, rgba(0, 0, 0, 0.45) 100%);
  pointer-events: none;
}

.replay-clip-play {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.replay-clip-play-triangle {
  width: 0;
  height: 0;
  margin-left: 6rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid rgba(255, 255, 255, 0.92);
}

.replay-clip-duration {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.6);
}

.replay-clip-duration text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  font-variant-numeric: tabular-nums;
}

.replay-clip-caption {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx 14rpx;
}

.replay-clip-publisher {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.theme-light .replay-group-label-text {
  color: rgba(0, 0, 0, 0.6);
}

.theme-light .replay-group-label-hint {
  color: rgba(0, 0, 0, 0.35);
}

.theme-light .replay-clip-card {
  background: rgba(0, 0, 0, 0.03);
  border-color: rgba(0, 0, 0, 0.08);
}

.theme-light .replay-clip-publisher {
  color: rgba(0, 0, 0, 0.55);
}

.livestream-btn--replay {
  border-color: rgba(90, 170, 255, 0.35);
}

.livestream-btn-icon--replay,
.livestream-btn-icon--replay-link {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.livestream-btn-icon--replay .livestream-icon-img,
.livestream-btn-icon--replay-link .livestream-icon-img {
  width: 40rpx;
  height: 40rpx;
  margin: 12rpx;
  /* svg currentColor 经 <image> 渲染为黑色，深色主题反白 */
  filter: invert(0.92);
}

.theme-light .replay-member-pill {
  background: rgba(255, 165, 60, 0.14);
  border-color: rgba(230, 140, 40, 0.4);
}

.theme-light .replay-member-pill text {
  color: #c97a1e;
}

.theme-light .livestream-btn-icon--replay,
.theme-light .livestream-btn-icon--replay-link {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .livestream-btn-icon--replay .livestream-icon-img,
.theme-light .livestream-btn-icon--replay-link .livestream-icon-img {
  filter: none;
}

.livestream-btn-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.livestream-btn-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
}

.livestream-btn-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.icon-arrow--livestream {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

.detail-subscribe-section {
  margin-bottom: 24rpx;
}

.subscribe-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(30, 30, 30, 0.35);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  gap: 20rpx;
}

.subscribe-row--active {
  background: rgba(7, 193, 96, 0.1);
  border-color: rgba(7, 193, 96, 0.32);
  box-shadow: 0 0 0 1rpx rgba(7, 193, 96, 0.12) inset;
}

.subscribe-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.subscribe-icon-wrap--active {
  background: #07C160;
  border: 1px solid rgba(7, 193, 96, 0.55);
  box-sizing: border-box;
  box-shadow: 0 0 20rpx rgba(7, 193, 96, 0.28);
}

.icon-bell--subscribe {
  width: 51rpx;
  height: 51rpx;
  display: block;
  margin: auto;
  flex-shrink: 0;
}

.subscribe-info {
  flex: 1;
  min-width: 0;
}

.subscribe-title {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.subscribe-title--active {
  color: #07C160;
}

.subscribe-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.subscribe-desc--active {
  color: rgba(196, 255, 211, 0.82);
}

.icon-arrow--subscribe,
.subscribe-check {
  font-size: 30rpx;
  color: #8e8e93;
}

.subscribe-check--active {
  color: #34c759;
  font-size: 34rpx;
  font-weight: 700;
}

/* ===== 地图预览 ===== */
.mission-map-preview-wrap {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  margin-bottom: 16rpx;
}

.mission-map-preview {
  width: 100%;
  height: 320rpx;
  pointer-events: none;
}

.mission-map-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  padding: 16rpx;
  z-index: 10;
  pointer-events: none;
}

.mission-map-site-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #34c759;
  animation: pulse-dot 1.5s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.mission-map-site-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.4;
  text-align: center;
  word-break: break-all;
}

.mission-map-site-caption {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 4rpx 24rpx 14rpx;
}

.mission-map-tap-hint text {
  padding: 10rpx 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(10rpx);
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.mission-map-quick-links {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mission-map-quick-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 122, 255, 0.1);
  border: 1px solid rgba(0, 122, 255, 0.25);
}

.mission-map-quick-link-text {
  font-size: 24rpx;
  color: #4ea1ff;
}

.mission-map-quick-link-arrow {
  font-size: 24rpx;
  color: rgba(78, 161, 255, 0.6);
}

/* ===== 可点击链接芯片（发射商 / 序列号） ===== */
.detail-link-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 22rpx 10rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5ac8fa 0%, #007aff 100%);
  transition: opacity 0.2s;
}

.detail-link-chip:active {
  opacity: 0.85;
}

.detail-link-chip-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
}

.detail-link-chip-arrow {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 2rpx;
}

.detail-link-chip--booster .detail-link-chip-arrow {
  color: rgba(90, 200, 250, 0.6);
}

.vote-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  flex-wrap: wrap;
}

.vote-type-tabs--detail {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin: 0 0 12rpx;
}
.vote-type-tab {
  font-size: 29rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.4);
  padding: 10rpx 19rpx;
  border-radius: 12rpx;
}
.vote-type-tab--active {
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.1);
}

.vote-box--detail {
  padding: 18rpx 18rpx;
}

.vote-box-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  white-space: nowrap;
  margin-right: 2rpx;
}

.vote-pill {
  min-height: 52rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.05);
}

.vote-pill--active-ge {
  background: rgba(255, 149, 0, 0.18);
}

.vote-pill--active-buge {
  background: rgba(7, 193, 96, 0.18);
}

.vote-pill--voted {
  border: 1px solid rgba(255,255,255,0.12);
}

.vote-pill-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.vote-pill-dot--ge {
  background: #ff9500;
}

.vote-pill-dot--buge {
  background: #07C160;
}

.vote-pill-text,
.vote-pill-count {
  font-size: 24rpx;
  color: #ffffff;
}

.vote-bar-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.vote-bar {
  flex: 1;
  display: flex;
  height: 10rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.08);
}

.vote-bar-ge {
  background: #ff9500;
}

.vote-bar-buge {
  background: #07C160;
}

.vote-total {
  font-size: 22rpx;
  color: #8e8e93;
}
.vote-pill--disabled {
  opacity: 0.5;
  pointer-events: none;
}
.vote-closed-banner {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255,152,0,0.8);
  padding: 16rpx 0;
}
.vote-result-banner {
  text-align: center;
  font-size: 28rpx;
  padding: 16rpx 0;
  font-weight: 600;
}
.vote-result--correct {
  color: #4ecdc4;
}
.vote-result--wrong {
  color: rgba(255,255,255,0.5);
}

.detail-section-content {
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.8;
  width: 100%;
  box-sizing: border-box;
}

/* 任务类型 / 轨道（对齐参考：左图标 + 主标题白 + 次文案灰） */
.detail-icon-summary {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 18rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.detail-icon-summary__img {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  opacity: 0.92;
}

.detail-icon-summary__col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.detail-icon-summary__label {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.detail-icon-summary__value {
  font-size: 26rpx;
  color: #8e8e93;
  line-height: 1.45;
  word-break: break-word;
}

/* 紧凑版：任务类型 / 轨道并排成一行两张小卡，省纵向空间 */
.detail-icon-summary-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.detail-icon-summary-grid .detail-icon-summary {
  flex: 1;
  min-width: 0;
  padding: 16rpx 18rpx;
  gap: 14rpx;
  border-bottom: none;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  box-sizing: border-box;
}

.detail-icon-summary-grid .detail-icon-summary__img {
  width: 36rpx;
  height: 36rpx;
}

.detail-icon-summary-grid .detail-icon-summary__col {
  gap: 2rpx;
}

.detail-icon-summary-grid .detail-icon-summary__label {
  font-size: 21rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.45);
}

.detail-icon-summary-grid .detail-icon-summary__value {
  font-size: 25rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 注意：脉冲只做 box-shadow / opacity，不做 transform 缩放——
   scroll-view（WKChildScrollView）内持续的 transform 动画会让该节点
   及内部 SVG 图标在 iOS 滚动时脱离滚动层、出现位置漂移 */
@keyframes launchTimelineNodePulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(47, 143, 255, 0.45);
  }
  50% {
    box-shadow: 0 0 0 12rpx rgba(47, 143, 255, 0);
  }
}

@keyframes launchTimelineLiveDot {
  0%, 100% { opacity: 0.45; }
  50% { opacity: 1; }
}

/* ===== 发射时间表（垂直时间线） ===== */
.lt-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.lt-status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(142, 142, 147, 0.9);
  flex-shrink: 0;
}

.lt-status-dot--live {
  background: #2f8fff;
  animation: launchTimelineLiveDot 1.4s ease-in-out infinite;
}

.lt-status-text {
  font-size: 22rpx;
  color: #8e8e93;
}

.lt-status-text--live {
  color: #7ec3ff;
}

.lt-card {
  background: rgba(255, 255, 255, 0.035);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
}

/* 步骤行：左轨道 + 右内容 */
.lt-step {
  display: flex;
  gap: 24rpx;
}

.lt-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 56rpx;
  flex-shrink: 0;
}

/* 普通节点（小圆点） */
.lt-node {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: transparent;
  border: 3rpx solid rgba(255, 255, 255, 0.22);
  box-sizing: border-box;
  margin: 6rpx 0;
  flex-shrink: 0;
}

.lt-node--done {
  background: #2f8fff;
  border-color: #2f8fff;
}

.lt-node--active {
  background: #2f8fff;
  border-color: rgba(126, 195, 255, 0.5);
  box-shadow: 0 0 16rpx rgba(47, 143, 255, 0.8);
  animation: launchTimelineLiveDot 1.4s ease-in-out infinite;
}

/* T-0 火箭节点（大徽章） */
.lt-node--rocket {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 4rpx 0;
}

.lt-node--rocket.lt-node--done {
  background: rgba(47, 143, 255, 0.2);
  border-color: rgba(126, 195, 255, 0.6);
  box-shadow: none;
  animation: none;
}

.lt-node--rocket.lt-node--active {
  background: rgba(47, 143, 255, 0.28);
  border-color: #7ec3ff;
  box-shadow: 0 0 20rpx rgba(47, 143, 255, 0.5);
  animation: launchTimelineNodePulse 1.8s ease-in-out infinite;
}

.lt-node-icon {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.9;
}

/* 连接线 */
.lt-line {
  width: 4rpx;
  flex: 1;
  min-height: 36rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
}

.lt-line--done {
  background: linear-gradient(180deg, #2f8fff 0%, rgba(47, 143, 255, 0.4) 100%);
}

/* 内容区 */
.lt-step-body {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex: 1;
  min-width: 0;
  padding-bottom: 28rpx;
}

.lt-step--last .lt-step-body {
  padding-bottom: 0;
}

.lt-step--liftoff .lt-step-body {
  align-items: center;
}

.lt-step-label {
  font-size: 24rpx;
  color: #8e8e93;
}

.lt-step-label--liftoff {
  font-size: 26rpx;
  font-weight: 600;
  color: #7ec3ff;
}

.lt-step-time {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.lt-step-time--liftoff {
  font-size: 44rpx;
  font-weight: 700;
  color: #7ec3ff;
  text-shadow: 0 0 24rpx rgba(47, 143, 255, 0.35);
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 24rpx;
  color: #8e8e93;
  flex-shrink: 0;
  width: 160rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #e5e5ea;
  flex: 1;
  word-break: break-word;
  text-align: right;
}

.detail-value--row {
  display: flex;
  justify-content: flex-end;
}

.detail-value--wrap {
  text-align: right;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-value-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.section-text,
.detail-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #d7d7db;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-text-clamp {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.expand-toggle {
  display: inline-block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4ea1ff;
}

.detail-tag {
  font-size: 24rpx;
  color: #007aff;
  background: rgba(0,122,255,0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.detail-link {
  color: #007aff;
  word-break: break-all;
}

.detail-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  padding: 16rpx 0 8rpx;
  margin-top: 8rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.detail-block {
  margin-bottom: 28rpx;
  overflow: hidden;
}

.detail-block-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(0,122,255,0.08);
}

.detail-block-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #007aff;
  flex: 1;
}

/* 翻译按钮统一靠标题行右侧（折叠箭头之前） */
.detail-block-header .translate-toggle {
  flex-shrink: 0;
  margin-right: 12rpx;
}

.icon-arrow--detail-block {
  font-size: 24rpx;
  color: #8e8e93;
}

/* 发射动态入口：› 跳转箭头 */
.icon-arrow--detail-nav {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
  color: #8e8e93;
}

.detail-block-body {
  padding: 16rpx 24rpx 24rpx;
}

/* —— 状态说明（LL2 status.description，基础信息底部备注） —— */
.detail-status-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8e8e93;
}

/* —— 所属计划（LL2 program） —— */
.detail-program-card {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
}

.detail-program-card + .detail-program-card {
  margin-top: 20rpx;
}

.detail-program-img {
  width: 100%;
  height: 240rpx;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
}

.detail-program-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.detail-program-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5ea;
}

.detail-program-type {
  font-size: 20rpx;
  color: #007aff;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(0, 122, 255, 0.35);
}

.detail-program-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.detail-program-meta-item {
  font-size: 22rpx;
  color: #8e8e93;
}

.detail-program-links {
  margin-top: 12rpx;
  font-size: 24rpx;
}

/* —— 任务信息图（LL2 infographic） —— */
.detail-infographic-img {
  width: 100%;
  border-radius: 12rpx;
}

/* —— 相关链接（LL2 info_urls / vid_urls / flightclub_url） —— */
.detail-related-link {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.detail-related-link:last-child {
  border-bottom: none;
}

.detail-related-link-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #007aff;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(0, 122, 255, 0.35);
}

.detail-related-link-title {
  flex: 1;
  font-size: 24rpx;
  color: #e5e5ea;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* —— 失败原因（LL2 failreason） —— */
.detail-failreason-card {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(255, 69, 58, 0.08);
  border: 1px solid rgba(255, 69, 58, 0.25);
}

.detail-failreason-text {
  color: #ff6961;
}

/* —— 发射动态（LL2 updates，时间轴样式，与飞行时间线视觉统一） —— */
.detail-update-item {
  display: flex;
  align-items: stretch;
}

.detail-update-axis {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.detail-update-line {
  width: 2rpx;
  flex: 1;
  min-height: 12rpx;
  background: rgba(255, 255, 255, 0.14);
}

.detail-update-line--up {
  flex: 0 0 14rpx;
}

.detail-update-line--hidden {
  background: transparent;
}

.detail-update-node {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.45);
  flex-shrink: 0;
  margin: 4rpx 0;
}

.detail-update-node--latest {
  background: #007aff;
  box-shadow: 0 0 10rpx rgba(0, 122, 255, 0.6);
}

.detail-update-main {
  flex: 1;
  min-width: 0;
  padding-bottom: 20rpx;
}

.detail-update-item:last-child .detail-update-main {
  padding-bottom: 4rpx;
}

.detail-update-comment {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #e5e5ea;
  word-break: break-word;
}

.detail-update-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 6rpx;
}

.detail-update-time,
.detail-update-author {
  font-size: 22rpx;
  color: #8e8e93;
}

.detail-update-link {
  font-size: 22rpx;
}

/* 折叠卡标题行的辅助提示（如「点击复制」） */
.detail-block-hint {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8e8e93;
  margin-right: 12rpx;
}

/* 相关链接行尾的复制暗示 */
.detail-related-link-copy {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #007aff;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(0, 122, 255, 0.35);
}

.detail-related-link--tap {
  opacity: 0.6;
}

/* 发射统计卡内的序号网格与上方大数字卡留距 */
.mission-stats-seq-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

/* 折叠子标题行（子标题 + 翻译按钮同行） */
.detail-subtitle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 卡片化后：版块卡内部的玻璃子卡改为轻量平面底，避免「卡中卡」双重玻璃 */
.detail-stats-section .mission-stats-card,
.detail-section .detail-ll2-card {
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  box-shadow: none;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* 多芯火箭（Falcon Heavy 等）助推器分卡 */
.booster-stage-card {
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.booster-stage-card:last-child {
  margin-bottom: 0;
}

.booster-stage-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0 10rpx;
  margin-bottom: 6rpx;
  border-bottom: 1px dashed rgba(255, 255, 255, 0.08);
}

.booster-stage-role {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 0.5px;
}

.booster-stage-index {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  font-family: -apple-system, BlinkMacSystemFont, "SF Mono", Menlo, monospace;
}

.payload-item {
  margin-bottom: 24rpx;
}

.payload-item:last-child {
  margin-bottom: 0;
}

.payload-image {
  max-width: 100%;
  border-radius: 8rpx;
  margin-top: 8rpx;
  display: block;
}

.recovery-icon-name {
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.recovery-icon {
  width: 32rpx;
  height: 32rpx;
}

.recovery-type-name,
.recovery-location-name {
  font-size: 28rpx;
  color: #e5e5ea;
}

.recovery-type-name--not-reused {
  color: #ffb340;
}

/* 回收成功 → 绿色（图标已通过 dataURI 自带绿色，文字也跟随） */
.recovery-icon-name--success .recovery-type-name,
.recovery-icon-name--success .recovery-location-name {
  color: #22c55e;
}

/* 回收失败 / 飞行失败 → 橙色 */
.recovery-icon-name--failure .recovery-type-name,
.recovery-icon-name--failure .recovery-location-name {
  color: #f97316;
}
/* 失败状态下覆盖"未复用/首次"的橙色，保持视觉统一 */
.recovery-icon-name--failure .recovery-type-name--not-reused {
  color: #f97316;
}

.loading-state,
.error-state {
  width: 100%;
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  text-align: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

/* 朋友圈单页预览无自定义 TabBar，略减底部占位以便垂直居中 */
.detail-page--moments .loading-state,
.detail-page--moments .error-state {
  min-height: calc(100vh - 280rpx);
}

/* 加载骨架屏：样式统一定义在 app.wxss（.detail-skeleton / .skeleton-card / .skeleton-line 等，各详情页共享） */

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 122, 255, 0.2);
  border-top-color: #4ea1ff;
  animation: spin 0.8s linear infinite;
}

/* 页签面板底部：完整详情拉取中的转圈占位 */
.detail-hydrating-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 64rpx 32rpx 48rpx;
}

.detail-hydrating-text {
  font-size: 26rpx;
  color: #b6b6bb;
}

.loading-text,
.error-text {
  display: block;
  width: 100%;
  max-width: 560rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #b6b6bb;
  text-align: center;
  box-sizing: border-box;
}

.error-title {
  display: block;
  width: 100%;
  max-width: 560rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  box-sizing: border-box;
}

.retry-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: center;
  margin-top: 10rpx;
  margin-left: auto;
  margin-right: auto;
  min-width: 220rpx;
  height: 84rpx;
  line-height: 1;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0a84ff, #4ea1ff);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.retry-btn::after {
  border: none;
}

/* B站直播二维码弹窗（与监控中心 monitor.wxss 完全一致的视觉） */
.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 10002;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: qrFadeIn 0.2s ease;
}

@keyframes qrFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.qrcode-modal-content {
  width: 600rpx;
  max-width: 90%;
  background: rgba(28, 28, 30, 0.95);
  backdrop-filter: blur(40rpx) saturate(150%);
  -webkit-backdrop-filter: blur(40rpx) saturate(150%);
  border-radius: 24rpx;
  overflow: hidden;
  animation: qrSlideUp 0.3s ease;
}

@keyframes qrSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.qrcode-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.qrcode-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}

.qrcode-close:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.icon-close--qrcode {
  font-size: 36rpx;
  color: #ffffff;
  line-height: 1;
}

.qrcode-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 40rpx;
  gap: 30rpx;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  padding: 20rpx;
  box-sizing: border-box;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #8E8E93;
  text-align: center;
}

.qrcode-tip--name {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.qrcode-copy-btn {
  margin-top: 10rpx;
  padding: 16rpx 40rpx;
  background: rgba(0, 122, 255, 0.9);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.qrcode-copy-btn:active {
  background: rgba(0, 122, 255, 0.7);
  transform: scale(0.97);
}

.qrcode-copy-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* LL2 飞行时间线（launch.timeline，与详情页 mission.id 绑定） */
.detail-ll2-section {
  margin-top: 36rpx;
}

/* 发射统计面板（基础信息上方）：型号/发射商两组大数字 */
.detail-stats-section .detail-section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.mission-stats-ordinal-chip {
  font-size: 22rpx;
  font-weight: 600;
  color: #64d2ff;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(100, 210, 255, 0.12);
  border: 1px solid rgba(100, 210, 255, 0.25);
}

.mission-stats-title-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mission-stats-global-link {
  font-size: 22rpx;
  font-weight: 600;
  color: #4a9eff;
  padding: 6rpx 4rpx;
}

.mission-stats-card--tap {
  opacity: 0.82;
  transform: scale(0.99);
}

.mission-stats-card {
  padding: 28rpx 24rpx 20rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.mission-stats-card--error {
  border-left: 4rpx solid rgba(255, 69, 58, 0.75);
}

.mission-stats-groups {
  display: flex;
  align-items: stretch;
}

.mission-stats-group {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mission-stats-group-gap {
  width: 1px;
  background: rgba(255, 255, 255, 0.08);
  margin: 0 24rpx;
}

.mission-stats-group-name {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.78);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mission-stats-pair {
  display: flex;
  align-items: center;
}

.mission-stats-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.mission-stats-cell-divider {
  width: 1px;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.06);
  margin: 0 16rpx;
}

.mission-stats-num {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #ffffff;
  font-variant-numeric: tabular-nums;
}

.mission-stats-num--accent {
  color: #64d2ff;
}

.mission-stats-cap {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.45);
}

.detail-ll2-timeline-head {
  margin-bottom: 20rpx;
}

.detail-ll2-section > .detail-section-title-row {
  width: 100%;
  box-sizing: border-box;
}

.detail-ll2-main .ll2-timeline-title {
  font-size: 29rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.45;
  font-weight: 500;
}

.detail-ll2-main .ll2-timeline-title--lift {
  font-weight: 700;
  color: #ffffff;
}

.detail-ll2-intro {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.detail-ll2-intro-net {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}

.detail-ll2-card {
  padding: 24rpx 28rpx;
  border-left: 4rpx solid rgba(100, 210, 255, 0.75);
  box-sizing: border-box;
}

.detail-ll2-card--body {
  padding: 28rpx 24rpx 32rpx;
}

.detail-ll2-card--error {
  border-left-color: rgba(255, 69, 58, 0.75);
}

.detail-ll2-card--pad {
  padding: 28rpx 30rpx;
}

.detail-ll2-muted {
  font-size: 26rpx;
  color: #8e8e93;
  line-height: 1.45;
}

.detail-ll2-error {
  font-size: 26rpx;
  color: #ff453a;
  line-height: 1.45;
  display: block;
  margin-bottom: 12rpx;
}

.detail-ll2-retry {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64d2ff;
}

.detail-ll2-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 16rpx 0;
}

.detail-ll2-axis {
  width: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.detail-ll2-line {
  width: 2rpx;
  flex: 1;
  min-height: 16rpx;
  background: rgba(255, 255, 255, 0.14);
}

.detail-ll2-node {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(100, 210, 255, 0.16);
  border: 2rpx solid rgba(100, 210, 255, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-ll2-node-mark {
  flex-shrink: 0;
  box-sizing: border-box;
}

.detail-ll2-node-mark--dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.detail-ll2-node-mark--solid {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
}

.detail-ll2-node-mark--ring {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
}

.detail-ll2-node-mark--diamond {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.88);
  transform: rotate(45deg);
}

.detail-ll2-node-mark--square {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.88);
}

.detail-ll2-node-mark--lift {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 9rpx 15rpx 9rpx;
  border-color: transparent transparent rgba(255, 255, 255, 0.9) transparent;
  background: transparent;
}

.detail-ll2-main {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.detail-ll2-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.58);
  margin-top: 8rpx;
  display: block;
  line-height: 1.45;
}

.detail-ll2-clock {
  font-size: 22rpx;
  color: rgba(100, 210, 255, 0.95);
  flex-shrink: 0;
  white-space: nowrap;
  align-self: flex-start;
  padding-top: 4rpx;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */

/* —— 页面骨架 —— */
.detail-page.theme-light {
  background: var(--color-bg-page);
}

.theme-light .nav-title-sub {
  color: var(--color-text-tertiary);
}

/* 本文件重定义了 .glass-card（深玻璃），需局部覆盖回浅玻璃 */
.theme-light .glass-card {
  background: var(--bg-glass);
  border: 1px solid var(--color-border-glass);
  box-shadow: var(--shadow-card), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

/* 版块卡片：浅色主题下为白底圆角卡（与监控中心一致） */
.theme-light .detail-section,
.theme-light .detail-block {
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.theme-light .meta-patch-img {
  background: rgba(0, 0, 0, 0.04);
}

/* 头图加载占位：深灰 → 浅灰 */
.theme-light .hero-image {
  background: #ECECF1;
}

/* —— 徽章 / 元信息 —— */
.theme-light .type-badge.status-pending {
  color: var(--color-brand);
  background: rgba(0, 122, 255, 0.12);
  border-color: rgba(0, 122, 255, 0.3);
}

.theme-light .type-badge.status-inflight {
  color: #0a84ff;
  background: rgba(90, 200, 250, 0.14);
  border-color: rgba(10, 132, 255, 0.35);
}

.theme-light .type-badge.status-deployed {
  color: #248a3d;
  background: rgba(52, 199, 89, 0.12);
  border-color: rgba(52, 199, 89, 0.3);
}

.theme-light .date-text {
  color: var(--color-text-secondary);
}

.theme-light .detail-title {
  color: var(--color-text-primary);
}

.theme-light .detail-subhead {
  color: var(--color-brand);
}

/* —— 正文文字 —— */
.theme-light .section-text--compact {
  color: var(--color-text-secondary);
}

.theme-light .section-text,
.theme-light .detail-text {
  color: #3A3A3C;
}

.theme-light .detail-section-content {
  color: var(--color-text-primary);
}

/* —— 失败原因 / 发射动态（浅色主题） —— */
.theme-light .detail-failreason-card {
  background: rgba(255, 59, 48, 0.06);
  border-color: rgba(255, 59, 48, 0.22);
}

.theme-light .detail-failreason-text {
  color: #d70015;
}

.theme-light .detail-update-comment {
  color: var(--color-text-primary);
}

.theme-light .detail-update-line {
  background: rgba(0, 0, 0, 0.12);
}

.theme-light .detail-update-line--hidden {
  background: transparent;
}

.theme-light .detail-update-node {
  background: rgba(0, 0, 0, 0.25);
}

.theme-light .detail-update-node--latest {
  background: #007aff;
  box-shadow: 0 0 10rpx rgba(0, 122, 255, 0.35);
}

.theme-light .detail-block-hint {
  color: var(--color-text-tertiary);
}

.theme-light .detail-stats-section .mission-stats-card,
.theme-light .detail-section .detail-ll2-card {
  background: rgba(0, 0, 0, 0.03);
  border: 1px solid var(--color-divider);
  box-shadow: none;
}

.theme-light .detail-update-time,
.theme-light .detail-update-author,
.theme-light .detail-status-note,
.theme-light .detail-program-meta-item {
  color: var(--color-text-tertiary);
}

.theme-light .detail-program-card {
  background: rgba(0, 0, 0, 0.03);
  border-color: var(--color-divider);
}

.theme-light .detail-program-name,
.theme-light .detail-related-link-title {
  color: var(--color-text-primary);
}

.theme-light .detail-related-link {
  border-bottom-color: var(--color-divider);
}

/* —— 规格胶囊 —— */
.theme-light .rocket-spec-cell {
  background: rgba(0, 0, 0, 0.04);
  border: 1px solid var(--color-divider);
}

.theme-light .rocket-spec-label {
  color: var(--color-text-tertiary);
}

.theme-light .rocket-spec-value {
  color: var(--color-text-primary);
}

/* —— 倒计时（卡片内，非压图，转浅色）—— */
.theme-light .countdown-item--tech {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.045), rgba(0, 0, 0, 0.02));
  border: 1px solid var(--color-divider);
}

.theme-light .countdown-value {
  color: var(--color-text-primary);
  text-shadow: none;
}

.theme-light .countdown-label {
  color: var(--color-text-tertiary);
}

.theme-light .countdown-value-seconds {
  color: var(--color-brand);
}

/* —— 直播观看 —— */
.theme-light .livestream-btn {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider);
}

.theme-light .livestream-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .livestream-btn--primary {
  border-color: rgba(0, 122, 255, 0.28);
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.10), rgba(255, 255, 255, 0.62));
}

.theme-light .livestream-btn--bilibili {
  border-color: rgba(251, 114, 153, 0.35);
  background: linear-gradient(135deg, rgba(251, 114, 153, 0.10), rgba(255, 255, 255, 0.62));
}

.theme-light .livestream-btn-title {
  color: var(--color-text-primary);
}

.theme-light .livestream-btn-sub {
  color: var(--color-text-tertiary);
}

.theme-light .icon-arrow--livestream {
  color: var(--color-text-tertiary);
}

/* —— 发射提醒 —— */
.theme-light .subscribe-row {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider);
}

.theme-light .subscribe-row--active {
  background: rgba(7, 193, 96, 0.1);
  border-color: rgba(7, 193, 96, 0.32);
}

.theme-light .subscribe-title {
  color: var(--color-text-primary);
}

.theme-light .subscribe-desc {
  color: var(--color-text-secondary);
}

.theme-light .subscribe-desc--active {
  color: #248A3D;
}

.theme-light .icon-arrow--subscribe,
.theme-light .subscribe-check {
  color: var(--color-text-secondary);
}

/* —— 地图预览（地图叠层提示保持深色压图样式）—— */
.theme-light .mission-map-preview-wrap {
  border: 1px solid var(--color-divider);
}

.theme-light .mission-map-site-name {
  color: var(--color-text-secondary);
}

.theme-light .mission-map-quick-link-text {
  color: var(--color-brand);
}

.theme-light .mission-map-quick-link-arrow {
  color: rgba(0, 122, 255, 0.55);
}

/* —— 竞猜 —— */
.theme-light .vote-box {
  border: 1px solid var(--color-divider);
  background: rgba(0, 0, 0, 0.03);
}

.theme-light .vote-box-label {
  color: var(--color-text-tertiary);
}

.theme-light .vote-type-tab {
  color: rgba(0, 0, 0, 0.4);
}

.theme-light .vote-type-tab--active {
  color: rgba(0, 0, 0, 0.88);
  background: rgba(0, 0, 0, 0.06);
}

.theme-light .vote-pill {
