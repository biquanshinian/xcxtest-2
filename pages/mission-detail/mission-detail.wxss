}
.theme-light .detail-sim-entry-dot {
  background: #00a862;
  box-shadow: 0 0 10rpx rgba(0, 168, 98, 0.6);
}
.theme-light .detail-sim-entry-tag {
  color: #00915a;
}
.theme-light .detail-sim-entry-title {
  color: #1C1C1E;
  text-shadow: none;
}
.theme-light .detail-sim-entry-desc {
  color: rgba(28, 28, 30, 0.55);
}
.theme-light .detail-sim-entry-arrow {
  color: #ffffff;
  background: linear-gradient(135deg, #00c46a, #00a862);
  box-shadow: 0 4rpx 16rpx rgba(0, 168, 98, 0.3);
}
