<wxs module="navPad" src="/utils/nav-scroll-pad.wxs"></wxs>
<!--pages/monitor/monitor.wxml-->
<page-meta background-color="{{pageBgColor}}" background-color-top="{{pageBgColor}}" background-color-bottom="{{pageBgColor}}" />
<view class="container {{themeClass}}">
  <!-- 顶部导航栏（包含状态栏） -->
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-center">
      <text class="nav-title nav-title--page-center">监控中心</text>
    </view>
  </view>

  <scroll-view
    class="content-scroll main-content-scroll nav-aware-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    bounces="{{true}}"
    refresher-enabled="{{true}}"
    refresher-default-style="{{themeLight ? 'black' : 'white'}}"
    refresher-background="{{pageBgColor}}"
    refresher-triggered="{{scrollRefreshing}}"
    data-nav-h="{{navPlaceholderHeight}}"
    bindrefresherpulling="{{navPad.onPulling}}"
    bindrefresherrestore="{{navPad.onReset}}"
    bindrefresherabort="{{navPad.onReset}}"
    bindrefresherrefresh="onScrollRefresh"
  >
    
    <nav-scroll-pad id="navScrollPad" class="nav-scroll-pad" height="{{navPlaceholderHeight}}" />
<!-- 星舰基地监控中心：MARS 预览（云中转）+ 关于 / 收藏（原生，防套壳） -->
    <view class="MARS-preview-section monitor-block">
      <view class="section-title">
        <text>星舰基地监控</text>
      </view>
      <!-- 新增：用户网页预览入口 -->
      <view class="MARS-preview-card glass-card card-hover" bindtap="openUserWebPreview">
        <view class="preview-card-content">
          <view class="preview-card-info">
            <text class="preview-card-title">星舰监控中心</text>
            <text class="preview-card-desc">实时监控星舰基地建设进度（网页版）</text>
          </view>
          <view class="icon-arrow icon-arrow--preview-card">›</view>
        </view>
      </view>
    </view>

    <!-- 直播观看：视频号 channel-live + B站入口（后台 enableLiveWatch 开关控制） -->
    <view class="monitor-livestream-section monitor-block" wx:if="{{enableLiveWatch}}">
        <view class="section-title monitor-livestream-section-title">
          <view class="monitor-livestream-title-left">
            <text class="monitor-livestream-heading-text">直播观看</text>
            <view class="livestream-live-tag" wx:if="{{channelsLiveStatus === 2}}">
              <view class="livestream-live-eq" aria-hidden="true">
                <view class="livestream-live-eq-bar"></view>
                <view class="livestream-live-eq-bar"></view>
                <view class="livestream-live-eq-bar"></view>
              </view>
              <text class="livestream-live-tag-text">直播中</text>
            </view>
          </view>
          <view class="section-title-right starbase-weather-cluster">
            <text class="starbase-weather-place">博卡奇卡</text>
            <view wx:if="{{starbaseWeather.loading}}" class="starbase-weather-loading"><text>天气载入中…</text></view>
            <block wx:elif="{{starbaseWeather.loaded}}">
              <view class="starbase-weather-row starbase-weather-row--main">
                <image class="starbase-wx-icon" src="{{starbaseWeather.weatherIcon}}" mode="aspectFit"></image>
                <text class="starbase-wx-condition">{{starbaseWeather.conditionText}}</text>
                <text class="starbase-wx-temp">{{starbaseWeather.tempLine}}</text>
              </view>
              <view class="starbase-weather-row starbase-weather-row--sub">
                <text class="starbase-wx-time">{{starbaseWeather.timeLine}}</text>
                <view class="starbase-wx-wind">
                  <image class="starbase-wind-icon" src="{{starbaseWeather.windIcon}}" mode="aspectFit"></image>
                  <text class="starbase-wx-wind-text">{{starbaseWeather.windLine}}</text>
                </view>
              </view>
            </block>
            <text wx:elif="{{starbaseWeather.error}}" class="starbase-weather-err">{{starbaseWeather.error}}</text>
          </view>
        </view>
        <view class="monitor-livestream-stack">
          <channels-live-panel
            id="channelsLivePanel"
            prefer-fallback-guide="{{channelsFallbackGuide.enabled}}"
            bind:statuschange="onChannelsLiveStatusChange"
            bind:fallbackguide="onChannelsLiveFallbackGuide"
          />

          <view class="monitor-livestream-entry-row">
            <view
              wx:if="{{channelsFallbackGuide.enabled}}"
              class="monitor-livestream-btn monitor-livestream-btn--channels-guide monitor-livestream-btn--half"
              bindtap="onChannelsGuideTap"
              hover-class="monitor-livestream-btn--hover"
            >
              <view class="monitor-livestream-btn-icon">
                <image class="monitor-livestream-icon-img" src="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E5%9B%BE%E6%A0%87/1778430366049_f5kzse.svg" mode="aspectFit"></image>
              </view>
              <view class="monitor-livestream-btn-info">
                <text class="monitor-livestream-btn-title">推荐直播</text>
                <text class="monitor-livestream-btn-sub">{{channelsFallbackGuide.nickname}}</text>
              </view>
            </view>

            <view class="monitor-livestream-btn monitor-livestream-btn--bilibili {{channelsFallbackGuide.enabled ? 'monitor-livestream-btn--half' : 'monitor-livestream-btn--full'}}" bindtap="onBiliLiveTap" hover-class="monitor-livestream-btn--hover">
              <view class="monitor-livestream-btn-icon">
                <image class="monitor-livestream-icon-img" src="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E5%9B%BE%E6%A0%87/1778430483411_43m2pg.svg" mode="aspectFit"></image>
              </view>
              <view class="monitor-livestream-btn-info">
                <text class="monitor-livestream-btn-title">B站直播</text>
                <text class="monitor-livestream-btn-sub">{{biliLive.title || '扫码进入'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

    <!-- 新增：太空轨道数据中心系统（科幻入口） -->
    <view class="odc-section monitor-block">
      <view class="section-title section-title--orbital">
        <text>太空轨道数据中心</text>
      </view>
      <view class="orbital-card glass-card card-hover" bindtap="openOrbitalDataCenter">
        <video
          wx:if="{{orbitalCardBgIsVideo && orbitalCardBg}}"
          class="orbital-card__bg-img"
          src="{{orbitalCardBg}}"
          object-fit="cover"
          autoplay="{{true}}"
          loop="{{true}}"
          muted="{{true}}"
          show-center-play-btn="{{false}}"
          show-play-btn="{{false}}"
          controls="{{false}}"
          enable-progress-gesture="{{false}}"
          show-fullscreen-btn="{{false}}"
          show-mute-btn="{{false}}"
          binderror="onOrbitalBgError"
        ></video>
        <image wx:elif="{{orbitalCardBg}}" class="orbital-card__bg-img" src="{{orbitalCardBg}}" mode="aspectFill" lazy-load="true" binderror="onOrbitalBgError"></image>
        <view class="orbital-card__bg-mask"></view>
        <view class="orbital-card__bg">
          <view class="orbital-card__orbit orbital-card__orbit--1">
            <view class="orbital-card__orbit-dot orbital-card__orbit-dot--green"></view>
          </view>
          <view class="orbital-card__orbit orbital-card__orbit--2">
            <view class="orbital-card__orbit-dot orbital-card__orbit-dot--blue"></view>
          </view>
          <view class="orbital-card__orbit orbital-card__orbit--3">
            <view class="orbital-card__orbit-dot orbital-card__orbit-dot--red"></view>
          </view>
          <view class="orbital-card__core"></view>
        </view>
        <view class="orbital-card__content">
          <view class="orbital-card__head">
            <view class="orbital-card__badge">
              <view class="orbital-card__badge-dot"></view>
              <text class="orbital-card__badge-text">FUTURE TECH · BETA</text>
            </view>
          </view>
          <text class="orbital-card__title">Orbital Data Center System</text>
          <text class="orbital-card__title-cn">太空轨道数据中心系统</text>
          <text class="orbital-card__desc">SpaceX 下一代轨道战略</text>
          <view class="orbital-card__metrics">
            <view class="orbital-card__metric">
              <text class="orbital-card__metric-value">{{orbitalLiveStats.activeNodes}}</text>
              <text class="orbital-card__metric-label">在轨节点</text>
            </view>
            <view class="orbital-card__metric-divider"></view>
            <view class="orbital-card__metric">
              <text class="orbital-card__metric-value">{{orbitalLiveStats.bandwidth}}</text>
              <text class="orbital-card__metric-label">数据吞吐</text>
            </view>
            <view class="orbital-card__metric-divider"></view>
            <view class="orbital-card__metric">
              <text class="orbital-card__metric-value">{{orbitalLiveStats.uptime}}</text>
              <text class="orbital-card__metric-label">系统在线</text>
            </view>
          </view>
        </view>
        <view class="orbital-card__cta {{isProUser ? 'pro-gold-frame' : ''}}">
          <text class="orbital-card__cta-text">{{orbitalCardCta || '进入指挥控制台'}}</text>
          <text class="orbital-card__cta-pro" wx:if="{{!isProUser}}"></text>
          <view class="orbital-card__cta-arrow">→</view>
        </view>
      </view>
    </view>

    <!-- 进度显示框 -->
    <!-- 空间站实时状态 -->
    <view class="station-section monitor-block">
      <view class="section-title">
        <view class="section-title-main">
          <text>空间站实时状态</text>
          <text class="section-subtitle">ISS / 天宫</text>
        </view>
        <view class="section-badge" wx:if="{{stationList.length}}">{{stationList.length}}</view>
        <view class="section-title-right">
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="station" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态 -->
      <lazy-load-card wx:if="{{!stationReady}}" icon="" text="点击加载空间站状态" hint="ISS / 天宫空间站实时数据" bind:tap="onLoadStationStatus" />

      <block wx:else>
      <!-- 加载中 -->
      <view class="station-loading" wx:if="{{stationLoading}}">
        <text class="station-loading-text">加载空间站数据...</text>
      </view>

      <!-- 两个空间站卡片并排 -->
      <view class="station-row" wx:if="{{stationList.length}}">
        <view class="station-mini-card glass-card"
              wx:for="{{stationList}}" wx:key="id"
              data-station-id="{{item.id}}" bindtap="onStationCardTap">
          <image class="station-mini-img {{stationImageLoadedMap[index] ? 'station-mini-img--loaded' : ''}}" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" lazy-load bindload="onStationImageLoad" binderror="onStationImageError" data-index="{{index}}" />
          <view class="station-mini-img station-mini-img--placeholder" wx:else></view>
          <view class="station-mini-body">
            <text class="station-mini-name">{{item.name}}</text>
            <view class="station-mini-tags">
              <text class="station-tag station-tag--active" wx:if="{{item.statusTone === 'active'}}">运行中</text>
              <text class="station-mini-dock">{{item.dockedCount}} 艘停靠</text>
            </view>
          </view>
          <view class="station-mini-arrow">
            <text>›</text>
          </view>
        </view>
      </view>

      <!-- 无数据 -->
      <view class="station-empty" wx:if="{{!stationLoading && !stationList.length}}">
        <view class="station-empty-visual"></view>
        <text class="empty-state-text">空间站数据加载失败</text>
        <text class="empty-state-hint">请稍后重试</text>
      </view>
      </block>
    </view>

    <!-- 星链实时分布 -->
    <view class="starlink-section monitor-block">
      <view class="section-title">
        <text>星链实时分布</text>
        <view class="section-badge" wx:if="{{starlinkCount}}">{{starlinkCount}}</view>
        <view class="section-title-right">
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="starlink" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态：显示加载按钮 -->
      <lazy-load-card wx:if="{{!starlinkReady}}" icon="" text="点击加载卫星实时分布" hint="需加载轨道数据，可能需要几秒" bind:tap="onLoadStarlink" />

      <view class="starlink-card glass-card" wx:else>
        <!-- 加载态 -->
        <view class="starlink-loading" wx:if="{{starlinkLoading}}">
          <text class="starlink-loading-icon"></text>
          <text class="starlink-loading-text">加载卫星轨道数据...</text>
        </view>
        <!-- 错误态 -->
        <view class="starlink-error" wx:elif="{{starlinkError}}">
          <text class="starlink-error-text">{{starlinkError}}</text>
          <view class="starlink-retry-btn" bindtap="retryLoadStarlink">重试</view>
        </view>
        <!-- 正常态：Canvas 地图 -->
        <block wx:else>
          <view class="starlink-canvas-wrap">
            <canvas type="2d" id="starlinkCanvas" class="starlink-canvas" bindtouchstart="onStarlinkTouchStart" bindtouchmove="onStarlinkTouchMove" bindtouchend="onStarlinkTouchEnd"></canvas>
            <!-- 全屏按钮 -->
            <view class="starlink-expand-hint {{isProUser ? 'pro-gold-frame' : ''}}" bindtap="openStarlinkFullscreen">
              <text class="starlink-expand-text">全屏</text>
            </view>
            <!-- 暂停/播放按钮 -->
            <view class="starlink-ctrl-bar">
              <view class="starlink-ctrl-btn" bindtap="toggleStarlinkPause">
                <text>{{starlinkPaused ? '▶' : '⏸'}}</text>
              </view>
              <text class="starlink-ctrl-info">在轨 {{starlinkCount}} 颗 · {{starlinkUpdateTime}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- Starlink 过境预报 -->
    <view class="pass-section monitor-block">
      <view class="section-title">
        <text>星链过境预报</text>
        <view class="section-title-right pass-actions">
          <view class="pass-refresh-chip" bindtap="refreshPasses" wx:if="{{passReady && !passLoading}}">
            <text>刷新</text>
          </view>
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="pass" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态 -->
      <lazy-load-card wx:if="{{!passReady}}" icon="" text="点击加载过境预报" hint="需要位置权限和轨道数据" bind:tap="onLoadStarlinkPasses" />

      <block wx:else>
      <!-- 融合入口卡片：位置 + 预报摘要 + 光效背景 -->
      <view class="pass-hero-card glass-card" wx:if="{{passReady && !passLoading && !passNoLocation && !passError}}" bindtap="openPassDetail">
        <!-- 星链列车拖尾光效 -->
        <view class="pass-hero-trail pass-hero-trail--1"></view>
        <view class="pass-hero-trail pass-hero-trail--2"></view>
        <view class="pass-hero-trail pass-hero-trail--3"></view>

        <view class="pass-hero-card-body">
          <view class="pass-hero-card-top">
            <view class="pass-hero-card-info">
              <text class="pass-hero-card-title" wx:if="{{passList.length > 0}}">{{passList.length}} 次可见过境</text>
              <text class="pass-hero-card-title" wx:else>暂无可见过境</text>
              <text class="pass-hero-card-loc" wx:if="{{passLocation}}">{{passLocation}}</text>
            </view>
            <view class="pass-hero-card-btns">
              <view class="pass-hero-chip {{isProUser ? 'pass-hero-chip--pro' : ''}}" catchtap="openPassMap" wx:if="{{passList.length > 0}}">
                <text>地图</text>
              </view>
              <view class="pass-hero-chip {{isProUser ? 'pass-hero-chip--pro' : ''}}" catchtap="openStarlinkAR">
                <text>AR</text>
              </view>
            </view>
          </view>
          <view class="pass-hero-card-bottom" wx:if="{{passList.length > 0 && passList[0]}}">
            <text class="pass-hero-card-next">最近 {{passList[0].startTimeStr}}</text>
            <text class="pass-hero-card-meta">仰角 {{passList[0].maxElev}}° · {{passList[0].startDirection}}→{{passList[0].endDirection}} · {{passList[0].durationMin}}分钟</text>
          </view>
          <view class="pass-hero-card-bottom" wx:elif="{{passList.length === 0}}">
            <text class="pass-hero-card-meta">查看观测指南与讨论区</text>
          </view>
        </view>
        <text class="pass-hero-card-arrow">›</text>
      </view>

      <view class="pass-loading glass-card" wx:elif="{{passLoading}}">
        <text class="empty-state-text">计算过境数据...</text>
      </view>
      <view class="pass-empty glass-card" wx:elif="{{passNoLocation}}">
        <image class="pass-location-icon" src="/images/icons/icon-location.svg" mode="aspectFit"></image>
        <text class="empty-state-text">需要位置权限</text>
        <text class="empty-state-hint" wx:if="{{passError}}">{{passError}}</text>
        <view class="pass-locate-btn" bindtap="requestPassLocation">
          <text>授权定位</text>
        </view>
      </view>
      <view class="pass-empty glass-card" wx:elif="{{passError}}">
        <text class="empty-state-text">加载失败</text>
        <text class="empty-state-hint">{{passError}}</text>
        <view class="pass-locate-btn" bindtap="refreshPasses">
          <text>重试</text>
        </view>
      </view>
      </block>
    </view>

    <!-- ========== 全球发射商图鉴 ========== -->
    <view class="agency-section monitor-block">
      <view class="section-title">
        <text>全球发射商图鉴</text>
        <view class="section-badge" wx:if="{{agencyTotal}}">{{agencyTotal}}</view>
        <view class="section-title-right">
          <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
                bindtap="onViewAllAgencies">
            <text>查看全部</text>
            <text class="booster-view-all-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 加载骨架 -->
      <view class="agency-grid" wx:if="{{agencyLoading}}">
        <view class="agency-hw-card glass-card agency-hw-card-skeleton skeleton-shimmer" wx:for="{{[0, 1]}}" wx:key="*this"></view>
      </view>

      <!-- 错误态 -->
      <view class="agency-error glass-card" wx:elif="{{agencyError}}">
        <text class="empty-state-text">{{agencyError}}</text>
        <view class="agency-retry-btn" bindtap="retryLoadAgencies">
          <text>重试</text>
        </view>
      </view>

      <block wx:else>
        <!-- 卡片网格（预览 2 张） -->
        <view class="agency-grid" wx:if="{{agencyVisible.length > 0}}">
          <view
            class="agency-hw-card glass-card card-hover"
            wx:for="{{agencyVisible}}"
            wx:key="id"
            data-id="{{item.id}}"
            data-index="{{index}}"
            bindtap="onAgencyTap"
          >
            <view class="agency-hw-card-image-wrap">
              <image
                wx:if="{{item.displayImage}}"
                class="agency-hw-card-image {{item.imageMode === 'aspectFit' ? 'agency-hw-card-image--logo' : ''}}"
                src="{{item.displayImage}}"
                mode="{{item.imageMode}}"
                lazy-load="{{true}}"
                data-index="{{index}}"
                binderror="onAgencyImageError"
              ></image>
              <view class="agency-hw-card-image-placeholder" wx:else>
                <text>{{item.countryFlag || '🛰'}}</text>
              </view>
              <view class="agency-hw-card-image-mask"></view>
              <view class="agency-hw-card-overlay">
                <view class="agency-hw-card-badge">
                  <text class="agency-type-tag agency-type--{{item.typeClass}}">{{item.typeZh}}</text>
                </view>
                <text class="agency-hw-card-name">{{item.displayName}}</text>
              </view>
            </view>
            <view class="agency-hw-card-body">
              <text class="agency-hw-card-meta">{{item.countryFlag}} {{item.metaLine}}</text>
              <text class="agency-hw-card-notes">{{item.description}}</text>
            </view>
          </view>
        </view>

        <!-- 空态 -->
        <view class="agency-empty glass-card" wx:if="{{agencyVisible.length === 0}}">
          <text>暂无发射商数据，稍后再来看看</text>
        </view>

      </block>
    </view>

    <!-- Artemis II 遥测已迁至 NASA 发射商详情页；手机直连星链(D2C) 已迁至 SpaceX 发射商详情页 -->

    <!-- 可回收火箭族谱 -->
    <view class="booster-section monitor-block">
      <view class="section-title">
        <text>全球可回收火箭族谱</text>
        <view class="section-badge" wx:if="{{boosterList.length}}">{{boosterList.length}}</view>
        <view class="section-title-right">
          <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
                bindtap="onViewAllBoosters" wx:if="{{boosterFilterChips.length > 0}}">
            <text>查看全部</text>
            <text class="booster-view-all-arrow">›</text>
          </view>
        </view>
      </view>
      <!-- 筛选 chip：全部 / 中国 / 各厂商（数据动态生成） -->
      <scroll-view scroll-x class="booster-filter-scroll" wx:if="{{boosterFilterChips.length > 0}}" enhanced show-scrollbar="{{false}}">
        <view class="booster-filter-row">
          <view class="booster-filter-chip {{boosterFilter === chip.id ? 'booster-filter-chip--active' : ''}}"
                wx:for="{{boosterFilterChips}}" wx:for-item="chip" wx:key="id"
                data-filter="{{chip.id}}" bindtap="onBoosterFilterTap">
            <text>{{chip.label}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="booster-summary glass-card" wx:if="{{boosterList.length > 0}}">
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{boosterStats.activeCount}}</text>
          <text class="booster-summary-label">现役</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{boosterStats.maxFlights}}</text>
          <text class="booster-summary-label">最高复用</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{boosterStats.totalFlights}}</text>
          <text class="booster-summary-label">总飞行</text>
        </view>
        <view class="booster-summary-item" wx:if="{{boosterStats.manufacturerCount > 1}}">
          <text class="booster-summary-value">{{boosterStats.manufacturerCount}}</text>
          <text class="booster-summary-label">厂商</text>
        </view>
      </view>
      <scroll-view scroll-x class="booster-scroll" wx:if="{{boosterList.length > 0}}" bindscroll="onBoosterScroll" throttle="{{true}}">
        <view class="booster-card glass-card" wx:for="{{boosterList}}" wx:key="serial" data-serial="{{item.serial}}" bindtap="onBoosterCardTap">
          <!-- 助推器图片 -->
          <view class="booster-img-wrap">
            <image class="booster-img {{boosterImageLoadedMap[index] ? 'booster-img--loaded' : ''}}"
                   wx:if="{{item.thumbnailUrl}}"
                   src="{{item.thumbnailUrl}}"
                   mode="aspectFill" lazy-load
                   bindload="onBoosterImageLoad"
                   binderror="onBoosterImageError"
                   data-index="{{index}}" />
            <view class="booster-img booster-img--placeholder" wx:else>
              <text class="booster-img-icon"></text>
            </view>
            <!-- 状态角标 -->
            <text class="booster-status-badge booster-status-badge--{{item.status}}">{{item.statusText}}</text>
          </view>
          <!-- 信息区 -->
          <view class="booster-card-body">
            <view class="booster-serial-row">
              <text class="booster-serial">{{item.serial}}</text>
              <text class="booster-country-flag" wx:if="{{item.countryFlag}}">{{item.countryFlag}}</text>
            </view>
            <view class="booster-tag-row">
              <text class="booster-family-tag">{{item.rocketFamily}}</text>
              <text class="booster-mfr-tag" wx:if="{{item.manufacturer}}">{{item.manufacturer}}</text>
            </view>
            <view class="booster-key-stats">
              <view class="booster-stat-item">
                <text class="booster-stat-num">{{item.flights}}</text>
                <text class="booster-stat-label">飞行</text>
              </view>
              <view class="booster-stat-item">
                <text class="booster-stat-num">{{item.successfulLandings}}</text>
                <text class="booster-stat-label">着陆</text>
              </view>
            </view>
            <view class="booster-flights-bar">
              <view class="flight-block {{flight.pending ? 'flight-pending' : (flight.success ? 'flight-success' : (flight.failed ? 'flight-fail' : 'flight-unknown'))}}" wx:for="{{item.flightBlocks}}" wx:for-item="flight" wx:key="idx"></view>
            </view>
            <text class="booster-turnaround" wx:if="{{item.fastestTurnaroundText}}">⚡ {{item.fastestTurnaroundText}}</text>
          </view>
          <!-- 箭头 -->
          <view class="booster-card-arrow">›</view>
        </view>
      </scroll-view>
      <view class="booster-loading glass-card" wx:elif="{{boosterLoading}}">
        <text class="empty-state-text">加载助推器数据...</text>
      </view>
      <view class="booster-loading glass-card" wx:elif="{{boosterLoadError}}" bindtap="onRetryBoosterLoad">
        <text class="empty-state-text">助推器数据加载失败，点击重试</text>
      </view>
      <view class="booster-loading glass-card" wx:elif="{{boosterFilterEmpty}}">
        <text class="empty-state-text">该筛选下暂无箭实体记录，首飞后自动收录</text>
      </view>
      <empty-state wx:else icon="" text="暂无助推器数据" hint="数据同步后将自动展示" />
    </view>

    <!-- ========== 全球飞船图鉴 ========== -->
    <view class="sc-section monitor-block">
      <view class="section-title">
        <text>全球飞船图鉴</text>
        <view class="section-badge" wx:if="{{spacecraftList.length}}">{{spacecraftList.length}}</view>
        <view class="section-title-right">
          <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
                bindtap="onViewAllSpacecraft" wx:if="{{spacecraftFilterChips.length > 0}}">
            <text>查看全部</text>
            <text class="booster-view-all-arrow">›</text>
          </view>
        </view>
      </view>
      <!-- 筛选 chip：全部 / 现役 / 各类型（数据动态生成） -->
      <scroll-view scroll-x class="booster-filter-scroll" wx:if="{{spacecraftFilterChips.length > 0}}" enhanced show-scrollbar="{{false}}">
        <view class="booster-filter-row">
          <view class="booster-filter-chip {{spacecraftFilter === chip.id ? 'booster-filter-chip--active' : ''}}"
                wx:for="{{spacecraftFilterChips}}" wx:for-item="chip" wx:key="id"
                data-filter="{{chip.id}}" bindtap="onSpacecraftFilterTap">
            <text>{{chip.label}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="booster-summary glass-card" wx:if="{{spacecraftList.length > 0}}">
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{spacecraftStats.inUseCount}}</text>
          <text class="booster-summary-label">现役</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{spacecraftStats.typeCount}}</text>
          <text class="booster-summary-label">类型</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{spacecraftStats.agencyCount}}</text>
          <text class="booster-summary-label">机构</text>
        </view>
      </view>
      <scroll-view scroll-x class="booster-scroll" wx:if="{{spacecraftList.length > 0}}">
        <view class="sc-card glass-card" wx:for="{{spacecraftList}}" wx:key="id" data-id="{{item.id}}" data-name="{{item.name}}" data-img="{{item.imageUrl}}" bindtap="onSpacecraftCardTap">
          <view class="sc-img-wrap">
            <image class="sc-img"
                   wx:if="{{item.imageUrl}}"
                   src="{{item.imageUrl}}"
                   mode="aspectFill" lazy-load
                   binderror="onSpacecraftImageError"
                   data-index="{{index}}" />
            <view class="sc-img sc-img--placeholder" wx:else>
              <text class="sc-img-icon"></text>
            </view>
            <text class="sc-status-badge {{item.inUse ? 'sc-status-badge--active' : 'sc-status-badge--retired'}}">{{item.statusText}}</text>
          </view>
          <view class="sc-card-body">
            <text class="sc-name">{{item.name}}</text>
            <view class="sc-tag-row">
              <text class="sc-type-tag" wx:if="{{item.typeLabel}}">{{item.typeLabel}}</text>
              <text class="sc-agency-tag" wx:if="{{item.agencyLabel}}">{{item.agencyLabel}}</text>
            </view>
          </view>
          <view class="booster-card-arrow">›</view>
        </view>
      </scroll-view>
      <view class="booster-loading glass-card" wx:elif="{{spacecraftLoading}}">
        <text class="empty-state-text">加载飞船数据...</text>
      </view>
      <view class="booster-loading glass-card" wx:elif="{{spacecraftLoadError}}" bindtap="onRetrySpacecraftLoad">
        <text class="empty-state-text">飞船数据加载失败，点击重试</text>
      </view>
      <view class="booster-loading glass-card" wx:elif="{{spacecraftFilterEmpty}}">
        <text class="empty-state-text">该筛选下暂无飞船记录</text>
      </view>
      <empty-state wx:else icon="" text="暂无飞船数据" hint="数据同步后将自动展示" />
    </view>

    <!-- ========== 全球发射场分布 ========== -->
    <view class="ls-section monitor-block">
      <view class="section-title">
        <text>全球发射场分布</text>
        <view class="section-badge" wx:if="{{launchSiteList.length}}">{{launchSiteList.length}}</view>
        <view class="section-title-right">
          <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
                bindtap="onViewAllLaunchSites" wx:if="{{launchSiteFilterChips.length > 0}}">
            <text>查看全部</text>
            <text class="booster-view-all-arrow">›</text>
          </view>
        </view>
      </view>
      <!-- 筛选 chip：全部 / 活跃 / 各国家（数据动态生成） -->
      <scroll-view scroll-x class="booster-filter-scroll" wx:if="{{launchSiteFilterChips.length > 0}}" enhanced show-scrollbar="{{false}}">
        <view class="booster-filter-row">
          <view class="booster-filter-chip {{launchSiteFilter === chip.id ? 'booster-filter-chip--active' : ''}}"
                wx:for="{{launchSiteFilterChips}}" wx:for-item="chip" wx:key="id"
                data-filter="{{chip.id}}" bindtap="onLaunchSiteFilterTap">
            <text>{{chip.label}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="booster-summary glass-card" wx:if="{{launchSiteList.length > 0}}">
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{launchSiteStats.siteCount}}</text>
          <text class="booster-summary-label">发射场</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{launchSiteStats.activeCount}}</text>
          <text class="booster-summary-label">活跃</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{launchSiteStats.countryCount}}</text>
          <text class="booster-summary-label">国家</text>
        </view>
        <view class="booster-summary-item">
          <text class="booster-summary-value">{{launchSiteStats.totalLaunches}}</text>
          <text class="booster-summary-label">累计发射</text>
        </view>
      </view>
      <scroll-view scroll-x class="booster-scroll" wx:if="{{launchSiteList.length > 0}}">
        <view class="ls-card glass-card" wx:for="{{launchSiteList}}" wx:key="id" data-id="{{item.id}}" bindtap="onLaunchSiteCardTap">
          <view class="ls-img-wrap">
            <image class="ls-img"
                   wx:if="{{item.imageUrl}}"
                   src="{{item.imageUrl}}"
                   mode="aspectFill" lazy-load
                   binderror="onLaunchSiteImageError"
                   data-index="{{index}}" />
            <view class="ls-img ls-img--placeholder" wx:else>
              <text class="ls-img-icon"></text>
            </view>
            <text class="sc-status-badge {{item.active ? 'sc-status-badge--active' : 'sc-status-badge--retired'}}">{{item.statusText}}</text>
            <text class="ls-launch-badge">{{item.totalLaunchCount}} 次</text>
          </view>
          <view class="ls-card-body">
            <text class="ls-name">{{item.nameZh || item.name}}</text>
            <view class="ls-tag-row">
              <text class="ls-country-tag" wx:if="{{item.countryLabel}}">{{item.countryLabel}}</text>
              <text class="ls-sub-name" wx:if="{{item.nameZh}}">{{item.name}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="booster-loading glass-card" wx:elif="{{launchSiteLoading}}">
        <text class="empty-state-text">加载发射场数据...</text>
      </view>
      <view class="booster-loading glass-card" wx:elif="{{launchSiteLoadError}}" bindtap="onRetryLaunchSiteLoad">
        <text class="empty-state-text">发射场数据加载失败，点击重试</text>
      </view>
      <view class="booster-loading glass-card" wx:elif="{{launchSiteFilterEmpty}}">
        <text class="empty-state-text">该筛选下暂无发射场记录</text>
      </view>
      <empty-state wx:else icon="" text="暂无发射场数据" hint="数据同步后将自动展示" />
    </view>

    <!-- 即将进行的在轨任务（懒加载，节约资源） -->
    <view class="orbit-section monitor-block">
      <view class="section-title">
        <text>即将进行的在轨任务</text>
        <view class="section-badge" wx:if="{{orbitalReady && upcomingOrbitalEvents.length}}">{{upcomingOrbitalEvents.length}}</view>
        <view class="section-title-right">
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="orbit" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态 -->
      <lazy-load-card wx:if="{{!orbitalReady}}" icon="" text="点击加载在轨任务" hint="对接 / 出舱 / 入轨 等近期事件" bind:tap="onLoadUpcomingOrbitalEvents" />

      <block wx:else>
        <view class="station-loading" wx:if="{{orbitalLoading}}">
          <text class="station-loading-text">加载在轨任务...</text>
        </view>
        <view class="orbit-list" wx:elif="{{upcomingOrbitalEvents.length}}">
          <!-- 第一个任务：大号倒计时面板 -->
          <view class="orbit-hero glass-card" data-id="{{upcomingOrbitalEvents[0].id}}" bindtap="onUpcomingEventTap">
            <image class="orbit-hero-bg" wx:if="{{upcomingOrbitalEvents[0].imageUrl}}" src="{{upcomingOrbitalEvents[0].imageUrl}}" mode="aspectFill" lazy-load />
            <view class="orbit-hero-mask"></view>
            <view class="orbit-hero-content">
              <view class="orbit-hero-tags">
                <text class="orbit-hero-type">{{upcomingOrbitalEvents[0].typeName}}</text>
              </view>
              <text class="orbit-hero-title">{{upcomingOrbitalEvents[0].name}}</text>
              <view class="orbit-hero-countdown" wx:if="{{!orbitalCountdown.isExpired}}">
                <view class="orbit-cd-item">
                  <text class="orbit-cd-value">{{orbitalCountdown.days}}</text>
                  <text class="orbit-cd-label">天</text>
                </view>
                <text class="orbit-cd-sep">:</text>
                <view class="orbit-cd-item">
                  <text class="orbit-cd-value">{{orbitalCountdown.hours}}</text>
                  <text class="orbit-cd-label">时</text>
                </view>
                <text class="orbit-cd-sep">:</text>
                <view class="orbit-cd-item">
                  <text class="orbit-cd-value">{{orbitalCountdown.minutes}}</text>
                  <text class="orbit-cd-label">分</text>
                </view>
                <text class="orbit-cd-sep">:</text>
                <view class="orbit-cd-item">
                  <text class="orbit-cd-value">{{orbitalCountdown.seconds}}</text>
                  <text class="orbit-cd-label">秒</text>
                </view>
              </view>
              <view class="orbit-hero-countdown orbit-hero-countdown--live" wx:else>
                <text class="orbit-cd-live-text">进行中 / 已开始</text>
              </view>
              <view class="orbit-hero-meta">
                <text class="orbit-hero-date">{{upcomingOrbitalEvents[0].dateText}}</text>
                <text class="orbit-hero-location" wx:if="{{upcomingOrbitalEvents[0].location}}">{{upcomingOrbitalEvents[0].location}}</text>
              </view>
              <view class="orbit-hero-cta">
                <text class="orbit-hero-cta-text">查看详情 ›</text>
              </view>
            </view>
          </view>

          <!-- 其余任务：保持原有小卡片 -->
          <view class="orbit-card glass-card orbit-card--clickable" wx:for="{{upcomingOrbitalEvents}}" wx:if="{{index > 0}}" wx:key="id" data-id="{{item.id}}" bindtap="onUpcomingEventTap">
            <image class="orbit-card-img" wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
            <view class="orbit-card-body">
              <view class="orbit-card-meta orbit-card-meta--top">
                <text class="orbit-meta-tag orbit-meta-tag--type">{{item.typeName}}</text>
                <text class="orbit-meta-tag orbit-meta-tag--date">{{item.dateText}}</text>
              </view>
              <text class="orbit-card-title">{{item.name}}</text>
              <view class="orbit-card-meta" wx:if="{{item.location}}">
                <text class="orbit-meta-tag orbit-meta-tag--location">{{item.location}}</text>
              </view>
              <view class="orbit-timeline">
                <view class="orbit-stat orbit-stat--countdown {{item.countdownClass}}" wx:if="{{item.countdownText}}">
                  <text class="orbit-stat-value">{{item.countdownText}}</text>
                  <text class="orbit-stat-label">距开始</text>
                </view>
                <view class="orbit-stat orbit-stat--cta">
                  <text class="orbit-stat-value orbit-stat-cta-text">查看详情 ›</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <empty-state wx:else icon="" text="暂无即将进行的在轨任务" hint="对接、出舱等事件将自动汇聚" />
      </block>
    </view>

    <view style="height: {{tabBarReservedHeight}}px;"></view>
  </scroll-view>

  <!-- B站直播二维码弹窗 -->
  <view wx:if="{{showBiliQRModal}}" class="qrcode-modal" bindtap="hideBiliQRCode">
    <view class="qrcode-modal-content" catchtap="">
      <view class="qrcode-header">
        <text class="qrcode-title">B站直播</text>
        <view class="qrcode-close" bindtap="hideBiliQRCode">
          <text class="icon-close icon-close--qrcode">×</text>
        </view>
      </view>
      <view class="qrcode-body">
        <image class="qrcode-image" src="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E4%BA%8C%E7%BB%B4%E7%A0%81/1773602498836_o237or.png" mode="aspectFit" show-menu-by-longpress="{{true}}" bindtap="onBiliQRImageTap"></image>
        <text class="qrcode-tip">点击图片可预览，或复制链接在浏览器打开</text>
        <view class="qrcode-copy-btn" bindtap="onCopyBiliLiveLink">
          <text>复制直播链接</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 推荐第三方视频号主页二维码 -->
  <view wx:if="{{showChannelsGuideModal}}" class="qrcode-modal" bindtap="hideChannelsGuideModal">
    <view class="qrcode-modal-content" catchtap="">
      <view class="qrcode-header">
        <text class="qrcode-title">{{channelsFallbackGuide.title || '推荐观看'}}</text>
        <view class="qrcode-close" bindtap="hideChannelsGuideModal">
          <text class="icon-close icon-close--qrcode">×</text>
        </view>
      </view>
      <view class="qrcode-body">
        <text class="qrcode-tip qrcode-tip--name">{{channelsFallbackGuide.nickname}}</text>
        <image class="qrcode-image" src="{{channelsFallbackGuide.qrDisplayUrl || channelsFallbackGuide.qrUrl}}" mode="aspectFit" show-menu-by-longpress="{{true}}" bindtap="onChannelsGuideQRImageTap"></image>
        <text class="qrcode-tip">{{channelsFallbackGuide.tip || '扫码前往视频号主页，可预约或观看直播'}}</text>
        <view class="qrcode-copy-btn" bindtap="onCopyChannelsGuideNickname">
          <text>复制公众号名称</text>
        </view>
      </view>
    </view>
  </view>
  <ai-chat id="ai-chat" />
  <nasa-float />
  <privacy-modal id="globalPrivacyModal"></privacy-modal>
  <popup-ad visible="{{popupAdVisible}}" shop-item="{{popupAdItem}}" bind:close="onPopupAdClose"></popup-ad>
  <demo-overlay id="demoOverlay" showControls="{{false}}" qrcodeUrl="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E5%B0%8F%E7%A8%8B%E5%BA%8F%E4%BA%8C%E7%BB%B4%E7%A0%81/1775323336594_jkl6zv.png" loop="{{true}}" />
  <share-guide />
</view>
