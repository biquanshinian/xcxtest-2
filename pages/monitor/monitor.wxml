<wxs module="navPad" src="/utils/nav-scroll-pad.wxs"></wxs>
<!--pages/monitor/monitor.wxml-->
<page-meta background-color="{{pageBgColor}}" background-color-top="{{pageBgColor}}" background-color-bottom="{{pageBgColor}}" />
<view class="container {{themeClass}}">
  <!-- 顶部导航栏（包含状态栏） -->
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-center">
      <text class="nav-title nav-title--page-center">监控中心</text>
    </view>
  </view>

  <!-- 自定义下拉三点：复用首页样式（app.wxss + nav-scroll-pad.wxs） -->
  <view id="pullRefreshDots" class="pull-refresh-dots" aria-hidden="true">
    <view class="pull-refresh-dots__dot"></view>
    <view class="pull-refresh-dots__dot"></view>
    <view class="pull-refresh-dots__dot"></view>
  </view>

  <scroll-view
    class="content-scroll main-content-scroll nav-aware-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    bounces="{{true}}"
    refresher-enabled="{{true}}"
    refresher-default-style="none"
    refresher-background="{{pageBgColor}}"
    refresher-threshold="36"
    refresher-triggered="{{scrollRefreshing}}"
    data-nav-h="{{navPlaceholderHeight}}"
    data-refresh-threshold="36"
    bindtouchend="{{navPad.onRelease}}"
    bindtouchcancel="{{navPad.onRelease}}"
    bindrefresherpulling="{{navPad.onPulling}}"
    bindrefresherrestore="{{navPad.onReset}}"
    bindrefresherabort="{{navPad.onReset}}"
    bindrefresherrefresh="onScrollRefresh"
    bindscroll="onMonitorScroll"
  >
    
    <nav-scroll-pad id="navScrollPad" class="nav-scroll-pad" height="{{navPlaceholderHeight}}" />
<!-- 星舰基地监控中心：MARS 预览（云中转）+ 关于 / 收藏（原生，防套壳） -->
    <view class="MARS-preview-section monitor-block">
      <view class="section-title">
        <text>星舰基地监控</text>
      </view>
      <!-- 新增：用户网页预览入口 -->
      <view class="MARS-preview-card glass-card card-hover" bindtap="openUserWebPreview">
        <view class="preview-card-content">
          <view class="preview-card-info">
            <text class="preview-card-title">星舰监控中心</text>
            <text class="preview-card-desc">实时监控星舰基地建设进度（网页版）</text>
          </view>
          <view class="icon-arrow icon-arrow--preview-card">›</view>
        </view>
      </view>
    </view>

    <!-- 直播观看：视频号 channel-live + B站入口（后台 enableLiveWatch 开关控制） -->
    <view class="monitor-livestream-section monitor-block" wx:if="{{enableLiveWatch}}">
        <view class="section-title monitor-livestream-section-title">
          <view class="monitor-livestream-title-left">
            <text class="monitor-livestream-heading-text">直播观看</text>
            <view class="livestream-live-tag" wx:if="{{channelsLiveStatus === 2}}">
              <view class="livestream-live-eq" aria-hidden="true">
                <view class="livestream-live-eq-bar"></view>
                <view class="livestream-live-eq-bar"></view>
                <view class="livestream-live-eq-bar"></view>
              </view>
              <text class="livestream-live-tag-text">直播中</text>
            </view>
          </view>
          <view class="section-title-right starbase-weather-cluster">
            <text class="starbase-weather-place">博卡奇卡</text>
            <view wx:if="{{starbaseWeather.loading}}" class="starbase-weather-loading"><text>天气载入中…</text></view>
            <block wx:elif="{{starbaseWeather.loaded}}">
              <view class="starbase-weather-row starbase-weather-row--main">
                <image class="starbase-wx-icon" src="{{starbaseWeather.weatherIcon}}" mode="aspectFit"></image>
                <text class="starbase-wx-condition">{{starbaseWeather.conditionText}}</text>
                <text class="starbase-wx-temp">{{starbaseWeather.tempLine}}</text>
              </view>
              <view class="starbase-weather-row starbase-weather-row--sub">
                <text class="starbase-wx-time">{{starbaseWeather.timeLine}}</text>
                <view class="starbase-wx-wind">
                  <image class="starbase-wind-icon" src="{{starbaseWeather.windIcon}}" mode="aspectFit"></image>
                  <text class="starbase-wx-wind-text">{{starbaseWeather.windLine}}</text>
                </view>
              </view>
            </block>
            <text wx:elif="{{starbaseWeather.error}}" class="starbase-weather-err">{{starbaseWeather.error}}</text>
          </view>
        </view>
        <view class="monitor-livestream-stack">
          <channels-live-panel
            id="channelsLivePanel"
            prefer-fallback-guide="{{channelsFallbackGuide.enabled}}"
            show-extra-guide="{{channelsFallbackGuide.enabled}}"
            extra-guide-label="推荐直播"
            show-bili-live="{{true}}"
            bili-live-label="B站直播"
            bind:statuschange="onChannelsLiveStatusChange"
            bind:fallbackguide="onChannelsLiveFallbackGuide"
            bind:extraguide="onChannelsGuideTap"
            bind:bililive="onBiliLiveTap"
          />
        </view>
      </view>

    <!-- 太空轨道数据中心入口卡：组件在 monitor-pages 分包（wxml/wxss 不占主包），
         逻辑在 monitor-orbital.js（页面经 require.async 委托） -->
    <monitor-orbital-card
      orbital-card-bg="{{orbitalCardBg}}"
      orbital-card-bg-is-video="{{orbitalCardBgIsVideo}}"
      orbital-live-stats="{{orbitalLiveStats}}"
      orbital-card-cta="{{orbitalCardCta}}"
      is-pro-user="{{isProUser}}"
      bind:cardtap="openOrbitalDataCenter"
      bind:bgerror="onOrbitalBgError"
    />

    <!-- 进度显示框 -->
    <!-- 空间站实时状态 -->
    <view class="station-section monitor-block">
      <view class="section-title">
        <view class="section-title-main">
          <text>空间站实时状态</text>
          <text class="section-subtitle">ISS / 天宫</text>
        </view>
        <view class="section-badge" wx:if="{{stationList.length}}">{{stationList.length}}</view>
        <view class="section-title-right">
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="station" bindtap="markPendingShareType" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态 -->
      <lazy-load-card wx:if="{{!stationReady}}" icon="" text="点击加载空间站状态" hint="ISS / 天宫空间站实时数据" bind:tap="onLoadStationStatus" />

      <block wx:else>
      <!-- 加载中 -->
      <view class="station-loading" wx:if="{{stationLoading}}">
        <text class="station-loading-text">加载空间站数据...</text>
      </view>

      <!-- 两个空间站卡片并排 -->
      <view class="station-row" wx:if="{{stationList.length}}">
        <view class="station-mini-card glass-card"
              wx:for="{{stationList}}" wx:key="id"
              data-station-id="{{item.id}}" bindtap="onStationCardTap">
          <image class="station-mini-img {{stationImageLoadedMap[index] ? 'station-mini-img--loaded' : ''}}" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" lazy-load bindload="onStationImageLoad" binderror="onStationImageError" data-index="{{index}}" />
          <view class="station-mini-img station-mini-img--placeholder" wx:else></view>
          <view class="station-mini-body">
            <text class="station-mini-name">{{item.name}}</text>
            <view class="station-mini-tags">
              <text class="station-tag station-tag--active" wx:if="{{item.statusTone === 'active'}}">运行中</text>
              <text class="station-mini-dock">{{item.dockedCount}} 艘停靠</text>
            </view>
          </view>
          <view class="station-mini-arrow">
            <text>›</text>
          </view>
        </view>
      </view>

      <!-- 无数据 -->
      <view class="station-empty" wx:if="{{!stationLoading && !stationList.length}}">
        <view class="station-empty-visual"></view>
        <text class="empty-state-text">空间站数据加载失败</text>
        <text class="empty-state-hint">请稍后重试</text>
      </view>
      </block>
    </view>

    <!-- 星链实时分布 -->
    <view class="starlink-section monitor-block">
      <view class="section-title">
        <text>星链实时分布</text>
        <view class="section-badge" wx:if="{{starlinkCount}}">{{starlinkCount}}</view>
        <view class="section-title-right">
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="starlink" bindtap="markPendingShareType" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态：显示加载按钮 -->
      <lazy-load-card wx:if="{{!starlinkReady}}" icon="" text="点击加载卫星实时分布" hint="需加载轨道数据，可能需要几秒" bind:tap="onLoadStarlink" />

      <view class="starlink-card glass-card" wx:else>
        <!-- 加载态 -->
        <view class="starlink-loading" wx:if="{{starlinkLoading}}">
          <view class="starlink-loading-orbit"></view>
          <text class="starlink-loading-text">加载卫星轨道数据...</text>
        </view>
        <!-- 错误态 -->
        <view class="starlink-error" wx:elif="{{starlinkError}}">
          <text class="starlink-error-text">{{starlinkError}}</text>
          <view class="starlink-retry-btn" bindtap="retryLoadStarlink">重试</view>
        </view>
        <!-- 正常态：Canvas 地图 -->
        <block wx:else>
          <view class="starlink-canvas-wrap">
            <canvas type="2d" id="starlinkCanvas" class="starlink-canvas" bindtouchstart="onStarlinkTouchStart" bindtouchmove="onStarlinkTouchMove" bindtouchend="onStarlinkTouchEnd"></canvas>
            <!-- HUD 四角角框装饰 -->
            <view class="starlink-hud-corners starlink-hud-corners--top"></view>
            <view class="starlink-hud-corners starlink-hud-corners--bottom"></view>
            <!-- 全屏按钮 -->
            <view class="starlink-expand-hint {{isProUser ? 'pro-gold-frame' : ''}}" bindtap="openStarlinkFullscreen">
              <text class="starlink-expand-text">全屏</text>
            </view>
            <!-- 暂停/播放按钮 -->
            <view class="starlink-ctrl-bar">
              <view class="starlink-ctrl-btn" bindtap="toggleStarlinkPause">
                <view class="ctrl-icon-play" wx:if="{{starlinkPaused}}"></view>
                <view class="ctrl-icon-pause" wx:else></view>
              </view>
              <text class="starlink-ctrl-info">在轨 {{starlinkCount}} 颗 · {{starlinkUpdateTime}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- Starlink 过境预报 -->
    <view class="pass-section monitor-block">
      <view class="section-title">
        <text>星链过境预报</text>
        <view class="section-title-right pass-actions">
          <view class="pass-refresh-chip" bindtap="refreshPasses" wx:if="{{passReady && !passLoading}}">
            <text>刷新</text>
          </view>
          <view class="monitor-share-wrap">
            <image class="icon-share icon-share--monitor" src="/images/share-arrow.svg" mode="aspectFit"></image>
            <button class="monitor-share-btn" open-type="share" hover-class="none" data-share-type="pass" bindtap="markPendingShareType" plain="true"></button>
          </view>
        </view>
      </view>

      <!-- 未加载态 -->
      <lazy-load-card wx:if="{{!passReady}}" icon="" text="点击加载过境预报" hint="需要位置权限和轨道数据" bind:tap="onLoadStarlinkPasses" />

      <block wx:else>
      <!-- 融合入口卡片：位置 + 预报摘要 + 光效背景 -->
      <view class="pass-hero-card glass-card" wx:if="{{passReady && !passLoading && !passNoLocation && !passError}}" bindtap="openPassDetail">
        <!-- 星链列车拖尾光效 -->
        <view class="pass-hero-trail pass-hero-trail--1"></view>
        <view class="pass-hero-trail pass-hero-trail--2"></view>
        <view class="pass-hero-trail pass-hero-trail--3"></view>

        <view class="pass-hero-card-body">
          <view class="pass-hero-card-top">
            <view class="pass-hero-card-info">
              <text class="pass-hero-card-title" wx:if="{{passList.length > 0}}">{{passList.length}} 次可见过境</text>
              <text class="pass-hero-card-title" wx:else>暂无可见过境</text>
              <text class="pass-hero-card-loc" wx:if="{{passLocation}}">{{passLocation}}</text>
            </view>
            <view class="pass-hero-card-btns">
              <view class="pass-hero-chip {{isProUser ? 'pass-hero-chip--pro' : ''}}" catchtap="openPassMap" wx:if="{{passList.length > 0}}">
                <text>地图</text>
              </view>
              <view class="pass-hero-chip {{isProUser ? 'pass-hero-chip--pro' : ''}}" catchtap="openStarlinkAR">
                <text>AR</text>
              </view>
            </view>
          </view>
          <view class="pass-hero-card-bottom" wx:if="{{passList.length > 0 && passList[0]}}">
            <text class="pass-hero-card-next">最近 {{passList[0].startTimeStr}}</text>
            <text class="pass-hero-card-meta">仰角 {{passList[0].maxElev}}° · {{passList[0].startDirection}}→{{passList[0].endDirection}} · {{passList[0].durationMin}}分钟</text>
          </view>
          <view class="pass-hero-card-bottom" wx:elif="{{passList.length === 0}}">
            <text class="pass-hero-card-meta">查看观测指南与讨论区</text>
          </view>
        </view>
        <text class="pass-hero-card-arrow">›</text>
      </view>

      <view class="pass-loading glass-card" wx:elif="{{passLoading}}">
        <text class="empty-state-text">计算过境数据...</text>
      </view>
      <view class="pass-empty glass-card" wx:elif="{{passNoLocation}}">
        <image class="pass-location-icon" src="/images/icons/icon-location.svg" mode="aspectFit"></image>
        <text class="empty-state-text">需要位置权限</text>
        <text class="empty-state-hint" wx:if="{{passError}}">{{passError}}</text>
        <view class="pass-locate-btn" bindtap="requestPassLocation">
          <text>授权定位</text>
        </view>
      </view>
      <view class="pass-empty glass-card" wx:elif="{{passError}}">
        <text class="empty-state-text">加载失败</text>
        <text class="empty-state-hint">{{passError}}</text>
        <view class="pass-locate-btn" bindtap="refreshPasses">
          <text>重试</text>
        </view>
      </view>
      </block>
    </view>

    <!-- 图鉴四板块（发射商/火箭族谱/飞船/发射场）：组件在 monitor-pages 分包，
         逻辑在 monitor-galleries.js（页面经 require.async 委托），wxml/wxss 不占主包。
         所有交互经单一 galleryevent 通道回传（detail: { name, dataset, edetail }） -->
    <monitor-galleries
      theme-class="{{themeClass}}"
      agency-visible="{{agencyVisible}}"
      agency-loading="{{agencyLoading}}"
      agency-error="{{agencyError}}"
      agency-total="{{agencyTotal}}"
      booster-list="{{boosterList}}"
      booster-loading="{{boosterLoading}}"
      booster-load-error="{{boosterLoadError}}"
      booster-image-loaded-map="{{boosterImageLoadedMap}}"
      spacecraft-list="{{spacecraftList}}"
      spacecraft-loading="{{spacecraftLoading}}"
      spacecraft-load-error="{{spacecraftLoadError}}"
      launch-site-list="{{launchSiteList}}"
      launch-site-loading="{{launchSiteLoading}}"
      launch-site-load-error="{{launchSiteLoadError}}"
      bind:galleryevent="onGalleryEvent"
    />

    <!-- 即将进行的在轨任务：组件在 monitor-pages 分包，逻辑在 monitor-orbital.js -->
    <monitor-orbit-events
      theme-class="{{themeClass}}"
      orbital-ready="{{orbitalReady}}"
      orbital-loading="{{orbitalLoading}}"
      upcoming-orbital-events="{{upcomingOrbitalEvents}}"
      orbital-countdown="{{orbitalCountdown}}"
      bind:loadtap="onLoadUpcomingOrbitalEvents"
      bind:eventtap="onOrbitEventTapFromComp"
      bind:imageerror="onOrbitEventImageErrorFromComp"
    />

    <view style="height: {{tabBarReservedHeight}}px;"></view>
  </scroll-view>

  <!-- B站直播二维码弹窗 -->
  <view wx:if="{{showBiliQRModal}}" class="qrcode-modal" bindtap="hideBiliQRCode">
    <view class="qrcode-modal-content" catchtap="">
      <view class="qrcode-header">
        <text class="qrcode-title">B站直播</text>
        <view class="qrcode-close" bindtap="hideBiliQRCode">
          <text class="icon-close icon-close--qrcode">×</text>
        </view>
      </view>
      <view class="qrcode-body">
        <image class="qrcode-image" src="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E4%BA%8C%E7%BB%B4%E7%A0%81/1773602498836_o237or.png" mode="aspectFit" show-menu-by-longpress="{{true}}" bindtap="onBiliQRImageTap"></image>
        <text class="qrcode-tip">点击图片可预览，或复制链接在浏览器打开</text>
        <view class="qrcode-copy-btn" bindtap="onCopyBiliLiveLink">
          <text>复制直播链接</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 推荐第三方视频号主页二维码 -->
  <view wx:if="{{showChannelsGuideModal}}" class="qrcode-modal" bindtap="hideChannelsGuideModal">
    <view class="qrcode-modal-content" catchtap="">
      <view class="qrcode-header">
        <text class="qrcode-title">{{channelsFallbackGuide.title || '推荐观看'}}</text>
        <view class="qrcode-close" bindtap="hideChannelsGuideModal">
          <text class="icon-close icon-close--qrcode">×</text>
        </view>
      </view>
      <view class="qrcode-body">
        <text class="qrcode-tip qrcode-tip--name">{{channelsFallbackGuide.nickname}}</text>
        <image class="qrcode-image" src="{{channelsFallbackGuide.qrDisplayUrl || channelsFallbackGuide.qrUrl}}" mode="aspectFit" show-menu-by-longpress="{{true}}" bindtap="onChannelsGuideQRImageTap"></image>
        <text class="qrcode-tip">{{channelsFallbackGuide.tip || '扫码前往视频号主页，可预约或观看直播'}}</text>
        <view class="qrcode-copy-btn" bindtap="onCopyChannelsGuideNickname">
          <text>复制公众号名称</text>
        </view>
      </view>
    </view>
  </view>
  <ai-chat id="ai-chat" />
  <nasa-float id="nasaFloat" />
  <privacy-modal id="globalPrivacyModal"></privacy-modal>
  <popup-ad visible="{{popupAdVisible}}" shop-item="{{popupAdItem}}" bind:close="onPopupAdClose"></popup-ad>
  <demo-overlay id="demoOverlay" showControls="{{false}}" qrcodeUrl="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E5%B0%8F%E7%A8%8B%E5%BA%8F%E4%BA%8C%E7%BB%B4%E7%A0%81/1775323336594_jkl6zv.png" loop="{{true}}" />
  <share-guide />
</view>
