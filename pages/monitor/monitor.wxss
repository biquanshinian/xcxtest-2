/* pages/monitor/monitor.wxss */
/* 禁止页面级滚动，避免安卓真机整页（含顶部栏、tabbar）跟随滑动；仅由 scroll-view 负责滚动 */
page {
  overflow: hidden;
  height: 100vh;
  width: 100%;
}

.container {
  padding-bottom: 0;
  padding-top: 0;
}

/* 顶部导航栏容器（包含状态栏和导航栏） */
.top-nav-wrapper {
  background: rgba(12, 14, 18, 0.08);
  backdrop-filter: blur(48rpx) saturate(170%);
  -webkit-backdrop-filter: blur(48rpx) saturate(170%);
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
}

/* 顶部导航栏 */
.content-scroll {
  padding: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
}

.section-title-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.section-subtitle {
  font-size: 20rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.32);
}

.section-title-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pass-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}


.pass-map-btn,
.pass-ar-btn {
  min-width: 124rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.pass-map-btn {
  background: rgba(10, 132, 255, 0.16);
  border: 1px solid rgba(10, 132, 255, 0.45);
}

.pass-map-text,
.pass-ar-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.pass-ar-btn {
  background: rgba(52, 199, 89, 0.16);
  border: 1px solid rgba(52, 199, 89, 0.42);
}

.pass-ar-text {
  color: #A7FFCA;
}

/* MARS预览区域 */
.MARS-preview-section {
  margin-bottom: 40rpx;
}

.MARS-preview-card {
  padding: 0;
  overflow: hidden;
}

.preview-card-content {
  display: flex;
  align-items: center;
  /* 纵向略收紧：相对原 40rpx 上下各减 5rpx（约 5px@375 宽），卡片整体缩窄约 5px 视觉高度 */
  padding: 35rpx 40rpx;
  gap: 30rpx;
}

.preview-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.preview-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.preview-card-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.icon-arrow--preview-card {
  font-size: 48rpx;
  color: #8E8E93;
  font-weight: 300;
  flex-shrink: 0;
}

/* ========== 直播观看（视频号 / B站 并排卡片） ========== */
/* 与页面同级内容共用 content-scroll 的 30rpx 左右内边距，勿再叠加 padding，否则会比「星舰监控中心」卡片窄一截 */
.monitor-livestream-section {
  padding: 0;
  margin-bottom: 40rpx;
}

/* 紧邻「星舰监控中心」卡片下方：与「太空轨道数据中心」标题区 margin-top（32rpx）同级节奏，避免两块贴太近 */
.MARS-preview-section > .monitor-livestream-section {
  margin-top: 32rpx;
}

.monitor-livestream-section .section-title {
  padding: 0;
  gap: 14rpx;
}

.monitor-livestream-section-title {
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: nowrap;
  gap: 20rpx;
}

.monitor-livestream-title-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.monitor-livestream-heading-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 博卡奇卡实况天气（时间行为 CST 中国标准时间） */
.starbase-weather-cluster {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.starbase-weather-place {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 1rpx;
}

.starbase-weather-loading text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}

.starbase-weather-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  width: 100%;
}

.starbase-weather-row--main {
  flex-wrap: wrap;
}

.starbase-weather-row--sub {
  gap: 16rpx;
  flex-wrap: wrap;
}

.starbase-wx-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.starbase-wx-condition {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
}

.starbase-wx-temp {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.starbase-wx-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: right;
}

.starbase-wx-wind {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.starbase-wind-icon {
  width: 44rpx;
  height: 22rpx;
  flex-shrink: 0;
}

.starbase-wx-wind-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.starbase-weather-err {
  font-size: 22rpx;
  color: rgba(255, 160, 140, 0.85);
  text-align: right;
}

.monitor-livestream-section .livestream-live-tag {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  box-sizing: border-box;
  background: linear-gradient(90deg, #ff2d55, #ff453a);
  box-shadow: 0 4rpx 12rpx rgba(255, 45, 85, 0.35);
}

.monitor-livestream-section .livestream-live-tag-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
  letter-spacing: 0.5rpx;
}

.monitor-livestream-section .livestream-live-eq {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 3rpx;
  height: 18rpx;
  flex-shrink: 0;
}

.monitor-livestream-section .livestream-live-eq-bar {
  width: 4rpx;
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transform-origin: center bottom;
  animation: monitor-livestream-eq 0.8s ease-in-out infinite;
}

.monitor-livestream-section .livestream-live-eq-bar:nth-child(1) { animation-delay: 0s; }
.monitor-livestream-section .livestream-live-eq-bar:nth-child(2) { animation-delay: 0.15s; }
.monitor-livestream-section .livestream-live-eq-bar:nth-child(3) { animation-delay: 0.3s; }

@keyframes monitor-livestream-eq {
  0%, 100% { transform: scaleY(0.35); }
  25% { transform: scaleY(1); }
  50% { transform: scaleY(0.55); }
  75% { transform: scaleY(0.85); }
}

/* 视频号 + B站：统一纵向间距，与上方卡片节奏一致 */
.monitor-livestream-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.monitor-livestream-entry-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
}

.monitor-livestream-btn--full {
  width: 100%;
  flex: 1;
}

.monitor-livestream-btn--half {
  flex: 1;
  width: 0;
  min-width: 0;
}

.monitor-livestream-btn {
  min-width: 0;
  min-height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 18rpx;
  background: rgba(30, 30, 30, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  transition: all 0.18s ease;
  box-sizing: border-box;
}

.monitor-livestream-btn--half {
  padding: 18rpx 16rpx;
  gap: 12rpx;
}

.monitor-livestream-btn--hover {
  background: rgba(255, 255, 255, 0.06);
  transform: scale(0.98);
}

.monitor-livestream-btn--bilibili {
  border-color: rgba(251, 114, 153, 0.3);
  background: linear-gradient(135deg, rgba(251, 114, 153, 0.1), rgba(30, 30, 30, 0.45));
}

.monitor-livestream-btn-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.monitor-livestream-icon-img {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.monitor-livestream-btn-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.monitor-livestream-btn-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.35);
  font-weight: 300;
  flex-shrink: 0;
  line-height: 1;
}

.monitor-livestream-btn-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.2;
}

.monitor-livestream-btn-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 即将进行的在轨任务（事件流，可点击跳详情） ========== */
.orbit-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.orbit-card--clickable {
  position: relative;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.orbit-card--clickable:active {
  transform: scale(0.98);
}

.orbit-card-meta--top {
  margin-bottom: 6rpx;
}

.orbit-meta-tag--type {
  color: #5AC8FA;
  background: rgba(90, 200, 250, 0.15);
  font-weight: 600;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.orbit-meta-tag--date {
  color: rgba(255, 255, 255, 0.85);
}

.orbit-meta-tag--location {
  color: #fff;
  background: rgba(0, 122, 255, 0.45);
}

.orbit-stat--countdown .orbit-stat-value {
  color: #34C759;
  font-size: 26rpx;
}

.orbit-stat--countdown.soon .orbit-stat-value {
  color: #FF9F0A;
}

.orbit-stat--countdown.live .orbit-stat-value {
  color: #FF453A;
}

.orbit-stat--cta {
  margin-left: auto;
}

.orbit-stat-cta-text {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
}

.section-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  margin-left: 12rpx;
  background: rgba(255, 59, 48, 0.8);
  border-radius: 18rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.orbit-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.orbit-card {
  display: flex;
  flex-direction: row;
  overflow: hidden;
  border-radius: 20rpx;
}

.orbit-card-img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.orbit-card-body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.orbit-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.orbit-card-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.orbit-meta-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.orbit-timeline {
  display: flex;
  gap: 24rpx;
}

.orbit-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.orbit-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #34C759;
}

.orbit-stat-value.orbit-date {
  font-size: 22rpx;
  font-weight: 500;
  color: #FF9F0A;
}

.orbit-stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 2rpx;
}

/* ========== 在轨任务 Hero 倒计时面板 ========== */
.orbit-hero {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  min-height: 360rpx;
}

.orbit-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.orbit-hero-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.75) 100%);
}

.orbit-hero-content {
  position: relative;
  z-index: 1;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.orbit-hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.orbit-hero-type {
  font-size: 22rpx;
  color: #fff;
  background: rgba(52, 199, 89, 0.25);
  border: 1rpx solid rgba(52, 199, 89, 0.5);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.orbit-hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin-bottom: 20rpx;
}

.orbit-hero-countdown {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.orbit-hero-countdown--live {
  justify-content: center;
}

.orbit-cd-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.orbit-cd-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}

.orbit-cd-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 4rpx;
}

.orbit-cd-sep {
  font-size: 44rpx;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  margin-top: -20rpx;
}

.orbit-cd-live-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FF453A;
}

.orbit-hero-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 16rpx;
}

.orbit-hero-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.orbit-hero-location {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.08);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.orbit-hero-cta {
  margin-top: 4rpx;
}

.orbit-hero-cta-text {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

/* ========== 通用空状态 ========== */
.empty-state {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 20rpx;
  border: 1px dashed rgba(255, 255, 255, 0.1);
}

.empty-state-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.empty-state-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.empty-state-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.25);
  margin-top: 6rpx;
}

.monitor-share-wrap {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-share--monitor {
  width: 28rpx;
  height: 28rpx;
}

.monitor-share-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100% !important;
  height: 100% !important;
  min-width: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: 0 !important;
  border-width: 0 !important;
  outline: 0 !important;
  box-shadow: none !important;
  opacity: 0;
}

.monitor-share-btn::after {
  display: none;
}

/* ========== D2C 折叠按钮 ========== */

/* ========== Starlink 卫星实时分布 ========== */
.starlink-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.starlink-card {
  padding: 0;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1px solid rgba(0, 255, 136, 0.1);
  background: linear-gradient(135deg, rgba(28, 28, 30, 0.9), rgba(0, 255, 136, 0.02));
}

.starlink-loading {
  height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

/* 轨道环加载动画：细描边圆环 + 环上旋转的绿色亮点 */
.starlink-loading-orbit {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 255, 136, 0.2);
  box-sizing: border-box;
  animation: starlinkOrbitSpin 1.2s linear infinite;
}

.starlink-loading-orbit::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  margin-left: -5rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00ff88;
  box-shadow: 0 0 12rpx rgba(0, 255, 136, 0.8);
}

@keyframes starlinkOrbitSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.starlink-loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.starlink-error {
  height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.starlink-error-text {
  font-size: 26rpx;
  color: rgba(255, 100, 100, 0.8);
}

.starlink-retry-btn {
  font-size: 24rpx;
  color: #00ff88;
  padding: 10rpx 32rpx;
  border: 1px solid rgba(0, 255, 136, 0.3);
  border-radius: 999rpx;
}

.starlink-canvas-wrap {
  position: relative;
  width: 100%;
}

/* HUD 四角 L 形角框（科幻取景框） */
.starlink-hud-corners {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  height: 24rpx;
  pointer-events: none;
  z-index: 2;
}

.starlink-hud-corners--top {
  top: 12rpx;
}

.starlink-hud-corners--bottom {
  bottom: 12rpx;
}

.starlink-hud-corners::before,
.starlink-hud-corners::after {
  content: '';
  position: absolute;
  top: 0;
  width: 24rpx;
  height: 24rpx;
  box-sizing: border-box;
}

.starlink-hud-corners--top::before {
  left: 0;
  border-top: 2rpx solid rgba(0, 255, 136, 0.5);
  border-left: 2rpx solid rgba(0, 255, 136, 0.5);
}

.starlink-hud-corners--top::after {
  right: 0;
  border-top: 2rpx solid rgba(0, 255, 136, 0.5);
  border-right: 2rpx solid rgba(0, 255, 136, 0.5);
}

.starlink-hud-corners--bottom::before {
  left: 0;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.5);
  border-left: 2rpx solid rgba(0, 255, 136, 0.5);
}

.starlink-hud-corners--bottom::after {
  right: 0;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.5);
  border-right: 2rpx solid rgba(0, 255, 136, 0.5);
}

.starlink-canvas {
  width: 100%;
  height: 420rpx;
  display: block;
}

.starlink-ctrl-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
}

.starlink-ctrl-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 255, 136, 0.15);
  border: 1px solid rgba(0, 255, 136, 0.3);
  border-radius: 50%;
}

/* CSS 播放三角（border 三角形） */
.ctrl-icon-play {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 9rpx 0 9rpx 15rpx;
  border-color: transparent transparent transparent #00ff88;
  margin-left: 4rpx;
}

