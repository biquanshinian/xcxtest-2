/* pages/monitor/monitor.wxss */
@import "../../styles/monitor-block.wxss";
/* 禁止页面级滚动，避免安卓真机整页（含顶部栏、tabbar）跟随滑动；仅由 scroll-view 负责滚动 */
page {
  overflow: hidden;
  height: 100vh;
  width: 100%;
}
.container {
  padding-bottom: 0;
  padding-top: 0;
}
/* 顶部导航栏容器（包含状态栏和导航栏） */
.top-nav-wrapper {
  background: rgba(12, 14, 18, 0.08);
  backdrop-filter: blur(48rpx) saturate(170%);
  -webkit-backdrop-filter: blur(48rpx) saturate(170%);
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
}
/* 顶部导航栏 */
.content-scroll {
  padding: 30rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
}
/* 板块标题数字角标：页面与图鉴/在轨任务等分包组件共用（apply-shared 作用进组件） */
.section-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  margin-left: 12rpx;
  background: rgba(255, 59, 48, 0.8);
  border-radius: 18rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}
.section-title-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}
.section-subtitle {
  font-size: 20rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.32);
}
.section-title-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.pass-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
/* MARS预览区域 */
.MARS-preview-section {
  margin-bottom: 40rpx;
}
.MARS-preview-card {
  padding: 0;
  overflow: hidden;
}
.preview-card-content {
  display: flex;
  align-items: center;
  /* 纵向略收紧：相对原 40rpx 上下各减 5rpx（约 5px@375 宽），卡片整体缩窄约 5px 视觉高度 */
  padding: 35rpx 40rpx;
  gap: 30rpx;
}
.preview-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.preview-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.preview-card-desc {
  font-size: 24rpx;
  color: #8E8E93;
}
.icon-arrow--preview-card {
  font-size: 48rpx;
  color: #8E8E93;
  font-weight: 300;
  flex-shrink: 0;
}
/* ========== 直播观看（视频号 / B站 并排卡片） ========== */
/* 与页面同级内容共用 content-scroll 的 30rpx 左右内边距，勿再叠加 padding，否则会比「星舰监控中心」卡片窄一截 */
.monitor-livestream-section {
  padding: 0;
  margin-bottom: 40rpx;
}
/* 紧邻「星舰监控中心」卡片下方：与「太空轨道数据中心」标题区 margin-top（32rpx）同级节奏，避免两块贴太近 */
.MARS-preview-section > .monitor-livestream-section {
  margin-top: 32rpx;
}
.monitor-livestream-section .section-title {
  padding: 0;
  gap: 14rpx;
}
.monitor-livestream-section-title {
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: nowrap;
  gap: 20rpx;
}
.monitor-livestream-title-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}
.monitor-livestream-heading-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}
/* 博卡奇卡实况天气（时间行为 CST 中国标准时间） */
.starbase-weather-cluster {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.starbase-weather-place {
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 1rpx;
}
.starbase-weather-loading text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}
.starbase-weather-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  width: 100%;
}
.starbase-weather-row--main {
  flex-wrap: wrap;
}
.starbase-weather-row--sub {
  gap: 16rpx;
  flex-wrap: wrap;
}
.starbase-wx-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
.starbase-wx-condition {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
}
.starbase-wx-temp {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.starbase-wx-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: right;
}
.starbase-wx-wind {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}
.starbase-wind-icon {
  width: 44rpx;
  height: 22rpx;
  flex-shrink: 0;
}
.starbase-wx-wind-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}
.starbase-weather-err {
  font-size: 22rpx;
  color: rgba(255, 160, 140, 0.85);
  text-align: right;
}
.monitor-livestream-section .livestream-live-tag {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  box-sizing: border-box;
  background: linear-gradient(90deg, #ff2d55, #ff453a);
  box-shadow: 0 4rpx 12rpx rgba(255, 45, 85, 0.35);
}
.monitor-livestream-section .livestream-live-tag-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
  letter-spacing: 0.5rpx;
}
.monitor-livestream-section .livestream-live-eq {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 3rpx;
  height: 18rpx;
  flex-shrink: 0;
}
.monitor-livestream-section .livestream-live-eq-bar {
  width: 4rpx;
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transform-origin: center bottom;
  animation: monitor-livestream-eq 0.8s ease-in-out infinite;
}
.monitor-livestream-section .livestream-live-eq-bar:nth-child(1) { animation-delay: 0s; }
.monitor-livestream-section .livestream-live-eq-bar:nth-child(2) { animation-delay: 0.15s; }
.monitor-livestream-section .livestream-live-eq-bar:nth-child(3) { animation-delay: 0.3s; }
@keyframes monitor-livestream-eq {
  0%, 100% { transform: scaleY(0.35); }
  25% { transform: scaleY(1); }
  50% { transform: scaleY(0.55); }
  75% { transform: scaleY(0.85); }
}
/* 视频号 + B站：统一纵向间距，与上方卡片节奏一致 */
.monitor-livestream-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.monitor-livestream-entry-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
}
.monitor-livestream-btn--full {
  width: 100%;
  flex: 1;
}
.monitor-livestream-btn--half {
  flex: 1;
  width: 0;
  min-width: 0;
}
.monitor-livestream-btn {
  min-width: 0;
  min-height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 18rpx;
  background: rgba(30, 30, 30, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  transition: all 0.18s ease;
  box-sizing: border-box;
}
.monitor-livestream-btn--half {
  padding: 18rpx 16rpx;
  gap: 12rpx;
}
.monitor-livestream-btn--hover {
  background: rgba(255, 255, 255, 0.06);
  transform: scale(0.98);
}
.monitor-livestream-btn--bilibili {
  border-color: rgba(251, 114, 153, 0.3);
  background: linear-gradient(135deg, rgba(251, 114, 153, 0.1), rgba(30, 30, 30, 0.45));
}
.monitor-livestream-btn-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.monitor-livestream-icon-img {
  width: 48rpx;
  height: 48rpx;
  display: block;
}
.monitor-livestream-btn-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.monitor-livestream-btn-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.2;
}
.monitor-livestream-btn-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* ========== 通用空状态 ========== */
.empty-state {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 20rpx;
  border: 1px dashed rgba(255, 255, 255, 0.1);
}
.empty-state-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}
.empty-state-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}
.empty-state-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.25);
  margin-top: 6rpx;
}
.monitor-share-wrap {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-share--monitor {
  width: 28rpx;
  height: 28rpx;
}
.monitor-share-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100% !important;
  height: 100% !important;
  min-width: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: 0 !important;
  border-width: 0 !important;
  outline: 0 !important;
  box-shadow: none !important;
  opacity: 0;
}
.monitor-share-btn::after {
  display: none;
}
/* ========== D2C 折叠按钮 ========== */

/* ========== Starlink 卫星实时分布 ========== */
.starlink-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}
.starlink-card {
  padding: 0;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1px solid rgba(0, 255, 136, 0.1);
  background: linear-gradient(135deg, rgba(28, 28, 30, 0.9), rgba(0, 255, 136, 0.02));
}
.starlink-loading {
  height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
/* 轨道环加载动画：细描边圆环 + 环上旋转的绿色亮点 */
.starlink-loading-orbit {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 255, 136, 0.2);
  box-sizing: border-box;
  animation: starlinkOrbitSpin 1.2s linear infinite;
}
.starlink-loading-orbit::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  margin-left: -5rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00ff88;
  box-shadow: 0 0 12rpx rgba(0, 255, 136, 0.8);
}
@keyframes starlinkOrbitSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.starlink-loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}
.starlink-error {
  height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}
.starlink-error-text {
  font-size: 26rpx;
  color: rgba(255, 100, 100, 0.8);
}
.starlink-retry-btn {
  font-size: 24rpx;
  color: #00ff88;
  padding: 10rpx 32rpx;
  border: 1px solid rgba(0, 255, 136, 0.3);
  border-radius: 999rpx;
}
.starlink-canvas-wrap {
  position: relative;
  width: 100%;
}
/* HUD 四角 L 形角框（科幻取景框） */
.starlink-hud-corners {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  height: 24rpx;
  pointer-events: none;
  z-index: 2;
}
.starlink-hud-corners--top {
  top: 12rpx;
}
.starlink-hud-corners--bottom {
  bottom: 12rpx;
}
.starlink-hud-corners::before,
.starlink-hud-corners::after {
  content: '';
  position: absolute;
  top: 0;
  width: 24rpx;
  height: 24rpx;
  box-sizing: border-box;
}
.starlink-hud-corners--top::before {
  left: 0;
  border-top: 2rpx solid rgba(0, 255, 136, 0.5);
  border-left: 2rpx solid rgba(0, 255, 136, 0.5);
}
.starlink-hud-corners--top::after {
  right: 0;
  border-top: 2rpx solid rgba(0, 255, 136, 0.5);
  border-right: 2rpx solid rgba(0, 255, 136, 0.5);
}
.starlink-hud-corners--bottom::before {
  left: 0;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.5);
  border-left: 2rpx solid rgba(0, 255, 136, 0.5);
}
.starlink-hud-corners--bottom::after {
  right: 0;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.5);
  border-right: 2rpx solid rgba(0, 255, 136, 0.5);
}
.starlink-canvas {
  width: 100%;
  height: 420rpx;
  display: block;
}
.starlink-ctrl-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
}
.starlink-ctrl-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 255, 136, 0.15);
  border: 1px solid rgba(0, 255, 136, 0.3);
  border-radius: 50%;
}
/* CSS 播放三角（border 三角形） */
.ctrl-icon-play {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 9rpx 0 9rpx 15rpx;
  border-color: transparent transparent transparent #00ff88;
  margin-left: 4rpx;
}
/* CSS 暂停：两条圆角竖线 */
.ctrl-icon-pause {
  display: flex;
  gap: 6rpx;
}
.ctrl-icon-pause::before,
.ctrl-icon-pause::after {
  content: '';
  display: block;
  width: 5rpx;
  height: 18rpx;
  border-radius: 3rpx;
  background: #00ff88;
}
.starlink-ctrl-info {
  font-size: 22rpx;
  font-family: 'Courier New', Consolas, monospace;
  letter-spacing: 1rpx;
  color: rgba(255, 255, 255, 0.5);
}
.starlink-expand-hint {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
  border: 1px solid rgba(0, 255, 136, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}
.starlink-expand-text {
  font-size: 20rpx;
  color: rgba(0, 255, 136, 0.85);
  line-height: 1;
}
/* ========== D2C 折叠按钮 ========== */

/* ========== 助推器族谱 ========== */

/* ========== Starlink 过境预报 ========== */
.pass-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}
/* 融合入口卡片 */
.pass-hero-card {
  position: relative;
  overflow: hidden;
  padding: 36rpx 36rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
/* 星链列车流星光效 —— 单条，偶尔一闪而过 */
.pass-hero-trail {
  position: absolute;
  height: 1.5rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.6) 40%, rgba(255, 255, 255, 0.9) 60%, transparent 100%);
  opacity: 0;
  pointer-events: none;
}
.pass-hero-trail--1 {
  top: 30%;
  left: -60%;
  width: 35%;
  animation: passTrailFlash 8s ease-in-out infinite;
  animation-delay: 2s;
}
.pass-hero-trail--2 {
  top: 62%;
  left: -50%;
  width: 25%;
  animation: passTrailFlash 12s ease-in-out infinite;
  animation-delay: 6s;
  height: 1rpx;
}
.pass-hero-trail--3 {
  display: none;
}
@keyframes passTrailFlash {
  0%, 85%, 100% {
    transform: translateX(0);
    opacity: 0;
  }
  90% {
    opacity: 0.7;
  }
  95% {
    transform: translateX(450%);
    opacity: 0;
  }
}
.pass-hero-card-body {
  flex: 1;
  min-width: 0;
  position: relative;
  z-index: 1;
}
.pass-hero-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.pass-hero-card-info {
  flex: 1;
  min-width: 0;
}
.pass-hero-card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}
.pass-hero-card-loc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}
.pass-hero-card-btns {
  display: flex;
  gap: 14rpx;
  flex-shrink: 0;
}
.pass-hero-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.12);
}
.pass-hero-chip text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  line-height: 1;
}
.pass-hero-chip--pro {
  border-color: rgba(255, 214, 10, 0.25);
  background: rgba(255, 214, 10, 0.06);
}
.pass-hero-chip--pro text {
  color: #FFD60A;
}
.pass-hero-card-bottom {
  position: relative;
  z-index: 1;
}
.pass-hero-card-next {
  display: inline;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 12rpx;
}
.pass-hero-card-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}
.pass-hero-card-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.2);
  line-height: 1;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.pass-refresh-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 80rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
}
.pass-refresh-chip text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1;
}
.pass-location {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.icon-arrow--pass-toggle {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}
.icon-arrow--pass-toggle.expanded {
  transform: rotate(90deg);
}
.pass-time {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  font-variant-numeric: tabular-nums;
}
.pass-loading, .pass-empty {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  gap: 12rpx;
}
.pass-location-icon {
  width: 56rpx;
  height: 56rpx;
}
.pass-locate-btn {
  margin-top: 12rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: rgba(0, 122, 255, 0.15);
  border: 1px solid rgba(0, 122, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.pass-locate-btn text {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}
/* ========== D2C 折叠按钮（续） ========== */
/* B站直播二维码弹窗 */
.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 10002;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: qrFadeIn 0.2s ease;
}
@keyframes qrFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.qrcode-modal-content {
  width: 600rpx;
  max-width: 90%;
  background: rgba(28, 28, 30, 0.95);
  backdrop-filter: blur(40rpx) saturate(150%);
  -webkit-backdrop-filter: blur(40rpx) saturate(150%);
  border-radius: 24rpx;
  overflow: hidden;
  animation: qrSlideUp 0.3s ease;
}
@keyframes qrSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.qrcode-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}
.qrcode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.qrcode-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}
.qrcode-close:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}
.icon-close--qrcode {
  font-size: 36rpx;
}
.qrcode-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 40rpx;
  gap: 30rpx;
}
.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  padding: 20rpx;
  box-sizing: border-box;
}
.qrcode-tip {
  font-size: 24rpx;
  color: #8E8E93;
  text-align: center;
}
.qrcode-tip--name {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.qrcode-copy-btn {
  margin-top: 10rpx;
  padding: 16rpx 40rpx;
  background: rgba(0, 122, 255, 0.9);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}
.qrcode-copy-btn:active {
  background: rgba(0, 122, 255, 0.7);
  transform: scale(0.97);
}
.qrcode-copy-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}
/* ========== 空间站实时状态 ========== */
.station-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}
.station-loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}
.station-loading-text {
  font-size: 24rpx;
  color: #636366;
}
/* 两个空间站卡片并排 */
.station-row {
  display: flex;
  gap: 16rpx;
}
.station-mini-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}
.station-mini-card:active {
  transform: scale(0.97);
}
.station-mini-img {
  width: 100%;
  height: 140rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  margin-bottom: 12rpx;
  opacity: 0;
  transform: scale(1.02);
  transition: opacity 0.32s ease, transform 0.32s ease;
}
.station-mini-img--loaded {
  opacity: 1;
  transform: scale(1);
}
.station-mini-img--placeholder {
  background: radial-gradient(circle at center, rgba(90, 200, 250, 0.10), rgba(255, 255, 255, 0.03) 72%);
  box-shadow: inset 0 0 18rpx rgba(90, 200, 250, 0.05);
  position: relative;
}
.station-mini-img--placeholder::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 44rpx;
  height: 44rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 2rpx solid rgba(90, 200, 250, 0.22);
  box-shadow: 0 0 16rpx rgba(90, 200, 250, 0.08);
}
.station-mini-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.station-mini-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-align: center;
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.station-mini-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
  justify-content: center;
}
.station-mini-dock {
  font-size: 20rpx;
  color: #8E8E93;
}
.station-mini-arrow {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #636366;
  transition: transform 0.25s ease;
}
/* 空间站标签 */
.station-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}
.station-tag--active {
  color: #34C759;
  background: rgba(52, 199, 89, 0.15);
  border: 1px solid rgba(52, 199, 89, 0.3);
}
/* 空间站无数据 */
.station-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}
.station-empty-visual {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: radial-gradient(circle at 35% 35%, rgba(90, 200, 250, 0.22), rgba(90, 200, 250, 0.06) 32%, rgba(255, 255, 255, 0.03) 72%);
  border: 1px solid rgba(90, 200, 250, 0.16);
  box-shadow: inset 0 0 32rpx rgba(90, 200, 250, 0.08), 0 0 32rpx rgba(90, 200, 250, 0.08);
  position: relative;
}
.station-empty-visual::after {
  content: '';
  position: absolute;
  inset: 26rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(90, 200, 250, 0.3);
  box-shadow: 0 0 16rpx rgba(90, 200, 250, 0.1);
}
/* ========== 懒加载占位卡片 ========== */
.lazy-load-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  border-radius: 20rpx;
  gap: 8rpx;
}
.lazy-load-card:active {
  opacity: 0.7;
  transform: scale(0.98);
}
.lazy-load-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.lazy-load-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}
.lazy-load-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}
/* ========== 明亮主题（theme-light）覆盖 ========== */
/* 说明：以下元素刻意保持深色，不做覆盖 ——
   1. .orbital-card 及其全部子元素（黑色磨砂玻璃卡片，压在背景图/视频上的白字浮层）；
   2. .orbit-hero 及其子元素（图片 + 深色渐变蒙版上的白字倒计时面板）；
   3. .starlink-card 内部（Canvas 星图深色可视化容器，含 loading/error/控制条/全屏按钮浮层）；
   4. .qrcode-modal 全屏遮罩本体（深色遮罩保持，弹窗内容转浅色）；
   5. .agency-hw-card-image-mask / -overlay / -name / .agency-type-tag（压在照片上的白字与深色衬底）；
   6. .booster-status-badge / .sc-status-badge（压在卡片图片上的状态角标）。 */

/* --- 顶部导航 --- */
.theme-light .top-nav-wrapper {
  background: var(--bg-glass-nav);
  border-bottom: 1px solid var(--color-divider);
}
