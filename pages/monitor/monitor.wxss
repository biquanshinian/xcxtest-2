/* ===== 功能板块分组卡片 =====
   每个功能板块套一个圆角卡片，与页面背景区分，布局更干净整洁。
   放在文件末尾：同为单类选择器，按书写顺序覆盖各 section 原有的 padding/margin */
.monitor-block {
  margin: 0 0 28rpx;
  padding: 26rpx 22rpx 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.045);
  border: 1px solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
  overflow: hidden;
}

/* 轨道数据中心标题原有的 32rpx 顶部间距在独立卡片内不再需要 */
.odc-section .section-title--orbital {
  margin-top: 0;
}

.theme-light .monitor-block {
  background: #FFFFFF;
  border-color: var(--color-divider);
}
