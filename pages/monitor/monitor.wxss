/* 星链列车流星光效 —— 单条，偶尔一闪而过 */
.pass-hero-trail {
  position: absolute;
  height: 1.5rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.6) 40%, rgba(255, 255, 255, 0.9) 60%, transparent 100%);
  opacity: 0;
  pointer-events: none;
}

.pass-hero-trail--1 {
  top: 30%;
  left: -60%;
  width: 35%;
  animation: passTrailFlash 8s ease-in-out infinite;
  animation-delay: 2s;
}

.pass-hero-trail--2 {
  top: 62%;
  left: -50%;
  width: 25%;
  animation: passTrailFlash 12s ease-in-out infinite;
  animation-delay: 6s;
  height: 1rpx;
}

.pass-hero-trail--3 {
  display: none;
}

@keyframes passTrailFlash {
  0%, 85%, 100% {
    transform: translateX(0);
    opacity: 0;
  }
  90% {
    opacity: 0.7;
  }
  95% {
    transform: translateX(450%);
