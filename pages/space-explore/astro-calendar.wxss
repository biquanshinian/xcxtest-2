.page { min-height: 100vh; background: #000; color: #fff; }
/* 全屏滚动骨架：内容从磨砂导航栏下方穿过（内部导航占位撑开首屏） */
.page-scroll { height: 100vh; width: 100%; box-sizing: border-box; padding-bottom: env(safe-area-inset-bottom); }

/* 导航栏 */
.top-nav-wrapper { }

/* 区块 */
.section-header { display: flex; align-items: center; padding: 40rpx 32rpx 20rpx; gap: 12rpx; }
.section-icon { font-size: 28rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #fff; flex: 1; }

/* 日期选择 */
.date-row { display: flex; align-items: center; justify-content: space-between; padding: 0 32rpx 20rpx; }
.date-label { font-size: 28rpx; color: rgba(255,255,255,0.7); }
.date-picker-btn { padding: 12rpx 28rpx; border-radius: 24rpx; background: rgba(255,87,51,0.15); border: 1px solid rgba(255,87,51,0.3); display: flex; align-items: center; justify-content: center; }
.date-picker-btn text { font-size: 24rpx; color: #FF5733; line-height: 1; }

/* 加载 */
.loading-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; gap: 24rpx; }
.loading-spinner-lg { width: 56rpx; height: 56rpx; border: 4rpx solid rgba(255,255,255,0.1); border-top-color: #FF5733; border-radius: 50%; animation: spin 0.8s linear infinite; }
.loading-text { font-size: 26rpx; color: rgba(255,255,255,0.4); }
@keyframes spin { to { transform: rotate(360deg); } }

/* 错误 */
.error-card { display: flex; flex-direction: column; align-items: center; margin: 20rpx 32rpx; padding: 60rpx 32rpx; background: rgba(255,255,255,0.04); border-radius: 20rpx; border: 1px solid rgba(255,255,255,0.06); gap: 20rpx; }
.error-icon { font-size: 48rpx; }
.error-text { font-size: 26rpx; color: #FF453A; text-align: center; }
.retry-btn { padding: 16rpx 48rpx; border-radius: 24rpx; background: rgba(255,87,51,0.15); border: 1px solid rgba(255,87,51,0.3); }
.retry-btn text { font-size: 26rpx; color: #FF5733; }

/* APOD 卡片 */
.apod-card { margin: 0 32rpx 20rpx; background: rgba(255,255,255,0.04); border-radius: 20rpx; border: 1px solid rgba(255,255,255,0.06); overflow: hidden; }
.apod-image-wrap { position: relative; }
.apod-image { width: 100%; display: block; }
.apod-image-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 20rpx; background: linear-gradient(transparent, rgba(0,0,0,0.7)); text-align: right; }
.apod-image-hint { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.apod-video-placeholder { padding: 120rpx 32rpx; text-align: center; background: rgba(255,255,255,0.02); }
.video-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.video-hint { font-size: 26rpx; color: rgba(255,255,255,0.4); }

.apod-info { padding: 28rpx 28rpx 20rpx; }
.apod-title { display: block; font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; line-height: 1.4; }
.apod-date-text { display: block; font-size: 22rpx; color: #FF5733; margin-bottom: 8rpx; }
.apod-copyright { display: block; font-size: 20rpx; color: rgba(255,255,255,0.3); margin-bottom: 16rpx; }
.apod-explanation { display: block; font-size: 26rpx; color: rgba(255,255,255,0.65); line-height: 1.75; }

/* 分享按钮 */
.share-actions { display: flex; gap: 20rpx; padding: 24rpx 32rpx; }
.share-btn { flex: 1; height: 80rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 500; border: none; display: flex; align-items: center; justify-content: center; background: rgba(255,87,51,0.15); color: #FF5733; line-height: 80rpx; }
.share-btn::after { border: none; }
.share-btn--outline { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); }
.share-btn--outline text { color: rgba(255,255,255,0.6); }

/* 天文事件 */
.sub-header { display: flex; align-items: center; gap: 10rpx; padding: 16rpx 32rpx 8rpx; }
.sub-header-dot { width: 12rpx; height: 12rpx; border-radius: 50%; }
.sub-header-dot--upcoming { background: #FF5733; box-shadow: 0 0 8rpx rgba(255,87,51,0.6); }
.sub-header-dot--past { background: rgba(255,255,255,0.2); }
.sub-header-text { font-size: 24rpx; color: rgba(255,255,255,0.5); }

.event-card { display: flex; align-items: center; gap: 16rpx; margin: 8rpx 32rpx; padding: 24rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; border: 1px solid rgba(255,255,255,0.06); }
.event-card--past { opacity: 0.5; }
.event-left { flex-shrink: 0; }
.event-icon { font-size: 32rpx; }
.event-body { flex: 1; min-width: 0; }
.event-title { display: block; font-size: 28rpx; font-weight: 500; color: #fff; }
.event-desc { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 4rpx; }
.event-right { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.event-date { font-size: 22rpx; color: #FF5733; font-variant-numeric: tabular-nums; }
.event-remind-btn { display: flex; align-items: center; gap: 4rpx; padding: 6rpx 14rpx; border-radius: 999rpx; background: rgba(255, 255, 255, 0.06); border: 1rpx solid rgba(255, 255, 255, 0.1); transition: all 0.3s ease; }
.event-remind-btn:active { transform: scale(0.92); }
.event-remind-btn--active { background: rgba(255, 87, 51, 0.15); border-color: rgba(255, 87, 51, 0.3); }
.event-remind-icon { font-size: 20rpx; }
.event-remind-text { font-size: 18rpx; color: rgba(255, 255, 255, 0.5); }
.event-remind-btn--active .event-remind-text { color: #FF5733; }

/* 页脚 */
.page-footer { text-align: center; padding: 40rpx 0 80rpx; }
.footer-text { font-size: 22rpx; color: rgba(255,255,255,0.15); letter-spacing: 3rpx; }

/* ========== 明亮主题（theme-light）覆盖 ========== */
/* 页面根 */
.page.theme-light {
  background: var(--color-bg-page, #F2F2F7);
  color: var(--color-text-primary);
}

/* 区块 */
.theme-light .section-title { color: var(--color-text-primary); }

/* 日期选择 */
.theme-light .date-label { color: var(--color-text-secondary); }
.theme-light .date-picker-btn {
  background: rgba(255, 87, 51, 0.12);
  border-color: rgba(255, 87, 51, 0.3);
}

/* 加载 */
.theme-light .loading-spinner-lg { border-color: rgba(0, 0, 0, 0.08); border-top-color: #FF5733; }
.theme-light .loading-text { color: var(--color-text-tertiary); }

/* 错误 */
.theme-light .error-card {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .retry-btn {
  background: rgba(255, 87, 51, 0.12);
  border-color: rgba(255, 87, 51, 0.3);
}

/* APOD 卡片（图上浮层 .apod-image-overlay / .apod-image-hint 保持深色压图样式） */
.theme-light .apod-card {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .apod-video-placeholder { background: rgba(0, 0, 0, 0.03); }
.theme-light .video-hint { color: var(--color-text-tertiary); }
.theme-light .apod-title { color: var(--color-text-primary); }
.theme-light .apod-copyright { color: var(--color-text-tertiary); }
.theme-light .apod-explanation { color: var(--color-text-secondary); }

/* 分享按钮 */
.theme-light .share-btn--outline {
  background: rgba(0, 0, 0, 0.05);
  border-color: var(--color-divider);
}
.theme-light .share-btn--outline text { color: var(--color-text-secondary); }

/* 天文事件 */
.theme-light .sub-header-dot--past { background: rgba(0, 0, 0, 0.15); }
.theme-light .sub-header-text { color: var(--color-text-tertiary); }
.theme-light .event-card {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .event-title { color: var(--color-text-primary); }
.theme-light .event-desc { color: var(--color-text-tertiary); }
.theme-light .event-remind-btn {
  background: rgba(0, 0, 0, 0.05);
  border-color: var(--color-divider);
}
.theme-light .event-remind-text { color: var(--color-text-tertiary); }
.theme-light .event-remind-btn--active {
  background: rgba(255, 87, 51, 0.12);
  border-color: rgba(255, 87, 51, 0.3);
}
.theme-light .event-remind-btn--active .event-remind-text { color: #FF5733; }

/* 页脚 */
.theme-light .footer-text { color: rgba(0, 0, 0, 0.25); }
