.page { min-height: 100vh; background: #000; color: #fff; }
/* 全屏滚动骨架：内容从磨砂导航栏下方穿过（内部导航占位撑开首屏） */
.page-scroll { height: 100vh; width: 100%; box-sizing: border-box; padding-bottom: env(safe-area-inset-bottom); }

.top-nav-wrapper { }

.section-header { display: flex; align-items: center; padding: 32rpx 32rpx 16rpx; gap: 12rpx; }
.section-icon { font-size: 28rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #fff; flex: 1; }

/* 统计条 */
.stats-bar { display: flex; align-items: center; justify-content: center; margin: 20rpx 32rpx 0; padding: 28rpx 0; background: rgba(255,255,255,0.04); border-radius: 16rpx; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.06); }
.stat-item { flex: 1; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.stat-num { display: block; font-size: 36rpx; font-weight: 700; color: #FF5733; font-variant-numeric: tabular-nums; text-align: center; line-height: 1.3; }
.stat-label { display: block; font-size: 20rpx; color: rgba(255,255,255,0.45); margin-top: 4rpx; text-align: center; line-height: 1.3; }
.stat-divider { width: 1px; height: 40rpx; background: rgba(255,255,255,0.1); }

/* 筛选 */
.filter-scroll { padding: 8rpx 0; white-space: nowrap; }
.filter-chips-row { display: inline-flex; gap: 12rpx; padding: 0 32rpx; }
.chip { padding: 10rpx 24rpx; border-radius: 24rpx; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; text-align: center; box-sizing: border-box; }
.chip text { font-size: 24rpx; color: rgba(255,255,255,0.5); white-space: nowrap; line-height: 1.4; }
.chip--active { background: rgba(255,87,51,0.15); border-color: rgba(255,87,51,0.4); }
.chip--active text { color: #FF5733; font-weight: 600; }
.chip--habitable { background: rgba(76,175,80,0.15); border-color: rgba(76,175,80,0.4); }
.chip--habitable text { color: #4CAF50; font-weight: 600; }

.planet-count { padding: 8rpx 32rpx 4rpx; }
.planet-count text { font-size: 22rpx; color: rgba(255,255,255,0.3); }

/* 行星卡片 */
.planet-card { margin: 12rpx 32rpx; background: rgba(255,255,255,0.04); border-radius: 20rpx; border: 1px solid rgba(255,255,255,0.06); overflow: hidden; }
.planet-card-header { display: flex; align-items: center; gap: 14rpx; padding: 24rpx 24rpx 12rpx; }
.planet-icon-wrap { width: 56rpx; height: 56rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid; text-align: center; }
.planet-icon-text { font-size: 28rpx; line-height: 1; text-align: center; }
.planet-name-wrap { flex: 1; min-width: 0; }
.planet-name { display: block; font-size: 30rpx; font-weight: 600; color: #fff; }
.planet-name-en { display: block; font-size: 20rpx; color: rgba(255,255,255,0.3); margin-top: 2rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.planet-type-badge { flex-shrink: 0; padding: 4rpx 14rpx; border-radius: 10rpx; display: inline-flex; align-items: center; justify-content: center; text-align: center; }
.planet-type-badge text { font-size: 20rpx; font-weight: 600; line-height: 1.4; }

.planet-desc { display: block; font-size: 24rpx; color: rgba(255,255,255,0.5); line-height: 1.6; padding: 0 24rpx; }

.planet-quick-stats { display: flex; gap: 12rpx; padding: 16rpx 24rpx 0; }
.planet-stat { flex: 1; padding: 12rpx 8rpx; background: rgba(255,255,255,0.03); border-radius: 12rpx; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; box-sizing: border-box; }
.planet-stat-label { display: block; font-size: 20rpx; color: rgba(255,255,255,0.3); text-align: center; line-height: 1.4; }
.planet-stat-value { display: block; font-size: 24rpx; color: #fff; font-weight: 500; margin-top: 4rpx; text-align: center; line-height: 1.4; }

/* 展开详情 */
.planet-detail { padding: 16rpx 24rpx 0; border-top: 1px solid rgba(255,255,255,0.04); margin-top: 16rpx; animation: fadeSlide 0.25s ease-out; }
@keyframes fadeSlide { from { opacity: 0; transform: translateY(-8rpx); } to { opacity: 1; transform: translateY(0); } }
.planet-detail-row { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.pd-label { font-size: 24rpx; color: rgba(255,255,255,0.4); flex-shrink: 0; }
.pd-value { font-size: 24rpx; color: rgba(255,255,255,0.75); text-align: right; }
.pd-value--habitable { color: #4CAF50; font-weight: 500; }

/* 大小对比 */
.size-compare { margin-top: 16rpx; padding: 16rpx; background: rgba(255,255,255,0.03); border-radius: 12rpx; }
.size-compare-label { display: block; font-size: 20rpx; color: rgba(255,255,255,0.35); margin-bottom: 12rpx; }
.size-bar-track { width: 100%; height: 20rpx; background: rgba(255,255,255,0.06); border-radius: 10rpx; overflow: hidden; }
.size-bar-fill { height: 100%; border-radius: 10rpx; min-width: 10rpx; transition: width 0.5s ease; }
.size-compare-icons { display: flex; justify-content: space-between; margin-top: 8rpx; }
.size-earth-icon { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.size-planet-icon { font-size: 22rpx; color: rgba(255,255,255,0.6); }

.planet-expand-hint { text-align: center; padding: 12rpx 0 16rpx; }
.planet-expand-hint text { font-size: 22rpx; color: rgba(255,87,51,0.6); }

/* 发现方法 */
.method-card { display: flex; gap: 16rpx; margin: 8rpx 32rpx; padding: 24rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; border: 1px solid rgba(255,255,255,0.06); }
.method-icon { font-size: 32rpx; flex-shrink: 0; width: 48rpx; text-align: center; line-height: 1; display: flex; align-items: flex-start; justify-content: center; }
.method-body { flex: 1; min-width: 0; }
.method-header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4rpx; }
.method-name { font-size: 28rpx; font-weight: 500; color: #fff; }
.method-count { font-size: 22rpx; color: rgba(255,87,51,0.6); }
.method-desc { display: block; font-size: 24rpx; color: rgba(255,255,255,0.4); line-height: 1.5; }

/* 分享 */
.share-actions { display: flex; gap: 20rpx; padding: 32rpx 32rpx 16rpx; }
.share-btn { flex: 1; height: 80rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 500; border: none; display: flex; align-items: center; justify-content: center; background: rgba(255,87,51,0.15); color: #FF5733; line-height: 80rpx; }
.share-btn::after { border: none; }
.share-btn--outline { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); }
.share-btn--outline text { color: rgba(255,255,255,0.6); }

.page-footer { text-align: center; padding: 40rpx 0 80rpx; }
.footer-text { font-size: 22rpx; color: rgba(255,255,255,0.15); letter-spacing: 3rpx; }

/* ========== 明亮主题（theme-light）覆盖 ========== */
/* 页面根 */
.page.theme-light {
  background: var(--color-bg-page, #F2F2F7);
  color: var(--color-text-primary);
}

/* 区块标题 */
.theme-light .section-title { color: var(--color-text-primary); }

/* 统计条 */
.theme-light .stats-bar {
  background: rgba(255, 255, 255, 0.62);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .stat-label { color: var(--color-text-tertiary); }
.theme-light .stat-divider { background: var(--color-divider); }

/* 筛选胶囊 */
.theme-light .chip {
  background: rgba(0, 0, 0, 0.05);
  border-color: var(--color-divider);
}
.theme-light .chip text { color: var(--color-text-tertiary); }
.theme-light .chip--active {
  background: rgba(255, 87, 51, 0.12);
  border-color: rgba(255, 87, 51, 0.4);
}
.theme-light .chip--active text { color: #FF5733; }
.theme-light .chip--habitable {
  background: rgba(76, 175, 80, 0.12);
  border-color: rgba(76, 175, 80, 0.4);
}
.theme-light .chip--habitable text { color: #4CAF50; }
.theme-light .planet-count text { color: var(--color-text-tertiary); }

/* 行星卡片 */
.theme-light .planet-card {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .planet-name { color: var(--color-text-primary); }
.theme-light .planet-name-en { color: var(--color-text-tertiary); }
.theme-light .planet-desc { color: var(--color-text-tertiary); }
.theme-light .planet-stat { background: rgba(0, 0, 0, 0.04); }
.theme-light .planet-stat-label { color: var(--color-text-tertiary); }
.theme-light .planet-stat-value { color: var(--color-text-primary); }

/* 展开详情 */
.theme-light .planet-detail { border-top-color: rgba(0, 0, 0, 0.06); }
.theme-light .pd-label { color: var(--color-text-tertiary); }
.theme-light .pd-value { color: var(--color-text-secondary); }

/* 大小对比 */
.theme-light .size-compare { background: rgba(0, 0, 0, 0.04); }
.theme-light .size-compare-label { color: var(--color-text-tertiary); }
.theme-light .size-bar-track { background: rgba(0, 0, 0, 0.08); }
.theme-light .size-earth-icon { color: var(--color-text-tertiary); }
.theme-light .size-planet-icon { color: var(--color-text-secondary); }
.theme-light .planet-expand-hint text { color: rgba(255, 87, 51, 0.9); }

/* 发现方法 */
.theme-light .method-card {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .method-name { color: var(--color-text-primary); }
.theme-light .method-count { color: rgba(255, 87, 51, 0.9); }
.theme-light .method-desc { color: var(--color-text-tertiary); }

/* 分享按钮 */
.theme-light .share-btn--outline {
  background: rgba(0, 0, 0, 0.05);
  border-color: var(--color-divider);
}
.theme-light .share-btn--outline text { color: var(--color-text-secondary); }

/* 页脚 */
.theme-light .footer-text { color: rgba(0, 0, 0, 0.25); }
