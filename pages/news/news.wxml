<wxs module="navPad" src="/utils/nav-scroll-pad.wxs"></wxs>
<!--pages/news/news.wxml-->
<template name="photoCard">
  <view class="photo-card glass-card card-hover">
    <navigator class="card-link" url="/subpackages/news-extra/photo-detail?id={{item.id}}" bindtap="onNewsCardSnapshotTap" data-id="{{item.id}}">
      <view class="photo-cover-wrap" style="aspect-ratio: {{item.coverAspectRatio || 1}};">
        <image
          class="photo-cover"
          wx:if="{{item.cardImage || item.coverUrl}}"
          src="{{item.cardImage || item.coverUrl}}"
          mode="aspectFill"
          lazy-load="{{true}}"
        ></image>
        <view class="photo-count-badge" wx:if="{{item.photoCountText}}">{{item.photoCountText}}</view>
      </view>
      <view class="photo-meta" wx:if="{{item.location || item.publishedAtText}}">
        <view class="photo-meta-row">
          <view class="meta-item" wx:if="{{item.location}}">
            <image class="meta-location-icon" src="/images/icons/icon-location.svg" mode="aspectFit"></image>
            <text class="meta-text">{{item.location}}</text>
          </view>
          <text class="photo-shot-at" wx:if="{{item.publishedAtText}}">{{item.publishedAtText}}</text>
        </view>
      </view>
    </navigator>
    <view class="article-footer photo-card-footer">
      <view class="photo-author-row">
        <view class="photo-avatar">{{item.authorAvatar}}</view>
        <text class="photo-author-name">{{item.authorName}}</text>
      </view>
      <view class="article-actions">
        <button class="article-share-btn" open-type="share" data-id="{{item.id}}" data-type="photo" catchtap="sharePhoto">
          <image class="icon-share icon-share--article" src="/images/share-arrow.svg" mode="aspectFit" data-id="{{item.id}}" data-type="photo"></image>
        </button>
      </view>
    </view>
  </view>
</template>
<page-meta background-color="{{pageBgColor}}" background-color-top="{{pageBgColor}}" background-color-bottom="{{pageBgColor}}" />
<view class="container {{themeClass}}">
  <!-- 顶部导航栏（包含状态栏） -->
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav">
    <view
      wx:if="{{showPhotosNav}}"
      class="nav-button {{contentType === 'photos' ? 'active' : ''}} nav-button--photos"
      bindtap="switchContentType"
      data-type="photos"
    >
      <text>航天摄影</text>
      <view wx:if="{{showPhotosNavDot}}" class="nav-red-dot"></view>
    </view>
    <view class="nav-button {{contentType === 'articles' ? 'active' : ''}} nav-button--articles" bindtap="switchContentType" data-type="articles">
      <text>航天事件</text>
      <view wx:if="{{showArticlesNavDot}}" class="nav-red-dot"></view>
    </view>
    <view class="nav-button {{contentType === 'events' ? 'active' : ''}}" bindtap="switchContentType" data-type="events">
      <text>即将发生</text>
    </view>
    </view>
  </view>

  <!-- 自定义下拉三点：避开固定导航，位于导航底部与下拉内容之间（复用首页样式，样式在 app.wxss） -->
  <view id="pullRefreshDots" class="pull-refresh-dots" aria-hidden="true">
    <view class="pull-refresh-dots__dot"></view>
    <view class="pull-refresh-dots__dot"></view>
    <view class="pull-refresh-dots__dot"></view>
  </view>

  <scroll-view
    class="content-scroll main-content-scroll nav-aware-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    bounces="{{true}}"
    refresher-enabled="{{true}}"
    refresher-default-style="none"
    refresher-background="{{pageBgColor}}"
    refresher-threshold="36"
    refresher-triggered="{{scrollRefreshing}}"
    data-nav-h="{{navPlaceholderHeight}}"
    data-refresh-threshold="36"
    bindtouchend="{{navPad.onRelease}}"
    bindtouchcancel="{{navPad.onRelease}}"
    bindrefresherpulling="{{navPad.onPulling}}"
    bindrefresherrestore="{{navPad.onReset}}"
    bindrefresherabort="{{navPad.onReset}}"
    bindrefresherrefresh="onScrollRefresh"
    lower-threshold="{{loadMoreLowerThreshold}}"
    bindscroll="onNewsScroll"
    bindscrolltolower="loadMoreNews"
  >
    
    <nav-scroll-pad id="navScrollPad" class="nav-scroll-pad" height="{{navPlaceholderHeight}}" />
<!-- 内容列表 -->
    <view class="news-list">
      <!-- 航天摄影：双列瀑布流（按封面比例错落）；wx:if 与列表拆开避免串 Tab -->
      <block wx:if="{{contentType === 'photos'}}">
        <view class="photo-masonry">
          <view class="photo-masonry-col">
            <block wx:for="{{photoColLeft}}" wx:key="id">
              <template is="photoCard" data="{{item: item}}" />
            </block>
          </view>
          <view class="photo-masonry-col">
            <block wx:for="{{photoColRight}}" wx:key="id">
              <template is="photoCard" data="{{item: item}}" />
            </block>
          </view>
        </view>
      </block>

      <!-- 事件卡片 -->
      <block wx:if="{{contentType === 'events'}}">
      <view class="news-card glass-card card-hover" wx:for="{{newsList}}" wx:key="id">
        <navigator class="card-link" url="/subpackages/news-extra/detail?id={{item.id}}&type=event" bindtap="onNewsCardSnapshotTap" data-id="{{item.id}}">
          <image class="news-image" wx:if="{{item.image}}" src="{{item.cardImage || item.image}}" mode="aspectFill" lazy-load="{{true}}"></image>

          <view class="news-content">
            <view class="news-header">
              <view class="event-type-badge">
                <text class="event-type-text">{{item.type}}</text>
              </view>
              <text class="news-time">{{item.formattedTime}}</text>
            </view>

            <text class="news-title">{{item.title}}</text>

            <text class="news-summary" wx:if="{{item.description}}">{{item.description}}</text>
          </view>
        </navigator>

        <view class="news-bottom-row" catchtap="stopPropagation">
          <view class="news-meta-inline">
            <view class="meta-item" wx:if="{{item.location}}">
              <image class="meta-location-icon" src="/images/icons/icon-location.svg" mode="aspectFit"></image>
              <text class="meta-text">{{item.location}}</text>
            </view>
            <view class="meta-item" wx:if="{{item.webcastLive}}">
              <text class="meta-icon">🔴</text>
              <text class="meta-text live-text">直播中</text>
            </view>
          </view>
          <view class="article-actions">
            <button class="article-share-btn" open-type="share" data-id="{{item.id}}" data-type="event" catchtap="shareEvent">
              <image class="icon-share icon-share--article" src="/images/share-arrow.svg" mode="aspectFit" data-id="{{item.id}}" data-type="event"></image>
            </button>
          </view>
        </view>
      </view>
      </block>

      <!-- 文章卡片（配图区域与「即将发生」同款：整宽 news-image + 下方正文） -->
      <block wx:if="{{contentType === 'articles'}}">
      <view class="article-card glass-card card-hover" wx:for="{{newsList}}" wx:key="id">
        <navigator class="card-link" url="/subpackages/news-extra/detail?id={{item.id}}&type=article" bindtap="onNewsCardSnapshotTap" data-id="{{item.id}}">
          <image class="news-image" wx:if="{{item.cardImage}}" src="{{item.cardImage}}" mode="aspectFill" lazy-load="{{true}}"></image>

          <view class="news-content">
            <view class="news-header">
              <text class="article-site">{{item.newsSite}}</text>
              <text class="article-time">{{item.formattedTime}}</text>
            </view>

            <text class="article-title">{{item.title}}</text>

            <text class="article-summary" wx:if="{{item.summary}}">
              {{item.summary}}
            </text>
          </view>
        </navigator>

        <view class="article-footer">
          <view class="article-author">
            <image class="article-author-icon" src="/images/tabbar/news.svg" mode="aspectFit"></image>
            <text class="article-author-text">{{item.author}}</text>
          </view>
          <view class="article-actions">
            <button class="article-share-btn" open-type="share" data-id="{{item.id}}" data-type="article" catchtap="shareArticle">
              <image class="icon-share icon-share--article" src="/images/share-arrow.svg" mode="aspectFit" data-id="{{item.id}}" data-type="article"></image>
            </button>
          </view>
        </view>
      </view>
      </block>
    </view>

    <!-- 触底加载：微信原生三点 -->
    <view class="wx-native-dots" wx:if="{{hasMore && loadMoreTriggered && newsList.length > 0}}">
      <view class="wx-native-dots__dot"></view>
      <view class="wx-native-dots__dot"></view>
      <view class="wx-native-dots__dot"></view>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && !loadMoreTriggered && newsList.length > 0}}">
      <text>没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{newsList.length === 0 && !loading}}">
      <text class="empty-text">{{contentType === 'photos' ? '暂无航天摄影，欢迎投稿分享' : '暂无数据，下拉刷新试试'}}</text>
    </view>

    <view style="height: {{tabBarReservedHeight}}px;"></view>
  </scroll-view>

  <!-- 影像投稿入口：滑动收起，停滑自动展现 -->
  <view
    wx:if="{{showPhotosNav && contentType === 'photos'}}"
    class="photo-upload-fab {{photoFabHidden ? 'photo-upload-fab--hidden' : ''}}"
    style="bottom: {{tabBarReservedHeight + 24}}px;"
    bindtap="goPhotoUpload"
  >
    <text class="photo-upload-fab__text">投稿</text>
  </view>

  <ai-chat id="ai-chat" />
  <nasa-float id="nasaFloat" show="{{!loading || newsList.length > 0}}" />
  <popup-ad visible="{{popupAdVisible}}" shop-item="{{popupAdItem}}" bind:close="onPopupAdClose"></popup-ad>
  <demo-overlay id="demoOverlay" showControls="{{false}}" qrcodeUrl="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E5%B0%8F%E7%A8%8B%E5%BA%8F%E4%BA%8C%E7%BB%B4%E7%A0%81/1775323336594_jkl6zv.png" loop="{{true}}" />
  <share-guide />

</view>
