  color: var(--color-text-tertiary);
}

.theme-light .prize-tracking-label {
  color: var(--color-text-tertiary);
}

/* 金色文字在白底不可读，压深为琥珀色（保持金色语义） */
.theme-light .prize-tracking-copy {
  color: #B8860B;
  border-color: rgba(184, 134, 11, 0.4);
}

/* —— 我的收藏 —— */
