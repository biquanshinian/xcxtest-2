  font-size: 22rpx !important;
  color: #7b8cff !important;
  background: rgba(123,140,255,0.1) !important;
  border: 1rpx solid rgba(123,140,255,0.3) !important;
  border-radius: 26rpx !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}
.prize-copy-btn::after {
  border: none !important;
}
.prize-copy-btn--hover {
  opacity: 0.6;
}


/* ══ 太空旅程入口 ══ */
.growth-entries {
  margin: 0 24rpx 28rpx;
}

.growth-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.growth-entry-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.growth-entry-icon-img {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.growth-entry-info {
  flex: 1;
}

.growth-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
}

.growth-entry-desc {
  font-size: 22rpx;
  color: #8B92B8;
  margin-top: 4rpx;
  display: block;
}

.growth-entry-arrow {
  font-size: 32rpx;
  color: #8B92B8;
}

/* ══ 标题行设置图标 ══ */
.section-title-action {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.section-settings-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

/* ══ 年度报告入口 ══ */
.year-review-entry {
  margin-bottom: 24rpx;
  padding: 28rpx 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(0, 122, 255, 0.25);
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.12) 0%, rgba(12, 14, 18, 0.85) 100%);
}

.year-review-entry-inner {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.year-review-entry-text {
  flex: 1;
  min-width: 0;
}

.year-review-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.year-review-entry-desc {
  font-size: 22rpx;
  color: #8eb5ff;
  margin-top: 6rpx;
  display: block;
}

.year-review-entry-arrow {
  font-size: 26rpx;
  color: #6aa8ff;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */

/* —— 页面骨架 / 顶部导航 —— */
.container.theme-light {
  background: var(--color-bg-page);
}

.theme-light .top-nav-wrapper {
  background: rgba(255, 255, 255, 0.62);
  border-bottom: 1rpx solid var(--color-divider);
}

/* —— 签到卡 —— */
.theme-light .checkin-stat-num {
  color: var(--color-text-primary);
}

.theme-light .checkin-stat-label {
  color: var(--color-text-tertiary);
}

.theme-light .checkin-stat-divider {
  background: var(--color-divider);
}

.theme-light .checkin-btn--done {
  background: rgba(0, 0, 0, 0.06);
}

.theme-light .checkin-btn--done .checkin-btn-text {
  color: var(--color-text-secondary);
}

.theme-light .checkin-btn--done .checkin-btn-icon {
  color: #07C160;
}

.theme-light .checkin-week {
  border-top: 1rpx solid var(--color-divider);
}

.theme-light .checkin-dot {
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .checkin-dot--checked {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.15) 0%, rgba(6, 173, 86, 0.15) 100%);
  border-color: rgba(7, 193, 96, 0.45);
}

.theme-light .checkin-dot--today {
  border-color: rgba(0, 0, 0, 0.2);
}

.theme-light .checkin-dot--today.checkin-dot--checked {
  border-color: #07C160;
  box-shadow: 0 0 12rpx rgba(7, 193, 96, 0.3);
}

.theme-light .checkin-dot-num {
  color: var(--color-text-tertiary);
}

.theme-light .checkin-dot--checked .checkin-dot-num {
  color: #07C160;
}

.theme-light .checkin-dot-label--today {
  color: #07C160;
}

.theme-light .checkin-dot-label {
  color: var(--color-text-tertiary);
}

/* —— 知识卡 —— */
.theme-light .fact-card-close {
  color: var(--color-text-tertiary);
}

.theme-light .fact-card-category {
  color: var(--color-text-tertiary);
  background: rgba(0, 0, 0, 0.05);
}

.theme-light .fact-card-text {
  color: var(--color-text-primary);
}

.theme-light .fact-card-source {
  color: var(--color-text-tertiary);
}

/* —— 区块标题 —— */
.theme-light .section-title-text {
  color: var(--color-text-primary);
}

.theme-light .section-title-count {
  color: var(--color-text-tertiary);
}

/* 齿轮图标 svg 为白色描边，浅色主题反色成深灰 */
.theme-light .section-settings-icon {
  filter: invert(1);
  opacity: 0.7;
}

/* —— 成就徽章 —— */
.theme-light .achievement-item {
  background: var(--color-bg-card);
  border-color: var(--color-divider);
}

.theme-light .achievement-name {
  color: var(--color-text-primary);
}

.theme-light .achievement-desc {
  color: var(--color-text-tertiary);
}

/* —— 徽章弹窗（遮罩保持深色，弹窗体随玻璃卡变浅）—— */
/* —— 徽章弹窗（无框设计）：浅色主题下去掉黑底，遮罩透明磨砂 + 深色文字 —— */
.theme-light .badge-modal-mask {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(48rpx) saturate(140%);
  -webkit-backdrop-filter: blur(48rpx) saturate(140%);
}

.theme-light .badge-modal-close {
  background: rgba(0, 0, 0, 0.06);
  border-color: rgba(0, 0, 0, 0.1);
  color: rgba(0, 0, 0, 0.55);
}

.theme-light .badge-modal-icon-img {
  filter: drop-shadow(0 12rpx 32rpx rgba(0, 0, 0, 0.18));
}

.theme-light .badge-modal-icon--locked .badge-modal-icon-img {
  filter: grayscale(1);
}

.theme-light .badge-modal-name {
  color: var(--color-text-primary);
  text-shadow: none;
}

.theme-light .badge-modal-desc {
  color: var(--color-text-secondary);
}

.theme-light .badge-modal-status {
  background: rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.08);
}

.theme-light .badge-modal-status--unlocked {
  color: #34C759;
}

.theme-light .badge-modal-status--locked {
  color: var(--color-text-secondary);
}

/* —— 我的奖品 —— */
.theme-light .prize-card-title {
  color: var(--color-text-primary);
}

.theme-light .prize-card-desc {
  color: var(--color-text-tertiary);
}

.theme-light .prize-card-size {
