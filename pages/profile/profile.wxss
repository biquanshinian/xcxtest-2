/* pages/profile/profile.wxss */
@import "../../styles/tweet-stats-bar.wxss";

.container {
  background: linear-gradient(180deg, #060709 0%, #0f1115 100%);
}

.top-nav-wrapper {
  z-index: 20;
  background: rgba(12, 14, 18, 0.08);
  backdrop-filter: blur(48rpx) saturate(170%);
  -webkit-backdrop-filter: blur(48rpx) saturate(170%);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}

.nav-title--profile {
  letter-spacing: 2rpx;
}

.content-scroll {
  padding-left: 22rpx;
  padding-right: 22rpx;
}

/* ═══════ 签到卡片 ═══════ */
.checkin-section {
  margin-bottom: 24rpx;
  position: relative;
}

.checkin-card {
  padding: 28rpx 28rpx 20rpx;
}

.checkin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.checkin-stats {
  display: flex;
  align-items: center;
  gap: 0;
  flex: 1;
}

.checkin-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.checkin-stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}

.checkin-stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 4rpx;
}

.checkin-stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}

.checkin-btn-wrap {
  margin-left: 20rpx;
}

.checkin-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3a7bfd 0%, #6c5ce7 100%);
  box-shadow: 0 4rpx 16rpx rgba(58, 123, 253, 0.35);
  transition: all 0.3s ease;
}

.checkin-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.checkin-btn--done {
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  box-shadow: none;
}

.checkin-btn-icon {
  font-size: 28rpx;
  color: #07C160;
}

.checkin-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

/* 本周签到点 */
.checkin-week {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 8rpx 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.checkin-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.checkin-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.checkin-dot--checked {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.3) 0%, rgba(6, 173, 86, 0.3) 100%);
  border-color: rgba(7, 193, 96, 0.5);
}

.checkin-dot--today {
  border-color: rgba(255, 255, 255, 0.25);
}

.checkin-dot--today.checkin-dot--checked {
  border-color: #07C160;
  box-shadow: 0 0 12rpx rgba(7, 193, 96, 0.4);
}

.checkin-dot-num {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.checkin-dot--checked .checkin-dot-num {
  color: #fff;
}

.checkin-dot-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
}

.checkin-dot-label--today {
  color: rgba(7, 193, 96, 0.9);
  font-weight: 600;
}

/* ═══════ 知识卡片 ═══════ */
.fact-card {
  margin-top: 16rpx;
  padding: 28rpx;
  position: relative;
  opacity: 0;
  transform: translateY(20rpx) scale(0.96);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1rpx solid rgba(58, 123, 253, 0.2);
}

.fact-card--show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.fact-card-close {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
  z-index: 2;
}

.fact-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.fact-card-badge {
  font-size: 22rpx;
  color: rgba(58, 123, 253, 0.9);
  font-weight: 600;
}

.fact-card-category {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
}

.fact-card-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.7;
  display: block;
  margin-bottom: 12rpx;
}

.fact-card-source {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  display: block;
  text-align: right;
}

/* ═══════ 成就徽章 ═══════ */
.achievement-section {
  margin-bottom: 28rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

.section-title-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  font-variant-numeric: tabular-nums;
}

.achievement-scroll {
  width: 100%;
}

.achievement-list {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 4rpx 8rpx;
  white-space: nowrap;
}

.achievement-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 148rpx;
  min-width: 148rpx;
  padding: 20rpx 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.achievement-item--locked {
  opacity: 0.4;
}
.achievement-item--locked .achievement-icon-img {
  filter: grayscale(1);
}

.achievement-icon-img {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 8rpx;
}

.achievement-name {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 130rpx;
}

.achievement-desc {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.35);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 130rpx;
}

/* ── 徽章详情弹窗 ── */
.badge-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  /* 无边框设计：深色主题用深色遮罩做舞台，浅色主题见下方 .theme-light 透明磨砂覆盖 */
  background: rgba(8, 10, 16, 0.86);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
/* 无框弹层：徽章与文字直接悬浮在遮罩上 */
.badge-modal {
  width: 620rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.badge-modal-close {
  position: absolute;
  top: -60rpx;
  right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.75);
  font-size: 28rpx;
}
/* ── 徽章弹窗图标区域 ── */
.badge-modal-icon-wrap {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.badge-modal-icon-img {
  width: 232rpx;
  height: 232rpx;
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 12rpx 32rpx rgba(0, 0, 0, 0.45));
}
.badge-modal-icon--locked {
  opacity: 0.3;
  filter: grayscale(1);
}
.badge-modal-icon--locked .badge-modal-icon-img {
  filter: grayscale(1);
}

/* 金色柔光：深色遮罩上做呼吸光晕，不再是刺眼的橙色实心圆 */
.badge-modal-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 340rpx;
  height: 340rpx;
  margin-top: -170rpx;
  margin-left: -170rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 210, 110, 0.4) 0%, rgba(255, 180, 60, 0.16) 42%, transparent 68%);
  animation: glowPulse 2.4s ease-in-out infinite;
  z-index: 1;
}

@keyframes glowPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.75;
  }
  50% {
    transform: scale(1.12);
    opacity: 1;
  }
}

/* 3D 旋转登场动画 */
.badge-modal-icon--entrance {
  animation: badgeEntrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes badgeEntrance {
  0% {
    transform: perspective(800rpx) rotateY(180deg) scale(0.3);
    opacity: 0;
  }
  40% {
    transform: perspective(800rpx) rotateY(-20deg) scale(1.1);
    opacity: 1;
  }
  60% {
    transform: perspective(800rpx) rotateY(10deg) scale(0.95);
  }
  80% {
    transform: perspective(800rpx) rotateY(-5deg) scale(1.02);
  }
  100% {
    transform: perspective(800rpx) rotateY(0deg) scale(1);
    opacity: 1;
  }
}
.badge-modal-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.4);
}
.badge-modal-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 30rpx;
  text-align: center;
  line-height: 1.6;
}
.badge-modal-status {
  margin-top: 4rpx;
  padding: 14rpx 34rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
}
.badge-modal-status-text {
  font-size: 24rpx;
}
.badge-modal-status--unlocked {
  color: #6EE787;
}
.badge-modal-status--locked {
  color: rgba(255, 255, 255, 0.55);
}

/* ═══════ 每日问答挑战 ═══════ */

/* ═══ 我的奖品 ═══ */
.prize-section {
  margin-bottom: 28rpx;
}
.prize-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.prize-card {
  padding: 24rpx;
  border-radius: 20rpx;
}
.prize-card-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.prize-card-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
}
.prize-card-icon {
  width: 88rpx;
  height: 88rpx;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,215,0,0.12);
  border-radius: 14rpx;
  flex-shrink: 0;
}
.prize-card-info {
  flex: 1;
  min-width: 0;
}
.prize-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.4;
}
.prize-card-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.prize-card-size {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 2rpx;
}
.prize-status {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}
.prize-status--pending {
  background: rgba(255,152,0,0.15);
  color: #ff9800;
}
.prize-status--shipped {
  background: rgba(33,150,243,0.15);
  color: #42a5f5;
}
.prize-status--completed {
  background: rgba(76,175,80,0.15);
  color: #66bb6a;
}
.prize-tracking {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  font-size: 24rpx;
}
.prize-tracking--waiting {
  color: rgba(255,255,255,0.4);
  font-size: 22rpx;
}
.prize-tracking-label {
  color: rgba(255,255,255,0.5);
  flex-shrink: 0;
}
.prize-tracking-number {
  color: #42a5f5;
  margin-right: 12rpx;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}
.prize-tracking-copy {
  flex-shrink: 0;
  color: #ffd700;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid rgba(255,215,0,0.3);
  border-radius: 16rpx;
}

/* ═══ 我的提醒 ═══ */
/* ══ 我的收藏（发射商）══ */
.favorite-section {
  margin-bottom: 28rpx;
}

.favorite-scroll {
  width: 100%;
  white-space: nowrap;
}

.favorite-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 4rpx 12rpx;
}

.favorite-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  width: 176rpx;
  padding: 24rpx 16rpx 20rpx;
  border-radius: 20rpx;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.favorite-card--pressed {
  transform: scale(0.96);
  opacity: 0.85;
}

.favorite-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  z-index: 2;
}

/* logo 白底圆片（与发射商详情页 logo-chip 同视觉） */
.favorite-logo-chip {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.favorite-logo {
  width: 72rpx;
  height: 72rpx;
}

.favorite-logo-fallback {
  font-size: 44rpx;
}

.favorite-name {
  max-width: 100%;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.favorite-type {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.reminder-section {
  margin-bottom: 28rpx;
}

.appearance-section {
  margin-bottom: 28rpx;
}

/* ── 主题外观三段选择器（深色 / 浅色 / 跟随系统）── */
.theme-mode-group {
  display: flex;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 6rpx;
  background: var(--color-divider-faint, rgba(255, 255, 255, 0.06));
  border: 1rpx solid var(--color-divider, rgba(255, 255, 255, 0.08));
  border-radius: 16rpx;
}

.theme-mode-opt {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  line-height: 1;
  border-radius: 12rpx;
  color: var(--color-text-secondary, rgba(255, 255, 255, 0.55));
  transition: background 0.2s ease, color 0.2s ease;
}

.theme-mode-opt--active {
  background: rgba(7, 193, 96, 0.18);
  color: #07C160;
  font-weight: 600;
}

.oa-alert-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.oa-alert-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.oa-alert-info {
  flex: 1;
  min-width: 0;
}

.oa-alert-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.oa-alert-desc {
  display: block;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.55);
}

.oa-alert-switch {
  margin-top: 2rpx;
  transform-origin: center right;
}

.oa-alert-status {
  margin-top: 16rpx;
}

.oa-alert-status-text {
  font-size: 22rpx;
  color: rgba(255, 200, 120, 0.9);
}

.oa-alert-status-text--ready {
  color: rgba(120, 220, 160, 0.95);
}

.oa-alert-guide {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.oa-alert-guide-text {
  flex: 1;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.oa-alert-guide-copy {
  font-size: 22rpx;
  color: #07C160;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
}

/* ── 提醒时间线：单卡片承载，左轴节点按时间串联 ── */
.reminder-timeline {
  padding: 28rpx 24rpx 12rpx;
  border-radius: 20rpx;
}

.rm-item {
  display: flex;
  gap: 20rpx;
}

/* 左侧轴：节点 + 竖向连线 */
.rm-rail {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 24rpx;
  padding-top: 6rpx;
}

.rm-node {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* 24 小时内：琥珀色 + 呼吸光晕，最高优先级一眼可辨 */
.rm-node--today {
  background: #ffce5d;
  box-shadow: 0 0 0 6rpx rgba(255, 184, 0, 0.15), 0 0 16rpx rgba(255, 184, 0, 0.5);
  animation: rm-node-pulse 2s ease-in-out infinite;
}

@keyframes rm-node-pulse {
  0%, 100% { box-shadow: 0 0 0 6rpx rgba(255, 184, 0, 0.15), 0 0 16rpx rgba(255, 184, 0, 0.5); }
  50% { box-shadow: 0 0 0 10rpx rgba(255, 184, 0, 0.08), 0 0 24rpx rgba(255, 184, 0, 0.65); }
}

/* 未来任务：微信绿空心环 */
.rm-node--upcoming {
  background: transparent;
  border: 3rpx solid #07C160;
  box-sizing: border-box;
}

.rm-line {
  flex: 1;
  width: 2rpx;
  margin: 8rpx 0;
  background: linear-gradient(180deg, rgba(7, 193, 96, 0.35), rgba(255, 255, 255, 0.06));
}

/* 右侧内容体 */
.rm-body {
  flex: 1;
  min-width: 0;
  padding-bottom: 32rpx;
}

.rm-body--last {
  padding-bottom: 16rpx;
}

.rm-body:active {
  opacity: 0.75;
}

/* 第一行：时间 + 倒计时徽标 + 删除 */
.rm-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.rm-time {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.75);
  font-variant-numeric: tabular-nums;
}

.rm-time--today {
  color: #ffce5d;
}

.rm-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.rm-badge--today {
  background: rgba(255, 184, 0, 0.15);
  color: #ffce5d;
}

.rm-badge--upcoming {
  background: rgba(7, 193, 96, 0.12);
  color: #07C160;
}

.rm-cancel {
  margin-left: auto;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.rm-cancel:active {
