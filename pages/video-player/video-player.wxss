.video-player-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  background-color: #000000;
  box-sizing: border-box;
}

.video-player-video {
  width: 100%;
  height: 100%;
  display: block;
}

/* 固定左上角关闭，与胶囊垂直对齐；不进入原生横屏全屏，避免控件旋到左下角 */
.video-close {
  position: fixed;
  left: 16px;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.22);
  box-sizing: border-box;
}

.video-close-icon {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}
