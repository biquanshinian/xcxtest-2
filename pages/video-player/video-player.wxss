.video-player-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  background-color: #000000;
  box-sizing: border-box;
}

/* 下拉跟手关闭：wxs 直接改本容器 transform，视频随手指位移缩放 */
.video-drag-wrap {
  width: 100%;
  height: 100%;
  will-change: transform;
}

.video-player-video {
  width: 100%;
  height: 100%;
  display: block;
}

/* 固定左上角关闭：与胶囊同顶边同高，左边距镜像胶囊右边距（top/left/size 由 JS 按胶囊实测注入） */
.video-close {
  position: fixed;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.22);
  box-sizing: border-box;
}

.video-close-icon {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}
