/* pages/index/index.wxss */
@import "../../styles/tweet-stats-bar.wxss";
.container {
  padding-bottom: 0;
  padding-top: 0;
}
/* 顶部导航栏容器（包含状态栏和导航栏） */
.top-nav-wrapper {
  background: rgba(12, 14, 18, 0.08);
  backdrop-filter: blur(48rpx) saturate(170%);
  -webkit-backdrop-filter: blur(48rpx) saturate(170%);
  display: flex;
  flex-direction: column;
  /* 导航栏总高度：状态栏 + 40rpx(padding-top) + 80rpx(按钮) + 30rpx(padding-bottom) = 约150rpx + 状态栏 */
}
/* 顶部导航栏：上内边距加大，避免与右上角胶囊碰撞；整体下移 */
.top-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 70rpx 30rpx 0rpx;
  gap: 20rpx;
  min-height: 90rpx;
  position: relative;
}
.nav-search-btn {
  position: absolute;
  left: 30rpx;
  top: 12rpx;
  width: 74rpx;
  height: 54rpx;
  background: rgba(18, 20, 24, 0.16);
  backdrop-filter: blur(34rpx) saturate(170%);
  -webkit-backdrop-filter: blur(34rpx) saturate(170%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12);
  padding: 0;
  z-index: 2;
  transition: opacity 0.2s ease, transform 0.2s ease;
}
.icon-search--nav {
  position: absolute;
  left: 50%;
  top: 50%;
  font-size: 51rpx;
  transform: translate(-50%, -55%) scaleX(-1);
}
/* 倒计时卡片底部操作栏 */
.countdown-card-actions {
  position: relative;
  width: 100%;
  margin-top: 16rpx;
}
.nav-button {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 视觉微调：三按钮（即将发射/历史发射/发射日历）整体下移 3px 与胶囊对齐 */
  transform: translateY(3px);
  background: rgba(18, 20, 24, 0.16);
  backdrop-filter: blur(34rpx) saturate(170%);
  -webkit-backdrop-filter: blur(34rpx) saturate(170%);
  border: 1px solid var(--color-divider);
  border-radius: var(--radius-md);
  color: var(--color-text-secondary);
  font-size: var(--font-size-md);
  transition: all 0.3s ease;
  box-shadow: 
    0 4rpx 16rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12);
  position: relative;
  overflow: hidden;
}
.nav-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.3) 50%, 
    transparent 100%);
  pointer-events: none;
}
.nav-button.active {
  background: rgba(0, 122, 255, 0.15);
  border-color: rgba(0, 122, 255, 0.3);
  color: #007AFF;
  box-shadow: 
    0 4rpx 16rpx rgba(0, 122, 255, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
}
.nav-button--completed.active {
  background: rgba(255, 149, 0, 0.16);
  border-color: rgba(255, 149, 0, 0.34);
  color: #FF9500;
  box-shadow:
    0 4rpx 16rpx rgba(255, 149, 0, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
}
.nav-button--calendar {
  overflow: visible;
}
.nav-calendar-red-dot {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 16rpx;
  height: 16rpx;
  background: #FF3B30;
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(255, 59, 48, 0.6);
  pointer-events: none;
  z-index: 2;
}
/* 内容滚动区域 */
.content-scroll {
  padding: 0 30rpx;
}
/* 倒计时卡片 - 减少高度 */
.countdown-card {
  width: 100%;
  max-width: 100%;
  min-height: 380rpx;
  padding: 20rpx 30rpx 16rpx;
  margin-top: 0;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: visible;
  position: relative;
}
/* 去掉大倒计时卡底部玻璃压线（glass-card::after） */
.countdown-card.glass-card::after,
.countdown-card::after {
  content: none;
  display: none;
}

/* 重叠窗口副卡：精简条，倒计时字号偏大便于一眼扫到 */
.countdown-side-card {
  width: 100%;
  box-sizing: border-box;
  margin: -6rpx 0 16rpx;
  padding: 16rpx 20rpx 16rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: opacity 0.18s ease, transform 0.18s ease, background 0.18s ease;
}
.countdown-side-card:active {
  opacity: 0.88;
  transform: scale(0.992);
  background: rgba(255, 255, 255, 0.06);
}
.countdown-side-thumb {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}
.countdown-side-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}
.countdown-side-thumb-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.05);
}
.countdown-side-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.countdown-side-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}
.countdown-side-label {
  font-size: 18rpx;
  line-height: 1.2;
  letter-spacing: 0.04em;
  color: rgba(255, 255, 255, 0.42);
  flex-shrink: 0;
}
.countdown-side-status {
  font-size: 18rpx;
  line-height: 1.2;
  color: rgba(255, 196, 120, 0.88);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.countdown-side-main {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.countdown-side-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.countdown-side-name {
  font-size: 26rpx;
  line-height: 1.25;
  font-weight: 560;
  color: rgba(255, 255, 255, 0.9);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.countdown-side-cd {
  flex-shrink: 0;
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 640;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  color: rgba(255, 255, 255, 0.92);
}
.countdown-side-cd--confirm {
  color: rgba(255, 196, 120, 0.95);
  font-family: inherit;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0;
}
.countdown-side-meta {
  font-size: 20rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.38);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.countdown-side-chevron {
  flex-shrink: 0;
  font-size: 32rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.28);
  margin-top: -2rpx;
}
.countdown-card-main {
  display: flex;
  flex-direction: column;
  border-radius: 24rpx;
  transition: transform 0.18s ease, opacity 0.18s ease, background 0.18s ease;
}
.countdown-card-main:active {
  transform: scale(0.992);
  opacity: 0.92;
  background: rgba(255, 255, 255, 0.03);
}
/* 倒计时区：左侧圆形火箭配置图 + 时间与倒计时 */
.countdown-visual-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 22rpx;
  flex-shrink: 0;
}
/* 圆图 + 直播涟漪 / 下标签的定位容器 */
.countdown-rocket-wrap {
  position: relative;
  width: 132rpx;
  flex-shrink: 0;
  padding-bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.countdown-rocket-wrap.is-live {
  padding-bottom: 22rpx;
}
/* 外层定宽圆形容器：避免图片裁剪重心偏一侧，并让圆心在列方向稳定 */
.countdown-rocket-slot {
  position: relative;
  z-index: 2;
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}
.countdown-rocket-slot--live {
  border: 4rpx solid #ff2d55;
  animation: cd-live-ring-breathe 1.6s ease-in-out infinite;
}
.countdown-rocket-img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center center;
}
.countdown-rocket-slot-inner {
  width: 100%;
  height: 100%;
}
.countdown-rocket-avatar--placeholder {
  background: rgba(255, 255, 255, 0.05);
}
/* 抖音式外扩涟漪（放在 overflow:hidden 的 slot 外，避免被裁） */
.cd-live-ripple {
  position: absolute;
  top: 66rpx;
  left: 50%;
  width: 132rpx;
  height: 132rpx;
  margin-top: -66rpx;
  margin-left: -66rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 45, 85, 0.55);
  box-sizing: border-box;
  pointer-events: none;
  z-index: 1;
  animation: cd-live-ripple 1.8s ease-out infinite;
}
.cd-live-ripple--2 {
  animation-delay: 0.9s;
}
/* 下标签：声波 + 直播中 */
.cd-avatar-tag {
  position: absolute;
  left: 50%;
  bottom: 0;
  z-index: 3;
  transform: translateX(-50%);
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  box-sizing: border-box;
}
.cd-avatar-tag--live {
  background: linear-gradient(90deg, #ff2d55, #ff453a);
  box-shadow: 0 4rpx 12rpx rgba(255, 45, 85, 0.35);
}
.cd-avatar-tag-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
  letter-spacing: 0.5rpx;
}
/* 三柱声波均衡器 */
.cd-live-eq {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 3rpx;
  height: 18rpx;
  flex-shrink: 0;
}
.cd-live-eq-bar {
  width: 4rpx;
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
  transform-origin: center bottom;
  animation: cd-live-eq 0.8s ease-in-out infinite;
}
.cd-live-eq-bar:nth-child(1) { animation-delay: 0s; }
.cd-live-eq-bar:nth-child(2) { animation-delay: 0.15s; }
.cd-live-eq-bar:nth-child(3) { animation-delay: 0.3s; }
/* 点击进直播：压缩 → 微弹，再调起视频号 */
.countdown-rocket-wrap.is-entering .countdown-rocket-slot--live {
  animation: cd-live-enter 0.22s ease-out forwards;
}
.countdown-rocket-wrap.is-entering .cd-avatar-tag--live {
  animation: cd-live-tag-enter 0.22s ease-out forwards;
}
.countdown-rocket-wrap.is-entering .cd-live-ripple {
  animation: cd-live-ripple-burst 0.22s ease-out forwards;
}
/* 后台/隐藏时停动画省电（进入动画除外，避免打断跳转反馈） */
.countdown-rocket-wrap.is-paused:not(.is-entering) .countdown-rocket-slot--live,
.countdown-rocket-wrap.is-paused:not(.is-entering) .cd-live-ripple,
.countdown-rocket-wrap.is-paused:not(.is-entering) .cd-live-eq-bar {
  animation: none !important;
}
@keyframes cd-live-ring-breathe {
  0%, 100% { border-color: rgba(255, 45, 85, 0.85); }
  50% { border-color: rgba(255, 45, 85, 1); }
}
@keyframes cd-live-ripple {
  0% {
    transform: scale(1);
    opacity: 0.55;
  }
  100% {
    transform: scale(1.38);
    opacity: 0;
  }
}
@keyframes cd-live-eq {
  0%, 100% { transform: scaleY(0.35); }
  25% { transform: scaleY(1); }
  50% { transform: scaleY(0.55); }
  75% { transform: scaleY(0.85); }
}
@keyframes cd-live-enter {
  0% { transform: scale(1); }
  45% { transform: scale(0.9); }
  100% { transform: scale(1.05); }
}
@keyframes cd-live-tag-enter {
  0% { transform: translateX(-50%) scale(1); }
  45% { transform: translateX(-50%) scale(0.92); }
  100% { transform: translateX(-50%) scale(1.08); }
}
@keyframes cd-live-ripple-burst {
  0% {
    transform: scale(1);
    opacity: 0.65;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}
.countdown-visual-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.countdown-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: stretch;
  margin-bottom: 8rpx;
  flex-shrink: 0;
  gap: 16rpx;
}
.header-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}
/* 右侧：状态顶对齐「预计发射时间」；推迟徽标底对齐时间 */
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  flex-shrink: 0;
  min-width: 0;
  align-self: stretch;
}
/* 任务状态呼吸灯 */
.status-indicator {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
}
.status-light {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #8E8E93;
  animation: breathe 2s ease-in-out infinite;
  flex-shrink: 0;
}
/* 根据 statusCategory 设置颜色（与列表角标同源） */
.status-indicator[data-status="pending"] .status-light {
  background: #007AFF;
  box-shadow: 0 0 8rpx rgba(0, 122, 255, 0.55);
}
.status-indicator[data-status="pending"] .status-text {
  color: #007AFF;
}
.status-indicator[data-status="inflight"] .status-light {
  background: #5AC8FA;
  box-shadow: 0 0 8rpx rgba(90, 200, 250, 0.6);
}
.status-indicator[data-status="inflight"] .status-text {
  color: #5AC8FA;
}
.status-indicator[data-status="delayed"] .status-light,
.status-indicator[data-status="cancelled"] .status-light {
  background: #FF9500;
  box-shadow: 0 0 8rpx rgba(255, 149, 0, 0.6);
}
.status-indicator[data-status="delayed"] .status-text,
.status-indicator[data-status="cancelled"] .status-text {
  color: #FF9500;
}
.status-indicator[data-status="success"] .status-light,
.status-indicator[data-status="deployed"] .status-light {
  background: #34C759;
  box-shadow: 0 0 8rpx rgba(52, 199, 89, 0.6);
}
.status-indicator[data-status="success"] .status-text,
.status-indicator[data-status="deployed"] .status-text {
  color: #34C759;
}
.status-indicator[data-status="failure"] .status-light {
  background: #FF3B30;
  box-shadow: 0 0 8rpx rgba(255, 59, 48, 0.6);
}
.status-indicator[data-status="failure"] .status-text {
  color: #FF3B30;
}
.status-indicator[data-status="partial"] .status-light {
  background: #FF9500;
  box-shadow: 0 0 8rpx rgba(255, 149, 0, 0.6);
}
.status-indicator[data-status="partial"] .status-text {
  color: #FF9500;
}
.status-text {
  font-size: 28rpx;
  color: #8E8E93;
  line-height: 1;
  white-space: nowrap;
}
/* 呼吸灯动画 */
@keyframes breathe {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.8);
  }
}
/* label 行：仅「预计发射时间」；推迟徽标在右侧底对齐 */
.launch-time-label-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 4rpx;
  min-width: 0;
}
.launch-time-label {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.52);
  letter-spacing: 1rpx;
  flex-shrink: 0;
  line-height: 1.2;
}
/* 推迟徽标：右下，底边与时间底对齐；上移约 4px（8rpx） */
.launch-delay-badge {
  margin-left: 0;
  margin-bottom: 8rpx;
  padding: 0 8rpx;
  font-size: 17rpx;
  line-height: 26rpx;
  letter-spacing: 0;
  color: var(--color-warning, #FF9500);
  border: 1rpx solid rgba(255, 149, 0, 0.45);
  border-radius: 999rpx;
  white-space: nowrap;
  flex-shrink: 0;
  box-sizing: border-box;
  align-self: flex-end;
}
.launch-delay-badge-text {
  font-size: 17rpx;
  line-height: 26rpx;
  letter-spacing: 0;
  color: inherit;
}
.launch-time {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
  min-width: 0;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1.25;
}
/* 日期单独一行，缩短横向占用，给右侧状态留空 */
.launch-time-date {
  display: block;
  font-size: inherit;
  color: inherit;
  font-weight: inherit;
  line-height: inherit;
}
/* 星期与时刻并排 */
.launch-time-weekclock {
  display: block;
  font-size: inherit;
  color: inherit;
  font-weight: inherit;
  line-height: inherit;
  white-space: nowrap;
}
/* 倒计时显示 */
.countdown-display {
  display: flex;
  align-items: stretch;
  justify-content: center;
  margin: 6rpx 0 4rpx;
  gap: 18rpx;
  flex-shrink: 0;
}
.countdown-display--tech {
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
}
.countdown-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}
.countdown-visual-right .countdown-display {
  gap: 12rpx;
  margin-bottom: 2rpx;
}
.countdown-visual-right .countdown-item--tech {
  min-width: 0;
  flex: 1;
  padding: 8rpx 6rpx 6rpx;
}
.countdown-visual-right .countdown-value {
  font-size: 48rpx;
}
.countdown-visual-right .countdown-value-seconds {
  font-size: 48rpx;
}
.countdown-item--tech {
  min-width: 116rpx;
  padding: 10rpx 8rpx 8rpx;
  flex-direction: column;
  gap: 8rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
}
.countdown-item--seconds {
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.025));
  border-color: rgba(120, 192, 255, 0.16);
}
.countdown-value {
  font-size: 54rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
  margin-bottom: 0;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 10rpx rgba(72, 170, 255, 0.08);
}
.countdown-seconds-window {
  height: 58rpx;
  overflow: hidden;
  position: relative;
}
.countdown-seconds-reel {
  display: flex;
  flex-direction: column;
  transform: translateY(-58rpx);
  will-change: transform;
}
.countdown-seconds-reel--rolling {
  animation: countdown-seconds-roll-up 0.54s linear forwards;
}
.countdown-value-seconds {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  color: #8ebdff;
  text-shadow: none;
  letter-spacing: 2rpx;
}
.countdown-label {
  font-size: 22rpx;
  line-height: 1;
  margin-top: 0;
}
.countdown-label--tech {
  font-size: 18rpx;
  color: rgba(149, 208, 255, 0.62);
  letter-spacing: 2rpx;
}
@keyframes countdown-seconds-roll-up {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(-58rpx);
  }
}
@keyframes countdown-seconds-roll-up-detail {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(-54rpx);
  }
}
/* 任务信息 */
.mission-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  flex: 1;
  min-height: 0;
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  /* 每项上下各多出约 2px 呼吸感（约 4rpx，随屏宽缩放） */
  padding: 10rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  min-height: 44rpx;
}
.info-label {
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.42;
}
.info-value {
  font-size: 26rpx;
  color: #FFFFFF;
  line-height: 1.42;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
  word-break: break-word;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}
/* 值右侧带跳转按钮的行：改 flex 布局，文本收缩、按钮不压缩 */
.info-value--with-jump {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  overflow: visible;
}
.info-value--with-jump > text {
  min-width: 0;
  word-break: break-word;
}
/* 蓝色渐变跳转胶囊（与监控页「查看全部」同一渐变） */
.info-jump-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 2rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;
  padding: 5rpx 17rpx 5rpx 19rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #007AFF, #5856D6);
  line-height: 1.4;
}
.info-jump-arrow {
  font-size: 29rpx;
  line-height: 1;
}
/* 分享按钮 */
/* 滚动图片区域 - 与倒计时卡片高度一致 */
.image-carousel {
  width: 100%;
  max-width: 100%;
  height: 400rpx;
  margin-top: 25rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
  background-color: #1a1a1a;
  position: relative;
}
.swiper {
  width: 100%;
  height: 100%;
  background-color: transparent;
}
.swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.carousel-image-wrap {
  position: relative;
  width: 100%;
  height: 100%;
}
.carousel-image {
  width: 100%;
  height: 100%;
  display: block;
  background-color: #1a1a1a;
  object-fit: cover;
  border-radius: 16rpx;
  min-height: 300rpx;
}
.carousel-video-wrap {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #000;
}
.carousel-video {
  width: 100%;
  height: 100%;
}
/* 视频缓冲期占位封面：poster 图 + 半透明遮罩，替代 video 组件的原始黑屏 */
.carousel-video-cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(150deg, #1c2430 0%, #10151d 55%, #0a0d12 100%);
  pointer-events: none;
  overflow: hidden;
}
.carousel-video-cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}
.carousel-video-cover-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: rgba(0, 0, 0, 0.28);
}
.carousel-video-cover-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}
.carousel-video-cover-play {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-left: 6rpx;
}
.carousel-video-cover-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 2rpx;
}
.carousel-video-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 20rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  pointer-events: auto;
}
.carousel-video-caption-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.9);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}
/* 推文账号胶囊（左上角来源标识） */
.carousel-account-badge {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 60%;
  padding: 8rpx 20rpx 8rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  pointer-events: none;
  z-index: 3;
  transform: scale(0.7);
  transform-origin: top left;
}
.carousel-account-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.15);
}
.carousel-account-name {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
/* 任务列表区域 */
.missions-section {
  margin-bottom: 30rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}
.upcoming-agency-filter {
  padding: 0 10rpx;
  margin-bottom: 16rpx;
}
.upcoming-agency-scroll-wrap {
  position: relative;
}
.upcoming-agency-scroll {
  width: 100%;
  white-space: nowrap;
}
.upcoming-agency-scroll-fade {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 100%;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(14, 20, 34, 0), rgba(14, 20, 34, 0.92));
  border-top-right-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
}
.upcoming-agency-chips-row {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 12rpx;
  align-items: stretch;
  min-width: 100%;
  padding-right: 20rpx;
  box-sizing: border-box;
}
.upcoming-agency-chip.tweet-stat-item {
  flex: 0 0 auto;
  min-width: 168rpx;
  max-width: 300rpx;
  width: auto;
  box-sizing: border-box;
  position: relative;
  z-index: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  border-radius: 999rpx;
  overflow: visible;
  min-height: calc(60rpx - 2px);
  padding: calc(8rpx - 1px) 10rpx;
  background: #000000 !important;
}
.upcoming-agency-chip--free.tweet-stat-item {
  border: 2rpx solid rgba(255, 255, 255, 0.14) !important;
  box-shadow: none !important;
}
.upcoming-agency-chip--active.tweet-stat-item {
  background: rgba(79, 195, 247, 0.14) !important;
}
.upcoming-agency-chip-logo.tweet-stat-avatar {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}
.upcoming-agency-chip-label-col {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.upcoming-agency-chip-label-text {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.upcoming-agency-chip-count.tweet-stat-count {
  flex-shrink: 0;
  margin-left: 4rpx;
  font-size: 18rpx;
}
.missions-agency-empty {
  padding: 28rpx 16rpx 8rpx;
  text-align: center;
}
/* 非会员任务列表深度门控横幅 */
.mission-gate-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 8rpx 0 16rpx;
  padding: 28rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(255, 179, 71, 0.14), rgba(255, 120, 73, 0.10));
  border: 1rpx solid rgba(255, 179, 71, 0.35);
}
.mission-gate-banner-icon {
  font-size: 40rpx;
  line-height: 1;
}
.mission-gate-banner-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.mission-gate-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffb347;
}
.mission-gate-banner-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}
.mission-gate-banner-arrow {
  font-size: 44rpx;
  color: rgba(255, 179, 71, 0.8);
  line-height: 1;
}
.theme-light .mission-gate-banner {
  background: linear-gradient(135deg, rgba(255, 150, 40, 0.10), rgba(255, 110, 60, 0.07));
  border-color: rgba(220, 130, 30, 0.35);
}
.theme-light .mission-gate-banner-title {
  color: #c97a12;
}
.theme-light .mission-gate-banner-sub {
  color: rgba(60, 50, 40, 0.6);
}
.theme-light .mission-gate-banner-arrow {
  color: rgba(201, 122, 18, 0.8);
}
.missions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}
/* 首屏任务列表骨架占位 */
.mission-skeleton-card {
  width: 100%;
  aspect-ratio: 4 / 2;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  overflow: hidden;
}
.mission-skeleton-thumb {
  width: 35%;
  height: 100%;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.07);
  animation: mission-skeleton-pulse 1.4s ease-in-out infinite;
}
.mission-skeleton-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.mission-skeleton-line {
  height: 28rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.07);
  animation: mission-skeleton-pulse 1.4s ease-in-out infinite;
}
.mission-skeleton-line--wide {
  width: 80%;
}
.mission-skeleton-line--narrow {
  width: 50%;
}
@keyframes mission-skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.45; }
}
/* 即将发射列表：左滑 提醒 / 置顶 */
.mission-swipe-cell {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 24rpx;
}
/* 置顶：包在前景层上，避免 glass-card 伪元素盖住背景 */
.mission-swipe-cell--pinned > .mission-swipe-front {
  background: rgba(52, 199, 89, 0.22);
  border-radius: 24rpx;
  box-shadow:
    inset 0 0 0 3rpx rgba(130, 230, 156, 0.72),
    0 8rpx 28rpx rgba(52, 199, 89, 0.14);
}
.mission-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  padding: 24rpx 18rpx;
  /* 未左滑时隐藏：前景卡片是半透明玻璃底，操作区常驻会透出来；
     关闭时延迟 300ms 再隐藏，让 260ms 回弹动画期间按钮不消失 */
  opacity: 0;
  pointer-events: none;
  transition: opacity 0s linear 300ms;
  background: rgba(10, 14, 22, 0.94);
  z-index: 0;
}
/* 拖动中 / 已展开：立即显示操作区 */
.mission-swipe-actions--visible {
  opacity: 1;
  pointer-events: auto;
  transition: opacity 0s;
}
.mission-swipe-front {
  position: relative;
  z-index: 1;
  width: 100%;
  background: transparent;
}
.mission-swipe-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin: 0;
}
.mission-swipe-btn-stack {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: auto;
  gap: 8rpx;
}
.mission-swipe-btn-label {
  font-size: 20rpx;
  line-height: 1.1;
  color: rgba(255, 255, 255, 0.72);
  font-weight: 500;
}
.mission-swipe-btn--on-bell .mission-swipe-btn-label {
  color: rgba(185, 244, 201, 0.98);
}
.mission-swipe-btn--on-pin .mission-swipe-btn-label {
  color: rgba(185, 244, 201, 0.98);
}
.mission-swipe-btn-grow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  flex: none;
  min-height: 52rpx;
  will-change: transform, opacity;
}
/* 双图层置顶图标：白 pin-off / 绿 pin-on，由 item.pinnedOn → .mission-swipe-btn--on-pin */
.mission-swipe-icon-slot,
.mission-swipe-pin-slot {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}
.mission-swipe-icon-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 44rpx;
  height: 44rpx;
  display: block;
}
.mission-swipe-icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
}
.mission-swipe-pin-img-off {
  opacity: 0.88;
}
.mission-swipe-pin-img-on {
  opacity: 0;
  pointer-events: none;
}
.mission-swipe-btn--on-pin .mission-swipe-pin-img-off {
  opacity: 0;
  pointer-events: none;
}
.mission-swipe-btn--on-pin .mission-swipe-pin-img-on {
  opacity: 1;
  pointer-events: auto;
}
.mission-swipe-btn--on-bell {
  background: rgba(52, 199, 89, 0.26);
  border-radius: 999rpx;
  border: 2rpx solid rgba(130, 230, 156, 0.98);
}
.mission-swipe-btn--on-pin {
  background: rgba(52, 199, 89, 0.26);
  border-radius: 999rpx;
  border: 2rpx solid rgba(130, 230, 156, 0.98);
}
.mission-swipe-btn--on-pin .mission-swipe-pin-img-on {
  filter: drop-shadow(0 0 12rpx rgba(72, 230, 140, 0.85));
}
.mission-card-inner-row {
  display: flex;
  flex-direction: row;
  width: 100%;
  /* 高度跟随内容并由父级 flex stretch 撑满 min-height，不再固定 100% */
  height: auto;
  min-height: 0;
}
/* 任务卡片 - 默认 4:2 比例（min-height = 690rpx 卡宽 / 2）；
   任务名折行等内容超高时允许卡片自然长高，避免 aspect-ratio 锁死高度把文字压成半截 */
.mission-card {
  width: 100%;
  max-width: 100%;
  min-height: 345rpx;
  display: flex;
  flex-direction: row;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}
/* 历史发射：判定失败 → 红边；部分失败 → 橙边
   .glass-card / .mission-card 均 overflow:hidden，外阴影会被裁掉；
   用 border 简写 + inset 描边，保证浅色主题也清晰可见。 */
.mission-card.mission-card--failure {
  border: 3rpx solid #FF3B30 !important;
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 59, 48, 0.35),
    var(--shadow-card),
    var(--shadow-glass-inset);
}
.mission-card.mission-card--partial {
  border: 3rpx solid #FF9500 !important;
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 149, 0, 0.35),
    var(--shadow-card),
    var(--shadow-glass-inset);
}
.theme-light .mission-card.mission-card--failure {
  border: 3rpx solid #FF3B30 !important;
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 59, 48, 0.28),
    var(--shadow-card),
    var(--shadow-glass-inset);
}
.theme-light .mission-card.mission-card--partial {
  border: 3rpx solid #FF9500 !important;
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 149, 0, 0.28),
    var(--shadow-card),
    var(--shadow-glass-inset);
}
.mission-card-link {
  text-decoration: none;
  color: inherit;
}
.mission-card-link::after {
  border: none;
}
.mission-card-link:active {
  color: inherit;
}
.mission-rocket-slot {
  position: relative;
  width: 40%;
  /* 卡片高度改为可增长后，图片槽靠 flex 拉伸填满整列高度 */
  height: auto;
  align-self: stretch;
  min-width: 200rpx;
  flex-shrink: 0;
}
.mission-rocket-image {
  /* 绝对定位铺满图片槽：不依赖百分比高度链，卡片长高时同步拉伸 */
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  min-width: 0;
  object-fit: cover;
  background-color: #1a1a1a;
  display: block;
}
.mission-rocket-image--placeholder {
  background: rgba(255, 255, 255, 0.04);
}
.mission-rocket-countdown {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 36rpx 8rpx 10rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.78) 52%, rgba(0, 0, 0, 0.88) 100%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  pointer-events: none;
  box-sizing: border-box;
}
/* 复用首页 countdown-display--tech，在卡片火箭图内紧凑缩放 */
.mission-rocket-countdown .countdown-display--mission-card {
  width: 100%;
  margin: 0;
  gap: 6rpx;
}
.mission-rocket-countdown .countdown-item--tech {
  min-width: 0;
  flex: 1;
  padding: 6rpx 2rpx 4rpx;
  gap: 4rpx;
  border-radius: 8rpx;
}
.mission-rocket-countdown .countdown-value {
  font-size: 26rpx;
}
.mission-rocket-countdown .countdown-value-seconds {
  font-size: 26rpx;
  height: 30rpx;
  letter-spacing: 1rpx;
}
.mission-rocket-countdown .countdown-label--tech {
  font-size: 14rpx;
  letter-spacing: 1rpx;
}
.mission-info-content {
  flex: 1;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  box-sizing: border-box;
  min-width: 0;
  overflow: hidden;
}
/* 顶行：状态角标 + 右上方回收（图标+着陆方式名+地点）+ 发射国家 */
.mission-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.mission-card-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
  min-width: 0;
}
.mission-status-badge {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.mission-status-badge.status-success {
  color: #34C759;
  background: rgba(52, 199, 89, 0.15);
  border: 1px solid rgba(52, 199, 89, 0.35);
}
.mission-status-badge.status-failure {
  color: #FF3B30;
  background: rgba(255, 59, 48, 0.15);
  border: 1px solid rgba(255, 59, 48, 0.35);
}
.mission-status-badge.status-partial {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.15);
  border: 1px solid rgba(255, 149, 0, 0.35);
}
.mission-status-badge.status-delayed,
.mission-status-badge.status-cancelled {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.12);
  border: 1px solid rgba(255, 149, 0, 0.3);
}
.mission-status-badge.status-pending {
  color: #007AFF;
  background: rgba(0, 122, 255, 0.15);
  border: 1px solid rgba(0, 122, 255, 0.35);
}
.mission-status-badge.status-inflight {
  color: #5AC8FA;
  background: rgba(90, 200, 250, 0.15);
  border: 1px solid rgba(90, 200, 250, 0.4);
}
.mission-status-badge.status-deployed {
  color: #34C759;
  background: rgba(52, 199, 89, 0.15);
  border: 1px solid rgba(52, 199, 89, 0.35);
}
.mission-country {
  font-size: 22rpx;
  color: #8E8E93;
  flex-shrink: 0;
}
/* 主标题：仅任务名称，加粗大号 */
.mission-main-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1.35;
  word-break: break-word;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
/* 火箭名称、发射台：灰色次要信息，单行省略，详情见弹窗 */
.mission-meta {
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* 标称发射时间 net，大号核心位 */
.mission-time {
  font-size: 30rpx;
  font-weight: 600;
  color: #E5E5EA;
  line-height: 1.3;
}
/* 回收块：可回收(绿)/一次性(灰) + 仅图标区分 ASDS/RTLS，预定回收点不展示；分享图标与可回收标签同行右对齐 */
.mission-recovery-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 4rpx;
}
/* 任务卡片分享：图片展示 + 透明 button 覆盖层，仅箭头无边框占位 */
.mission-card-share-wrap {
  position: relative;
  flex: 0 0 28rpx;
  flex-shrink: 0;
  min-width: 28rpx;
  margin-left: auto;
  width: 28rpx;
  height: 28rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-share--mission-card {
  width: 28rpx;
  height: 28rpx;
}
.mission-card-share-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100% !important;
  height: 100% !important;
  min-width: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: 0 !important;
  border-width: 0 !important;
  outline: 0 !important;
  box-shadow: none !important;
  box-sizing: border-box !important;
  line-height: 0;
  font-size: 0;
  display: block;
  -webkit-appearance: none;
  appearance: none;
}
.mission-card-share-btn::after,
.mission-card-share-btn::before {
  content: none !important;
  display: none !important;
  border: 0 !important;
  border-width: 0 !important;
  opacity: 0 !important;
  visibility: hidden !important;
  pointer-events: none !important;
}
.mission-card-share-btn:active + .icon-share--mission-card,
.mission-recovery-block:active .icon-share--mission-card {
  opacity: 0.7;
}
.recovery-tag {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}
/* 回收结果图标组：紧贴在 recovery-tag 右边，撑满中间空隙之前 */
.mission-recovery-icons {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: 6px;         /* 与左侧「可回收/一次性」标签拉开间距 */
  margin-right: auto;       /* 把分享按钮推到最右 */
  flex-shrink: 0;
}
.mission-recovery-icon {
  width: 28rpx;
  height: 28rpx;
  /* 任务卡片回收图标统一放大 1.15 倍（transform 不改变占位，不影响布局） */
  transform: scale(1.15);
}
/* 网系回收图标视觉重量偏小，在统一 1.15 倍基础上再放大 1.1 倍（1.15 × 1.1 = 1.265） */
.mission-recovery-icon--net {
  transform: scale(1.265);
}
.recovery-tag--reuse {
  color: #34C759;
  background: rgba(52, 199, 89, 0.12);
  border: 1px solid rgba(52, 199, 89, 0.25);
}
.recovery-tag--expendable {
  color: #636366;
  background: rgba(99, 99, 102, 0.15);
  border: 1px solid rgba(99, 99, 102, 0.25);
}
.recovery-tag--not-reused {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.12);
  border: 1px solid rgba(255, 149, 0, 0.28);
}
.recovery-icon-name {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.recovery-icon {
  width: 26rpx;
  height: 26rpx;
  opacity: 0.9;
  flex-shrink: 0;
}
/* 倒计时板块「回收地点」图标统一放大 1.2 倍（transform 不改变占位，不影响行内布局）；
   scale 溢出会吃掉 gap，用 margin-right 补偿，保证图标与文字视觉间距统一约 3px */
.recovery-place-inline .recovery-icon {
  transform: scale(1.2);
  margin-right: 3rpx;
}
/* 网系回收 SVG 为宽扁形，同尺寸下视觉偏小，额外放大（与列表卡片 .mission-recovery-icon--net 同理），溢出更多故补偿更大 */
.recovery-place-inline .recovery-icon--net {
  transform: scale(1.5);
  margin-right: 7rpx;
}
.recovery-type-name {
  font-size: 20rpx;
  line-height: 1.2;
  color: #34C759;
  background: rgba(52, 199, 89, 0.12);
  border: 1px solid rgba(52, 199, 89, 0.25);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  white-space: nowrap;
}
.recovery-type-name--not-reused {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.12);
  border: 1px solid rgba(255, 149, 0, 0.28);
}
.recovery-location-name {
  font-size: 20rpx;
  color: #8E8E93;
  line-height: 1.2;
  white-space: nowrap;
}
/* 错误状态 */
.error-state {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx 0;
  min-height: 300rpx;
  box-sizing: border-box;
}
.error-message {
  font-size: 28rpx;
  color: #8E8E93;
  text-align: center;
  width: 100%;
}
.retry-button {
  padding: 15rpx 40rpx;
  background: rgba(0, 122, 255, 0.15);
  backdrop-filter: blur(30rpx) saturate(150%);
  -webkit-backdrop-filter: blur(30rpx) saturate(150%);
  border: 1px solid rgba(0, 122, 255, 0.3);
  border-radius: 12rpx;
  color: #007AFF;
  font-size: 26rpx;
  margin-top: 10rpx;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
  line-height: 1.5;
}
.retry-button::after {
  border: none;
}
/* 任务列表错误状态 */
.missions-error {
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-sizing: border-box;
}
.missions-empty {
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
}
.empty-text {
  font-size: 26rpx;
  color: #8E8E93;
}
.missions-list-footer {
  padding: 24rpx 0 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.missions-list-footer .footer-text {
  font-size: 24rpx;
  color: #8E8E93;
}
/* ========== 吸顶精简倒计时（胶囊按钮左侧） ========== */

.compact-cd {
  position: absolute;
  left: 16px;
  z-index: 10;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 0 14px;
  padding-left: 8px;
  border-radius: 999rpx;
  background: rgba(12, 14, 18, 0.55);
  backdrop-filter: blur(30rpx) saturate(170%);
  -webkit-backdrop-filter: blur(30rpx) saturate(170%);
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
  opacity: 0;
  transform: translateX(-20rpx);
  pointer-events: none;
  transition: opacity 0.28s ease, transform 0.28s ease;
}
.compact-cd--visible {
  opacity: 1;
  transform: translateX(0);
  pointer-events: auto;
}
.compact-cd-rocket-slot {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}
.compact-cd-rocket-img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center center;
}
.compact-cd-rocket-inner {
  width: 100%;
  height: 100%;
}
.compact-cd-rocket-placeholder {
  background: rgba(255, 255, 255, 0.04);
}
.compact-cd-name {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}
.compact-cd-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  flex-shrink: 0;
}
.nav-search-btn--hidden {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.8);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
/* 封路通知横幅 */
.road-closure-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 0 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.15) 0%, rgba(255, 87, 34, 0.12) 100%);
  border: 1px solid rgba(255, 152, 0, 0.3);
  /* 性能：横幅在纯色页面背景之上，backdrop-filter 视觉无差别但持续占用 GPU，已移除 */
  animation: roadClosurePulse 3s ease-in-out infinite;
  text-align: left;
  line-height: normal;
  box-sizing: border-box;
  overflow: hidden;
}
.road-closure-banner::after {
  border: none;
}
@keyframes roadClosurePulse {
  0%, 100% { border-color: rgba(255, 152, 0, 0.3); }
  50% { border-color: rgba(255, 152, 0, 0.6); }
}
.road-closure-icon-wrap {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 152, 0, 0.25);
  border-radius: 50%;
  margin-top: 2rpx;
}
.road-closure-icon {
  font-size: 26rpx;
  line-height: 1;
  color: #FF9800;
}
.road-closure-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}
.road-closure-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.road-closure-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF9800;
  line-height: 1.3;
}
.road-closure-msg-scroll {
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
}
.road-closure-msg-track {
  display: inline-flex;
  flex-wrap: nowrap;
  width: max-content;
  will-change: transform;
  backface-visibility: hidden;
  animation: marqueeScroll 18s linear infinite;
}
.road-closure-msg {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.4;
  flex-shrink: 0;
  white-space: nowrap;
  padding-right: 80rpx;
  box-sizing: content-box;
}
@keyframes marqueeScroll {
  from { transform: translate3d(0, 0, 0); }
  to { transform: translate3d(-50%, 0, 0); }
}
.road-closure-arrow {
  flex-shrink: 0;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 300;
}
.road-closure-source {
  font-size: 20rpx;
  color: rgba(255, 152, 0, 0.7);
  padding: 2rpx 10rpx;
  border: 1px solid rgba(255, 152, 0, 0.3);
  border-radius: 6rpx;
  flex-shrink: 0;
}
/* 系统通知滚动横幅 */
.announcement-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 12rpx 0 8rpx;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(255, 152, 0, 0.15) 0%, rgba(255, 87, 34, 0.12) 100%);
  border: 1px solid rgba(255, 152, 0, 0.3);
  /* 性能：横幅在纯色页面背景之上，backdrop-filter 视觉无差别但持续占用 GPU，已移除 */
  overflow: hidden;
  box-sizing: border-box;
}
.announcement-banner-icon-wrap {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 152, 0, 0.25);
  border-radius: 50%;
}
.announcement-banner-icon {
  font-size: 26rpx;
  line-height: 1;
  color: #FF9800;
}
.announcement-banner-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.announcement-banner-scroll {
  width: 100%;
  overflow: hidden;
  white-space: nowrap;
}
.announcement-banner-track {
  display: inline-flex;
  flex-wrap: nowrap;
  width: max-content;
  will-change: transform;
  backface-visibility: hidden;
  animation: announcementMarquee 18s linear infinite;
}
.announcement-banner-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
  flex-shrink: 0;
  white-space: nowrap;
  padding-right: 80rpx;
  box-sizing: content-box;
}
@keyframes announcementMarquee {
  from { transform: translate3d(0, 0, 0); }
  to { transform: translate3d(-50%, 0, 0); }
}
.announcement-banner-close {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
}
.announcement-banner-close:active {
  background: rgba(255, 255, 255, 0.1);
}
/* 公告详情弹窗 */
.announcement-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.22s ease;
  pointer-events: none;
  padding: 0 60rpx;
}
.announcement-dialog-mask--visible {
  opacity: 1;
  pointer-events: auto;
}
.announcement-dialog {
  width: 100%;
  max-width: 580rpx;
  background: #000000;
  border-radius: 28rpx;
  border: none;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.6);
  overflow: hidden;
  animation: announcement-dialog-pop 0.28s cubic-bezier(0.2, 0.9, 0.3, 1.15);
}
@keyframes announcement-dialog-pop {
  0% { transform: scale(0.82); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.announcement-dialog-header {
  padding: 40rpx 36rpx 20rpx;
  text-align: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.announcement-dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF9800;
}
.announcement-dialog-body {
  padding: 32rpx 36rpx;
  text-align: center;
}
.announcement-dialog-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
}
/* 公告弹窗在线客服入口（复用「关于我们」同款样式，button 需强制重置小程序默认样式） */
.announcement-dialog-service {
  padding: 0 32rpx 32rpx;
}
.service-contact-row {
  display: flex !important;
  align-items: center !important;
  gap: 20rpx;
  width: 100% !important;
  margin: 0 !important;
  padding: 22rpx 24rpx !important;
  border-radius: 18rpx !important;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.16) 0%, rgba(7, 193, 96, 0.06) 100%) !important;
  border: 1rpx solid rgba(7, 193, 96, 0.32) !important;
  box-sizing: border-box !important;
  line-height: normal !important;
  font-weight: normal !important;
  text-align: left !important;
  transition: opacity 0.18s, transform 0.18s;
}
.service-contact-row::after {
  border: none !important;
}
.service-contact-row--hover {
  opacity: 0.78;
  transform: scale(0.985);
}
.service-contact-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.service-contact-icon-img {
  width: 56rpx;
  height: 56rpx;
  display: block;
}
.service-contact-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.service-contact-title {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.service-contact-sub {
  color: rgba(255, 255, 255, 0.55);
  font-size: 22rpx;
  letter-spacing: 0.4rpx;
}
.service-contact-arrow {
  color: rgba(7, 193, 96, 0.9);
  font-size: 36rpx;
  font-weight: 300;
  flex-shrink: 0;
}
.announcement-dialog-close {
  padding: 28rpx;
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}
.announcement-dialog-close:active {
  background: rgba(255, 152, 0, 0.08);
}
.announcement-dialog-close text {
  font-size: 28rpx;
  color: #FF9800;
  font-weight: 500;
}
/* ========== 开屏动画 ========== */
.splash-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 99999;
  background: #000;
}
.splash-overlay--in {
  animation: splashFadeIn 0.45s ease-out forwards;
}
.splash-overlay--out {
  animation: splashFadeOut 0.5s ease-in forwards;
  pointer-events: none;
}
@keyframes splashFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes splashFadeOut {
  from { opacity: 1; }
  to   { opacity: 0; }
}
.splash-media {
  width: 100vw;
  height: 100vh;
  /* 视频/图都必须 cover 裁剪，禁止 stretch 变形 */
  object-fit: cover;
}
.splash-video-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
  background: #000;
}
.splash-video-cover-fallback {
  width: 100%;
  height: 100%;
  background: #000;
}
.splash-skip {
  position: fixed;
  right: 28rpx;
  display: flex;
  align-items: center;
  gap: 0;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 36rpx;
  /* 注意：隐私禁触遮罩挂在 root-portal 根层级，与本按钮不在同一层叠上下文，
     单纯抬 z-index 压不过它；开屏期间由 app.setSplashActive(true) 让遮罩不渲染
     （见 _showSplash / closeSplash），「跳过」才能收到点击 */
  z-index: 200000;
  animation: splashSkipIn 0.4s 0.3s ease-out both;
  overflow: hidden;
}
.splash-skip-countdown {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  font-variant-numeric: tabular-nums;
}
.splash-skip-divider {
  width: 1px;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.25);
  flex-shrink: 0;
}
.splash-skip-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
  line-height: 64rpx;
}
@keyframes splashSkipIn {
  from { opacity: 0; transform: translateY(-12rpx) scale(0.92); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
/* 开屏任务倒计时卡片：下部居中；尺寸按 1.2 倍实算（不用 transform scale，避免点击热区错位） */
.splash-mission-card {
  position: fixed;
  left: 50%;
  bottom: 180rpx;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  min-width: 504rpx;
  max-width: 672rpx;
  padding: 34rpx 44rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(
    165deg,
    rgba(255, 255, 255, 0.04) 0%,
    rgba(0, 0, 0, 0.13) 48%,
    rgba(0, 0, 0, 0.16) 100%
  );
  backdrop-filter: blur(7px) saturate(1.35);
  -webkit-backdrop-filter: blur(7px) saturate(1.35);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 38rpx;
  box-shadow:
    0 16rpx 48rpx rgba(0, 0, 0, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  animation: splashMissionIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.18s both;
}
.splash-mission-card:active {
  opacity: 0.92;
}
@keyframes splashMissionIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}
.splash-mission-eyebrow {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 3.6rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1;
}
.splash-mission-name {
  max-width: 600rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  letter-spacing: 0.5rpx;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
}
.splash-mission-cd {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 4rpx;
  color: #fff;
}
.splash-mission-cd-prefix {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.78);
  letter-spacing: 1rpx;
  padding-top: 2rpx;
}
.splash-mission-cd-cells {
  display: flex;
  align-items: stretch;
  gap: 0;
}
.splash-mission-cd-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  padding: 12rpx 14rpx 10rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}
.splash-mission-cd-cell--sec {
  background: rgba(255, 255, 255, 0.16);
  border-color: rgba(255, 255, 255, 0.26);
}
.splash-mission-cd-sep {
  align-self: center;
  width: 22rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1;
  padding-bottom: 16rpx;
}
.splash-mission-cd-num {
  font-size: 48rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  font-feature-settings: 'tnum' 1;
  line-height: 1;
  letter-spacing: 0.5rpx;
}
.splash-mission-cd-unit {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.58);
  letter-spacing: 1rpx;
  line-height: 1;
}
.splash-mission-cd--imminent {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 4rpx;
  padding: 14rpx 34rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #fff;
}
.splash-mission-imminent-dot {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #7dffb3;
  box-shadow: 0 0 12rpx rgba(125, 255, 179, 0.75);
  animation: splashMissionPulse 1.2s ease-in-out infinite;
}
@keyframes splashMissionPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.55; transform: scale(0.85); }
}
.splash-mission-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 2rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  width: 100%;
  justify-content: center;
  box-sizing: border-box;
}
.splash-mission-hint-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
  letter-spacing: 1.5rpx;
}
.splash-mission-hint-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.7);
  transform: translateY(-1rpx);
}
/* ========== 发射提醒 ========== */
.detail-subscribe-section {
  margin-bottom: 20rpx;
}
.subscribe-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(30, 30, 30, 0.35);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  gap: 20rpx;
}
.subscribe-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: rgba(0, 122, 255, 0.12);
}
.icon-bell--subscribe {
  width: 36rpx;
  height: 36rpx;
}
.subscribe-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.subscribe-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.subscribe-desc {
  font-size: 22rpx;
  color: #8E8E93;
}
.subscribe-check {
  font-size: 28rpx;
  color: #34C759;
  font-weight: 600;
}
/* ========== 发射日历 ========== */
.calendar-section {
  padding: 24rpx 0 40rpx;
}
.calendar-query-panel,
.calendar-map-link-panel {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
}
.calendar-page-anim--leave-prev {
  transform: translateX(-42rpx);
  opacity: 0.16;
  transition: transform 0.11s ease-out, opacity 0.11s ease-out;
}
.calendar-page-anim--enter-next {
  transform: translateX(42rpx);
  opacity: 0.18;
  animation: calendar-page-enter-next 0.22s ease-out forwards;
}
.calendar-page-anim--leave-next {
  transform: translateX(42rpx);
  opacity: 0.16;
  transition: transform 0.11s ease-out, opacity 0.11s ease-out;
}
.calendar-page-anim--enter-prev {
  transform: translateX(-42rpx);
  opacity: 0.18;
  animation: calendar-page-enter-prev 0.22s ease-out forwards;
}
@keyframes calendar-page-enter-next {
  from {
    transform: translateX(42rpx);
    opacity: 0.18;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}
@keyframes calendar-page-enter-prev {
  from {
    transform: translateX(-42rpx);
    opacity: 0.18;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}
.calendar-day-missions {
  margin-top: 24rpx;
}
.calendar-day-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.calendar-day-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}
.calendar-day-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}
.calendar-map-link-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.calendar-map-link-title {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}
.calendar-map-link-subtitle {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.42);
}
.calendar-map-link-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.calendar-map-link-chip {
  min-height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
  background: rgba(0, 122, 255, 0.12);
  border: 1px solid rgba(0, 122, 255, 0.24);
}
.calendar-map-link-chip-text {
  font-size: 24rpx;
  color: #7ec3ff;
}
.calendar-map-link-chip-count {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 20rpx;
}
/* ========== 倒计时卡片底部操作栏 ========== */
.countdown-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* VOTE_ANTIMIS_V1:START 原 gap: 14rpx；略增与铃铛间距 */
  gap: 18rpx;
  /* VOTE_ANTIMIS_V1:END */
  margin-top: 18rpx;
}
.vote-box-placeholder { flex: 1; }
/* 竞猜容器（带边框） */
.vote-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 6rpx 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 14rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
}
/* VOTE_ANTIMIS_V1:START 槽内防误触样式；回滚删除本块即可（并恢复上方 gap: 14rpx） */
.vote-box--antimiss {
  padding-right: 14rpx;
}
.vote-box--antimiss.vote-box--dual {
  /* 上下各再压约 1px（2rpx） */
  padding: 8rpx 14rpx 10rpx 10rpx;
  gap: 12rpx;
}
.vote-type-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-width: 0;
}
.vote-type-meta {
  flex-shrink: 0;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.34);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}
.vote-box--antimiss .vote-box-label.vote-box-label--polling {
  flex: 1;
  min-width: 0;
  flex-shrink: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}
.vote-box--antimiss .vote-pills-with-meta {
  flex-shrink: 0;
  gap: 14rpx;
}
.vote-box--antimiss .vote-pill {
  min-height: 48rpx;
  padding: 6rpx 14rpx;
}
/* VOTE_ANTIMIS_V1:END */
.vote-box--dual {
  flex-direction: column;
  align-items: stretch;
  gap: 6rpx;
  padding: 8rpx 10rpx 10rpx;
}
.vote-type-tabs {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 5rpx;
}
.vote-type-tab {
  font-size: 24rpx;
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.35);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}
.vote-type-tab--active {
  color: rgba(255, 255, 255, 0.88);
  background: rgba(255, 255, 255, 0.08);
}
.vote-box-body {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 6rpx 8rpx;
  min-width: 0;
}
.vote-box-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.vote-box-flex-fill {
  flex: 1;
  min-width: 0;
  margin-right: 4rpx;
}
.vote-pills-with-meta {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
}
/* 单行竞猜：题干完整显示（不换行、不省略），靠收紧右侧胶囊与人数区换空间 */
/* VOTE_ANTIMIS_V1: 双题型时由 .vote-box--antimiss 覆盖为 ellipsis；单题型仍尽量完整显示 */
.vote-box-label.vote-box-label--polling {
  flex-shrink: 0;
  overflow: visible;
  text-overflow: clip;
  white-space: nowrap;
}
.vote-pills-with-meta--compact .vote-pill {
  min-height: 48rpx;
  gap: 4rpx;
  padding: 6rpx 10rpx;
}
.vote-pills-with-meta--compact .vote-pill-dot {
  width: 12rpx;
  height: 12rpx;
}
.vote-pills-with-meta--compact .vote-pill-text {
  font-size: 22rpx;
}
.vote-pills-with-meta--compact .vote-pill-count {
  font-size: 18rpx;
}
.vote-pills-with-meta--compact .vote-total-inline {
  margin-left: 2rpx;
  padding-left: 6rpx;
}
.vote-total-inline {
  margin-left: 4rpx;
  padding-left: 10rpx;
  border-left: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.34);
  line-height: 1.15;
  white-space: nowrap;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.vote-box-label--closed {
  color: rgba(255, 152, 0, 0.7);
  font-size: 20rpx;
}
.vote-box-label--result {
  font-size: 22rpx;
}
.vote-pill--disabled {
  opacity: 0.5;
  pointer-events: none;
}
.vote-pill {
  min-height: 52rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  transition: all 0.25s ease;
}
.vote-pill:active {
  transform: scale(0.96);
}
.vote-pill-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.vote-pill-dot--ge {
  background: #FF9500;
  box-shadow: 0 0 6rpx rgba(255, 149, 0, 0.4);
}
.vote-pill-dot--buge {
  background: #07C160;
  box-shadow: 0 0 6rpx rgba(7, 193, 96, 0.4);
}
.vote-pill-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}
.vote-pill-count {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  font-variant-numeric: tabular-nums;
}
.vote-pill--active-ge {
  background: rgba(255, 149, 0, 0.15);
  border-color: rgba(255, 149, 0, 0.35);
}
.vote-pill--active-ge .vote-pill-text { color: #FF9500; }
.vote-pill--active-buge {
  background: rgba(7, 193, 96, 0.15);
  border-color: rgba(7, 193, 96, 0.35);
}
.vote-pill--active-buge .vote-pill-text { color: #07C160; }
.vote-pill--voted { pointer-events: none; }
/* 提醒 + 分享图标（独立 flex 子项，space-between 自动等距） */
.cd-icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 50%;
  transition: transform 0.18s ease, background 0.18s ease;
}
.cd-icon-btn:active {
  transform: scale(0.94);
  background: rgba(255, 255, 255, 0.08);
}
.icon-bell--countdown {
  width: 48rpx;
  height: 48rpx;
}
.cd-share-btn-wrap {
  position: relative;
}
.icon-share--countdown {
  /* 原 54rpx，缩小三分之一 → 36rpx */
  width: 36rpx;
  height: 36rpx;
}
.cd-share-ghost {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  min-height: 0 !important;
  background: transparent !important;
}
/* 投票比例条 */
.vote-bar-row {
  margin-top: 8rpx;
}
.vote-bar {
  display: flex;
  height: 6rpx;
  border-radius: 3rpx;
  overflow: hidden;
}
.vote-bar-ge {
  background: linear-gradient(90deg, #FF9500, #FF6B00);
  transition: width 0.6s ease;
}
.vote-bar-buge {
  background: linear-gradient(90deg, #07C160, #06AD56);
  transition: width 0.6s ease;
}
/* ============ 任务卡片长按分享对话框（居中） ============ */
.share-dialog-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.22s ease;
  padding: 0 60rpx;
}
.share-dialog-mask--visible {
  opacity: 1;
}
.share-dialog {
  width: 100%;
  max-width: 560rpx;
  background: #1c1c1e;
  border-radius: 28rpx;
  padding: 44rpx 36rpx 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.5);
  animation: share-dialog-pop 0.28s cubic-bezier(0.2, 0.9, 0.3, 1.15);
}
@keyframes share-dialog-pop {
  0% { transform: scale(0.82); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.share-dialog-header {
  text-align: center;
  margin-bottom: 40rpx;
}
.share-dialog-title {
  display: block;
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}
.share-dialog-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 20rpx;
}
.share-dialog-actions {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding: 0 0 36rpx;
}
/* 只有一个按钮时居中（移除朋友圈入口后，微信好友按钮单独使用） */
.share-dialog-actions--single {
  justify-content: center;
}
.share-dialog-btn {
  background: transparent !important;
  border: none !important;
  padding: 14rpx 10rpx !important;
  margin: 0 !important;
  display: flex !important;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  line-height: 1;
  border-radius: 16rpx;
  transition: background 0.18s ease;
}
.share-dialog-btn::after {
  border: none !important;
}
.share-dialog-btn--hover {
  background: rgba(255, 255, 255, 0.06) !important;
}
.share-dialog-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
}
.share-dialog-icon-img {
  width: 52rpx;
  height: 52rpx;
}
.share-dialog-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}
.share-dialog-cancel {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
}
.share-dialog-cancel--hover {
  background: rgba(255, 255, 255, 0.12);
}
/* ========== 明亮主题（theme-light）覆盖 ========== */
/* 根 view (.container) 挂 theme-light 后，以下覆盖沿 DOM 生效；
   例外（保持深色）：开屏 splash、图片/视频轮播底、压在火箭图上的卡片倒计时、
   全屏遮罩 mask、媒体上的文字浮层 */

/* --- 顶部导航 --- */
.theme-light .top-nav-wrapper {
  background: var(--bg-glass-nav);
}
.theme-light .nav-search-btn {
  background: rgba(255, 255, 255, 0.62);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .nav-button {
  background: rgba(255, 255, 255, 0.62);
  box-shadow: var(--shadow-card);
}
.theme-light .nav-button.active {
  background: rgba(0, 122, 255, 0.12);
  border-color: rgba(0, 122, 255, 0.3);
  box-shadow: var(--shadow-card);
}
.theme-light .nav-button--completed.active {
  background: rgba(255, 149, 0, 0.12);
  /* 补 border-color/color：否则上面 .nav-button.active 的蓝色边框胜出（深色模式基础规则里橙色完整） */
  border-color: rgba(255, 149, 0, 0.3);
  color: #FF9500;
  box-shadow: var(--shadow-card);
}
/* --- 吸顶精简倒计时 --- */
.theme-light .compact-cd {
  background: var(--bg-glass);
  border: 1px solid var(--color-divider);
  box-shadow: var(--shadow-card);
}
.theme-light .compact-cd-rocket-slot {
  background: rgba(0, 0, 0, 0.05);
  border: 1rpx solid var(--color-divider);
}
.theme-light .compact-cd-rocket-placeholder {
  background: #ECECF1;
}
.theme-light .compact-cd-name {
  color: var(--color-text-secondary);
}
.theme-light .compact-cd-time {
  color: var(--color-text-primary);
}
/* --- 倒计时卡片 --- */
.theme-light .countdown-card-main:active {
  background: rgba(0, 0, 0, 0.03);
