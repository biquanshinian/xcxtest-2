page {
  background: #000;
  overflow: hidden;
  height: 100vh;
}

.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
}

.main-map {
  width: 100%;
  height: 100vh;
}

.glass-card {
  background: rgba(18, 18, 20, 0.78);
  backdrop-filter: blur(18rpx);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* 底部面板 */
.panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.panel-category {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 500;
}

.panel-status {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.panel-status--open {
  background: rgba(52, 199, 89, 0.15);
}

.panel-status--open text {
  font-size: 22rpx;
  color: #34C759;
  font-weight: 600;
}

.panel-status--closed {
  background: rgba(142, 142, 147, 0.15);
}

.panel-status--closed text {
  font-size: 22rpx;
  color: #8E8E93;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.45;
}

.panel-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 0;
}

.panel-info-label {
  font-size: 24rpx;
  color: #8E8E93;
  flex-shrink: 0;
}

.panel-info-value {
  font-size: 24rpx;
  color: #E5E5EA;
  text-align: right;
}

.panel-coords-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding-top: 10rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.panel-coords-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.48);
  font-family: 'Menlo', 'Courier New', monospace;
}

.panel-copy-btn {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 122, 255, 0.14);
  border: 1px solid rgba(0, 122, 255, 0.3);
}

.panel-copy-btn text {
  font-size: 20rpx;
  color: #4ea1ff;
}

/* ========== 明亮主题（theme-light）覆盖 ========== */
.theme-light .glass-card {
  background: rgba(255, 255, 255, 0.85);
  border-color: var(--color-divider);
}

.theme-light .panel-status--open {
  background: rgba(52, 199, 89, 0.12);
}

.theme-light .panel-status--open text {
  color: #248A3D;
}

.theme-light .panel-status--closed {
  background: rgba(142, 142, 147, 0.12);
}

.theme-light .panel-info-label {
  color: var(--color-text-tertiary);
}

.theme-light .panel-info-value {
  color: var(--color-text-primary);
}

.theme-light .panel-coords-row {
  border-top-color: var(--color-divider);
}

.theme-light .panel-coords-text {
  color: var(--color-text-tertiary);
}

.theme-light .panel-copy-btn {
  background: rgba(0, 122, 255, 0.1);
  border-color: rgba(0, 122, 255, 0.3);
}

.theme-light .panel-copy-btn text {
  color: #0A84FF;
}
