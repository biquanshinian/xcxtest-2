}

.event-updates-card {
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-left: 4rpx solid #007AFF;
}

/* scroll-view 需明确高度，否则自定义 refresher 插槽 height:100% 会为 0，看不到转圈与文案 */
.event-updates-scroll {
  height: 900rpx;
  max-height: 900rpx;
  padding: 24rpx 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.event-updates-collapsed {
  padding: 24rpx 28rpx 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.event-updates-collapse-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #007AFF;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.expand-arrow {
  font-size: 32rpx;
  font-weight: 300;
  transform: rotate(90deg);
}

.expand-arrow--up {
  transform: rotate(-90deg);
}

.event-refresher-spinner {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
  border-top-color: #4ea1ff;
  box-sizing: border-box;
  animation: event-refresher-spin 0.8s linear infinite;
}

.event-refresher-text {
  font-size: 24rpx;
  color: #8e8e93;
}

@keyframes event-refresher-spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.event-update-item {
  padding-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
  border-radius: 18rpx;
  transition: transform 0.18s ease, opacity 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  transform-origin: center center;
}

.event-update-item--pressed {
  transform: scale(0.992);
  opacity: 0.92;
  background: rgba(255, 255, 255, 0.03);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.06);
}

.event-update-link {
  display: block;
}

.event-update-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.event-update-time {
  font-size: 22rpx;
  color: #007AFF;
  font-weight: 500;
}

.event-update-author-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx 6rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.event-author-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.event-update-author {
  font-size: 22rpx;
  color: #d0d0d4;
}

.event-update-title {
  display: block;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 10rpx;
  line-height: 1.4;
  width: 100%;
  word-break: break-word;
  overflow-wrap: break-word;
  box-sizing: border-box;
}

.event-update-content {
  display: block;
  font-size: 26rpx;
  color: #c7c7cc;
  line-height: 1.65;
  margin-bottom: 16rpx;
  text-align: justify;
  text-justify: inter-ideograph;
  width: 100%;
  word-break: break-word;
  overflow-wrap: break-word;
  box-sizing: border-box;
}

.event-update-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 14rpx;
}

.event-update-share-wrap {
  position: relative;
  flex: 0 0 44rpx;
  flex-shrink: 0;
  min-width: 44rpx;
  min-height: 44rpx;
  width: 44rpx;
  height: 44rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-share--event-update {
  width: 28rpx;
  height: 28rpx;
}

.event-update-share-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100% !important;
  height: 100% !important;
  min-width: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: 0 !important;
  border-width: 0 !important;
  outline: 0 !important;
  box-shadow: none !important;
  box-sizing: border-box !important;
  line-height: 0;
  font-size: 0;
  display: block;
  -webkit-appearance: none;
  appearance: none;
}

.event-update-share-btn::after,
.event-update-share-btn::before {
  content: none !important;
  display: none !important;
  border: 0 !important;
  border-width: 0 !important;
  opacity: 0 !important;
  visibility: hidden !important;
  pointer-events: none !important;
}

.event-update-share-btn:active + .icon-share--event-update,
.event-update-share-wrap:active .icon-share--event-update {
  opacity: 0.7;
}

