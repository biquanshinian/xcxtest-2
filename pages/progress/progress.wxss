  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.event-share-sheet-btn--primary {
  padding: 0 !important;
  line-height: 92rpx !important;
  background: linear-gradient(135deg, #1677ff 0%, #55a3ff 100%) !important;
  border: none !important;
  color: #fff !important;
}

.event-share-sheet-btn--primary::after {
  border: none;
}

.event-share-sheet-btn--cancel {
  color: rgba(255, 255, 255, 0.72);
}


/* ===== OpenClaw 自动追踪提示 ===== */
.openclaw-badge {
  position: absolute;
  right: 0;
  top: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: rgba(255, 149, 0, 0.15);
  border: 1px solid rgba(255, 149, 0, 0.4);
  border-radius: 16rpx;
  white-space: nowrap;
  z-index: 10;
  animation: openclawFadeIn 0.35s ease-out, openclawBounce 1.8s ease-in-out 0.4s infinite;
}

@keyframes openclawFadeIn {
  from { opacity: 0; transform: translateY(-16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes openclawBounce {
  0%, 100% { transform: translateY(0); }
  40% { transform: translateY(-10rpx); }
  60% { transform: translateY(-4rpx); }
}

.openclaw-badge-text {
  font-size: 20rpx;
  color: #ff9500;
  font-weight: 500;
}

.openclaw-badge-close {
  font-size: 20rpx;
  color: rgba(255, 149, 0, 0.6);
  line-height: 1;
}

