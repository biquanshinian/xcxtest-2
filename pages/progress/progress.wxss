/* Launch Library 飞行时间线（launch.timeline） */
.ll2-timeline-section {
  margin-bottom: 40rpx;
}

.ll2-timeline-card {
  padding: 24rpx 28rpx;
  border-left: 4rpx solid rgba(100, 210, 255, 0.75);
  box-sizing: border-box;
}

.ll2-timeline-card--body {
  padding: 16rpx 12rpx 16rpx 8rpx;
}

.ll2-timeline-card--error {
  padding: 28rpx 30rpx;
}

.ll2-timeline-card--pad {
  padding: 28rpx 30rpx;
}

.ll2-timeline-item {
  display: flex;
  align-items: stretch;
  flex-direction: row;
  min-height: 72rpx;
}

.ll2-timeline-axis {
  width: 56rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ll2-timeline-line {
  width: 3rpx;
  flex: 1;
  min-height: 14rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
}

.ll2-timeline-node {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(30, 34, 42, 0.95);
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

/* LL2 时间线节点：单色几何图形（与 utils/ll2-launch-timeline iconVariant 一致） */
.ll2-timeline-node-mark {
  flex-shrink: 0;
  box-sizing: border-box;
}

.ll2-timeline-node-mark--dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.ll2-timeline-node-mark--solid {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
}

.ll2-timeline-node-mark--ring {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
}

.ll2-timeline-node-mark--diamond {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.88);
  transform: rotate(45deg);
}

.ll2-timeline-node-mark--square {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: rgba(255, 255, 255, 0.88);
}

.ll2-timeline-node-mark--lift {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 9rpx 15rpx 9rpx;
  border-color: transparent transparent rgba(255, 255, 255, 0.9) transparent;
  background: transparent;
}

.ll2-timeline-main {
  flex: 1;
  min-width: 0;
  padding: 4rpx 16rpx 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ll2-timeline-title {
  font-size: 29rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.45;
  font-weight: 500;
}

.ll2-timeline-title--lift {
  font-weight: 700;
  color: #ffffff;
}

.ll2-timeline-desc {
  font-size: 22rpx;
  color: rgba(142, 142, 147, 0.95);
  line-height: 1.45;
}

.ll2-timeline-clock {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  font-variant-numeric: tabular-nums;
  padding-top: 6rpx;
  padding-left: 8rpx;
  max-width: 200rpx;
  text-align: right;
}

/*星舰动态追踪（LL2 updates） */
.ll2-updates-section {
