/* 事件更新区域 */
.event-updates-section {
  margin-bottom: 40rpx;
}

/* 标题下方横向滑动（复用首页发射商胶囊交互：scroll-x + 右侧渐隐提示） */
.tweet-stats-scroll-wrap {
  position: relative;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.tweet-stats-scroll {
  width: 100%;
  white-space: nowrap;
}

.tweet-stats-scroll-fade {
  position: absolute;
  top: 0;
  right: 10rpx;
  width: 44rpx;
  height: 100%;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(14, 20, 34, 0), rgba(14, 20, 34, 0.92));
  border-top-right-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
}

.tweet-stats-bar.tweet-stats-chips-row {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 10rpx;
  align-items: stretch;
  min-width: 100%;
  margin-bottom: 0;
  padding-right: 20rpx;
  box-sizing: border-box;
}

.tweet-stat-chip.tweet-stat-item {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
}

.tweet-stat-chip .tweet-stat-avatar {
