<page-meta background-color="{{pageBgColor}}" background-color-top="{{pageBgColor}}" background-color-bottom="{{pageBgColor}}" />
<view class="container {{themeClass}}">
  <!-- 顶部导航栏 -->
  <view class="top-nav-wrapper" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-nav top-nav--page-center">
      <text class="nav-title nav-title--page-center">星舰进度</text>
    </view>
  </view>

  <scroll-view class="content-scroll main-content-scroll" scroll-y="{{true}}">
    <view style="height: {{navPlaceholderHeight}}px;"></view>

    <!-- 星舰组合体进展（数据库） -->
    <view class="starship-section">
      <view class="section-title">
        <text>星舰组合体进展</text>
        <view class="section-title-right progress-map-actions">
          <view class="progress-map-btn" bindtap="openStarbaseMap">
            <text>设施图</text>
          </view>
          <view class="progress-map-btn progress-map-btn--blue" bindtap="openLaunchSiteMap">
            <text>发射场</text>
          </view>
        </view>
      </view>
      <!-- 加载失败：展示重试入口，避免无限骨架屏 -->
      <view class="starship-cards starship-cards--skeleton" wx:if="{{!starshipLoaded && starshipLoadError}}" bindtap="onRetryStarshipLoad">
        <view class="starship-card glass-card starship-card-skeleton skeleton-shimmer starship-card-error">
          <text class="starship-load-error-text">加载失败，点击重试</text>
        </view>
      </view>

      <!-- 数据就绪前显示骨架占位，避免旧编号闪现 -->
      <view class="starship-cards starship-cards--skeleton" wx:elif="{{!starshipLoaded}}">
        <view class="starship-card glass-card starship-card-skeleton skeleton-shimmer"></view>
        <view class="starship-card glass-card starship-card-skeleton skeleton-shimmer"></view>
      </view>

      <view class="starship-cards" wx:else>
        <!-- Ship -->
        <view class="starship-card glass-card card-hover {{selectedStarshipType === 'ship' ? 'starship-card-active' : ''}}" bindtap="onStarshipCardTap" bindlongpress="onStarshipCardLongPress" data-type="ship">
          <view class="starship-content">
            <view class="starship-image-container">
              <image
                class="starship-image"
                src="{{starshipData.ship.image}}"
                mode="aspectFill"
                lazy-load="{{true}}"
                data-type="ship"
                binderror="onStarshipImageError"
              ></image>
              <view class="starship-id-overlay">
                <text class="starship-id-text">{{starshipData.ship.id}}</text>
              </view>
            </view>
            <view class="starship-info-bottom">
              <view class="starship-header">
                <text class="starship-name">STARSHIP</text>
              </view>
              <view class="starship-status status-{{starshipData.ship.statusType}}">
                <text class="status-label">状态</text>
                <view class="status-indicator">
                  <view class="status-dot"></view>
                  <text class="status-value">{{starshipData.ship.status}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- Booster -->
        <view class="starship-card glass-card card-hover {{selectedStarshipType === 'booster' ? 'starship-card-active' : ''}}" bindtap="onStarshipCardTap" bindlongpress="onStarshipCardLongPress" data-type="booster">
          <view class="starship-content">
            <view class="starship-image-container">
              <image
                class="starship-image"
                src="{{starshipData.booster.image}}"
                mode="aspectFill"
                lazy-load="{{true}}"
                data-type="booster"
                binderror="onStarshipImageError"
              ></image>
              <view class="starship-id-overlay">
                <text class="starship-id-text">{{starshipData.booster.id}}</text>
              </view>
            </view>
            <view class="starship-info-bottom">
              <view class="starship-header">
                <text class="starship-name">SUPER HEAVY</text>
              </view>
              <view class="starship-status status-{{starshipData.booster.statusType}}">
                <text class="status-label">状态</text>
                <view class="status-indicator">
                  <view class="status-dot"></view>
                  <text class="status-value">{{starshipData.booster.status}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>


    </view>

    <!-- 星舰硬件设施（NSF 数据） -->
    <view class="hardware-section">
      <view class="section-title">
        <text>星舰硬件设施</text>
        <view class="section-title-right">
          <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
                bindtap="onHardwareViewAllTap">
            <text>查看全部</text>
            <text class="booster-view-all-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 骨架屏 -->
      <view class="hardware-grid" wx:if="{{!hardwareLoaded}}">
        <view class="hardware-card glass-card hardware-card-skeleton skeleton-shimmer" wx:for="{{[0, 1]}}" wx:key="*this"></view>
      </view>

      <block wx:else>
        <!-- 卡片网格 -->
        <view class="hardware-grid" wx:if="{{hardwareVisible.length > 0}}">
          <view
            class="hardware-card glass-card card-hover"
            wx:for="{{hardwareVisible}}"
            wx:key="id"
            data-id="{{item.id}}"
            data-index="{{index}}"
            bindtap="onHardwareCardTap"
          >
            <view class="hardware-card-image-wrap">
              <image
                class="hardware-card-image"
                src="{{item.displayImage}}"
                mode="aspectFill"
                lazy-load="{{true}}"
                data-index="{{index}}"
                binderror="onHardwareImageError"
              ></image>
              <view class="hardware-card-image-mask"></view>
              <view class="hardware-card-overlay">
                <view class="hardware-card-status status-{{item.statusType}}">
                  <view class="status-dot"></view>
                  <text class="status-value">{{item.statusZh}}</text>
                </view>
                <text class="hardware-card-name">{{item.name}}</text>
              </view>
            </view>
            <view class="hardware-card-body">
              <text class="hardware-card-type">{{item.typeZh}}</text>
              <text class="hardware-card-notes">{{item.notesZh}}</text>
            </view>
          </view>
        </view>

        <!-- 空态 -->
        <view class="hardware-empty glass-card" wx:if="{{hardwareVisible.length === 0}}">
          <text>{{hardwareError || '没有匹配的硬件，换个关键词试试'}}</text>
        </view>
      </block>
    </view>

    <!-- 事件更新（爱好者追踪） -->
    <view class="event-updates-section">
      <view class="section-title event-updates-title-row">
        <text>事件更新</text>
        <view class="section-badge" wx:if="{{tweetEventTotal}}">{{tweetEventTotal}}</view>
        <view class="section-title-right">
          <view class="booster-view-all" hover-class="booster-view-all--pressed" hover-stay-time="120"
                bindtap="openEventUpdatesList" wx:if="{{eventUpdates.length > 0}}">
            <text>查看更多</text>
            <text class="booster-view-all-arrow">›</text>
          </view>
        </view>
      </view>
      <!-- 今日各账号更新统计（标题下方横向滑动，复用首页发射商胶囊交互） -->
      <view class="tweet-stats-scroll-wrap" wx:if="{{tweetAccountStats.length > 0}}">
        <scroll-view class="tweet-stats-scroll" scroll-x="true" enhanced="true" show-scrollbar="false" bindscroll="onTweetStatsChipsScroll">
          <view class="tweet-stats-bar tweet-stats-chips-row">
            <view class="tweet-stat-item tweet-stat-chip {{isProUser ? 'pro-gold-frame-flat' : ''}}" wx:for="{{tweetAccountStats}}" wx:key="screenName" bindtap="onTweetAccountTap" data-index="{{index}}" data-source="{{item.screenName}}" data-label="{{item.label}}">
              <image class="tweet-stat-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
              <text class="tweet-stat-name">{{item.label}}</text>
              <text class="tweet-stat-count">{{item.todayCount}}</text>
            </view>
          </view>
        </scroll-view>
        <view class="tweet-stats-scroll-fade" wx:if="{{tweetStatsChipsHasOverflow}}"></view>
      </view>

      <view class="event-updates-card glass-card" wx:if="{{eventUpdates.length > 0}}">
        <!-- 折叠状态：只显示最新1条（含媒体） -->
        <view wx:if="{{!eventUpdatesExpanded}}">
          <view class="event-updates-collapsed">
            <view
              class="event-update-item {{pressedEventId === item._id ? 'event-update-item--pressed' : ''}}"
              wx:for="{{eventUpdates}}"
              wx:if="{{index < 1}}"
              wx:key="_id"
              bindtap="openEventDetail"
              bindtouchstart="onEventItemTouchStart"
              bindtouchend="onEventItemTouchEnd"
              bindtouchcancel="onEventItemTouchEnd"
              bindlongpress="openEventShareSheet"
              data-id="{{item._id}}"
              data-idx="{{index}}"
            >
              <view class="event-update-link">
                <view class="event-update-header">
                  <text class="event-update-time">{{item.publishedAtText}}</text>
                  <view class="event-update-author-wrap" wx:if="{{item.author}}">
                    <image class="event-author-avatar" src="{{item.authorAvatar}}" wx:if="{{item.authorAvatar && !item._avatarError}}" mode="aspectFill" binderror="onAvatarError" data-id="{{item._id}}" />
                    <text class="event-update-author">{{item.author}}</text>
                  </view>
                </view>
                <text class="event-update-title" wx:if="{{item.title}}">{{item.title}}</text>
                <text class="event-update-content" wx:if="{{item.content}}">{{item.content}}</text>
              </view>

              <!-- 折叠状态也显示媒体 -->
              <view class="event-media-list" wx:if="{{enableEventVideo && item.mediaList && item.mediaList.length > 0}}">
                <block wx:for="{{item.mediaList}}" wx:for-item="media" wx:for-index="mIdx" wx:key="mIdx">
                  <image
                    wx:if="{{media.type === 'image'}}"
                    class="event-media-image"
                    src="{{media.url}}"
                    mode="aspectFill"
                    lazy-load="{{true}}"
                    show-menu-by-longpress="{{true}}"
                    bindtap="onEventImagePreview"
                    data-urls="{{item.imageUrls}}"
                    data-current="{{media.url}}"
                  ></image>
                  <view wx:if="{{media.type === 'video'}}" class="event-media-video-wrap" catchtap="onVideoThumbnailTap" catchlongpress="onVideoSaveOriginal" data-url="{{media.url}}" data-playurl="{{media.playUrl}}" data-original="{{media.originalUrl || media.url}}" data-sourceurl="{{media.sourceUrl}}" data-videourl="{{media.videoUrl}}" data-islong="{{media.isLongVideo}}" data-thumb="{{media.thumbnailUrl}}" data-eventid="{{item._id}}" data-midx="{{mIdx}}">
                    <image wx:if="{{media.thumbnailUrl}}" class="event-media-video-thumb" src="{{media.thumbnailUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
                    <image wx:else class="event-media-video-thumb" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}"></image>
                    <view class="event-media-play-icon">▶</view>
                    <view wx:if="{{media.isLongVideo}}" class="event-media-link-badge">长视频 · 点击复制链接</view>
                    <view wx:elif="{{!media.isPlayable}}" class="event-media-link-badge">外部链接</view>
                  </view>
                </block>
              </view>
            </view>
          </view>
        </view>

        <!-- 展开状态 -->
        <view wx:else>
          <scroll-view
            class="event-updates-scroll"
            scroll-y="{{true}}"
            enhanced="{{true}}"
            show-scrollbar="{{false}}"
            bounces="{{true}}"
            refresher-enabled="{{true}}"
            refresher-triggered="{{eventScrollRefreshing}}"
            refresher-default-style="{{themeLight ? 'black' : 'white'}}"
            refresher-background="transparent"
            bindrefresherrefresh="onEventScrollRefresh"
            bindscrolltolower="onEventScrollToLower"
          >
          <view
            class="event-update-item {{pressedEventId === item._id ? 'event-update-item--pressed' : ''}}"
            wx:for="{{eventUpdates}}"
            wx:key="_id"
            bindtap="openEventDetail"
            bindtouchstart="onEventItemTouchStart"
            bindtouchend="onEventItemTouchEnd"
            bindtouchcancel="onEventItemTouchEnd"
            bindlongpress="openEventShareSheet"
            data-id="{{item._id}}"
            data-idx="{{index}}"
          >
            <view class="event-update-link">
              <view class="event-update-header">
                <text class="event-update-time">{{item.publishedAtText}}</text>
                <view class="event-update-author-wrap" wx:if="{{item.author}}">
                  <image class="event-author-avatar" src="{{item.authorAvatar}}" wx:if="{{item.authorAvatar && !item._avatarError}}" mode="aspectFill" binderror="onAvatarError" data-id="{{item._id}}" />
                  <text class="event-update-author">{{item.author}}</text>
                </view>
              </view>

              <text class="event-update-title" wx:if="{{item.title}}">{{item.title}}</text>
              <text class="event-update-content" wx:if="{{item.content}}">{{item.content}}</text>
            </view>

            <!-- 直播卡片 -->
            <view class="event-live-card" wx:if="{{item.liveRoomId}}" bindtap="onLiveCardTap" data-idx="{{index}}">
              <view class="event-live-cover-wrap">
                <image
                  class="event-live-cover"
                  src="{{item.liveCover || item._liveCover || ''}}"
                  mode="aspectFill"
                  wx:if="{{item.liveCover || item._liveCover}}"
                ></image>
                <view class="event-live-cover-placeholder" wx:else>
                  <text class="event-live-cover-placeholder-text">直播</text>
                </view>
                <view class="event-live-badge {{item._liveStatus === 1 ? 'event-live-badge-on' : ''}}">
                  <view class="event-live-dot" wx:if="{{item._liveStatus === 1}}"></view>
                  <text>{{item._liveStatus === 1 ? '直播中' : '未开播'}}</text>
                </view>
                <view class="event-live-play-overlay" wx:if="{{item._liveStatus === 1}}">
                  <view class="event-live-play-btn">▶</view>
                </view>
              </view>
              <view class="event-live-action">
                <text class="event-live-action-text">{{item._liveStatus === 1 ? '点击观看直播' : (item._liveTitle || '未开播')}}</text>
                <text class="event-live-action-arrow" wx:if="{{item._liveStatus === 1}}">›</text>
              </view>
            </view>

            <view class="event-media-list" wx:if="{{enableEventVideo && item.mediaList && item.mediaList.length > 0}}">
              <block wx:for="{{item.mediaList}}" wx:for-item="media" wx:for-index="mIdx" wx:key="mIdx">
                <image
                  wx:if="{{media.type === 'image'}}"
                  class="event-media-image"
                  src="{{media.url}}"
                  mode="aspectFill"
                  lazy-load="{{true}}"
                  show-menu-by-longpress="{{true}}"
                  bindtap="onEventImagePreview"
                  data-urls="{{item.imageUrls}}"
                  data-current="{{media.url}}"
                ></image>
                <view wx:if="{{media.type === 'video'}}" class="event-media-video-wrap" catchtap="onVideoThumbnailTap" catchlongpress="onVideoSaveOriginal" data-url="{{media.url}}" data-playurl="{{media.playUrl}}" data-original="{{media.originalUrl || media.url}}" data-sourceurl="{{media.sourceUrl}}" data-videourl="{{media.videoUrl}}" data-islong="{{media.isLongVideo}}" data-thumb="{{media.thumbnailUrl}}" data-eventid="{{item._id}}" data-midx="{{mIdx}}">
                  <image wx:if="{{media.thumbnailUrl}}" class="event-media-video-thumb" src="{{media.thumbnailUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
                  <image wx:else class="event-media-video-thumb" src="{{media.url}}" mode="aspectFill" lazy-load="{{true}}"></image>
                  <view class="event-media-play-icon">▶</view>
                  <view wx:if="{{media.isLongVideo}}" class="event-media-link-badge">长视频 · 点击复制链接</view>
                  <view wx:elif="{{!media.isPlayable}}" class="event-media-link-badge">外部链接</view>
                </view>
              </block>
            </view>

            <view class="event-update-actions">
              <view class="event-update-share-wrap" catchtap="stopPropagation">
                <image class="icon-share icon-share--event-update" src="/images/share-arrow.svg" mode="aspectFit"></image>
                <button
                  class="event-update-share-btn"
                  open-type="share"
                  hover-class="none"
                  plain="true"
                  data-share-type="eventUpdateItem"
                  data-id="{{item._id}}"
                  catchtap="onEventShareButtonTap"
                  style="border: none; border-width: 0;"
                ></button>
              </view>
            </view>

            <view class="event-update-divider" wx:if="{{index < eventUpdates.length - 1}}"></view>
          </view>

          <view class="event-updates-footer">
            <text class="event-updates-footer-text" wx:if="{{eventUpdatesNoMore}}">- 没有更多了 -</text>
            <text class="event-updates-footer-text" wx:elif="{{eventUpdatesLoading}}">加载中...</text>
          </view>
        </scroll-view>
          <view class="event-updates-collapse-btn" bindtap="toggleEventUpdatesExpanded">
            <text>收起事件更新</text>
            <text class="expand-arrow expand-arrow--up">‹</text>
          </view>
        </view>
      </view>

      <view class="event-updates-card glass-card event-updates-empty" wx:else>
        <text class="event-updates-empty-text">{{eventUpdatesLoading ? '加载中...' : (eventUpdatesError || '暂无事件更新')}}</text>
      </view>
    </view>

    <!-- 封路通知（API + DB覆盖） -->
    <view class="notice-section">
      <view class="section-title">
        <text>星舰基地封路通知</text>
        <text class="notice-sync-btn" bindtap="onSyncRoadClosure">{{roadClosureSyncing ? '同步中...' : '刷新'}}</text>
      </view>
      <view class="notice-card glass-card" wx:if="{{roadClosure.isActive}}" bindtap="openRoadClosureDetail">
        <view class="notice-map-entry" catchtap="openRoadClosureMap">
          <text>查看封路地图</text>
        </view>
        <view class="notice-header">
          <view class="notice-icon notice-icon--closure"></view>
          <text class="notice-title">交通管制信息</text>
          <text class="notice-source" wx:if="{{roadClosure.source}}">{{roadClosure.source === 'starbase_gov' ? 'Starbase.gov' : roadClosure.source === 'spacedevs' ? 'SpaceDevs' : roadClosure.source === 'manual' ? '管理员' : ''}}</text>
        </view>
        <text class="notice-message">{{roadClosure.message}}</text>
        <view class="notice-schedule" wx:if="{{roadClosure.beachClosureSchedule && roadClosure.beachClosureSchedule.length > 0}}">
          <text class="schedule-label">封闭计划</text>
          <text class="schedule-item" wx:for="{{roadClosure.beachClosureSchedule}}" wx:key="index">{{item}}</text>
        </view>
        <view class="notice-schedule" wx:if="{{roadClosure.roadDelays && roadClosure.roadDelays.length > 0}}">
          <text class="schedule-label">道路延迟</text>
          <text class="schedule-item" wx:for="{{roadClosure.roadDelays}}" wx:key="index">{{item}}</text>
        </view>
        <view class="notice-time" wx:if="{{roadClosure.timeRange && !roadClosure.beachClosureSchedule.length}}">
          <text class="time-label">时间范围</text>
          <text class="time-value">{{roadClosure.timeRange}}</text>
        </view>
      </view>
      <view class="notice-card glass-card" wx:else>
        <view class="notice-empty">
          <block wx:if="{{roadClosureSyncing || roadClosureStatus === 'loading'}}">
            <text class="notice-no-data">正在获取最新封路数据...</text>
          </block>
          <block wx:elif="{{roadClosureStatus === 'error'}}">
            <text class="notice-no-data">封路数据获取失败</text>
            <text class="notice-hint">网络异常，点击「刷新」重试</text>
          </block>
          <block wx:else>
            <text class="notice-no-data">官网当前无封路记录</text>
            <text class="notice-hint">Boca Chica 道路/海滩正常通行</text>
          </block>
        </view>
      </view>
    </view>

    <view class="flight-checklist-section nsf-checklist-section">
      <view class="nsf-checklist-card glass-card {{isProUser ? 'pro-gold-frame' : ''}}">
        <view class="nsf-checklist-card-header">
          <view class="nsf-checklist-summary-row">
            <text class="nsf-checklist-summary-title">星舰飞行检查清单</text>
            <text class="nsf-checklist-summary-ratio" wx:if="{{nsfChecklistProgressTotal > 0}}">{{nsfChecklistProgressDone}}/{{nsfChecklistProgressTotal}}</text>
          </view>
        </view>
        <view class="nsf-checklist-muted nsf-checklist-muted--pad" wx:if="{{nsfChecklistSyncing && nsfChecklistItems.length === 0}}">
          <text>同步中…</text>
        </view>
        <view class="nsf-checklist-muted nsf-checklist-muted--pad" wx:elif="{{nsfChecklistError && nsfChecklistItems.length === 0}}">
          <text>{{nsfChecklistError}}</text>
        </view>
        <view class="nsf-checklist-preview-rows" wx:if="{{nsfChecklistItems.length > 0}}">
          <view class="flight-checklist-row nsf-checklist-preview-row" wx:for="{{nsfChecklistItems}}" wx:key="id" wx:if="{{index < 3}}">
            <view class="flight-checklist-check {{item.done ? 'flight-checklist-check--done' : ''}}">
              <text wx:if="{{item.done}}" class="flight-checklist-check-mark">✓</text>
            </view>
            <view class="flight-checklist-main">
              <text wx:if="{{item.category}}" class="flight-checklist-category">{{item.category}}</text>
              <text class="flight-checklist-row-title">{{item.title}}</text>
            </view>
          </view>
        </view>
        <view class="nsf-checklist-expand-row" hover-class="nsf-checklist-expand-row--active" bindtap="onNsfChecklistExpandTap">
          <text class="nsf-checklist-expand-text">展开</text>
          <text class="nsf-checklist-expand-chevron">›</text>
        </view>
      </view>
    </view>

    <view class="flight-checklist-section ll2-progress-pack" wx:if="{{belowFoldSectionsReady && showLaunchLibraryUpdates}}">
      <view class="nsf-checklist-card glass-card ll2-progress-card">
        <view class="nsf-checklist-card-header">
          <view class="nsf-checklist-summary-row">
            <text class="nsf-checklist-summary-title">星舰飞行时间线</text>
            <text class="ll2-updates-sync-btn" catchtap="onRefreshLl2Timeline">{{ll2TimelineLoading ? '…' : '刷新'}}</text>
          </view>
        </view>
        <view class="nsf-checklist-muted nsf-checklist-muted--pad" wx:if="{{ll2TimelineLoading && ll2TimelineRows.length === 0}}">
          <text>同步中…</text>
        </view>
        <view class="nsf-checklist-muted nsf-checklist-muted--pad" wx:elif="{{ll2TimelineError && ll2TimelineRows.length === 0}}">
          <text>{{ll2TimelineError}}</text>
        </view>
        <view class="nsf-checklist-preview-rows ll2-preview-timeline-rows" wx:elif="{{ll2TimelineRows.length > 0}}">
          <view class="ll2-timeline-item" wx:for="{{ll2TimelineRows}}" wx:key="id" wx:if="{{index < 3}}">
            <view class="ll2-timeline-axis">
              <view class="ll2-timeline-line ll2-timeline-line--up" wx:if="{{index !== 0}}"></view>
              <view class="ll2-timeline-node">
                <view class="ll2-timeline-node-mark ll2-timeline-node-mark--{{item.iconVariant}}"></view>
              </view>
              <view class="ll2-timeline-line ll2-timeline-line--down" wx:if="{{index < ll2TimelineRows.length - 1 && index < 2}}"></view>
            </view>
            <view class="ll2-timeline-main">
              <text class="{{item.titleClass}}" user-select="{{true}}">{{item.title}}</text>
              <text class="ll2-timeline-desc" wx:if="{{item.description}}" user-select="{{true}}">{{item.description}}</text>
            </view>
            <text class="ll2-timeline-clock">{{item.timeLabel}}</text>
          </view>
        </view>
        <view class="nsf-checklist-expand-row" hover-class="nsf-checklist-expand-row--active" bindtap="onLl2TimelineExpandTap">
          <text class="nsf-checklist-expand-text">展开</text>
          <text class="nsf-checklist-expand-chevron">›</text>
        </view>
      </view>
    </view>

    <view class="flight-checklist-section ll2-progress-pack" wx:if="{{belowFoldSectionsReady && showLaunchLibraryUpdates}}">
      <view class="nsf-checklist-card glass-card ll2-progress-card">
        <view class="nsf-checklist-card-header">
          <view class="nsf-checklist-summary-row">
            <text class="nsf-checklist-summary-title">星舰动态追踪</text>
            <text class="ll2-updates-sync-btn" catchtap="onRefreshLl2LaunchUpdates">{{ll2LaunchUpdatesLoading ? '…' : '刷新'}}</text>
          </view>
        </view>
        <view class="nsf-checklist-muted nsf-checklist-muted--pad" wx:if="{{ll2LaunchUpdatesLoading && ll2LaunchUpdates.length === 0}}">
          <text>同步中…</text>
        </view>
        <view class="nsf-checklist-muted nsf-checklist-muted--pad" wx:elif="{{ll2LaunchUpdatesError && ll2LaunchUpdates.length === 0}}">
          <text>{{ll2LaunchUpdatesError}}</text>
        </view>
        <view class="nsf-checklist-preview-rows" wx:elif="{{ll2LaunchUpdates.length > 0}}">
          <view class="ll2-update-row ll2-update-row--compact" wx:for="{{ll2LaunchUpdates}}" wx:key="id" wx:if="{{index < 3}}">
            <view class="ll2-update-main">
              <text class="ll2-update-comment">{{item.comment}}</text>
              <text class="ll2-update-meta">{{item.createdBy}}{{item.timeLabel ? ' · ' + item.timeLabel : ''}}</text>
            </view>
            <text
              wx:if="{{item.infoUrl}}"
              class="flight-checklist-chevron ll2-update-chevron"
              catchtap="onFlightChecklistDetailTap"
              data-url="{{item.infoUrl}}"
            >›</text>
          </view>
        </view>
        <view class="nsf-checklist-expand-row" hover-class="nsf-checklist-expand-row--active" bindtap="onLl2LaunchUpdatesExpandTap">
          <text class="nsf-checklist-expand-text">展开</text>
          <text class="nsf-checklist-expand-chevron">›</text>
        </view>
      </view>
    </view>

    <view style="height: {{tabBarReservedHeight}}px;"></view>
  </scroll-view>

  <view class="event-share-sheet-mask" wx:if="{{showEventShareSheet}}" bindtap="closeEventShareSheet">
    <view class="event-share-sheet" catchtap="stopPropagation">
      <text class="event-share-sheet-title">分享这条推文</text>
      <text class="event-share-sheet-desc">长按已选中当前推文，可直接分享给朋友，或进入详情页后分享到朋友圈/收藏。</text>
      <button
        class="event-share-sheet-btn event-share-sheet-btn--primary"
        open-type="share"
        hover-class="none"
        plain="true"
        data-share-type="eventUpdateItem"
        data-id="{{selectedEventShareId}}"
        bindtap="onEventShareButtonTap"
      >分享给朋友</button>
      <view class="event-share-sheet-btn" bindtap="openSelectedEventDetailForShare">打开详情页分享到朋友圈/收藏</view>
      <view class="event-share-sheet-btn event-share-sheet-btn--cancel" bindtap="closeEventShareSheet">取消</view>
    </view>
  </view>

  <ai-chat id="ai-chat" />
  <nasa-float />
  <privacy-modal id="globalPrivacyModal"></privacy-modal>
  <popup-ad visible="{{popupAdVisible}}" shop-item="{{popupAdItem}}" bind:close="onPopupAdClose"></popup-ad>
  <demo-overlay id="demoOverlay" showControls="{{false}}" qrcodeUrl="https://mars-1397421562.cos.ap-guangzhou.myqcloud.com/%E5%B0%8F%E7%A8%8B%E5%BA%8F%E4%BA%8C%E7%BB%B4%E7%A0%81/1775323336594_jkl6zv.png" loop="{{true}}" />
  <share-guide />
</view>
